<?xml version="1.0"?><?mso-application progid="Excel.Sheet"?><Workbook xmlns="urn:schemas-microsoft-com:office:spreadsheet" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns:ss="urn:schemas-microsoft-com:office:spreadsheet" xmlns:html="http://www.w3.org/TR/REC-html40"><DocumentProperties xmlns="urn:schemas-microsoft-com:office:office"><LastAuthor>Luis Ferreira</LastAuthor><LastSaved>2020-01-16T15:13:46Z</LastSaved><Version>16.00</Version></DocumentProperties><OfficeDocumentSettings xmlns="urn:schemas-microsoft-com:office:office"><AllowPNG/></OfficeDocumentSettings><ExcelWorkbook xmlns="urn:schemas-microsoft-com:office:excel"><WindowHeight>10920</WindowHeight><WindowWidth>19365</WindowWidth><WindowTopX>32767</WindowTopX><WindowTopY>32767</WindowTopY><RefModeR1C1/><ProtectStructure>False</ProtectStructure><ProtectWindows>False</ProtectWindows></ExcelWorkbook><Styles><Style ss:ID="Default" ss:Name="Normal"><Alignment ss:Vertical="Bottom"/><Borders/><Font ss:FontName="Calibri" x:Family="Swiss" ss:Size="11" ss:Color="#000000"/><Interior/><NumberFormat/><Protection/></Style><Style ss:ID="s62"><Alignment ss:Vertical="Top" ss:WrapText="1"/></Style></Styles><Worksheet ss:Name="Script"><Table x:FullColumns="1" x:FullRows="1" ss:StyleID="s62" ss:DefaultColumnWidth="288.75" ss:DefaultRowHeight="15"><Column ss:StyleID="s62" ss:Width="156.75"/><Column ss:StyleID="s62" ss:Width="66.75"/><Column ss:StyleID="s62" ss:Width="399.75"/><Column ss:StyleID="s62" ss:Width="147.75"/><Column ss:StyleID="s62" ss:Width="283.5"/><Column ss:StyleID="s62" ss:Width="120.75"/><Row ss:AutoFitHeight="0" ss:Height="75"><Cell><Data ss:Type="String">DWELLING_SPECIESTHERIANS</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">The DEV TEAM / MISC NOTES column contains info on what text between { } signs means (if applicable). It usually stands for either a numeric value, or a numeric value with an icon. Text between [ ] signs stands for a certain type of icon. </Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SCENE ID</Data></Cell><Cell><Data ss:Type="String">TEXT ID</Data></Cell><Cell><Data ss:Type="String">ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZATION NOTES</Data></Cell><Cell><Data ss:Type="String">DEV TEAM / MISC NOTES</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">THERIANS_DWELLING</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Therians Dwelling</Data></Cell><Cell><Data ss:Type="String">Osada Terian</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="60"><Cell><Data ss:Type="String">THERIANS_DWELLING</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Make friends with the Therians faction to make purchases from this dwelling, or conquer it for immediate rewards and annexation. When annexed, this structure acts as a max level exploitation.[br/][br/]Grants {Cosmite} Cosmite and {Influence} Influence to the colony it is linked to.</Data></Cell><Cell><Data ss:Type="String">Zaprzyjaźnij się z frakcją Terian, aby uzyskać możliwość kupowania w tej osadzie – albo ją podbij, by natychmiast zdobyć nagrody i ją przyłączyć. Po przyłączeniu będzie działać jako eksploatacja maksymalnego poziomu.[br/][br/]Daje {Cosmite} kosmitu i {Influence} wpływów kolonii, z którą jest połączona.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">THERIANS_BASE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Therians Base</Data></Cell><Cell><Data ss:Type="String">Baza Terian</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">THERIANS_BASE</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This sector has been claimed by the Therians. You can either negotiate with them (and stay friends) or remove them by force and incur their wrath.</Data></Cell><Cell><Data ss:Type="String">Ten sektor został zajęty przez Terian. Możesz albo z nimi negocjować (i zachować ich przyjaźń), albo usunąć ich siłą, ryzykując ich gniew.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">"You" refers to the player and can either be male or female.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SECTOR_OPERATION_TRANSFER</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Transfer</Data></Cell><Cell><Data ss:Type="String">Przekaż</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SECTOR_OPERATION_TRANSFER</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Transfer the sector to another colony.</Data></Cell><Cell><Data ss:Type="String">Przekazuje sektor innej kolonii.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SECTOR_OPERATION_RAZE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Raze</Data></Cell><Cell><Data ss:Type="String">Spustosz</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SECTOR_OPERATION_RAZE</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Burn the base of a sector to the ground. This will also destroy all upgrades.</Data></Cell><Cell><Data ss:Type="String">Zrównuje z ziemią bazę sektora. Spowoduje to też zniszczenie wszystkich ulepszeń.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">THERIANS_SPAWNER01</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Pointed Claw Den</Data></Cell><Cell><Data ss:Type="String">Leże Ostrego Szponu</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">THERIANS_SPAWNER02</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Razor Paw Den</Data></Cell><Cell><Data ss:Type="String">Leże Pazurowej Brzytwy</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">THERIANS_SPAWNER03</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Stinging Barb Den</Data></Cell><Cell><Data ss:Type="String">Leże Kłujących Wąsów</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">THERIANS_SPAWNER04</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Sharpened Crook Den</Data></Cell><Cell><Data ss:Type="String">Leże Krzywego Kostura</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">THERIANS_SPAWNER05</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Salient Fang Den</Data></Cell><Cell><Data ss:Type="String">Leże Szpiczastego Kła</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">THERIANS_SPAWNER06</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Keen Grapnel Den</Data></Cell><Cell><Data ss:Type="String">Leże Ciętego Drapacza</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">THERIANS_SPAWNER07</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Edged Grappler Den</Data></Cell><Cell><Data ss:Type="String">Leże Zaostrzonego Haka</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">THERIANS_SPAWNER08</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Tapering Hook Den</Data></Cell><Cell><Data ss:Type="String">Leże Wąskiego Haka</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">THERIANS_SPAWNER09</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Aciculate Manus Den
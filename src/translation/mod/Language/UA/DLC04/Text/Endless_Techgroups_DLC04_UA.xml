<?xml version="1.0"?><?mso-application progid="Excel.Sheet"?><Workbook xmlns="urn:schemas-microsoft-com:office:spreadsheet" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns:ss="urn:schemas-microsoft-com:office:spreadsheet" xmlns:html="http://www.w3.org/TR/REC-html40"><DocumentProperties xmlns="urn:schemas-microsoft-com:office:office"><LastAuthor>Luis Ferreira</LastAuthor><LastSaved>2020-07-22T15:29:19Z</LastSaved><Version>16.00</Version></DocumentProperties><OfficeDocumentSettings xmlns="urn:schemas-microsoft-com:office:office"><AllowPNG/></OfficeDocumentSettings><ExcelWorkbook xmlns="urn:schemas-microsoft-com:office:excel"><WindowHeight>7620</WindowHeight><WindowWidth>21570</WindowWidth><WindowTopX>32767</WindowTopX><WindowTopY>32767</WindowTopY><RefModeR1C1/><ProtectStructure>False</ProtectStructure><ProtectWindows>False</ProtectWindows></ExcelWorkbook><Styles><Style ss:ID="Default" ss:Name="Normal"><Alignment ss:Vertical="Bottom"/><Borders/><Font ss:FontName="Calibri" x:Family="Swiss" ss:Size="11" ss:Color="#000000"/><Interior/><NumberFormat/><Protection/></Style><Style ss:ID="s62"><Alignment ss:Vertical="Bottom" ss:WrapText="1"/></Style><Style ss:ID="s63"><Alignment ss:Vertical="Top" ss:WrapText="1"/></Style><Style ss:ID="s64"><Alignment ss:Vertical="Bottom" ss:WrapText="1"/><Font ss:FontName="Calibri" x:Family="Swiss" ss:Size="11"/></Style><Style ss:ID="s65"><Alignment ss:Vertical="Bottom" ss:WrapText="1"/><Interior/></Style></Styles><Worksheet ss:Name="Script"><Table x:FullColumns="1" x:FullRows="1" ss:DefaultRowHeight="15"><Column ss:AutoFitWidth="0" ss:Width="186"/><Column ss:AutoFitWidth="0" ss:Width="147.75"/><Column ss:StyleID="s62" ss:AutoFitWidth="0" ss:Width="507.75"/><Column ss:Width="147.75"/><Column ss:StyleID="s62" ss:Width="262.5"/><Column ss:StyleID="s62" ss:Width="120"/><Row ss:AutoFitHeight="0" ss:Height="75"><Cell><Data ss:Type="String">ENDLESS_TECHGROUPS_DLC04</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">The DEV TEAM / MISC NOTES column contains info on what text between { } signs means (if applicable). It usually stands for either a numeric value, or a numeric value with an icon. Text between [ ] signs stands for a certain type of icon. </Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SCENE ID</Data></Cell><Cell><Data ss:Type="String">TEXT ID</Data></Cell><Cell><Data ss:Type="String">ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZATION NOTES</Data></Cell><Cell><Data ss:Type="String">DEV TEAM / MISC NOTES</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s63"><Data ss:Type="String">SONIC_WEAPONS_DAMAGE</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">NAME</Data></Cell><Cell ss:StyleID="s64"><Data ss:Type="String">Sonic Weaponry Breakthrough</Data></Cell><Cell><Data ss:Type="String">Przełom w dziedzinie broni dźwiękowej</Data></Cell><Cell ss:Index="8" ss:StyleID="s65"/></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s63"><Data ss:Type="String">SONIC_WEAPONS_DAMAGE</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">SUBSKILL_NAME</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">Sonic Weapon Damage</Data></Cell><Cell><Data ss:Type="String">Obrażenia od broni dźwiękowej</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Sonic is a weapon damage introduced in this DLC</Data></Cell><Cell ss:StyleID="s65"/></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s63"><Data ss:Type="String">SONIC_WEAPONS_DAMAGE</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">A major breakthrough from our weapons division has led to a boost to all of our armies' Sonic weaponry!</Data></Cell><Cell><Data ss:Type="String">Wielki przełom, jakiego dokonano w naszym dziale uzbrojenia, wzmocnił broń dźwiękową wszystkich naszych armii!</Data></Cell><Cell ss:Index="8" ss:StyleID="s65"/></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s63"><Data ss:Type="String">SONIC_WEAPONS_DAMAGE</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">SUBSKILL_DESCRIPTION</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">{damageBonus}% extra damage to all Sonic weapon attacks.</Data></Cell><Cell><Data ss:Type="String">{damageBonus}% dodatkowych obrażeń od wszystkich ataków bronią dźwiękową.</Data></Cell><Cell ss:Index="8" ss:StyleID="s65"/></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s63"><Data ss:Type="String">XENO_PANACEA</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">NAME</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">Xeno Panacea</Data></Cell><Cell><Data ss:Type="String">Ksenopanaceum</Data></Cell><Cell ss:Index="8" ss:StyleID="s65"/></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell ss:StyleID="s63"><Data ss:Type="String">XENO_PANACEA</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Accidental Breakthrough! While experimenting on the local wildlife, we managed to find a cure for the foreign pathogens that debilitate the Shakarn immune system.</Data></Cell><Cell><Data ss:Type="String">Przypadkowy przełom! Podczas eksperymentowania na miejscowej przyrodzie udało się nam znaleźć lek na obce patogeny, które osłabiają system odpornościowy Szakarnów.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Shakarn are a player Race in this DLC</Data></Cell><Cell ss:StyleID="s65"/></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s63"><Data ss:Type="String">XENO_PANACEA</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">SUBSKILL_NAME</Data></Cell><Cell><Data ss:Type="String">Shakarn Cure</Data></Cell><Cell><Data ss:Type="String">Lek Szakarnów</Data></Cell><Cell ss:Index="8" ss:StyleID="s65"/></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell ss:StyleID="s63"><Data ss:Type="String">XENO_PANACEA</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">SUBSKILL_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Units you control with Xeno Debilitation gain +{StatusEffectResist} resistance to status effects and +{Hp}[hp/].</Data></Cell><Cell><Data ss:Type="String">Kontrolowane przez ciebie jednostki z ksenoosłabieniem zyskują +{StatusEffectResist} do odporności na efekty stanu i +{Hp}[hp/].</Data></Cell><Cell ss:Index="8" ss:StyleID="s65"/></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s63"><Data ss:Type="String">CAPTIVE_THUNDER</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">NAME</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">Captive Thunder</Data></Cell><Cell><Data ss:Type="String">Zniewolony grzmot</Data></Cell><Cell ss:Index="8" ss:StyleID="s65"/></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell ss:StyleID="s63"><Data ss:Type="String">CAPTIVE_THUNDER</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Accidental Breakthrough! We managed to build containers strong enough to contain Thundermaws, the saurians native to the Shakarn Homeworld. We can now breed and train them!</Data></Cell><Cell><Data ss:Type="String">Przypadkowy przełom! Udało się nam zbudować na tyle mocne kontenery, aby oparły się sile grzmotopaszcza, gada pochodzącego ze świata macierzystego Szakarnów. Możemy teraz hodować i tresować grzmotopaszcze!</Data></Cell><Cell ss:Index="8" ss:StyleID="s65"/></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s63"><Data ss:Type="String">CAPTIVE_THUNDER</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">SUBSKILL_NAME_1</Data></Cell><Cell><Data ss:Type="String">Thundermaw Park</Data></Cell><Cell><Data ss:Type="String">Park grzmotopaski</Data></Cell><Cell ss:Index="8" ss:StyleID="s65"/></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s63"><Data ss:Type="String">CAPTIVE_THUNDER</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">SUBSKILL_DESCRIPTION_1</Data></Cell><Cell><Data ss:Type="String">Allows the production of Thundermaws in our colonies.</Data></Cell><Cell><Data ss:Type="String">Umożliwia werbowanie grzmotopaszczów w naszych koloniach.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Thundermaw is a Wildlife unit in this DLC</Data></Cell><Cell ss:StyleID="s65"/></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s63"><Data ss:Type="String">CAPTIVE_THUNDER</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">SUBSKILL_NAME_2</Data></Cell><Cell><Data ss:Type="String">Better Zoological Containers</Data></Cell><Cell><Data ss:Type="String">Lepsze kontenery zoologiczne</Data></Cell><Cell ss:Index="8" ss:StyleID="s65"/></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s63"><Data ss:Type="String">CAPTIVE_THUNDER</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">SUBSKILL_DESCRIPTION_2</Data></Cell><Cell><Data ss:Type="String">All Animal, Ethereal, Mineral and Plant units you produce in your colonies gain +{Amount}[medaliron/]</Data></Cell><Cell><Data ss:Type="String">Wszystkie wytwarzane w twoich koloniach jednostki zwierzęce, eteryczne, mineralne i roślinne zyskują +{Amount}[medaliron/].</Data></Cell><Cell ss:Index="8" ss:StyleID="s65"/></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s63"><Data ss:Type="String">CAPTIVE_THUNDER</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">SUBSKILL_PROP</Data></Cell><Cell><Data ss:Type="String">All Colonies produce Animal, Ethereal, Mineral and Plant units with +{Amount}[medaliron/]</Data></Cell><Cell><Data ss:Type="String">Wszystkie kolonie wytwarzają jednostki zwierzęce, eteryczne, mineralne i roślinne z +{Amount}[medaliron/].</Data></Cell><Cell ss:Index="8" ss:StyleID="s65"/></Row></Table><WorksheetOptions xmlns="urn:schemas-microsoft-com:office:excel"><Unsynced/><Print><ValidPrinterInfo/><HorizontalResolution>600</HorizontalResolution><VerticalResolution>600</VerticalResolution></Print><Selected/><Panes><Pane><Number>3</Number><ActiveRow>14</ActiveRow><ActiveCol>4</ActiveCol></Pane></Panes><ProtectObjects>False</ProtectObjects><ProtectScenarios>False</ProtectScenarios></WorksheetOptions></Worksheet></Workbook>
<?xml version="1.0"?><?mso-application progid="Excel.Sheet"?><Workbook xmlns="urn:schemas-microsoft-com:office:spreadsheet" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns:ss="urn:schemas-microsoft-com:office:spreadsheet" xmlns:html="http://www.w3.org/TR/REC-html40"><DocumentProperties xmlns="urn:schemas-microsoft-com:office:office"><LastAuthor>Djurre van Dijk</LastAuthor><Created>2019-05-06T09:40:05Z</Created><LastSaved>2019-05-06T09:40:05Z</LastSaved><Version>16.00</Version></DocumentProperties><OfficeDocumentSettings xmlns="urn:schemas-microsoft-com:office:office"><AllowPNG/></OfficeDocumentSettings><ExcelWorkbook xmlns="urn:schemas-microsoft-com:office:excel"><WindowHeight>7830</WindowHeight><WindowWidth>16170</WindowWidth><WindowTopX>32767</WindowTopX><WindowTopY>32767</WindowTopY><RefModeR1C1/><ProtectStructure>False</ProtectStructure><ProtectWindows>False</ProtectWindows></ExcelWorkbook><Styles><Style ss:ID="Default" ss:Name="Normal"><Alignment ss:Vertical="Bottom"/><Borders/><Font ss:FontName="Calibri" x:Family="Swiss" ss:Size="11" ss:Color="#000000"/><Interior/><NumberFormat/><Protection/></Style><Style ss:ID="s62"><Interior/></Style><Style ss:ID="s63"><Alignment ss:Vertical="Bottom" ss:WrapText="1"/><Interior/></Style></Styles><Worksheet ss:Name="Script"><Table x:FullColumns="1" x:FullRows="1" ss:StyleID="s62" ss:DefaultRowHeight="15"><Column ss:StyleID="s62" ss:AutoFitWidth="0" ss:Width="201"/><Column ss:StyleID="s62" ss:AutoFitWidth="0" ss:Width="80.25"/><Column ss:StyleID="s63" ss:AutoFitWidth="0" ss:Width="645.75"/><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">UNITPROPERTIES</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">The DEV TEAM / MISC NOTES column contains info on what text between { } signs means (if applicable). It usually stands for either a numeric value, or a numeric value with an icon. Text between [ ] signs stands for a certain type of icon. </Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SCENE ID</Data></Cell><Cell><Data ss:Type="String">TEXT ID</Data></Cell><Cell><Data ss:Type="String">ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZATION NOTES</Data></Cell><Cell><Data ss:Type="String">DEV TEAM / MISC NOTES</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">STATUS_EFFECT</Data></Cell><Cell><Data ss:Type="String">STUNNED_NAME</Data></Cell><Cell><Data ss:Type="String">Stunned</Data></Cell><Cell><Data ss:Type="String">Ogłuszenie</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">direct copy of AoW3 abilities.xml</Data></Cell><Cell><Data ss:Type="String">This unit cannot take any action (e.g. move, attack, retaliate) for {stunnedTime} combat rounds.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">STATUS_EFFECT</Data></Cell><Cell><Data ss:Type="String">STUNNED_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit cannot move or use abilities.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka nie może się poruszać ani używać umiejętności.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">direct copy of AoW3 abilities.xml</Data></Cell><Cell><Data ss:Type="String">{stunnedTime}: 2;</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">LARGE_TARGET</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Large Target</Data></Cell><Cell><Data ss:Type="String">Duży cel</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">LARGE_TARGET</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit is {largeTargetPenalty} easier to hit with ranged attacks. In addition, it cannot take cover itself, but counts as cover for other units.</Data></Cell><Cell><Data ss:Type="String">Tę jednostkę o {largeTargetPenalty} łatwiej trafić atakami dystansowymi. Dodatkowo nie może ona korzystać z osłony, ale stanowi osłonę dla innych jednostek.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">%</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HUGE_TARGET</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Huge Target</Data></Cell><Cell><Data ss:Type="String">Ogromny cel</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HUGE_TARGET</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit is {largeTargetPenalty} easier to hit with ranged attacks. In addition, it cannot take cover, and blocks line of sight.</Data></Cell><Cell><Data ss:Type="String">Tę jednostkę o {largeTargetPenalty} łatwiej trafić atakami dystansowymi. Dodatkowo nie może ona korzystać z osłony i blokuje linię widzenia.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">%</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PHASE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Phase</Data></Cell><Cell><Data ss:Type="String">Fazowanie</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Phase as in to teleport</Data></Cell><Cell><Data ss:Type="String">direct copy of AoW3 abilities.xml</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PHASE</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Teleport to target unoccupied hex.</Data></Cell><Cell><Data ss:Type="String">Teleportacja na wskazane niezajęte pole.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">In the game, the battlefield consists of hexagons (hexes) in the same way that a chess board consists of squares. Tactical combat refers to the part of the game where combat is being played out between players and/or the computer.</Data></Cell><Cell><Data ss:Type="String">direct copy of AoW3 abilities.xml</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HOPPER_JUMP</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Combat Jump</Data></Cell><Cell><Data ss:Type="String">Skok bojowy</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HOPPER_JUMP</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Jump at target Light ground unit, dealing damage, knocking them back.</Data></Cell><Cell><Data ss:Type="String">Skok na wskazaną lekką jednostkę lądową, zadający obrażenia i odpychający ją.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">DEATH_EXPLOSION</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Beetle Death Rattle</Data></Cell><Cell><Data ss:Type="String">Ostatnie pożegnanie</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="28.6875"><Cell><Data ss:Type="String">DEATH_EXPLOSION</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">When killed, this unit explodes, dealing {damage}[damagebio/] damage, destroying {armormelt}[armor/] and causing [abilityred]High Impact[/abilityred] to all adjacent units.</Data></Cell><Cell><Data ss:Type="String">W chwili śmierci ta jednostka wybucha, zadając {damage}[damagebio/] pkt. obrażeń, niszcząc {armormelt}[armor/] i powodując [abilityred]silne uderzenie[/abilityred] u wszystkich sąsiadujących jednostek.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">RESURGENCE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Resurgence</Data></Cell><Cell><Data ss:Type="String">Odrodzenie</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">RESURGENCE</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">When the unit dies in combat, it is revived at the end of combat if its owner is victorious. Revived units are brought back with {resurrectHP} of their maximum [hp/].</Data></Cell><Cell><Data ss:Type="String">Gdy jednostka zginie w walce, zostanie ożywiona na koniec walki, jeśli jej właściciel zwyciężył. Ożywione jednostki mają {resurrectHP} maksymalnej [hp/].</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">%</Data></Cell><Cell><Data ss:Type="String">{resurrectHP}: 25%; Updated Reloc-pass 19March</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">BEETLE_MORTAR</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Beetle Mortar</Data></Cell><Cell><Data ss:Type="String">Żuk-bombardier</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">BEETLE_MORTAR</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Strikes a 1 hex area with a toxic pod that spreads a Biochemical hazard.</Data></Cell><Cell><Data ss:Type="String">Trafia w jedno pole toksyczną kapsułą, która rozpyla zagrożenie biochemiczne.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FOREST_CAMOUFLAGE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Forest Camouflage</Data></Cell><Cell><Data ss:Type="String">Kamuflaż leśny</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FOREST_CAMOUFLAGE</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit cannot be detected when standing on Forest hexes.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka jest niewykrywalna, gdy znajduje się na polach lasu.</Data></Cell><Cell ss:Index="8"><Data ss:Type="String">This unit cannot be detected when stood on Forest hexes.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SWAMP_CAMOUFLAGE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Swamp Camouflage</Data></Cell><Cell><Data ss:Type="String">Kamuflaż bagienny</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SWAMP_CAMOUFLAGE</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit cannot be detected when standing on Wetland hexes.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka jest niewykrywalna, gdy znajduje się na polach mokradeł.</Data></Cell><Cell ss:Index="8"><Data ss:Type="String">This unit cannot be detected when stood on Wetland hexes.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">UNIVERSAL_CAMOUFLAGE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Universal Camouflage</Data></Cell><Cell><Data ss:Type="String">Kamuflaż uniwersalny</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">UNIVERSAL_CAMOUFLAGE</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit cannot be detected when standing on any hex.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka jest niewykrywalna, gdy znajduje się na dowolnym polu.</Data></Cell><Cell ss:Index="8"><Data ss:Type="String">This unit cannot be detected when stood on any hex.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ROUGH_TERRAIN_CAMOUFLAGE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Rough Terrain Camouflage</Data></Cell><Cell><Data ss:Type="String">Kamuflaż terenowy</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ROUGH_TERRAIN_CAMOUFLAGE</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit cannot be detected when standing on Mountain, Barren or Chasm hexes.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka jest niewykrywalna, gdy znajduje się na polach gór, skał lub Otchłani.</Data></Cell><Cell ss:Index="8"><Data ss:Type="String">This unit cannot be detected when stood on Mountain, Barren or Chasm hexes.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HOPPER_AIR_LEAP</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Air Leap</Data></Cell><Cell><Data ss:Type="String">Skok w powietrze</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HOPPER_AIR_LEAP</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">The unit leaps into the air, damaging any Flying units before landing behind them.</Data></Cell><Cell><Data ss:Type="String">Jednostka wyskakuje w górę, zadając obrażenia ewentualnym jednostkom latającym, a potem spada za nimi.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TUNNEL</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Tunnel</Data></Cell><Cell><Data ss:Type="String">Tunel</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TUNNEL</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Unit is able to tunnel through the ground in Tactical Combat, avoiding Overwatch.</Data></Cell><Cell><Data ss:Type="String">Jednostka potrafi ryć tunele w ziemi podczas walki taktycznej, dzięki czemu unika warty.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FLANKER</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Flanker</Data></Cell><Cell><Data ss:Type="String">Oskrzydlanie</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FLANKER</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Unit deals an additional {FlankingBonus}% damage when flanking.</Data></Cell><Cell><Data ss:Type="String">Jednostka zadaje dodatkowo {FlankingBonus}% obrażeń przy oskrzydleniu.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">WATER_CAMOUFLAGE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Water Camouflage</Data></Cell><Cell><Data ss:Type="String">Kamuflaż wodny</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">WATER_CAMOUFLAGE</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit cannot be detected when standing on Water hexes.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka jest niewykrywalna, gdy znajduje się na polach wodnych.</Data></Cell><Cell ss:Index="8"><Data ss:Type="String">This unit cannot be detected when stood on Water hexes.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">STRONG_WILL</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Mind Control Immunity</Data></Cell><Cell><Data ss:Type="String">Niewrażliwość na kontrolę umysłu</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">STRONG_WILL</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">The unit is immune to all effects which put the unit under direct control of the enemy.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka jest niewrażliwa na wszystkie efekty, które spowodowałyby jej przejście pod kontrolę wroga.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">mind control effects as in mind control abilities (e.g. Befriend Animal, Charm, Convert, Dominate, Seduce)</Data></Cell><Cell><Data ss:Type="String">{strongwillSpiritProtection}: 100% [spirit/];</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HERO</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell ss:StyleID="Default"><Data ss:Type="String">Hero</Data></Cell><Cell><Data ss:Type="String">Bohater</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HERO</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell ss:StyleID="Default"><Data ss:Type="String">This character is a Hero.</Data></Cell><Cell><Data ss:Type="String">Ta postać jest bohaterem.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">GREATER_DEATH_EXPLOSION</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Adult Beetle Death Rattle</Data></Cell><Cell><Data ss:Type="String">Ostatnie pożegnanie dorosłego żuka</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">CUMBERSOME</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Cumbersome</Data></Cell><Cell><Data ss:Type="String">Niezgrabność</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">CUMBERSOME</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit moves more slowly in tactical combat</Data></Cell><Cell><Data ss:Type="String">Ta jednostka porusza się wolniej w walce taktycznej.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">EVOLVED_VITALITY_1</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Evolved Vitality 1</Data></Cell><Cell><Data ss:Type="String">Rozwinięta żywotność 1</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">EVOLVED_VITALITY_1</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Experience gained in its previous form has strengthened this unit with +{HealthIncrease}[hp/]</Data></Cell><Cell><Data ss:Type="String">Doświadczenie zdobyte w poprzedniej postaci wzmocniło tę jednostkę o {HealthIncrease}[hp/]</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">EVOLVED_VITALITY_2</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Evolved Vitality 2</Data></Cell><Cell><Data ss:Type="String">Rozwinięta żywotność 2</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">EVOLVED_VITALITY_2</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Experience gained in its previous form has strengthened this unit with +{HealthIncrease}[hp/]</Data></Cell><Cell><Data ss:Type="String">Doświadczenie zdobyte w poprzedniej postaci wzmocniło tę jednostkę o {HealthIncrease}[hp/]</Data></Cell></Row></Table><WorksheetOptions xmlns="urn:schemas-microsoft-com:office:excel"><Unsynced/><Print><ValidPrinterInfo/><HorizontalResolution>600</HorizontalResolution><VerticalResolution>600</VerticalResolution></Print><Selected/><Panes><Pane><Number>3</Number><ActiveRow>8</ActiveRow><ActiveCol>2</ActiveCol></Pane></Panes><ProtectObjects>False</ProtectObjects><ProtectScenarios>False</ProtectScenarios></WorksheetOptions></Worksheet></Workbook>
<?xml version="1.0"?><?mso-application progid="Excel.Sheet"?><Workbook xmlns="urn:schemas-microsoft-com:office:spreadsheet" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns:ss="urn:schemas-microsoft-com:office:spreadsheet" xmlns:html="http://www.w3.org/TR/REC-html40"><DocumentProperties xmlns="urn:schemas-microsoft-com:office:office"><LastAuthor>Djurre van Dijk</LastAuthor><Created>2019-05-06T09:39:45Z</Created><LastSaved>2019-05-06T09:39:45Z</LastSaved><Version>16.00</Version></DocumentProperties><OfficeDocumentSettings xmlns="urn:schemas-microsoft-com:office:office"><AllowPNG/></OfficeDocumentSettings><ExcelWorkbook xmlns="urn:schemas-microsoft-com:office:excel"><WindowHeight>5640</WindowHeight><WindowWidth>15345</WindowWidth><WindowTopX>32767</WindowTopX><WindowTopY>32767</WindowTopY><ProtectStructure>False</ProtectStructure><ProtectWindows>False</ProtectWindows></ExcelWorkbook><Styles><Style ss:ID="Default" ss:Name="Normal"><Alignment ss:Vertical="Bottom"/><Borders/><Font ss:FontName="Calibri" x:Family="Swiss" ss:Size="11" ss:Color="#000000"/><Interior/><NumberFormat/><Protection/></Style><Style ss:ID="s62"><Alignment ss:Vertical="Bottom" ss:WrapText="1"/></Style></Styles><Worksheet ss:Name="Script"><Table x:FullColumns="1" x:FullRows="1" ss:StyleID="s62" ss:DefaultColumnWidth="51.75" ss:DefaultRowHeight="15"><Column ss:StyleID="s62" ss:AutoFitWidth="0" ss:Width="118.5"/><Column ss:StyleID="s62" ss:AutoFitWidth="0" ss:Width="221.25"/><Column ss:StyleID="s62" ss:AutoFitWidth="0" ss:Width="324" ss:Span="3"/><Column ss:Index="7" ss:StyleID="s62" ss:AutoFitWidth="0" ss:Width="306.75"/><Row ss:AutoFitHeight="0" ss:Height="90"><Cell><Data ss:Type="String">PSIONIC_TECHGROUPS</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Anything between straight brackets - i.e. [ ] - is a formatting tag. Do not change these tags and keep them in the same relative position in the text. Anything between curly brackets - i.e. { } - is a place where text or numbers will be inserted by the game. Do not change the tag, but feel free to change its position in the text to suit the localized text.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SCENE ID</Data></Cell><Cell><Data ss:Type="String">TEXT ID</Data></Cell><Cell><Data ss:Type="String">ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZATION NOTES</Data></Cell><Cell><Data ss:Type="String">DEV TEAM / MISC NOTES</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSIONICS_SKILLS</Data></Cell><Cell><Data ss:Type="String">GROUP_NAME</Data></Cell><Cell><Data ss:Type="String">Psionics</Data></Cell><Cell><Data ss:Type="String">Psionika</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSIONICS_SKILLS</Data></Cell><Cell><Data ss:Type="String">DOMINION_OF_PURIFICATION_NAME</Data></Cell><Cell><Data ss:Type="String">Dominion of Purification</Data></Cell><Cell><Data ss:Type="String">Domena oczyszczenia</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">PSIONICS_SKILLS</Data></Cell><Cell><Data ss:Type="String">DOMINION_OF_PURIFICATION_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">“Clear your mind and listen. Truth speaks with the quietest voice.”[br/]–  Hatyl Ur’Uk, Kir’Ko Dream Reader</Data></Cell><Cell><Data ss:Type="String">„Oczyść swój umysł i słuchaj. Prawda przemawia najcichszym głosem”.[br/]Hatyl Ur’Uk, objaśniacz snów Kir’ko</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Male</Data></Cell><Cell><Data ss:Type="String">V.O.: Kir’ko Male

Edit: Kir'ko -&gt; Kir'Ko</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSIONICS_SKILLS</Data></Cell><Cell><Data ss:Type="String">DOMINION_OF_AFFLICTION_NAME</Data></Cell><Cell><Data ss:Type="String">Dominion of Affliction</Data></Cell><Cell><Data ss:Type="String">Domena przypadłości</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">PSIONICS_SKILLS</Data></Cell><Cell><Data ss:Type="String">DOMINION_OF_AFFLICTION_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">“Through assaults, chemical or mental, the mind must remain stalwart. The mind must push beyond any affliction or it risks being wiped out.”[br/]– Malai of House Antares</Data></Cell><Cell><Data ss:Type="String">„Umysł musi przejść niewzruszony przez wszystkie ataki, chemiczne i myślowe. Umysł musi otrząsnąć się z każdej dolegliwości, inaczej ryzykuje wymazanie”.[br/]Malai z rodu Antares</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Female</Data></Cell><Cell><Data ss:Type="String">V.O.:  Syndicate Female</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSIONICS_SKILLS</Data></Cell><Cell><Data ss:Type="String">DOMINION_OF_VITALITY_NAME</Data></Cell><Cell><Data ss:Type="String">Dominion of Vitality</Data></Cell><Cell><Data ss:Type="String">Domena żywotności</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">PSIONICS_SKILLS</Data></Cell><Cell><Data ss:Type="String">DOMINION_OF_VITALITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">“The mind requires a body to inhabit. Though it be little more than an animal, it must be kept strong to nourish the whole.”[br/]– Malai of House Antares</Data></Cell><Cell><Data ss:Type="String">„Umysł potrzebuje ciała, które będzie zamieszkiwał. Choć ciało jest niemal tylko zwierzęciem, trzeba zadbać o jego siłę, by odżywić całość”.[br/]Malai z rodu Antares</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Female</Data></Cell><Cell><Data ss:Type="String">V.O.:  Syndicate Female</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSIONICS_SKILLS</Data></Cell><Cell><Data ss:Type="String">DOMINION_OF_COMMAND_NAME</Data></Cell><Cell><Data ss:Type="String">Dominion of Command</Data></Cell><Cell><Data ss:Type="String">Domena rozkazu</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">PSIONICS_SKILLS</Data></Cell><Cell><Data ss:Type="String">DOMINION_OF_COMMAND_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">“A word is power. Words can be imbued by memory, and fixed by experience. Spoken in command, it is a force to change worlds.”[br/]– Hatyl Ur’Uk, Kir’ko Dream Reader</Data></Cell><Cell><Data ss:Type="String">„Słowo to potęga. Słowa mogą wryć się pamięć i utrwalić wskutek doświadczenia. Słowa rozkazów są siłą zdolną zmieniać światy”.[br/]Hatyl Ur’Uk, objaśniacz snów Kir’ko</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Male</Data></Cell><Cell><Data ss:Type="String">V.O.: Kir’ko Male </Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSIONICS_SKILLS</Data></Cell><Cell><Data ss:Type="String">DOMINION_OF_AETHER_NAME</Data></Cell><Cell><Data ss:Type="String">Dominion of Aether</Data></Cell><Cell><Data ss:Type="String">Domena Eteru</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">PSIONICS_SKILLS</Data></Cell><Cell><Data ss:Type="String">DOMINION_OF_AETHER_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">“The Aether is a realm of tumultuous thought. Dream-forms become reality. To unleash it in this world breaks all rational thought, scattering them across a storm of contradictions and impossible ideas. Only the strongest mind would dare trespass there.”[br/]– Mordechai of House Antares </Data></Cell><Cell><Data ss:Type="String">„Eter jest królestwem wzburzonych myśli. Wyśnione kształty stają się rzeczywistością. Wyzwolenie ich w naszym świecie oznacza załamanie racjonalnego myślenia, rozproszenie ich pośród burzy sprzeczności i niewykonalnych pomysłów. Do Eteru mogą zapuścić się tylko najpotężniejsze umysły”.[br/]Mordechai z rodu Antares </Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Male</Data></Cell><Cell><Data ss:Type="String">V.O.: Syndicate Male </Data></Cell></Row></Table><WorksheetOptions xmlns="urn:schemas-microsoft-com:office:excel"><Unsynced/><Print><ValidPrinterInfo/><HorizontalResolution>600</HorizontalResolution><VerticalResolution>600</VerticalResolution></Print><Selected/><Panes><Pane><Number>3</Number><ActiveRow>16</ActiveRow><ActiveCol>1</ActiveCol></Pane></Panes><ProtectObjects>False</ProtectObjects><ProtectScenarios>False</ProtectScenarios></WorksheetOptions></Worksheet></Workbook>
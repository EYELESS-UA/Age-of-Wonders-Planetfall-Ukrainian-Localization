<?xml version="1.0"?><?mso-application progid="Excel.Sheet"?><Workbook xmlns="urn:schemas-microsoft-com:office:spreadsheet" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns:ss="urn:schemas-microsoft-com:office:spreadsheet" xmlns:html="http://www.w3.org/TR/REC-html40"><DocumentProperties xmlns="urn:schemas-microsoft-com:office:office"><LastAuthor>Luis Ferreira</LastAuthor><LastSaved>2019-09-06T14:29:11Z</LastSaved><Version>16.00</Version></DocumentProperties><OfficeDocumentSettings xmlns="urn:schemas-microsoft-com:office:office"><AllowPNG/></OfficeDocumentSettings><ExcelWorkbook xmlns="urn:schemas-microsoft-com:office:excel"><WindowHeight>7830</WindowHeight><WindowWidth>16170</WindowWidth><WindowTopX>32767</WindowTopX><WindowTopY>32767</WindowTopY><RefModeR1C1/><ProtectStructure>False</ProtectStructure><ProtectWindows>False</ProtectWindows></ExcelWorkbook><Styles><Style ss:ID="Default" ss:Name="Normal"><Alignment ss:Vertical="Bottom"/><Borders/><Font ss:FontName="Calibri" x:Family="Swiss" ss:Size="11" ss:Color="#000000"/><Interior/><NumberFormat/><Protection/></Style><Style ss:ID="s62"><Alignment ss:Vertical="Top" ss:WrapText="1"/></Style></Styles><Worksheet ss:Name="Script"><Table x:FullColumns="1" x:FullRows="1" ss:StyleID="s62" ss:DefaultColumnWidth="288.75" ss:DefaultRowHeight="15"><Column ss:StyleID="s62" ss:Width="156.75"/><Column ss:StyleID="s62" ss:Width="66.75"/><Column ss:StyleID="s62" ss:Width="399.75"/><Column ss:StyleID="s62" ss:Width="147.75"/><Column ss:StyleID="s62" ss:Width="283.5"/><Column ss:StyleID="s62" ss:Width="120.75"/><Row ss:AutoFitHeight="0" ss:Height="75"><Cell><Data ss:Type="String">DWELLING_SPECIESFORGOTTEN</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">The DEV TEAM / MISC NOTES column contains info on what text between { } signs means (if applicable). It usually stands for either a numeric value, or a numeric value with an icon. Text between [ ] signs stands for a certain type of icon. </Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SCENE ID</Data></Cell><Cell><Data ss:Type="String">TEXT ID</Data></Cell><Cell><Data ss:Type="String">ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZATION NOTES</Data></Cell><Cell><Data ss:Type="String">DEV TEAM / MISC NOTES</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FORGOTTEN_DWELLING</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Forgotten Dwelling</Data></Cell><Cell><Data ss:Type="String">Osada Zapomnianych</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">FORGOTTEN_DWELLING</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Make friends with the Forgotten faction to make purchases from this dwelling, or conquer it for immediate rewards and annexation. When annexed, this structure acts as a max level exploitation.[br/][br/]Grants {Cosmite} Cosmite and {Influence} Influence to the colony it is linked to.</Data></Cell><Cell><Data ss:Type="String">Zaprzyjaźnij się z frakcją Zapomnianych, aby uzyskać możliwość kupowania w tej osadzie – albo ją podbij, by natychmiast zdobyć nagrody i ją przyłączyć. Po przyłączeniu będzie działać jako eksploatacja maksymalnego poziomu.[br/][br/]Daje kolonii, z którą jest połączona, {Cosmite} kosmitu i {Influence} wpływów.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FORGOTTEN_BASE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Forgotten Base</Data></Cell><Cell><Data ss:Type="String">Baza Zapomnianych</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">FORGOTTEN_BASE</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This sector has been claimed by the Forgotten. You can either negotiate with them (and stay friends) or remove them by force and incur their wrath.</Data></Cell><Cell><Data ss:Type="String">Ten sektor został zajęty przez Zapomnianych. Możesz albo z nimi negocjować (i zachować ich przyjaźń), albo usunąć ich siłą, ryzykując ich gniew.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">"You" refers to the player and can either be male or female.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SECTOR_OPERATION_TRANSFER</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Transfer</Data></Cell><Cell><Data ss:Type="String">Przekaż</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SECTOR_OPERATION_TRANSFER</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Transfer the sector to another colony.</Data></Cell><Cell><Data ss:Type="String">Przekazuje sektor innej kolonii.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SECTOR_OPERATION_RAZE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Raze</Data></Cell><Cell><Data ss:Type="String">Spustosz</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SECTOR_OPERATION_RAZE</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Burn the base of a sector to the ground. This will also destroy all upgrades.</Data></Cell><Cell><Data ss:Type="String">Zrównuje z ziemią bazę sektora. Spowoduje to też zniszczenie wszystkich ulepszeń.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FORGOTTEN_SPAWNER01</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Reverence Shrine</Data></Cell><Cell><Data ss:Type="String">Kapliczka Pietyzmu</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FORGOTTEN_SPAWNER02</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Chronicle Shrine</Data></Cell><Cell><Data ss:Type="String">Kapliczka Kronik</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FORGOTTEN_SPAWNER03</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Eternity Shrine</Data></Cell><Cell><Data ss:Type="String">Kapliczka Wieczności</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FORGOTTEN_SPAWNER04</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Aeon Shrine</Data></Cell><Cell><Data ss:Type="String">Kapliczka Eonów</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FORGOTTEN_SPAWNER05</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Recollection Shrine</Data></Cell><Cell><Data ss:Type="String">Kapliczka Pamięci</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FORGOTTEN_SPAWNER06</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Memorial Shrine</Data></Cell><Cell><Data ss:Type="String">Kapliczka Wspomnień</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FORGOTTEN_SPAWNER07</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Memoir Shrine</Data></Cell><Cell><Data ss:Type="String">Kapliczka Pamiątek</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FORGOTTEN_SPAWNER08</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Remembrance Shrine</Data></Cell><Cell><Data ss:Type="String">Kapliczka Upamiętnienia</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FORGOTTEN_SPAWNER09</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Immortal Shrine</Data></Cell><Cell><Data ss:Type="String">Kapliczka Nieśmiertelnych</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FORGOTTEN_DWELLING01</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Final Rest Catacomb</Data></Cell><Cell><Data ss:Type="String">Grobowiec Wiecznego Spoczynku</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FORGOTTEN_DWELLING02</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Bleak Catacomb</Data></Cell><Cell><Data ss:Type="String">Grobowiec Smętku</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FORGOTTEN_DWELLING03</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Lamentation Catacomb</Data></Cell><Cell><Data ss:Type="String">Grobowiec Lamentu</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FORGOTTEN_DWELLING04</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Decaying Catacomb</Data></Cell><Cell><Data ss:Type="String">Grobowiec Rozkładu</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FORGOTTEN_DWELLING05</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Gloom Catacomb</Data></Cell><Cell><Data ss:Type="String">Grobowiec Mroku</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FORGOTTEN_DWELLING06</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Grim Catacomb</Data></Cell><Cell><Data ss:Type="String">Ponury Grobowiec</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FORGOTTEN_DWELLING07</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Somber Catacomb</Data></Cell><Cell><Data ss:Type="String">Posępny Grobowiec</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FORGOTTEN_DWELLING08</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Rotting Catacomb</Data></Cell><Cell><Data ss:Type="String">Grobowiec Zgnilizny</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">GOVERNANCE_1</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Forgotten Depths</Data></Cell><Cell><Data ss:Type="String">Głębiny Zapomnianych</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">GOVERNANCE_1</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">The Forgotten guide your researchers in how to better excavate and study Es'Teq Tombs and other ancient sites.[br/][br/]Each Knowledge [research/] sector now provides an additional {KnowleadgeBonus}[research/].</Data></Cell><Cell><Data ss:Type="String">Zapomniani prowadzą twoich uczonych, wskazując im lepsze metody odkopywania i badania grobowców Es’Tequ oraz innych pradawnych miejsc.[br/][br/]Każdy sektor poświęcony wiedzy [research/] zapewnia teraz dodatkowo {KnowleadgeBonus}[research/].</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">OPERATION_1</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Rot Proliferation</Data></Cell><Cell><Data ss:Type="String">Rozprzestrzenienie zgnilizny</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="75"><Cell><Data ss:Type="String">OPERATION_1</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Proliferate the Rot to target non-Mindless Infantry enemy unit.[br/]Unit has a {BleakChance}[strengthEntropy/] strength chance to gain [abilityred]Bleak Essence[/abilityred] which transforms the unit into a Desolate when it dies, permanently under your control. On failure, it gains [abilityred]Entropic Decay[/abilityred] instead.[br/]Cannot target Heroes or Commanders.</Data></Cell><Cell><Data ss:Type="String">Rozprzestrzeniaj zgniliznę, aby wziąć na cel wrogą jednostkę piechoty nienależącą do bezmózgich.[br/]Jednostka ma szansę (siła {BleakChance}[strengthEntropy/]) uzyskania [abilityred]ponurej Esencji[/abilityred], przez co w chwili śmierci zmieni się w opuszczonego będącego pod twoją stałą kontrolą. W razie porażki jednostka uzyska [abilityred]rozkład entropiczny[/abilityred].[br/]Umiejętność nie działa na bohaterów ani dowódców.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Desolate as in the Forgotten Unit</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FORGOTTEN_SPAWNER10</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Deference Shrine</Data></Cell><Cell><Data ss:Type="String">Kapliczka Poważania</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FORGOTTEN_SPAWNER11</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Devotion Shrine</Data></Cell><Cell><Data ss:Type="String">Kapliczka Pobożności</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FORGOTTEN_SPAWNER12</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Veneration Shrine</Data></Cell><Cell><Data ss:Type="String">Kapliczka Szacunku</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FORGOTTEN_SPAWNER13</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Obsequiousness Shrine</Data></Cell><Cell><Data ss:Type="String">Kapliczka Służalczości</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FORGOTTEN_SPAWNER14</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Apotheosis Shrine</Data></Cell><Cell><Data ss:Type="String">Kapliczka Apoteozy</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FORGOTTEN_DWELLING09</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Bereavement Catacomb</Data></Cell><Cell><Data ss:Type="String">Grobowiec Żałoby</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FORGOTTEN_DWELLING10</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Tribulation Catacomb</Data></Cell><Cell><Data ss:Type="String">Grobowiec Udręki</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FORGOTTEN_DWELLING11</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Misery Catacomb</Data></Cell><Cell><Data ss:Type="String">Grobowiec Niedoli</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FORGOTTEN_DWELLING12</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Anguish Catacomb</Data></Cell><Cell><Data ss:Type="String">Grobowiec Boleści</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FORGOTTEN_DWELLING13</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Millstone Catacomb</Data></Cell><Cell><Data ss:Type="String">Grobowiec Brzemienia</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FORGOTTEN_DWELLING14</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Crumbling Catacomb</Data></Cell><Cell><Data ss:Type="String">Zgruchotany Grobowiec</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FORGOTTEN_DWELLING15</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Decaying Catacomb</Data></Cell><Cell><Data ss:Type="String">Zmurszały Grobowiec</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FORGOTTEN_DWELLING16</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Austere Catacomb</Data></Cell><Cell><Data ss:Type="String">Grobowiec Srogości</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FORGOTTEN_DWELLING17</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Deprivation Catacomb</Data></Cell><Cell><Data ss:Type="String">Grobowiec Straty</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FORGOTTEN_DWELLING18</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Despair Catacomb</Data></Cell><Cell><Data ss:Type="String">Grobowiec Rozpaczy</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FORGOTTEN_DWELLING19</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Sorrow Catacomb</Data></Cell><Cell><Data ss:Type="String">Grobowiec Smutku</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FORGOTTEN_DWELLING20</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Suffering Catacomb</Data></Cell><Cell><Data ss:Type="String">Grobowiec Cierpienia</Data></Cell></Row><Row><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell><Cell ss:Index="7"><Data ss:Type="String">For references to game terminology and in-world references, please check the glossary delivered as part of the documentation.</Data></Cell></Row></Table><WorksheetOptions xmlns="urn:schemas-microsoft-com:office:excel"><Unsynced/><Print><ValidPrinterInfo/><HorizontalResolution>600</HorizontalResolution><VerticalResolution>600</VerticalResolution></Print><Zoom>115</Zoom><Selected/><Panes><Pane><Number>3</Number><ActiveRow>9</ActiveRow><ActiveCol>4</ActiveCol></Pane></Panes><ProtectObjects>False</ProtectObjects><ProtectScenarios>False</ProtectScenarios></WorksheetOptions></Worksheet></Workbook>
<?xml version="1.0"?><?mso-application progid="Excel.Sheet"?><Workbook xmlns="urn:schemas-microsoft-com:office:spreadsheet" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns:ss="urn:schemas-microsoft-com:office:spreadsheet" xmlns:html="http://www.w3.org/TR/REC-html40"><DocumentProperties xmlns="urn:schemas-microsoft-com:office:office"><LastAuthor>Djurre van Dijk</LastAuthor><Created>2019-05-06T09:39:11Z</Created><LastSaved>2019-05-06T09:39:11Z</LastSaved><Version>16.00</Version></DocumentProperties><OfficeDocumentSettings xmlns="urn:schemas-microsoft-com:office:office"><AllowPNG/></OfficeDocumentSettings><ExcelWorkbook xmlns="urn:schemas-microsoft-com:office:excel"><WindowHeight>9990</WindowHeight><WindowWidth>21525</WindowWidth><WindowTopX>32767</WindowTopX><WindowTopY>32767</WindowTopY><RefModeR1C1/><ProtectStructure>False</ProtectStructure><ProtectWindows>False</ProtectWindows></ExcelWorkbook><Styles><Style ss:ID="Default" ss:Name="Normal"><Alignment ss:Vertical="Bottom"/><Borders/><Font ss:FontName="Calibri" x:Family="Swiss" ss:Size="11" ss:Color="#000000"/><Interior/><NumberFormat/><Protection/></Style><Style ss:ID="s62"><Borders/></Style><Style ss:ID="s63"><Alignment ss:Vertical="Bottom" ss:WrapText="1"/><Borders/></Style><Style ss:ID="s64"><Alignment ss:Vertical="Bottom" ss:WrapText="1"/><Borders/><Font ss:FontName="Calibri" x:Family="Swiss" ss:Size="11" ss:Color="#000000"/></Style><Style ss:ID="s65"><Borders/><Interior ss:Color="#F8CBAD" ss:Pattern="Solid"/></Style></Styles><Worksheet ss:Name="Script"><Table x:FullColumns="1" x:FullRows="1" ss:StyleID="s62" ss:DefaultColumnWidth="219.75" ss:DefaultRowHeight="15"><Column ss:Index="2" ss:StyleID="s62" ss:AutoFitWidth="0" ss:Width="169.5"/><Column ss:StyleID="s63" ss:AutoFitWidth="0" ss:Width="235.5"/><Column ss:StyleID="s62" ss:AutoFitWidth="0" ss:Width="157.5"/><Column ss:StyleID="s62" ss:AutoFitWidth="0" ss:Width="174"/><Column ss:StyleID="s62" ss:AutoFitWidth="0" ss:Width="148.5"/><Column ss:StyleID="s63" ss:AutoFitWidth="0" ss:Width="235.5"/><Row ss:AutoFitHeight="0" ss:Height="75"><Cell><Data ss:Type="String">UPGRADES_UNCATEGORIZED_UNITPROPERTIES</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">The DEV TEAM / MISC NOTES column contains info on what text between { } signs means (if applicable). It usually stands for either a numeric value, or a numeric value with an icon. Text between [ ] signs stands for a certain type of icon. </Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SCENE ID</Data></Cell><Cell><Data ss:Type="String">TEXT ID</Data></Cell><Cell><Data ss:Type="String">ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZATION NOTES</Data></Cell><Cell><Data ss:Type="String">DEV TEAM / MISC NOTES</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">OMNIDIRECTIONAL_CAMERA</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Omnidirectional Camera</Data></Cell><Cell><Data ss:Type="String">Kamera wszechwidząca</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">OMNIDIRECTIONAL_CAMERA</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit has Overwatch in all directions.</Data></Cell><Cell><Data ss:Type="String">Warta tej jednostki działa we wszystkich kierunkach.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">CALCULATE_TARGETING_PARAMETERS</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Calculate Targeting Parameters</Data></Cell><Cell><Data ss:Type="String">Obliczanie parametrów celowniczych</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="60"><Cell><Data ss:Type="String">CALCULATE_TARGETING_PARAMETERS</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Raise this unit's accuracy and critical hit chance by {CalculateAccuracyIncrease}. All [abilityblue]Networked[/abilityblue] units also gain this effect.</Data></Cell><Cell><Data ss:Type="String">Zwiększa celność tej jednostki i szansę na trafienie krytyczne o {CalculateAccuracyIncrease}. Wszystkie jednostki [abilityblue]w sieci[/abilityblue] także uzyskują ten efekt.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">CALCULATE_TARGETING_PARAMETERS</Data></Cell><Cell><Data ss:Type="String">PROPERTY_NAME</Data></Cell><Cell><Data ss:Type="String">Enhanced Targeting</Data></Cell><Cell><Data ss:Type="String">Ulepszone celowanie</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">CALCULATE_TARGETING_PARAMETERS</Data></Cell><Cell><Data ss:Type="String">PROPERTY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit gains {CalculateAccuracyIncrease} accuracy and {CalculateCriticalIncrease} critical hit chance per stack.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka uzyskuje {CalculateAccuracyIncrease} do celności i {CalculateCriticalIncrease} do szansy na trafienie krytyczne za każdy poziom.</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">CALCULATE_TARGETING_PARAMETERS</Data></Cell><Cell><Data ss:Type="String">MODIFIER_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">{CalculateAccuracyIncrease} accuracy and {CalculateCriticalIncrease} critical hit chance.</Data></Cell><Cell><Data ss:Type="String">{CalculateAccuracyIncrease} do celności i {CalculateCriticalIncrease} do szansy na trafienie krytyczne.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">NANITE_REPAIR_CLOUD</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Transmit Repair Nanites</Data></Cell><Cell><Data ss:Type="String">Przesłanie nanitów naprawczych</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">NANITE_REPAIR_CLOUD</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Transmit repair nanites through the network, healing all [abilityblue]Networked[/abilityblue] units for {healAmount}.</Data></Cell><Cell><Data ss:Type="String">Przesyła nanity naprawcze przez sieć, przywracając {healAmount} wszystkim jednostkom [abilityblue]w sieci[/abilityblue].</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SHIELD_PROJECTION</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Shield Projection</Data></Cell><Cell><Data ss:Type="String">Projekcja tarczy</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">SHIELD_PROJECTION</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Project a shield outwards, granting the unit and all [abilityblue]Networked[/abilityblue] friendly units {ShieldAmount} for {ShieldTurn}.</Data></Cell><Cell><Data ss:Type="String">Wznosi tarczę, zapewniając jednostce i wszystkim przyjaznym jednostkom [abilityblue]w sieci[/abilityblue] {ShieldAmount} na {ShieldTurn}.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SHIELD_PROJECTION</Data></Cell><Cell><Data ss:Type="String">PROPERTY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit has +{ShieldAmount}.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka ma +{ShieldAmount}.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">CONTACT_TECH_SUPPORT</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Contact Technical Support</Data></Cell><Cell><Data ss:Type="String">Pomoc techniczna</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">CONTACT_TECH_SUPPORT</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit calls for assistance and summons one random Autonom unit into an adjacent hex.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka wzywa pomoc i przywołuje jedną losową jednostkę Autonomów na sąsiednie pole.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SENTENCE_TARGET</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Sentence Target</Data></Cell><Cell><Data ss:Type="String">Wyrok</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">SENTENCE_TARGET</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Mark target unit for destruction. The unit has -{DamageResistanceDown} resistance in all damage channels and is {EvadeDown}% easier to hit.</Data></Cell><Cell><Data ss:Type="String">Znakuje jednostkę jako przeznaczoną do zniszczenia. Jednostka ma –{DamageResistanceDown} do odporności na wszystkie kanały obrażeń i łatwiej ją trafić o {EvadeDown}%.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SENTENCE_TARGET</Data></Cell><Cell><Data ss:Type="String">PROPERTY_NAME</Data></Cell><Cell><Data ss:Type="String">Sentenced</Data></Cell><Cell><Data ss:Type="String">Skazanie</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">SENTENCE_TARGET</Data></Cell><Cell><Data ss:Type="String">PROPERTY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Unit has -{DamageResistanceDown} resistance in all damage channels and is {EvadeDown}% easier to hit.</Data></Cell><Cell><Data ss:Type="String">Jednostka ma –{DamageResistanceDown} do odporności na wszystkie kanały obrażeń i łatwiej ją trafić o {EvadeDown}%.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">INITIALIZE_CONNECTION</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Initialize Connections</Data></Cell><Cell><Data ss:Type="String">Inicjalizacja łącza</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="180"><Cell><Data ss:Type="String">INITIALIZE_CONNECTION</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">[abilityblue]Network[/abilityblue] all friendly Mechanical units , granting them a bonus that becomes stronger with each subsequent use: [br/][br/][bulletList][bullet]Level 1: {accuracyBonus} accuracy on attacks and +{arcResistance}[DefenseWave/] resistance. [/bullet][bullet]Level 2: Unit's attacks gain one level of [abilityred]Stagger Impact[/abilityred]. [/bullet][bullet]Level 3: {damageBonus} increased damage to all attacks.[/bullet][/bulletList][br/][br/]On this unit's death the buff will be removed, and affected units have a strength {strength} chance to be [abilityred]Stunned[/abilityred/] for {stunDuration}, or [abilityred]Staggered[/abilityred] on resist.[br/]</Data></Cell><Cell><Data ss:Type="String">[abilityblue]Łączy w sieć[/abilityblue] wszystkie przyjazne jednostki mechaniczne, zapewniając im premię, której wartość wzrasta z każdym kolejnym użyciem. [br/][br/][bulletList][bullet]Poziom 1: {accuracyBonus} do celności ataku i premia do odporności (+{arcResistance}[DefenseWave/]). [/bullet][bullet]Poziom 2: ataki jednostki uzyskują jeden poziom [abilityred]powodowania zachwiania[/abilityred]. [/bullet][bullet]Poziom 3: {damageBonus} do obrażeń od wszystkich ataków.[/bullet][/bulletList][br/][br/]W chwili wyeliminowania tej jednostki wzmocnienie znika i wszystkie jednostki, które znajdowały się pod jego wpływem, mają szansę o sile {strength} na [abilityred]ogłuszenie[/abilityred/] na {stunDuration}, a w przypadku oparcia się – na [abilityred]zachwianie[/abilityred].[br/]</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">CONNECTED_LEVEL_1</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Networked Level 1</Data></Cell><Cell><Data ss:Type="String">Sieć poziomu 1</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="60"><Cell><Data ss:Type="String">CONNECTED_LEVEL_1</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit is sharing processing power with its allies, gaining {accuracyBonus} accuracy and +{arcResistance}[DefenseWave/] resistance.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka współdzieli moc obliczeniową ze swoimi sojusznikami, uzyskując {accuracyBonus} do celności i premię do odporności (+{arcResistance}[DefenseWave/]).</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">CONNECTED_LEVEL_2</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Networked Level 2</Data></Cell><Cell><Data ss:Type="String">Sieć poziomu 2</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">CONNECTED_LEVEL_2</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">All of this unit's attacks gain one level of [abilityred]Stagger Impact[/abilityred].</Data></Cell><Cell><Data ss:Type="String">Wszystkie ataki tej jednostki uzyskują jeden poziom [abilityred]powodowania zachwiania[/abilityred].</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">CONNECTED_LEVEL_3</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Networked Level 3</Data></Cell><Cell><Data ss:Type="String">Sieć poziomu 3</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">CONNECTED_LEVEL_3</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit gains {damageBonus} increased damage on all attacks.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka uzyskuje {damageBonus} pkt. do obrażeń od wszystkich ataków.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">CONNECTED_LEVEL_3</Data></Cell><Cell><Data ss:Type="String">MODIFIER_DESCRIPTION_MELEE</Data></Cell><Cell><Data ss:Type="String">{damageBonus} increased damage.</Data></Cell><Cell><Data ss:Type="String">{damageBonus} pkt. do obrażeń.</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">CONNECTED_LEVEL_3</Data></Cell><Cell><Data ss:Type="String">MODIFIER_DESCRIPTION_RANGE</Data></Cell><Cell><Data ss:Type="String">{damageBonus} increased damage.</Data></Cell><Cell><Data ss:Type="String">{damageBonus} pkt. do obrażeń.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SUDDEN_DISCONNECTION</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Sudden Disconnection</Data></Cell><Cell><Data ss:Type="String">Nagłe rozłączenie</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">MAIN_NODE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Main Node</Data></Cell><Cell><Data ss:Type="String">Węzeł główny</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">MAIN_NODE</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">If this unit is killed then all units will lose one level of [abilityblue]Networked[/abilityblue]. Affected units will also have a strength {strength} chance to be [abilityred]Stunned[/abilityred/] for {stunDuration}, on resist the unit will be [abilityred]Staggered[/abilityred] instead.</Data></Cell><Cell><Data ss:Type="String">Jeśli ta jednostka zginie, wszystkie połączone z nią jednostki utracą jeden poziom [abilityblue]w sieci[/abilityblue]. Jednostki, które znajdowały się pod wpływem tego efektu, mają szansę o sile {strength} na [abilityred]ogłuszenie[/abilityred/] na {stunDuration}, a w przypadku oparcia się – na [abilityred]zachwianie[/abilityred].</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">CONCUSSIVE_ORDENANCE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Concussive Ordnance</Data></Cell><Cell><Data ss:Type="String">Amunicja wstrząsowa</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="75"><Cell><Data ss:Type="String">CONCUSSIVE_ORDENANCE</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit's Explosive attacks gain a {ConcussChance}[strengthPhysical/] strength chance ({ConcussChanceRep}[strengthPhysical/] for repeating attacks) to apply [abilityred]Concussion[/abilityred] to non-Ethereal and non-Mechanical units for {ConcussTurn}[turn/].</Data></Cell><Cell><Data ss:Type="String">Ataki wybuchowe tej jednostki uzyskują szansę (siła{ConcussChance}[strengthPhysical/], {ConcussChanceRep}[strengthPhysical/] dla ataków wielokrotnych) na spowodowanie [abilityred]wstrząsu[/abilityred] u jednostek nieeterycznych i niemechanicznych przez {ConcussTurn}[turn/].</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SELF_REPAIR_SYSTEMS</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Self-repair Systems</Data></Cell><Cell><Data ss:Type="String">Systemy samonaprawy</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="60"><Cell><Data ss:Type="String">SELF_REPAIR_SYSTEMS</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit has self-repair systems that heal it during battle for {healbattle} each turn, and heal it to full [hp/] at the start of every Strategic turn.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka ma systemy samonaprawy, które podczas bitwy leczą ją za {healbattle} w każdej turze i regenerują jej pełną [hp/] na początku każdej tury strategicznej.</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">SELF_REPAIR_SYSTEMS</Data></Cell><Cell><Data ss:Type="String">PROP_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit self-repairs during battle for {healbattle} each turn, and heals to full [hp/] at the start of every Strategic turn.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka podczas bitwy naprawia się samoczynnie za {healbattle} w każdej turze i regeneruje pełną [hp/] na początku każdej tury strategicznej.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">IMMOLATION_MATRIX</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Immolation Matrix</Data></Cell><Cell><Data ss:Type="String">Macierz podpalenia</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="60"><Cell><Data ss:Type="String">IMMOLATION_MATRIX</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This matrix causes Laser attacks to ignite units hit, giving a {DisruptionMatStr}[strengthThermal/] strength chance ({DisruptionMatStrRep}[strengthThermal/] for repeating attacks) to [abilityred]Immolate[/abilityred] non-Ethereal and non-Mineral units for {ImmoTurn}[turn/]. If resisted, apply [abilityred]Burning[/abilityred] instead.</Data></Cell><Cell><Data ss:Type="String">Ta macierz powoduje, że atak laserem podpala trafione jednostki, dając szansę (siła {DisruptionMatStr}[strengthThermal/], {DisruptionMatStrRep}[strengthThermal/] dla ataków wielokrotnych) na [abilityred]podpalenie[/abilityred] jednostek nieeterycznych i niemineralnych na {ImmoTurn}[turn/]. W wypadku odparcia cel otrzymuje [abilityred]oparzenie[/abilityred].</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">MINING_LASER_UPGRADE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Mining Laser Upgrade</Data></Cell><Cell><Data ss:Type="String">Laser górniczy</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">MINING_LASER_UPGRADE</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">All Laser attacks gain [abilityred]Melt Armor[/abilityred], removing {armorMelt}[armor/] with each hit.</Data></Cell><Cell><Data ss:Type="String">Wszystkie ataki laserem uzyskują [abilityred]topienie pancerza[/abilityred], które usuwa {armorMelt}[armor/] z każdym trafieniem.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">NETWORK_COMPATIBLE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Network Compatible</Data></Cell><Cell><Data ss:Type="String">Zgodność z siecią</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">NETWORK_COMPATIBLE</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit is Nework Compatible and can benefit from [abilityblue]Networked[/abilityblue].</Data></Cell><Cell><Data ss:Type="String">Ta jednostka jest zgodna z siecią i może czerpać korzyści z pozostawania [abilityblue]w sieci[/abilityblue].</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">AUTONOM_NETWORK_CONNECTOR</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Autonom Network Connector</Data></Cell><Cell><Data ss:Type="String">Łącze sieciowe Autonomów</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">AUTONOM_NETWORK_CONNECTOR</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit gains Network Compatible, allowing it to benefit from [abilityblue]Networked[/abilityblue].</Data></Cell><Cell><Data ss:Type="String">Ta jednostka uzyskuje zgodność z siecią, dzięki czemu może czerpać korzyści z pozostawania [abilityblue]w sieci[/abilityblue].</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">AUTONOM_NETWORK_CONNE
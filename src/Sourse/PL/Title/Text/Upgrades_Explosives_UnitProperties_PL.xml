s:AutoFitWidth="0" ss:Width="327"/><Column ss:StyleID="s62" ss:Width="120"/><Column ss:StyleID="s62" ss:AutoFitWidth="0" ss:Width="323.25"/><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">UNIT_UPGRADES_EXPLOSIVES</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">The DEV TEAM / MISC NOTES column contains info on what text between { } signs means (if applicable). It usually stands for either a numeric value, or a numeric value with an icon. Text between [ ] signs stands for a certain type of icon. </Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SCENE ID</Data></Cell><Cell><Data ss:Type="String">TEXT ID</Data></Cell><Cell><Data ss:Type="String">ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZATION NOTES</Data></Cell><Cell><Data ss:Type="String">DEV TEAM / MISC NOTES</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FRAG_GRENADE</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Grenade</Data></Cell><Cell><Data ss:Type="String">Granat</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">FRAG_GRENADE</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Throw a grenade, dealing damage in a {hexrad} hex radius.</Data></Cell><Cell><Data ss:Type="String">Granat zadaje obrażenia w promieniu {hexrad} pól.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FRAG_MISSILE</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Strike Missile</Data></Cell><Cell><Data ss:Type="String">Pocisk szturmowy</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FRAG_MISSILE</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Launch a missile, dealing damage in a {hexrad} hex radius.</Data></Cell><Cell><Data ss:Type="String">Wystrzeliwuje pocisk zadający obrażenia w promieniu {hexrad} pól.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SELF_DESTRUCT_MODULE</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Self-destruct</Data></Cell><Cell><Data ss:Type="String">Samozniszczenie</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SELF_DESTRUCT_MODULE</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit self-destructs, dealing damage to all adjacent units.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka dokonuje samozniszczenia, zadając obrażenia wszystkim sąsiednim jednostkom.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SELF_DESTRUCT_ON_DEATH</Data></Cell><Cell><Data ss:Type="String">PROPERTY_NAME</Data></Cell><Cell><Data ss:Type="String">Unstable Construction</Data></Cell><Cell><Data ss:Type="String">Nietrwała konstrukcja</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">SELF_DESTRUCT_ON_DEATH</Data></Cell><Cell><Data ss:Type="String">PROPERTY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit will explode on death, dealing {DestructDamage} damage to all adjacent units.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka wybuchnie w chwili zniszczenia, zadając {DestructDamage} pkt. obrażeń wszystkim sąsiednim jednostkom.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PYRX_SELF_DESTRUCT</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Incendiary Self-destruct</Data></Cell><Cell><Data ss:Type="String">Samozniszczenie zapalające</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">PYRX_SELF_DESTRUCT</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit self-destructs, dealing [damagethermal/] damage to all adjacent units.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka dokonuje samozniszczenia, zadając obrażenia ([damagethermal/]) wszystkim sąsiednim jednostkom.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">BIOGAS_SELF_DESTRUCT</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Bio-gas Self-destruct</Data></Cell><Cell><Data ss:Type="String">Samozniszczenie z emisją biogazu</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">BIOGAS_SELF_DESTRUCT</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit self-destructs, dealing [damageBio/] damage to all adjacent units.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka dokonuje samozniszczenia, zadając obrażenia ([damageBio/]) wszystkim sąsiednim jednostkom.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">EMP_SELF_DESTRUCT</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Arc Self-destruct</Data></Cell><Cell><Data ss:Type="String">Samozniszczenie elektryczne</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">EMP_SELF_DESTRUCT</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit self-destructs, dealing [damagewave/] damage to all adjacent units.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka dokonuje samozniszczenia, zadając obrażenia ([damagewave/]) wszystkim sąsiednim jednostkom.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">EQUIPMENT</Data></Cell><Cell><Data ss:Type="String">BASIC_GRENADE_NAME</Data></Cell><Cell><Data ss:Type="String">Basic Grenade</Data></Cell><Cell><Data ss:Type="String">Granat podstawowy</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SWARM_MISSILES</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Swarm Missiles</Data></Cell><Cell><Data ss:Type="String">Pociski rojowe</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">SWARM_MISSILES</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Fire a swarm of missiles, striking an area around the target unit.</Data></Cell><Cell><Data ss:Type="String">Wystrzeliwuje rój pocisków rażących obszar wokół wskazanej jednostki.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">EXECUTION_MISSILES</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Punisher Missile</Data></Cell><Cell><Data ss:Type="String">Pocisk „Egzekutor”</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">EXECUTION_MISSILES</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Launch a missile at the target hex, dealing damage to everything in the area of effect.</Data></Cell><Cell><Data ss:Type="String">Skierowany na wskazane pole pocisk rani wszystko, co znajdzie się w obszarze rażenia.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">BUSTER_MISSILES</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Buster Missile</Data></Cell><Cell><Data ss:Type="String">Pocisk burzący</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">BUSTER_MISSILES</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Launch a missile at the target hex, dealing damage to everything in the area of effect.</Data></Cell><Cell><Data ss:Type="String">Skierowany na wskazane pole pocisk rani wszystko, co znajdzie się w obszarze rażenia.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FLASHBANG_GRENADE</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Flashbang Grenade</Data></Cell><Cell><Data ss:Type="String">Granat hukowy</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">FLASHBANG_GRENADE</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Throw a grenade that does Explosive damage in a flash to target hex and adjacent hexes.</Data></Cell><Cell><Data ss:Type="String">Granat zadaje obrażenia od wybuchu na wskazanym polu i polach sąsiednich.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FLASHBANG_GRENADE</Data></Cell><Cell><Data ss:Type="String">PLUGIN_ADDITION</Data></Cell><Cell><Data ss:Type="String">Flashbang</Data></Cell><Cell><Data ss:Type="String">Granat hukowy</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HAND_MORTAR</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Hand Mortar</Data></Cell><Cell><Data ss:Type="String">Moździerz ręczny</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HAND_MORTAR</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Fire a Hand Mortar, damaging units in a {hexrad} hex radius.</Data></Cell><Cell><Data ss:Type="String">Moździerz ręczny zadaje obrażenia jednostkom w obszarze o promieniu {hexrad} pól.</Data></Cell><Cell ss:Index="8" ss:StyleID="s63"/></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">RAMJET_MISSILE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Ramjet Rocket</Data></Cell><Cell><Data ss:Type="String">Rakieta taranująca</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">RAMJET_MISSILE</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Fire a rocket, dealing Explosive damage in a {hexrad} hex radius.</Data></Cell><Cell><Data ss:Type="String">Wystrzeliwuje rakietę zadającą obrażenia od wybuchu w promieniu {hexrad} pól.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">DEMOLISHER_CANNON</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Demolisher Cannon</Data></Cell><Cell><Data ss:Type="String">Działo niszczące</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">DEMOLISHER_CANNON</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Fire the Demolisher Cannon, doing Explosive damage to targets in a {hexread} hex radius.</Data></Cell><Cell><Data ss:Type="String">Działo niszczące zadaje obrażenia od wybuchu celom w promieniu {hexread} pól.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">MISSILE_BARRAGE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Missile Barrage</Data></Cell><Cell><Data ss:Type="String">Ostrzał rakietowy</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">MISSILE_BARRAGE</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Fire a repeating barrage of Explosives at the target.</Data></Cell><Cell><Data ss:Type="String">Ostrzał celu wieloma seriami pocisków wybuchowych.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TOSS_BOMB</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Toss Bomb</Data></Cell><Cell><Data ss:Type="String">Zrzucenie bomby</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TOSS_BOMB</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Throw a bomb at a single target, dealing Explosive damage.</Data></Cell><Cell><Data ss:Type="String">Zrzucenie na jeden cel bomby zadającej obrażenia od wybuchu.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">GUIDED_DELIVERY_MECHANISMS</Data></Cell><Cell><Data ss:Type="String">UPGRADE_NAME</Data></Cell><Cell><Data ss:Type="String">Guided Delivery Mechanisms</Data></Cell><Cell><Data ss:Type="String">Mechanizm naprowadzający</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">GUIDED_DELIVERY_MECHANISMS</Data></Cell><Cell><Data ss:Type="String">UPGRADE_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Increases the range of ranged Explosive attacks by {GuidedDelRan} hexes and their accuracy by {GuidedDelAcc}.</Data></Cell><Cell><Data ss:Type="String">Zwiększa zasięg dystansowych ataków wybuchowych o {GuidedDelRan} pól, a ich celność – o {GuidedDelAcc}.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">GUIDED_DELIVERY_MECHANISMS</Data></Cell><Cell><Data ss:Type="String">MOD_NAME</Data></Cell><Cell><Data ss:Type="String">Guiding Mechanism</Data></Cell><Cell><Data ss:Type="String">Mechanizm nakierowujący</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">GUIDED_DELIVERY_MECHANISMS</Data></Cell><Cell><Data ss:Type="String">MOD_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Attack range is increased by {GuidedDelRan} hexes and has +{GuidedDelAcc} accuracy.</Data></Cell><Cell><Data ss:Type="String">Zwiększa zasięg ataku o {GuidedDelRan} pól i ma +{GuidedDelAcc} do celności.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FLASH_PAYLOAD</Data></Cell><Cell><Data ss:Type="String">UPGRADE_NAME</Data></Cell><Cell><Data ss:Type="String">Flash Payload</Data></Cell><Cell><Data ss:Type="String">Amunicja błyskowa</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">FLASH_PAYLOAD</Data></Cell><Cell><Data ss:Type="String">UPGRADE_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Explosive attacks now have a {FlashPayloadStrength}[strengthphysical/] strength chance ({FlashPayloadStrengthRepeating}[strengthphysical/] for repeating attacks) to apply [abilityred]Blinded[/abilityred] to non-Ethereal units, for {BlindDuration}[turn/].</Data></Cell><Cell><Data ss:Type="String">Ataki wybuchowe mają teraz szansę (siła {FlashPayloadStrength}[strengthphysical/], {FlashPayloadStrengthRepeating}[strengthphysical/] dla ataków wielokrotnych) na spowodowanie [abilityred]oślepienia[/abilityred] u jednostek nieeterycznych na {BlindDuration}[turn/].</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">INCENDIARY_PAYLOAD</Data></Cell><Cell><Data ss:Type="String">UPGRADE_NAME</Data></Cell><Cell><Data ss:Type="String">Explosives: Incendiary</Data></Cell><Cell><Data ss:Type="String">Materiały wybuchowe – zapalające</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">INCENDIARY_PAYLOAD</Data></Cell><Cell><Data ss:Type="String">UPGRADE_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Explosive attacks now deal Thermal damage and have a 12[StrengthThermal/] strength chance (8[strengthThermal/] for repeating attacks) to apply [abilityred]Burning[/abilityred].[br/][br/][productioncol]Cannot be combined with Explosives: Electrical.[/productioncol]</Data></Cell><Cell><Data ss:Type="String">Ataki wybuchowe zadają teraz obrażenia cieplne i mają szansę (siła 12[StrengthThermal/], 8[strengthThermal/] dla ataków wielokrotnych) na spowodowanie [abilityred]oparzenia[/abilityred].[br/][br/][productioncol]Nie można łączyć z materiałami wybuchowymi – elektrycznymi.[/productioncol]</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SABOTAGE_PAYLOAD</Data></Cell><Cell><Data ss:Type="String">UPGRADE_NAME</Data></Cell><Cell><Data ss:Type="String">Explosives: Arc Overload</Data></Cell><Cell><Data ss:Type="String">Materiały wybuchowe – przeciążenie elektryczne</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">SABOTAGE_PAYLOAD</Data></Cell><Cell><Data ss:Type="String">UPGRADE_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Explosive attacks now deal Arc damage and have a 6[StrengthWave/] strength chance (3[strengthWave/] for repeating attacks) to apply [abilityred]Stunned[/abilityred].[br/][br/][productioncol]Cannot be combined with Explosives: Incendiary.[/productioncol]</Data></Cell><Cell><Data ss:Type="String">Ataki wybuchowe zadają teraz obrażenia elektryczne i mają szansę (siła 6[StrengthWave/], 3[strengthWave/] dla ataków wielokrotnych) na spowodowanie [abilityred]ogłuszenia[/abilityred].[br/][br/][productioncol]Nie można łączyć z materiałami wybuchowymi – zapalającymi.[/productioncol]</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">MICRO_NUCLEAR_PAYLOAD</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Micro Nuclear Payload</Data></Cell><Cell><Data ss:Type="String">Mikroatomówka</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="75"><Cell><Data ss:Type="String">MICRO_NUCLEAR_PAYLOAD</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Explosive attacks gain a level of [abilityred]Stagger Impact[/abilityred], destroy {amountA}[armor/] and {amountS}[shield/] per hit and have a {ImmolateStrength}[strengthThermal/] strength chance ({ImmolateStrengthRepeating}[strengthThermal/] for repeating attacks) to apply [abilityred]Immolate[/abilityred].</Data></Cell><Cell><Data ss:Type="String">Ataki wybuchowe uzyskują poziom [abilityred]zachwiania[/abilityred], niszczą {amountA}[armor/] i {amountS}[shield/] każdym trafieniem; mają też szansę (siła {ImmolateStrength}[strengthThermal/], {ImmolateStrengthRepeating}[strengthThermal/] dla ataków wielokrotnych) na spowodowanie [abilityred]podpalenia[/abilityred].</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">MICRO_NUCLEAR_PAYLOAD</Data></Cell><Cell><Data ss:Type="String">MOD_NAME</Data></Cell><Cell><Data ss:Type="String">Defense Melt</Data></Cell><Cell><Data ss:Type="String">Likwidacja obrony</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">MICRO_NUCLEAR_PAYLOAD</Data></Cell><Cell><Data ss:Type="String">MOD_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Destroy {amountA}[armor/] and {amountS}[shield/] per hit.</Data></Cell><Cell><Data ss:Type="String">Niszczy {amountA}[armor/] i {amountS}[shield/] każdym trafieniem.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SMART_PAYLOAD</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Smart Payload</Data></Cell><Cell><Data ss:Type="String">Broń inteligentna</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">SMART_PAYLOAD</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Explosive attacks ignore friendly targets and gain a level of [abilityred]Stagger Impact[/abilityred].</Data></Cell><Cell><Data ss:Type="String">Ataki wybuchowe ignorują przyjazne cele i uzyskują poziom [abilityred]powodowania zachwiania[/abilityred].</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">SMART_PAYLOAD</Data></Cell><Cell><Data ss:Type="String">MOD_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Ignores friendly targets</Data></Cell><Cell><Data ss:Type="String">Ignoruje przyjazne cele</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">NAVAL_MISSILE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Launch Naval Missile</Data></Cell><Cell><Data ss:Type="String">Pocisk okrętowy</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">NAVAL_MISSILE</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Launch a missile at the target hex, dealing damage to everything in the area of effect.</Data></Cell><Cell><Data ss:Type="String">Skierowany na wskazane pole pocisk rani wszystko, co znajdzie się w obszarze rażenia.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HEAVY_SHELL_TURRET</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Heavy Shell Turret</Data></Cell><Cell><Data ss:Type="String">Wieżyczka z ciężkim działem</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">HEAVY_SHELL_TURRET</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Fire the Heavy Shell Turret at the target, dealing Explosive damage. Adjacent units receive {DamagePercentage} of that damage.</Data></Cell><Cell><Data ss:Type="String">Wieżyczka z ciężkim działem strzela do celu, zadając mu obrażenia od wybuchu. Sąsiadujące z celem jednostki otrzymują {DamagePercentage} tych obrażeń.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">BROADSIDE_BOMBARDMENT</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Broadside Bombardment</Data></Cell><Cell><Data ss:Type="String">Salwa burtowa</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">BROADSIDE_BOMBARDMENT</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Let loose with all available weapons, dealing damage in a {hexrad} hex radius. This builds up smoke and heat which need to be expelled before this attack can be used again.</Data></Cell><Cell><Data ss:Type="String">Otwiera ogień ze wszystkich dostępnych broni i zadaje obrażenia na obszarze o promieniu {hexrad} pól. Powoduje nagromadzenie się dymu i ciepła, które trzeba rozproszyć przed ponownym użyciem salwy.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">EXPEL_EXHAUST_FUMES</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Expel Exhaust Fumes</Data></Cell><Cell><Data ss:Type="String">Rozproszenie dymów prochowych</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">EXPEL_EXHAUST_FUMES</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Vent exhaust fumes and heat, enabling Broadside Bombardment and clouding the area around this unit. All units in the smoke are {evadeup} harder to hit.</Data></Cell><Cell><Data ss:Type="String">Odprowadzenie dymów wylotowych i ciepła umożliwia ponowne użycie salwy, a zarazem przesłania obszar dookoła jednostki. Wszystkie osłonięte dymem jednostki trudniej trafić o {evadeup}.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">BOMBARD</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Bombard</Data></Cell><Cell><Data ss:Type="String">Bombarda</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">BOMBARD</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Fire a powerful but inaccurate artillery shell at the target location, dealing damage in a 1 hex radius area.</Data></Cell><Cell><Data ss:Type="String">Wystrzeliwuje ciężki pocisk artyleryjski o niskiej celności, zadając obrażenia w promieniu 2 pól od wskazanego miejsca.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">EXPLOSIVE_ROUND</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Explosive Round</Data></Cell><Cell><Data ss:Type="String">Pocisk wybuchowy</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">EXPLOSIVE_ROUND</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Fire a single Explosive round at the target location, dealing damage in a {hexrad} hex radius.</Data></Cell><Cell><Data ss:Type="String">Wystrzeliwuje pojedynczy pocisk wybuchowy, zadając obrażenia w promieniu {hexrad} pól od wskazanego miejsca.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TACTICAL_FACE</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Tactical F.A.C.E.</Data></Cell><Cell><Data ss:Type="String">TWARZ</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">TACTICAL_FACE</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">The Forcefully Applied Contact Explosive is a highly efficient method of crowd control.</Data></Cell><Cell><Data ss:Type="String">Taktyczny Wybuchowy Atak Radialnego Zniszczenia to bardzo skuteczne narzędzie do walki z grupami przeciwników.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">BOMB</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">B.O.M.B.</Data></Cell><Cell><Data ss:Type="String">BOMBA</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">BOMB</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">The Body-Originating Mass Blast hits all adjacent units, dealing Explosive damage. Ideal for when you don't have the time to F.A.C.E everybody.</Data></Cell><Cell><Data ss:Type="String">Bezwzględna Ofensywna Masowa Bomba Absolutna razi wszystkie sąsiednie jednostki, zadając obrażenia od wybuchu. Jest idealna w sytuacji, gdy musisz zachować TWARZ na inną okazję.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FLASH_PAYLOAD</Data></Cell><Cell><Data ss:Type="String">TEMPLATE_NAME_1</Data></Cell><Cell ss:StyleID="s64"><Data ss:Type="String">Flashy</Data></Cell><Cell><Data ss:Type="String">Poblask</Data></Cell><Cell ss:In
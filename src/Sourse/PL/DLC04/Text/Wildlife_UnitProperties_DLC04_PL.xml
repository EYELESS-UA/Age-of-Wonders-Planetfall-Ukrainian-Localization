<?xml version="1.0"?><?mso-application progid="Excel.Sheet"?><Workbook xmlns="urn:schemas-microsoft-com:office:spreadsheet" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns:ss="urn:schemas-microsoft-com:office:spreadsheet" xmlns:html="http://www.w3.org/TR/REC-html40"><DocumentProperties xmlns="urn:schemas-microsoft-com:office:office"><Author>Arnout Sas</Author><LastAuthor>Luis Ferreira</LastAuthor><Created>2019-10-11T10:53:00Z</Created><LastSaved>2020-03-11T10:09:59Z</LastSaved><Version>16.00</Version></DocumentProperties><OfficeDocumentSettings xmlns="urn:schemas-microsoft-com:office:office"><AllowPNG/></OfficeDocumentSettings><ExcelWorkbook xmlns="urn:schemas-microsoft-com:office:excel"><WindowHeight>7830</WindowHeight><WindowWidth>16170</WindowWidth><WindowTopX>32767</WindowTopX><WindowTopY>32767</WindowTopY><RefModeR1C1/><ProtectStructure>False</ProtectStructure><ProtectWindows>False</ProtectWindows></ExcelWorkbook><Styles><Style ss:ID="Default" ss:Name="Normal"><Alignment ss:Vertical="Bottom"/><Borders/><Font ss:FontName="Calibri" x:Family="Swiss" ss:Size="11" ss:Color="#000000"/><Interior/><NumberFormat/><Protection/></Style><Style ss:ID="s62"><Alignment ss:Vertical="Top" ss:WrapText="1"/></Style></Styles><Worksheet ss:Name="Script"><Table x:FullColumns="1" x:FullRows="1" ss:StyleID="s62" ss:DefaultColumnWidth="383.25" ss:DefaultRowHeight="15"><Column ss:StyleID="s62" ss:Width="210.75"/><Column ss:StyleID="s62" ss:Width="113.25"/><Column ss:Index="4" ss:StyleID="s62" ss:Width="147.75"/><Column ss:StyleID="s62" ss:AutoFitWidth="0" ss:Width="282"/><Column ss:StyleID="s62" ss:Width="120.75"/><Row ss:AutoFitHeight="0" ss:Height="75"><Cell><Data ss:Type="String">WILDLIFE_UNITPROPERTIES_DLC04</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">The DEV TEAM / MISC NOTES column contains info on what text between { } signs means (if applicable). It usually stands for either a numeric value, or a numeric value with an icon. Text between [ ] signs stands for a certain type of icon. </Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SCENE ID</Data></Cell><Cell><Data ss:Type="String">TEXT ID</Data></Cell><Cell><Data ss:Type="String">ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZATION NOTES</Data></Cell><Cell><Data ss:Type="String">DEV TEAM / MISC NOTES</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">BIO_STAFF</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Bio Staff</Data></Cell><Cell><Data ss:Type="String">Biokostur</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">BIO_STAFF</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Biochemical ranged attack.</Data></Cell><Cell><Data ss:Type="String">Atak biochemiczny na odległość.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">REJUVENATING_RAY</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Rejuvenating Ray</Data></Cell><Cell><Data ss:Type="String">Promień odmładzający</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">REJUVENATING_RAY</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Heal target Biological or Cyborg unit for {HP}[hp/]. If the target is dead, revive it for {HPRevive}% of its max [hp/].</Data></Cell><Cell><Data ss:Type="String">Przywraca wskazanej jednostce organicznej lub cyborgowi {HP}[hp/]. Jeśli cel jest martwy, ożywia go z {HPRevive}% maksymalnej [hp/].</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">GROWTH_RAY</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Growth Ray</Data></Cell><Cell><Data ss:Type="String">Promień wzrostu</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">GROWTH_RAY</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Evolve target unit through metamorphosis. They suffer from [abilityred]Sudden Growth[/abilityred], reducing damage by {DamageDown}% and losing {Amount}[armor/] and [shield/].</Data></Cell><Cell><Data ss:Type="String">Powoduje przemianę wskazanej jednostki. Jednostka doznaje [abilityred]nagłego wzrostu[/abilityred], co zmniejsza zadawane przez nią obrażenia o {DamageDown}% oraz powoduje utratę {Amount}[armor/] i [shield/].</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">WILD_PHEROMONES</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Wild Pheromones</Data></Cell><Cell><Data ss:Type="String">Dzikie feromony</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">WILD_PHEROMONES</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">When unit drops to {Health}% [hp/] or lower, attract a random Wildlife unit adjacent to this one.</Data></Cell><Cell><Data ss:Type="String">Gdy wytrzymałość jednostki spada do {Health}% [hp/] lub mniej, następuje przyciągnięcie sąsiadującej z nią losowo wybranej jednostki dzikiego zwierzęcia.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">DIRE_CLAW</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Dire Claw</Data></Cell><Cell><Data ss:Type="String">Złowieszczy pazur</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">DIRE_CLAW</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">A melee attack.</Data></Cell><Cell><Data ss:Type="String">Atak wręcz.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">BOOM_BURST</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Boom Burst</Data></Cell><Cell><Data ss:Type="String">Seria łoskotów</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">BOOM_BURST</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Project a Sonic attack at the target.</Data></Cell><Cell><Data ss:Type="String">Razi cel atakiem dźwiękowym.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HEAVY_DIRE_CLAW</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Heavy Dire Claw</Data></Cell><Cell><Data ss:Type="String">Ciężki złowieszczy pazur</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HEAVY_DIRE_CLAW</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">A melee attack.</Data></Cell><Cell><Data ss:Type="String">Atak wręcz.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">THUNDEROUS_BURST</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Thunderous Burst</Data></Cell><Cell><Data ss:Type="String">Gromka seria</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">THUNDEROUS_BURST</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Deal Sonic damage to all units in a {HexCone} hex cone in front of this unit.</Data></Cell><Cell><Data ss:Type="String">Zadaje obrażenia dźwiękowe wszystkim jednostkom w stożku o długości {HexCone} pól na wprost atakującej jednostki.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">BERSERK</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Berserk</Data></Cell><Cell><Data ss:Type="String">Berserk</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">BERSERK</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">When unit drops to {Health}% [hp/] or lower, this unit gains +{Damage}% damage and becomes [abilityred]Insane[/abilityred], causing it to attack enemies at random.</Data></Cell><Cell><Data ss:Type="String">Gdy wytrzymałość jednostki spada do {Health}% [hp/] lub mniej, jednostka zyskuje +{Damage}% do obrażeń i popada w [abilityred]obłęd[/abilityred], przez co będzie atakować losowo wybranych wrogów.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">GROWTH_RAY</Data></Cell><Cell><Data ss:Type="String">PROP_NAME</Data></Cell><Cell><Data ss:Type="String">Sudden Growth</Data></Cell><Cell><Data ss:Type="String">Nagły wzrost</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">GROWTH_RAY</Data></Cell><Cell><Data ss:Type="String">PROP_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit evolved rapidly, reducing damage by {DamageDown}% and losing {Amount}[armor/] and [shields/].</Data></Cell><Cell><Data ss:Type="String">Ta jednostka błyskawicznie wyewoluowała, co zmniejszyło zadawane przez nią obrażenia o {DamageDown}% oraz spowodowało utratę {Amount}[armor/] i [shields/].</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">BERSERK</Data></Cell><Cell><Data ss:Type="String">PROP_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit is raging, attacking enemies at random with +{Damage}% damage.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka wpadła w szał i atakuje losowo wybranych wrogów, zadając o {Damage}% więcej obrażeń.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">THUNDERMAW_RAGE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Precise</Data></Cell><Cell><Data ss:Type="String">Dokładność</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">THUNDERMAW_RAGE</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">+{CritChance}% critical hit chance</Data></Cell><Cell><Data ss:Type="String">+{CritChance}% do szansy na trafienie krytyczne.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">RESOLUTE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Resolute</Data></Cell><Cell><Data ss:Type="String">Stanowczość</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">RESOLUTE</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit will not lose overwatch when staggered.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka nie wyjdzie z trybu warty, gdy ulegnie zachwianiu.</Data></Cell></Row><Row><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell><Cell ss:Index="7"><Data ss:Type="String">In the text below, text refers to a person that can either be male or female. If relevant for translation, please use the ‘localized string’ column for the male text and the ‘alternative localized string’ column for the female text. You and Your might be examples of this.</Data></Cell></Row><Row><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell><Cell ss:Index="7"><Data ss:Type="String">In the text below, any inserted strings - anything of the form {text} - is replaced by an integer value for the thing described in the brackets. If the {text} is not followed by a unit - e.g. shields, hitpoints - the icon for the unit is inserted together with the integer. The same holds for symbols - e.g. '+', '%' - which are occasionally inserted together with the integer.</Data></Cell></Row><Row><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell><Cell ss:Index="7"><Data ss:Type="String">For references to game terminology and in-world references, please check the glossary delivered as part of the documentation.</Data></Cell></Row></Table><WorksheetOptions xmlns="urn:schemas-microsoft-com:office:excel"><Unsynced/><Print><ValidPrinterInfo/><HorizontalResolution>600</HorizontalResolution><VerticalResolution>600</VerticalResolution></Print><Selected/><TopRowVisible>3</TopRowVisible><Panes><Pane><Number>3</Number><ActiveRow>8</ActiveRow><ActiveCol>2</ActiveCol></Pane></Panes><ProtectObjects>False</ProtectObjects><ProtectScenarios>False</ProtectScenarios></WorksheetOptions></Worksheet></Workbook>
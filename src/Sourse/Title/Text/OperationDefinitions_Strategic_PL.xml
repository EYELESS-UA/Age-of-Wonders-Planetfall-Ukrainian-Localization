<?xml version="1.0"?><?mso-application progid="Excel.Sheet"?><Workbook xmlns="urn:schemas-microsoft-com:office:spreadsheet" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns:ss="urn:schemas-microsoft-com:office:spreadsheet" xmlns:html="http://www.w3.org/TR/REC-html40"><DocumentProperties xmlns="urn:schemas-microsoft-com:office:office"><LastAuthor>Djurre van Dijk</LastAuthor><Created>2019-05-06T09:39:38Z</Created><LastSaved>2019-05-06T09:39:38Z</LastSaved><Version>16.00</Version></DocumentProperties><OfficeDocumentSettings xmlns="urn:schemas-microsoft-com:office:office"><AllowPNG/></OfficeDocumentSettings><ExcelWorkbook xmlns="urn:schemas-microsoft-com:office:excel"><WindowHeight>16365</WindowHeight><WindowWidth>28800</WindowWidth><WindowTopX>32767</WindowTopX><WindowTopY>32767</WindowTopY><RefModeR1C1/><ProtectStructure>False</ProtectStructure><ProtectWindows>False</ProtectWindows></ExcelWorkbook><Styles><Style ss:ID="Default" ss:Name="Normal"><Alignment ss:Vertical="Bottom"/><Borders/><Font ss:FontName="Calibri" x:Family="Swiss" ss:Size="11" ss:Color="#000000"/><Interior/><NumberFormat/><Protection/></Style><Style ss:ID="s62"><Alignment ss:Vertical="Bottom" ss:WrapText="1"/></Style></Styles><Worksheet ss:Name="Script"><Table x:FullColumns="1" x:FullRows="1" ss:DefaultRowHeight="15"><Column ss:Width="235.5"/><Column ss:Width="132.75"/><Column ss:AutoFitWidth="0" ss:Width="315.75"/><Column ss:AutoFitWidth="0" ss:Width="549"/><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s62"><Data ss:Type="String">OPERATIONDEFINITIONS_STRATEGIC</Data></Cell><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"><Data ss:Type="String">The DEV TEAM / MISC NOTES column contains info on what text between { } signs means (if applicable). It usually stands for either a numeric value, or a numeric value with an icon. Text between [ ] signs stands for a certain type of icon. </Data></Cell><Cell ss:StyleID="s62"/></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s62"><Data ss:Type="String">SCENE ID</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">TEXT ID</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">ENGLISH STRING</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">LOCALIZED STRING</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">ALTERNATIVE ENGLISH STRING</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">ALTERNATIVE LOCALIZED STRING</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">LOCALIZATION NOTES</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">DEV TEAM / MISC NOTES</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s62"><Data ss:Type="String">CITY_OPERATION_ABSORB</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">NAME</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Absorb</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Wchłoń</Data></Cell><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"><Data ss:Type="String">text for the button to absorb the colony into your own kingdom</Data></Cell><Cell ss:StyleID="s62"/></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s62"><Data ss:Type="String">CITY_OPERATION_ABSORB</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">You absorb the colony into your empire, bringing it under your control.</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Wchłoniesz kolonię do swojego imperium i przejmiesz nad nią kontrolę.</Data></Cell><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s62"><Data ss:Type="String">CITY_OPERATION_ABSORB</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">INPROGRESS_DESCRIPTION</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">This colony is being absorbed. Process will complete in [INT_duration].</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Trwa włączanie tej kolonii do twojego imperium. Prace zakończą się za [INT_duration].</Data></Cell><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s62"><Data ss:Type="String">CITY_OPERATION_RAZE</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">NAME</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Raze</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Spustosz</Data></Cell><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"><Data ss:Type="String">text for the button to raze the colony, see cell below for more information about the action</Data></Cell><Cell ss:StyleID="s62"/></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s62"><Data ss:Type="String">CITY_OPERATION_RAZE</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Burn the colony to the ground. This renders various colony upgrades unusable and the colony itself uninhabitable until reconstructed.[br/][br/]You receive:[br/][fireCol]{ReputationDecrease} Reputation[br/]{RaceRelationDecrease} Race Relations with the race of the colony[/fireCol] </Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Spowoduje zburzenie kolonii do fundamentów. W rezultacie różne ulepszenia kolonii przestaną działać, a sama kolonia przestanie się nadawać do zamieszkania do czasu odbudowy.[br/][br/]Otrzymasz:[br/][fireCol]{ReputationDecrease} do reputacji[br/]{RaceRelationDecrease} do stosunków cywilizacyjnych z cywilizacją zamieszkującą tę kolonię[/fireCol] </Data></Cell><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"><Data ss:Type="String">Burns the town to the ground. Removed Instantly for each language!</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s62"><Data ss:Type="String">CITY_OPERATION_RAZE</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">INPROGRESS_DESCRIPTION</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">The colony is being razed. Process will complete in [INT_duration].</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Kolonia jest burzona. Prace zakończą się za [INT_duration].</Data></Cell><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s62"><Data ss:Type="String">SECTOR_OPERATION_TRANSFER</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">NAME</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Transfer to {STR_cityName}</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Przekaż do {STR_cityName}</Data></Cell><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s62"><Data ss:Type="String">SECTOR_OPERATION_TRANSFER</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Transfer the sector from one colony to another colony.</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Przekazuje sektor z jednej kolonii do innej.</Data></Cell><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s62"><Data ss:Type="String">SECTOR_OPERATION_TRANSFER</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">INPROGRESS_DESCRIPTION</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Transferring the sector into your colony. Process will complete in [INT_duration].</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Przenoszenie sektora do twojej kolonii. Prace zakończą się za [INT_duration].</Data></Cell><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s62"><Data ss:Type="String">SECTOR_OPERATION_RAZE</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">NAME</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Raze</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Spustosz</Data></Cell><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s62"><Data ss:Type="String">SECTOR_OPERATION_RAZE</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Burn a sector's base to the ground.[br/][firecol]This will also destroy all upgrades and remove ownership over this sector.[/firecol]</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Zrównuje z ziemią bazę sektorową.[br/][firecol]Spowoduje to też zniszczenie wszystkich ulepszeń i sprawi, że sektor nie będzie potem należeć do nikogo.[/firecol]</Data></Cell><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s62"><Data ss:Type="String">SECTOR_OPERATION_RAZE</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">INPROGRESS_DESCRIPTION</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">The sector's base is being razed. Process will complete in [INT_duration].</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Baza sektorowa jest burzona. Prace zakończą się za [INT_duration].</Data></Cell><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s62"><Data ss:Type="String">ENTER_STRUCTURE</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">NAME</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Enter</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Wejdź</Data></Cell><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s62"><Data ss:Type="String">ENTER_STRUCTURE</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Enter this location to fight its inhabitants. Only the army standing on top of the structure can enter, adjacent armies will not participate in this combat. </Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Wejdź do tego miejsca, aby walczyć z jego mieszkańcami. Wejść może tylko armia stojąca na polu z miejscem, sąsiadujące armie nie będą brać udziału w tej walce. </Data></Cell><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s62"><Data ss:Type="String">CITY_OPERATION_TRANSFER_HQ</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">NAME</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Transfer HQ</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Przeniesienie sztabu</Data></Cell><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s62"><Data ss:Type="String">CITY_OPERATION_TRANSFER_HQ</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Transfers the HQ building to another colony center. The HQ building is responsible for base economic income and is where your Leader will appear when they return from the Void.</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Przenosi budynek sztabu do innego centrum kolonii. Sztab odpowiada za podstawowy dochód gospodarczy i jest miejscem, w którym pojawi się twój przywódca po powrocie z Głębi.</Data></Cell><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s62"><Data ss:Type="String">CITY_OPERATION_TRANSFER_HQ</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">INPROGRESS_DESCRIPTION</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">The HQ is being transferred. Process will complete in [INT_duration].</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Sztab jest przenoszony. Prace zakończą się za [INT_duration].</Data></Cell><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s62"><Data ss:Type="String">SECTOR_OPERATION_CAPTURE</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">NAME</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">[annex/] Capture and annex sector to {STR_cityName}</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">[annex/] Podbij i przyłącz sektor do kolonii {STR_cityName}</Data></Cell><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s62"><Data ss:Type="String">SECTOR_OPERATION_CAPTURE</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Captures the sector and annexes it to your colony.</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Powoduje zdobycie sektora i przyłączenie go do twojej kolonii.</Data></Cell><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s62"><Data ss:Type="String">SECTOR_OPERATION_CAPTURE</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">INPROGRESS_DESCRIPTION</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">This sector is currently being annexed. Process will complete in [INT_duration].</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Ten sektor jest obecnie przyłączany. Prace zakończą się za [INT_duration].</Data></Cell><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s62"><Data ss:Type="String">SECTOR_OPERATION_RELEASE_FORWARD_BASE</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">NAME</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Release sector as forward base</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Uwolnij sektor jako wysuniętą bazę</Data></Cell><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s62"><Data ss:Type="String">SECTOR_OPERATION_RELEASE_FORWARD_BASE</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Releases the sector base as a forward base, detaching it from your colony.[br/][firecol]This removes all income from this sector.[/firecol][br/][br/]A forward base does not allow you to gather income from the sector, but it does project a claim to all adjacent sectors, give vision of the surrounding area and serves as an obstacle for your enemies.</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Przekształca bazę sektorową w wysuniętą bazę, odłączając sektor od twojej kolonii.[br/][firecol]Spowoduje to wyzerowanie wszystkich dochodów z tego sektora.[/firecol][br/][br/]Wysunięta baza nie umożliwia uzyskiwania dochodu z sektora, ale rozszerza twoje roszczenie na wszystkie sąsiednie sektory, daje możliwość obserwowania otoczenia i stanowi przeszkodę dla wrogów.</Data></Cell><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s62"><Data ss:Type="String">SECTOR_OPERATION_RELEASE_FORWARD_BASE</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">INPROGRESS_DESCRIPTION</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">This sector is being released as a forward base. Process will complete in [INT_duration].</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Ten sektor jest uwalniany jako wysunięta baza. Prace zakończą się za [INT_duration].</Data></Cell><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s62"><Data ss:Type="String">SECTOR_OPERATION_FORWARD_BASE_ANNEX</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">NAME</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">[annex/] Annex forward base to {STR_cityName}</Data></Cell><Cell><Data ss:Type="String">[annex/] Przyłącz wysuniętą bazę do kolonii {STR_cityName}</Data></Cell><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s62"><Data ss:Type="String">SECTOR_OPERATION_FORWARD_BASE_ANNEX</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Link the forward base to your colony.[br/][br/]{XML_COLONYDEFINITION_STRATEGIC@SECTOR_OPERATION_BUILD_BASE@SHARED_TEXT}</Data></Cell><Cell><Data ss:Type="String">Przyłącza wysuniętą bazę do twojej kolonii.[br/][br/]{XML_COLONYDEFINITION_STRATEGIC@SECTOR_OPERATION_BUILD_BASE@SHARED_TEXT}</Data></Cell><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s62"><Data ss:Type="String">SECTOR_OPERATION_FORWARD_BASE_ANNEX</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">INPROGRESS_DESCRIPTION</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Annexing the forward base as a sector base. Process will complete in [INT_duration].</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Przyłączanie wysuniętej bazy jako bazy sektorowej. Prace zakończą się za [INT_duration].</Data></Cell><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s62"><Data ss:Type="String">SECTOR_OPERATION_FORWARD_BASE_CAPTURE</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">NAME</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Capture forward base</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Zdobądź wysuniętą bazę</Data></Cell><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s62"><Data ss:Type="String">SECTOR_OPERATION_FORWARD_BASE_CAPTURE</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Captures the forward base, transferring ownership of it to you.</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Powoduje zdobycie wysuniętej bazy i przekazanie jej na twoją własność.</Data></Cell><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s62"><Data ss:Type="String">SECTOR_OPERATION_FORWARD_BASE_CAPTURE</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">INPROGRESS_DESCRIPTION</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">This forward base is being captured. Process will complete in [INT_duration].</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Ta wysunięta baza jest zajmowana. Prace zakończą się za [INT_duration].</Data></Cell><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s62"><Data ss:Type="String">LANDMARK_OPERATION_ANNEX</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">NAME</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">[annex/] Annex landmark to {STR_cityName}</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">[annex/] Przyłącz miejsce charakterystyczne do kolonii {STR_cityName}</Data></Cell><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s62"><Data ss:Type="String">LANDMARK_OPERATION_ANNEX</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Link the landmark to your colony.[br/][br/]{XML_COLONYDEFINITION_STRATEGIC@SECTOR_OPERATION_BUILD_BASE@SHARED_TEXT}</Data></Cell><Cell><Data ss:Type="String">Przyłącza miejsce charakterystyczne do twojej kolonii.[br/][br/]{XML_COLONYDEFINITION_STRATEGIC@SECTOR_OPERATION_BUILD_BASE@SHARED_TEXT}</Data></Cell><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s62"><Data ss:Type="String">LANDMARK_OPERATION_ANNEX</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">INPROGRESS_DESCRIPTION</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">This landmark is currently being annexed. Process will complete in [INT_duration].</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">To miejsce charakterystyczne jest obecnie przyłączane. Prace zakończą się za [INT_duration].</Data></Cell><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s62"><Data ss:Type="String">LANDMARK_OPERATION_RELEASE</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">NAME</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Release landmark</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Uwolnij miejsce charakterystyczne</Data></Cell><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/><Cell ss:StyleID="s62"/></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s62"><Data ss:Type="String">LANDMARK_OPERATION_RELEASE</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell s
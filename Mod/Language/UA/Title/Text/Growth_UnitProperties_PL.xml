<?xml version="1.0"?><?mso-application progid="Excel.Sheet"?><Workbook xmlns="urn:schemas-microsoft-com:office:spreadsheet" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns:ss="urn:schemas-microsoft-com:office:spreadsheet" xmlns:html="http://www.w3.org/TR/REC-html40"><DocumentProperties xmlns="urn:schemas-microsoft-com:office:office"><LastAuthor>Djurre van Dijk</LastAuthor><Created>2019-05-06T09:39:28Z</Created><LastSaved>2019-05-06T09:39:28Z</LastSaved><Version>16.00</Version></DocumentProperties><OfficeDocumentSettings xmlns="urn:schemas-microsoft-com:office:office"><AllowPNG/></OfficeDocumentSettings><ExcelWorkbook xmlns="urn:schemas-microsoft-com:office:excel"><WindowHeight>9990</WindowHeight><WindowWidth>21525</WindowWidth><WindowTopX>32767</WindowTopX><WindowTopY>32767</WindowTopY><RefModeR1C1/><ProtectStructure>False</ProtectStructure><ProtectWindows>False</ProtectWindows></ExcelWorkbook><Styles><Style ss:ID="Default" ss:Name="Normal"><Alignment ss:Vertical="Bottom"/><Borders/><Font ss:FontName="Calibri" x:Family="Swiss" ss:Size="11" ss:Color="#000000"/><Interior/><NumberFormat/><Protection/></Style><Style ss:ID="s62"><Alignment ss:Vertical="Bottom" ss:WrapText="1"/></Style></Styles><Worksheet ss:Name="Script"><Table x:FullColumns="1" x:FullRows="1" ss:DefaultRowHeight="15"><Column ss:AutoFitWidth="0" ss:Width="167.25"/><Column ss:AutoFitWidth="0" ss:Width="126"/><Column ss:StyleID="s62" ss:AutoFitWidth="0" ss:Width="783.75"/><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">THEGROWTH_UNITPROPERTIES</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">The DEV TEAM / MISC NOTES column contains info on what text between { } signs means (if applicable). It usually stands for either a numeric value, or a numeric value with an icon. Text between [ ] signs stands for a certain type of icon. </Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SCENE ID</Data></Cell><Cell><Data ss:Type="String">TEXT ID</Data></Cell><Cell><Data ss:Type="String">ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZATION NOTES</Data></Cell><Cell><Data ss:Type="String">DEV TEAM / MISC NOTES</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">WORKER_BEE_STING</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Sting</Data></Cell><Cell><Data ss:Type="String">Żądło</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">WORKER_BEE_STING</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Pierce the target with a sharp stinger.</Data></Cell><Cell><Data ss:Type="String">Przebija cel ostrym szpikulcem.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PHEROMONE_SPRAY</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Pheromone Spray</Data></Cell><Cell><Data ss:Type="String">Mgiełka feromonowa</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PHEROMONE_SPRAY</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Deploy a spray of pheromones, attempting to apply [abilityred]Mind Control[/abilityred] to a non-Mindless Biological or Cyborg target until end of combat. This has a {MindControlChance} strength chance to succeed.</Data></Cell><Cell><Data ss:Type="String">Rozpyla aerozol feromonowy, próbując poddać [abilityred]kontroli umysłu[/abilityred] wskazany cel organiczny lub cyborga (nie działa na istoty bezmózgie). W razie powodzenia trwa do końca walki. Szansa na udane użycie wynosi {MindControlChance} siły.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SEED_BOMB</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Seed Bomb</Data></Cell><Cell><Data ss:Type="String">Bomba nasienna</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SEED_BOMB</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Shoot a single seed that detonates when it makes contact with the target.</Data></Cell><Cell><Data ss:Type="String">Wystrzeliwuje pojedyncze nasiono, które wybucha w zetknięciu z celem.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SEED_BARRAGE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Seed Barrage</Data></Cell><Cell><Data ss:Type="String">Ostrzał nasienny</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SEED_BARRAGE</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Long-range {hexrad} hex radius Biochemical burst.</Data></Cell><Cell><Data ss:Type="String">Atak biochemiczny dalekiego zasięgu na obszar o promieniu {hexrad} pól.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SPAWN_VINE_SPROUT</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Spawn Vine Sprout</Data></Cell><Cell><Data ss:Type="String">Kiełkowanie pnączy</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SPAWN_VINE_SPROUT</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Spawn a Vine Sprout that lasts until end of combat. Puts the unit into Defense Mode after use.[br/][br/]The summoned unit will inherit any compatible mods that do not grant an active ability.[br/]</Data></Cell><Cell><Data ss:Type="String">Tworzy pęd pnączy, który utrzymuje się do końca walki. Po użyciu przełącza jednostkę w tryb obronny.[br/][br/]Przywołana jednostka „odziedziczy” wszystkie zgodne modyfikacje niedające umiejętności aktywnej.[br/]</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ENTANGLING_STRIKE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Entangling Strike</Data></Cell><Cell><Data ss:Type="String">Oplatający cios</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ENTANGLING_STRIKE</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Chance to entangle the target for {entanglingstrikeTime}.</Data></Cell><Cell><Data ss:Type="String">Szansa oplątania celu na {entanglingstrikeTime}.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">REGENERATIVE_POLLENATION</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Regenerative Pollenation</Data></Cell><Cell><Data ss:Type="String">Zapylenie regenerujące</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">REGENERATIVE_POLLENATION</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Heal target friendly Biological or Cyborg unit for {RegenerativeHeal}.</Data></Cell><Cell><Data ss:Type="String">Leczy wskazaną przyjazną jednostkę organiczną lub cyborga za {RegenerativeHeal}.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SHOOT_POLLEN</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Allergenic Spray</Data></Cell><Cell><Data ss:Type="String">Mgiełka alergenna</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SHOOT_POLLEN</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Spray pollen at the target, dealing Biochemical damage.</Data></Cell><Cell><Data ss:Type="String">Otacza cel chmurą pyłku, który zadaje obrażenia biochemiczne.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">REGENERATION_SPORES</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Regeneration Spores</Data></Cell><Cell><Data ss:Type="String">Zarodniki regenerujące</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">REGENERATION_SPORES</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit releases regenerative spores which heal it and all adjacent friendly Biological or Cyborg units for {RegenerationHeal}[hp/] at the end of each turn in tactical combat.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka wydziela zarodniki regenerujące, które na końcu każdej tury walki taktycznej przywracają {RegenerationHeal}[hp/] jej samej i wszystkim sąsiednim przyjaznym jednostkom organicznym lub cyborgom.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ALLERGIC_POLLEN</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Allergic Pollen</Data></Cell><Cell><Data ss:Type="String">Pyłek alergenny</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Ability Modifier</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ALLERGIC_POLLEN</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">{AllergicPollenChance}[StrengthBio/] strength chance to apply [abilityred]Allergic Reaction[/abilityred] to Biological or Cyborg for {AllergicPollenDuration}[turn/].</Data></Cell><Cell><Data ss:Type="String">Szansa ({AllergicPollenChance}[StrengthBio/] siły) na spowodowanie [abilityred]reakcji alergicznej[/abilityred] u jednostki organicznej lub cyborga na {AllergicPollenDuration}[turn/].</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ALLERGIC_POLLEN_REACTION</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Allergic Reaction</Data></Cell><Cell><Data ss:Type="String">Reakcja alergiczna</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Status effect</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ALLERGIC_POLLEN_REACTION</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit has -{AllergicReactionPenalty}[DamagePhysical/] and -{AllergicReactionPenalty}[DamageBio/] resistance.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka ma –{AllergicReactionPenalty}[DamagePhysical/] i –{AllergicReactionPenalty}[DamageBio/] odporności.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">NOXIOUS_POLLEN</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Noxious Pollen</Data></Cell><Cell><Data ss:Type="String">Szkodliwy pyłek</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">NOXIOUS_POLLEN</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Release a large quantity of pollen in an {hexrad} hex area.</Data></Cell><Cell><Data ss:Type="String">Wydziela dużą ilość pyłku w obszarze o promieniu {hexrad} pól.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">POLLEN_DELUGE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Regenerative Pollen Deluge</Data></Cell><Cell><Data ss:Type="String">Regenerujący się pyłkowy potop</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">POLLEN_DELUGE</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">A deluge of nectarized pollen floods the area, removing negative Status Effect from all friendly Biological and Cyborg units as well as making them regenerate {PollenDelugeRegen}[hp/] at the start of their turn, for {PollenDelugeDuration}[turn/].</Data></Cell><Cell><Data ss:Type="String">Potop nektaryzowanego pyłku zalewa okolicę, usuwając negatywne efekty stanu wszystkich przyjaznych jednostek organicznych i cyborgów, regenerując jednocześnie {PollenDelugeRegen}[hp/] na początku każdej tury przez {PollenDelugeDuration}[turn/].</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">POLLEN_DELUGE</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION_UNIT</Data></Cell><Cell><Data ss:Type="String">Unit is healing {PollenDelugeRegen} health per turn.</Data></Cell><Cell><Data ss:Type="String">Jednostka odzyskuje {PollenDelugeRegen} wytrzymałości na turę.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">EUPHORIC_SPORES</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Euphoric Spores</Data></Cell><Cell><Data ss:Type="String">Zarodniki euforyczne</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">EUPHORIC_SPORES</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit releases euphoria-inducing spores, giving [abilityblue]Euphoric[/abilityblue] to itself and all adjacent Biological and Cyborg units. These units gain +{EuphoriaMorale} and ignore morale penalties in combat. </Data></Cell><Cell><Data ss:Type="String">Ta jednostka wydziela niosące upojenie zarodniki, wywołując [abilityblue]euforię[/abilityblue] u siebie oraz wszystkich sąsiednich jednostek organicznych i cyborgów. Te jednostki uzyskują +{EuphoriaMorale} i ignorują kary do morale podczas walki. </Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">EUPHORIC_SPORES</Data></Cell><Cell><Data ss:Type="String">PROP_NAME</Data></Cell><Cell><Data ss:Type="String">Euphoric</Data></Cell><Cell><Data ss:Type="String">Euforia</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">EUPHORIC_SPORES</Data></Cell><Cell><Data ss:Type="String">PROP_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit has +{EuphoriaMorale} and +{EuphoricRes} resistance.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka ma +{EuphoriaMorale} i +{EuphoricRes} odporności.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">REGENERATION_SPORES</Data></Cell><Cell><Data ss:Type="String">PROP_NAME</Data></Cell><Cell><Data ss:Type="String">Regeneration</Data></Cell><Cell><Data ss:Type="String">Regeneracja</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">REGENERATION_SPORES</Data></Cell><Cell><Data ss:Type="String">PROP_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Unit is healing {PollenDelugeRegen}[hp/] per turn.</Data></Cell><Cell><Data ss:Type="String">Jednostka odzyskuje {PollenDelugeRegen}[hp/] na turę.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">POISON_GLANDS</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Poison Glands</Data></Cell><Cell><Data ss:Type="String">Gruczoły z trucizną</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">POISON_GLANDS</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Specialized glands coat this unit's melee attacks in poison, granting these a {Poisongland}[strengthBio/] strength chance ({PoisonglandRep}[strengthBio/] for repeating attacks) of applying [abilityred]Poisoned[/abilityred].</Data></Cell><Cell><Data ss:Type="String">Specjalne gruczoły dają jednostce możliwość zatruwania w walce wręcz. Jednostka ma szansę (siła {Poisongland}[strengthBio/], {PoisonglandRep}[strengthBio/] dla ataków wielokrotnych) spowodowania [abilityred]zatrucia[/abilityred].</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SPROUTING_INFESTATION</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Sprouting Infestation</Data></Cell><Cell><Data ss:Type="String">Kiełkująca plaga</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SPROUTING_INFESTATION</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">The unit's Biochemical attacks have a {SproutInfest}[strengthBio/] strength chance ({SproutInfestRep}[strengthBio/] for repeating attacks) to apply [abilityred]Sprouting Infestation[/abilityred] to Biological or Cyborg units. This deals {BioDamage}[damagebio/] each turn until the end of combat. [br/]A unit that dies while under this effect creates a friendly Vine Sprout.</Data></Cell><Cell><Data ss:Type="String">Biochemiczne ataki tej jednostki mają szansę (siła {SproutInfest}[strengthBio/], {SproutInfestRep}[strengthBio/] dla ataków wielokrotnych) na wywołanie [abilityred]kiełkującej plagi[/abilityred] u jednostek organicznych lub cyborgów. Zadaje ona {BioDamage}[damagebio/] co turę do końca walki. [br/]Jednostka, która zginie, znajdując się pod wpływem tego efektu, wytworzy przyjazny pęd pnączy.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SPROUTING_INFESTATION</Data></Cell><Cell><Data ss:Type="String">MOD_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">{SproutInfest} strength chance to apply [abilityred]Sprouting Infestation[/abilityred] to Biological or Cyborg units until the end of combat.</Data></Cell><Cell><Data ss:Type="String">Szansa ({SproutInfest} siły) na wywołanie [abilityred]kiełkującej plagi[/abilityred] u jednostek organicznych lub cyborgów do końca walki.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SPROUTING_INFESTATION</Data></Cell><Cell><Data ss:Type="String">PROP_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit is suffering {InfestationDamage} damage per turn. [br/]If this unit dies, it turns into a Vine Sprout under the enemy's control.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka otrzymuje {InfestationDamage} pkt. obrażeń na turę. [br/]Jeśli zginie, zmieni się w pęd pnączy pod kontrolą przeciwnika.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">REGENERATION_SPORES</Data></Cell><Cell><Data ss:Type="String">TEMPLATE_NAME_1</Data></Cell><Cell><Data ss:Type="String">Sporepuff</Data></Cell><Cell><Data ss:Type="String">Zarodnia</Data></Cell><Cell ss:Index="8"><Data ss:Type="String">Review needed?</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">REGENERATION_SPORES</Data></Cell><Cell><Data ss:Type="String">TEMPLATE_NAME_2</Data></Cell><Cell><Data ss:Type="String">Floral Healer</Data></Cell><Cell><Data ss:Type="String">Kwietne leczenie</Data></Cell><Cell ss:Index="8"><Data ss:Type="String">Review needed?</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">REGENERATION_SPORES</Data></Cell><Cell><Data ss:Type="String">TEMPLATE_NAME_3</Data></Cell><Cell><Data ss:Type="String">Herbal</Data></Cell><Cell><Data ss:Type="String">Zielarstwo</Data></Cell><Cell ss:Index="8"><Data ss:Type="String">Review needed?</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">REGENERATION_SPORES</Data></Cell><Cell><Data ss:Type="String">TEMPLATE_NAME_4</Data></Cell><Cell><Data ss:Type="String">Verdant</Data></Cell><Cell><Data ss:Type="String">Zieleń</Data></Cell><Cell ss:Index="8"><Data ss:Type="String">Review needed?</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">REGENERATION_SPORES</Data></Cell><Cell><Data ss:Type="String">TEMPLATE_NAME_5</Data></Cell><Cell><Data ss:Type="String">Mending Bud</Data></Cell><Cell><Data ss:Type="String">Pąk gojący</Data></Cell><Cell ss:Index="8"><Data ss:Type="String">Review needed?</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">REGENERATION_SPORES</Data></Cell><Cell><Data ss:Type="String">TEMPLATE_NAME_6</Data></Cell><Cell><Data ss:Type="String">Photosynthesis</Data></Cell><Cell><Data ss:Type="String">Fotosynteza</Data></Cell><Cell ss:Index="8"><Data ss:Type="String">Review needed?</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">REGENERATION_SPORES</Data></Cell><Cell><Data ss:Type="String">TEMPLATE_NAME_7</Data></Cell><Cell><Data ss:Type="String">Pollinating</Data></Cell><Cell><Data ss:Type="String">Zapylenie</Dat
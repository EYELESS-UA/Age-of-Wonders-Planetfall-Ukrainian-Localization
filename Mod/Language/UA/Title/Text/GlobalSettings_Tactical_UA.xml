<?xml version="1.0"?><?mso-application progid="Excel.Sheet"?><Workbook xmlns="urn:schemas-microsoft-com:office:spreadsheet" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns:ss="urn:schemas-microsoft-com:office:spreadsheet" xmlns:html="http://www.w3.org/TR/REC-html40"><DocumentProperties xmlns="urn:schemas-microsoft-com:office:office"><LastAuthor>Djurre van Dijk</LastAuthor><Created>2019-05-06T09:39:27Z</Created><LastSaved>2019-05-06T09:39:27Z</LastSaved><Version>16.00</Version></DocumentProperties><OfficeDocumentSettings xmlns="urn:schemas-microsoft-com:office:office"><AllowPNG/></OfficeDocumentSettings><ExcelWorkbook xmlns="urn:schemas-microsoft-com:office:excel"><WindowHeight>5640</WindowHeight><WindowWidth>15345</WindowWidth><WindowTopX>32767</WindowTopX><WindowTopY>32767</WindowTopY><ProtectStructure>False</ProtectStructure><ProtectWindows>False</ProtectWindows></ExcelWorkbook><Styles><Style ss:ID="Default" ss:Name="Normal"><Alignment ss:Vertical="Bottom"/><Borders/><Font ss:FontName="Calibri" x:Family="Swiss" ss:Size="11" ss:Color="#000000"/><Interior/><NumberFormat/><Protection/></Style></Styles><Worksheet ss:Name="Script"><Table x:FullColumns="1" x:FullRows="1" ss:DefaultColumnWidth="51.75" ss:DefaultRowHeight="14.4375"><Column ss:AutoFitWidth="0" ss:Width="229.5"/><Column ss:AutoFitWidth="0" ss:Width="234.75"/><Column ss:AutoFitWidth="0" ss:Width="384"/><Column ss:AutoFitWidth="0" ss:Width="125.25"/><Column ss:AutoFitWidth="0" ss:Width="370.5"/><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TACTICAL</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">The DEV TEAM / MISC NOTES column contains info on what text between { } signs means (if applicable). It usually stands for either a numeric value, or a numeric value with an icon. Text between [ ] signs stands for a certain type of icon. </Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SCENE ID</Data></Cell><Cell><Data ss:Type="String">TEXT ID</Data></Cell><Cell><Data ss:Type="String">ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZATION NOTES</Data></Cell><Cell><Data ss:Type="String">DEV TEAM / MISC NOTES</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ABILITY_ERROR</Data></Cell><Cell><Data ss:Type="String">ACTION_COMPLETE</Data></Cell><Cell><Data ss:Type="String">Unit has already acted this turn</Data></Cell><Cell><Data ss:Type="String">Ta jednostka już podjęła działanie w tej turze.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Unit has used all his action points thus game turn and has to wait for the next game turn to be able to do something again </Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ABILITY_ERROR</Data></Cell><Cell><Data ss:Type="String">COOLDOWN</Data></Cell><Cell><Data ss:Type="String">Can't use ability for {INT_turns} turns</Data></Cell><Cell><Data ss:Type="String">Nie można użyć tej umiejętności przez pewną liczbę tur ({INT_turns}).</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">{INT_turns} will be replaced with a numerical value for the number of turns to wait before using the skill again </Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ABILITY_ERROR</Data></Cell><Cell><Data ss:Type="String">BAD_ACTION_POINTS</Data></Cell><Cell><Data ss:Type="String">Not enough action points</Data></Cell><Cell><Data ss:Type="String">Za mało punktów akcji.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Displayed when a unit has not enough action points left to perform a action </Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ABILITY_ERROR</Data></Cell><Cell><Data ss:Type="String">ONCE_PER_BATTLE</Data></Cell><Cell><Data ss:Type="String">Already used this battle</Data></Cell><Cell><Data ss:Type="String">Już użyto w tej bitwie.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Displayed in the tooltip of a spell when it is already used and is only allowed to be used once</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ABILITY_ERROR</Data></Cell><Cell><Data ss:Type="String">DEPLOYMENT</Data></Cell><Cell><Data ss:Type="String">Cannot be used during deployment</Data></Cell><Cell><Data ss:Type="String">Nie można użyć podczas rozstawiania.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ABILITY_ERROR</Data></Cell><Cell><Data ss:Type="String">TARGET_IMMUNE</Data></Cell><Cell><Data ss:Type="String">Target cannot be affected</Data></Cell><Cell><Data ss:Type="String">Cel nie odczuje żadnego efektu.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Printed over units/obstacles when the current spell/ability would not affect them</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ABILITY_ERROR</Data></Cell><Cell><Data ss:Type="String">OUT_OF_RANGE</Data></Cell><Cell><Data ss:Type="String">Out of range</Data></Cell><Cell><Data ss:Type="String">Poza zasięgiem.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Printed when a target is too far away from a caster to affected by an ability</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ABILITY_ERROR</Data></Cell><Cell><Data ss:Type="String">NO_LINE_OF_SIGHT</Data></Cell><Cell><Data ss:Type="String">No line of sight</Data></Cell><Cell><Data ss:Type="String">Brak linii widzenia.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Printed when a target cannot be hit by an ability due to an obstacle being in the way</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ABILITY_ERROR</Data></Cell><Cell><Data ss:Type="String">CANNOT_REACH_TARGET</Data></Cell><Cell><Data ss:Type="String">Cannot reach target</Data></Cell><Cell><Data ss:Type="String">Nie można dosięgnąć celu.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Printed when a target cannot be moved to because it is too far away ro the path is blocked</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ABILITY_ERROR</Data></Cell><Cell><Data ss:Type="String">WEAPON_NOT_LOADED</Data></Cell><Cell><Data ss:Type="String">Weapon not loaded</Data></Cell><Cell><Data ss:Type="String">Broń nie jest załadowana.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Indicates to the player that they cannot use an ability until they reload</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ABILITY_ERROR</Data></Cell><Cell><Data ss:Type="String">RELOAD_NOT_NEEDED</Data></Cell><Cell><Data ss:Type="String">Weapon already loaded</Data></Cell><Cell><Data ss:Type="String">Broń jest już załadowana.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Indicates to the player that they cannot reload, since they're already loaded</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ABILITY_ERROR</Data></Cell><Cell><Data ss:Type="String">IN_TRANSPORT</Data></Cell><Cell><Data ss:Type="String">Cannot be used in a transport</Data></Cell><Cell><Data ss:Type="String">Nie można użyć w transportowcu.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Indicates to the player that they cannot use an ability because the unit is on a transport ship</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">GUARD_BUTTON</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Guard</Data></Cell><Cell><Data ss:Type="String">Straż</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Header of the guard button tooltip, name of the button </Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">GUARD_BUTTON</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Puts the unit into a defensive stance, reducing incoming damage. Guarded units have heightened awareness and cannot be flanked.</Data></Cell><Cell><Data ss:Type="String">Nakazuje jednostce zająć pozycję obronną, co zmniejszy otrzymywane obrażenia. Jednostki w trybie straży mają zwiększoną czujność i nie można ich oskrzydlić.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Description of the guard button. [def/] and [resist/]  are icons </Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">MOVE_BUTTON</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Move</Data></Cell><Cell><Data ss:Type="String">Ruch</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">As in: the ability move. Used as name for the move action button in tactical combat </Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">MOVE_BUTTON</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Move the unit over the battlefield</Data></Cell><Cell><Data ss:Type="String">Przemieszczanie jednostki po polu bitwy</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">As in: the ability move. Used as name for the move action button in tactical combat </Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HUD_COMBAT</Data></Cell><Cell><Data ss:Type="String">AUTO_COMBAT</Data></Cell><Cell><Data ss:Type="String">Auto Combat</Data></Cell><Cell><Data ss:Type="String">Walka automatyczna</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Let the AI handle the combat</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ALL_TODO_EVENTS_HANDLED_EVENT</Data></Cell><Cell><Data ss:Type="String">TODO_MESSAGE</Data></Cell><Cell><Data ss:Type="String">Click to end turn</Data></Cell><Cell><Data ss:Type="String">Kliknij, by zakończyć turę</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Notifies the player to end his turn </Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ABILITY</Data></Cell><Cell><Data ss:Type="String">AFFECTED_LINE_OF_SIGHT</Data></Cell><Cell><Data ss:Type="String">Affected by line of sight rules</Data></Cell><Cell><Data ss:Type="String">Pod wpływem zasad linii widzenia</Data></Cell><Cell ss:Index="8"><Data ss:Type="String">prev sk_interface</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ABILITY</Data></Cell><Cell><Data ss:Type="String">NO_COVER_OR_UNIT_PENALTIES</Data></Cell><Cell><Data ss:Type="String">Ignores cover and unit penalties</Data></Cell><Cell><Data ss:Type="String">Ignoruje kary od osłony i jednostek</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Indicates that an ability can be aimed through cover or other units without an accuracy penalty. See NO_LINE_OF_SIGHT in Interface.xml</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ABILITY</Data></Cell><Cell><Data ss:Type="String">NO_LINE_OF_SIGHT_PENALTIES</Data></Cell><Cell><Data ss:Type="String">Ignores line of sight penalties</Data></Cell><Cell><Data ss:Type="String">Ignoruje kary od linii widzenia</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Indicates that an ability can be fired through units, and most obstacles without penalty</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ABILITY</Data></Cell><Cell><Data ss:Type="String">OVERWATCH_NAME</Data></Cell><Cell><Data ss:Type="String">Overwatch</Data></Cell><Cell><Data ss:Type="String">Warta</Data></Cell><Cell ss:Index="8"><Data ss:Type="String">prev sk_interface</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ABILITY</Data></Cell><Cell><Data ss:Type="String">OVERWATCH_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Units in Overwatch will automatically shoot at enemies who move through, or shoot from, unprotected hexes in their field of view.</Data></Cell><Cell><Data ss:Type="String">Jednostki w trybie warty będą automatycznie ostrzeliwać wrogów przemieszczających się 
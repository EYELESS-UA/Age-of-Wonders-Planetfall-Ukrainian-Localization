ring">NAME</Data></Cell><Cell><Data ss:Type="String">Junkheap Refinery</Data></Cell><Cell><Data ss:Type="String">Śmietnikowa Rafineria</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SPACERS_SPECIAL_SPAWNER09</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Rusted Refinery</Data></Cell><Cell><Data ss:Type="String">Zardzewiała Rafineria</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SPACERS_SPECIAL_SPAWNER10</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Patrolia Refinery</Data></Cell><Cell><Data ss:Type="String">Rafineria Patrolia</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SPACERS_SPECIAL_SPAWNER11</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Refined Refinery</Data></Cell><Cell><Data ss:Type="String">Rafinowana Rafineria</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SPACERS_DWELLING01</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Macabre Shanty Town</Data></Cell><Cell><Data ss:Type="String">Makabryczne Slumsy</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SPACERS_DWELLING02</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Deviant Shanty Town</Data></Cell><Cell><Data ss:Type="String">Slumsy Dewiantów</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SPACERS_DWELLING03</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Unstable Shanty Town</Data></Cell><Cell><Data ss:Type="String">Niestabilne Slumsy</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SPACERS_DWELLING04</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Psychotic Shanty Town</Data></Cell><Cell><Data ss:Type="String">Psychotyczne Slumsy</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SPACERS_DWELLING05</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Maniac Shanty Town</Data></Cell><Cell><Data ss:Type="String">Slumsy Maniaków</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SPACERS_DWELLING06</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Lunatic Shanty Town</Data></Cell><Cell><Data ss:Type="String">Slumsy Wariatów</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SPACERS_DWELLING07</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Grim Shanty Town</Data></Cell><Cell><Data ss:Type="String">Ponure Slumsy</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SPACERS_DWELLING08</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Bizarre Shanty Town</Data></Cell><Cell><Data ss:Type="String">Dziwaczne Slumsy</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">GOVERNANCE_1</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Wasteland Scavengers</Data></Cell><Cell><Data ss:Type="String">Złomiarze z pustkowia</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">GOVERNANCE_1</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">The Spacers are experts at spotting valuables amongst the rubble. By installing Spacer specialists with our combat groups, we can recover valuable resources after battles.[br/][br/]You gain a small amount of energy after each battle. This scales with the number of units that were killed.</Data></Cell><Cell><Data ss:Type="String">Przestrzennicy są specjalistami od wyszukiwania cennych rzeczy wśród odpadków. Dzięki dołączeniu ekspertów Przestrzenników do naszych oddziałów bojowych możemy odzyskiwać przydatne zasoby po bitwach.[br/][br/]Uzyskasz niewielką ilość energii po każdej bitwie. Rośnie ona wraz ze wzrostem liczby zlikwidowanych jednostek.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String"> 'You' refers to the player and can either be male or female.</Data></Cell><Cell><Data ss:Type="String">Is this 'number of units' both friendly and enemy, or only enemy units? May need clarification.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SPACERS_SPAWNER10</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Heaping Scrapyard</Data></Cell><Cell><Data ss:Type="String">Spiętrzone Złomowisko</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SPACERS_SPAWNER11</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Assembled Scrapyard</Data></Cell><Cell><Data ss:Type="String">Zgarnięte Złomowisko</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SPACERS_SPAWNER12</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Accumulated Scrapyard</Data></Cell><Cell><Data ss:Type="String">Zebrane Złomowisko</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SPACERS_SPAWNER13</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Huddled Scrapyard</Data></Cell><Cell><Data ss:Type="String">Stłoczone Złomowisko</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SPACERS_SPAWNER14</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">United Scrapyard</Data></Cell><Cell><Data ss:Type="String">Zjednoczone Złomowisko</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SPACERS_DWELLING09</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Ghoulish Shanty Town</Data></Cell><Cell><Data ss:Type="String">Makabryczne Slumsy</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SPACERS_DWELLING10</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Cadaverous Shanty Town</Data></Cell><Cell><Data ss:Type="String">Trupie Slumsy</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SPACERS_DWELLING11</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Hideous Shanty Town</Data></Cell><Cell><Data ss:Type="String">Ohydne Slumsy</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SPACERS_DWELLING12</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Heteroclite Shanty Town</Data></Cell><Cell><Data ss:Type="String">Nieregularne Slumsy</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SPACERS_DWELLING13</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Anomalous Shanty Town</Data></Cell><Cell><Data ss:Type="String">Nienormalne Slumsy</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SPACERS_DWELLING14</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Peculiar Shanty Town</Data></Cell><Cell><Data ss:Type="String">Szczególne Slumsy</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SPACERS_DWELLING15</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Incongruous Shanty Town</Data></Cell><Cell><Data ss:Type="String">Niestosowne Slumsy</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SPACERS_DWELLING16</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Disconsonant Shanty Town</Data></Cell><Cell><Data ss:Type="String">Hałaśliwe Slumsy</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SPACERS_DWELLING17</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="St
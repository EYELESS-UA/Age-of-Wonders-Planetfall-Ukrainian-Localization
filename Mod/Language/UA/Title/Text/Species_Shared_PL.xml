<?xml version="1.0"?><?mso-application progid="Excel.Sheet"?><Workbook xmlns="urn:schemas-microsoft-com:office:spreadsheet" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns:ss="urn:schemas-microsoft-com:office:spreadsheet" xmlns:html="http://www.w3.org/TR/REC-html40"><DocumentProperties xmlns="urn:schemas-microsoft-com:office:office"><LastAuthor>Djurre van Dijk</LastAuthor><Created>2019-05-06T09:39:58Z</Created><LastSaved>2019-05-06T09:39:58Z</LastSaved><Version>16.00</Version></DocumentProperties><OfficeDocumentSettings xmlns="urn:schemas-microsoft-com:office:office"><AllowPNG/></OfficeDocumentSettings><ExcelWorkbook xmlns="urn:schemas-microsoft-com:office:excel"><WindowHeight>5640</WindowHeight><WindowWidth>15345</WindowWidth><WindowTopX>32767</WindowTopX><WindowTopY>32767</WindowTopY><ProtectStructure>False</ProtectStructure><ProtectWindows>False</ProtectWindows></ExcelWorkbook><Styles><Style ss:ID="Default" ss:Name="Normal"><Alignment ss:Vertical="Bottom"/><Borders/><Font ss:FontName="Calibri" x:CharSet="1" x:Family="Swiss" ss:Size="11" ss:Color="#000000"/><Interior/><NumberFormat/><Protection/></Style><Style ss:ID="s62"><Alignment ss:Vertical="Bottom" ss:WrapText="1"/></Style><Style ss:ID="s63"><Alignment ss:Vertical="Bottom" ss:WrapText="1"/><Borders/><Font ss:FontName="Calibri" x:CharSet="1" x:Family="Swiss" ss:Size="11" ss:Color="#000000"/><Interior/><NumberFormat/><Protection/></Style><Style ss:ID="s64"><Alignment ss:Vertical="Bottom" ss:WrapText="1"/><Borders/><Interior/><NumberFormat/><Protection/></Style></Styles><Worksheet ss:Name="Script"><Table x:FullColumns="1" x:FullRows="1" ss:DefaultRowHeight="14.4375"><Column ss:Width="107.25"/><Column ss:Width="84.75"/><Column ss:AutoFitWidth="0" ss:Width="281.25"/><Column ss:Width="144.75"/><Column ss:Width="191.25"/><Column ss:Width="117.75"/><Row ss:AutoFitHeight="0" ss:Height="86.4375"><Cell><Data ss:Type="String">SPECIES_SHARED</Data></Cell><Cell ss:Index="7" ss:StyleID="s62"><Data ss:Type="String">The DEV TEAM / MISC NOTES column contains info on what text between { } signs means (if applicable). It usually stands for either a numeric value, or a numeric value with an icon. Text between [ ] signs stands for a certain type of icon. </Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SCENE ID</Data></Cell><Cell><Data ss:Type="String">TEXT ID</Data></Cell><Cell><Data ss:Type="String">ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZATION NOTES</Data></Cell><Cell><Data ss:Type="String">DEV TEAM / MISC NOTES</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">COLONIZER</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">Colonizer</Data></Cell><Cell><Data ss:Type="String">Kolonizator</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="165"><Cell><Data ss:Type="String">COLONIZER</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell ss:StyleID="s64"><Data ss:Type="String">“From the ashes of the Star Union, a new age will dawn. The fallen empire hides powerful secrets yet to be found, a race in earnest to revive the powers hidden in our past. The colonizer is the first step towards that revival. The nurturing of colonies and the development of society is of delicate importance, more so for a foreign and unfamiliar planet with dangers unknown. The cosmic Dark Age is over, and the legendary remnants of the Empire lay dormant, waiting to be rediscovered.”— Quinlinn T. Ortivexis, “RV-4367H: Universal Coincidental History”</Data></Cell><Cell><Data ss:Type="String">„Z popiołów Związku Gwiezdnego narodzi się nowa era. Upadłe imperium skrywało wiele sekretów, które czekają na ujawnienie, na cywilizację, która szczerze pragnie przywrócić do życia potęgę z naszej przeszłości. Kolonizator stanowi pierwszy krok na tej drodze. Pielęgnowanie kolonii i rozwój społeczeństw jest sprawą szczególnej wagi, zwłaszcza na obcej, nieznanej planecie, na której czają się być może zagadkowe niebezpieczeństwa. Mroczne wieki kosmosu dobiegły końca, a szczątki legendarnego imperium spoczywają w uśpieniu, czekając na ponowne odkrycie” – Quinlinn T. Ortivexis, „RV-4367H – Powszechna historia przypadku”</Data></Cell></Row></Table><WorksheetOptions xmlns="urn:schemas-microsoft-com:office:excel"><Unsynced/><Selected/><Panes><Pane><Number>3</Number><ActiveRow>3</ActiveRow><ActiveCol>2</ActiveCol></Pane></Panes><ProtectObjects>False</ProtectObjects><ProtectScenarios>False</ProtectScenarios></WorksheetOptions></Worksheet></Workbook>
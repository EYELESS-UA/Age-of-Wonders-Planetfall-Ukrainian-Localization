<?xml version="1.0"?><?mso-application progid="Excel.Sheet"?><Workbook xmlns="urn:schemas-microsoft-com:office:spreadsheet" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns:ss="urn:schemas-microsoft-com:office:spreadsheet" xmlns:html="http://www.w3.org/TR/REC-html40"><DocumentProperties xmlns="urn:schemas-microsoft-com:office:office"><LastAuthor>Djurre van Dijk</LastAuthor><Created>2019-05-06T09:39:51Z</Created><LastSaved>2019-05-06T09:39:51Z</LastSaved><Version>16.00</Version></DocumentProperties><OfficeDocumentSettings xmlns="urn:schemas-microsoft-com:office:office"><AllowPNG/></OfficeDocumentSettings><ExcelWorkbook xmlns="urn:schemas-microsoft-com:office:excel"><WindowHeight>7620</WindowHeight><WindowWidth>21570</WindowWidth><WindowTopX>32767</WindowTopX><WindowTopY>32767</WindowTopY><RefModeR1C1/><ProtectStructure>False</ProtectStructure><ProtectWindows>False</ProtectWindows></ExcelWorkbook><Styles><Style ss:ID="Default" ss:Name="Normal"><Alignment ss:Vertical="Bottom"/><Borders/><Font ss:FontName="Calibri" x:Family="Swiss" ss:Size="11" ss:Color="#000000"/><Interior/><NumberFormat/><Protection/></Style><Style ss:ID="s62"><Alignment ss:Vertical="Top" ss:WrapText="1"/></Style><Style ss:ID="s63"><Alignment ss:Vertical="Top" ss:WrapText="1"/><Borders/><Font ss:FontName="Calibri" x:Family="Swiss" ss:Size="11" ss:Color="#000000"/></Style><Style ss:ID="s64"><Alignment ss:Vertical="Top" ss:WrapText="1"/><Borders/></Style></Styles><Worksheet ss:Name="Script"><Table x:FullColumns="1" x:FullRows="1" ss:StyleID="s62" ss:DefaultColumnWidth="51.75" ss:DefaultRowHeight="15"><Column ss:StyleID="s62" ss:Width="175.5"/><Column ss:StyleID="s62" ss:Width="108.75"/><Column ss:StyleID="s62" ss:AutoFitWidth="0" ss:Width="303"/><Column ss:StyleID="s62" ss:Width="147.75"/><Column ss:StyleID="s62" ss:Width="311.25"/><Column ss:StyleID="s62" ss:Width="120"/><Column ss:StyleID="s62" ss:AutoFitWidth="0" ss:Width="265.5"/><Row ss:AutoFitHeight="0" ss:Height="60"><Cell><Data ss:Type="String">SPACERS_UNITPROPERTIES</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">The DEV TEAM / MISC NOTES column contains info on what text between { } signs means (if applicable). It usually stands for either a numeric value, or a numeric value with an icon. Text between [ ] signs stands for a certain type of icon. </Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SCENE ID</Data></Cell><Cell><Data ss:Type="String">TEXT ID</Data></Cell><Cell><Data ss:Type="String">ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZATION NOTES</Data></Cell><Cell><Data ss:Type="String">DEV TEAM / MISC NOTES</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FRENZIED_BASH</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Bash</Data></Cell><Cell><Data ss:Type="String">Rąbnięcie</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FRENZIED_BASH</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">A melee bashing attack.</Data></Cell><Cell><Data ss:Type="String">Cios w walce wręcz.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">BERSERK_CHEMICALS</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Berserk Chemicals</Data></Cell><Cell><Data ss:Type="String">Dopalacze chemiczne</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">BERSERK_CHEMICALS</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit consumes chemicals that give it Fast Movement, [abilityblue]Massive Impact[/abilityblue] and increase its damage dealt by {BerserkChemicals}% for {BerserkDuration}.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka zażywa substancje chemiczne, które zapewniają jej szybki ruch i [abilityblue]potężne uderzenie[/abilityblue] oraz zwiększają zadawane przez nią obrażenia o {BerserkChemicals}% na {BerserkDuration}.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">MAKESHIFT_TURRET</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Makeshift Turret</Data></Cell><Cell><Data ss:Type="String">Prowizoryczna wieżyczka</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">MAKESHIFT_TURRET</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Fire the Makeshift Turret at the target.</Data></Cell><Cell><Data ss:Type="String">Cel zostaje ostrzelany przez prowizoryczną wieżyczkę.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">RECKLESS_CRASH</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Reckless Crash</Data></Cell><Cell><Data ss:Type="String">Bezmyślna kraksa</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">RECKLESS_CRASH</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Drive full throttle at the target, damaging it. [abilityred]Knocks back[/abilityred] Light units.</Data></Cell><Cell><Data ss:Type="String">Jednostka wjeżdża w cel z pełną szybkością. [abilityred]Odpycha[/abilityred] jednostki lekkie.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">UNSTABLE_CONSTRUCTION</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Unstable Construction</Data></Cell><Cell><Data ss:Type="String">Nietrwała konstrukcja</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">UNSTABLE_CONSTRUCTION</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Unit is poorly constructed and will explode on death.</Data></Cell><Cell><Data ss:Type="String">Jednostka jest kiepsko zbudowana i wybuchnie w chwili śmierci.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">EFFIGY_CARRIER</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Effigy Carrier</Data></Cell><Cell><Data ss:Type="String">Nosiciel kukieł</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">EFFIGY_CARRIER</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">When this unit dies, it leaves behind a Spacer Effigy that has the ability to boost ally damage.</Data></Cell><Cell><Data ss:Type="String">Gdy ta jednostka ginie, pozostawia po sobie kukłę Przestrzenników, która zwiększa potencjał ofensywny sprzymierzeńców.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">MAKESHIFT_ACID_JET</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Makeshift Acid Jet</Data></Cell><Cell><Data ss:Type="String">Prowizoryczna struga kwasu</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">MAKESHIFT_ACID_JET</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Shoot a jet of acid at the target unit.</Data></Cell><Cell><Data ss:Type="String">Strzela we wskazaną jednostkę strumieniem kwasu.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ACID_BATH</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Acid Bath</Data></Cell><Cell><Data ss:Type="String">Kwasowa łaźnia</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ACID_BATH</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Spray acid in front of this unit, damaging those hit.</Data></Cell><Cell><Data ss:Type="String">Powoduje rozpylenie przed jednostką kwasu, który zadaje obrażenia wszystkim trafionym.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">MAKESHITFT_FIREBLAST_TURRET</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Makeshift Laser Turret</Data></Cell><Cell><Data ss:Type="String">Prowizoryczna wieżyczka laserowa</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">MAKESHITFT_FIREBLAST_TURRET</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Fire a volley of Laser rounds at the target.</Data></Cell><Cell><Data ss:Type="String">Ostrzeliwuje cel serią z lasera.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">LAUNCH_FIRE_BARREL</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Spacer Missile</Data></Cell><Cell><Data ss:Type="String">Pocisk Przestrzenników</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">LAUNCH_FIRE_BARREL</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Launch an Explosive rocket, dealing damage in a {hexrad} hex radius.</Data></Cell><Cell><Data ss:Type="String">Wystrzeliwuje wybuchową rakietę, zadającą obrażenia w promieniu {hexrad} pól.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FUEL_RAGE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Fuel Rage</Data></Cell><Cell><Data ss:Type="String">Podsycony szał</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FUEL_RAGE</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Target friendly unit gains increased damage.</Data></Cell><Cell><Data ss:Type="String">Wskazana przyjazna jednostka uzyskuje zwiększenie obrażeń.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FUEL_RAGE</Data></Cell><Cell><Data ss:Type="String">NAME_BUFF</Data></Cell><Cell><Data ss:Type="String">Fueled Rage</Data></Cell><Cell><Data ss:Type="String">Podsycenie szału</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">FUEL_RAGE</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION_BUFF</Data></Cell><Cell><Data ss:Type="String">This unit pushes beyond its limits, increasing damage dealt by {FuelRageDamage}.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka przekracza granice swoich możliwości i zadaje obrażenia zwiększone o {FuelRageDamage}.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">INCENDIARY_SHOT</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Incendiary Shot</Data></Cell><Cell><Data ss:Type="String">Pocisk zapalający</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">INCENDIARY_SHOT</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">A fiery round shot from a turret that has a chance of setting the target on fire.</Data></Cell><Cell><Data ss:Type="String">Wystrzeliwuje z wieżyczki pocisk, który ma pewną szansę podpalenia celu.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">LAUNCH_TAR_BARREL</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Launch Tar Barrel</Data></Cell><Cell><Data ss:Type="String">Beczka smoły</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="60"><Cell><Data ss:Type="String">LAUNCH_TAR_BARREL</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Launch a barrel filled with tar, applying [abilityred]Tar Drench[/abilityred], causing units hit to both suffer from -{TardrenchResistance} resistance and [abilityred]Slow[/abilityred] them for {DrenchTurn}.</Data></Cell><Cell><Data ss:Type="String">Wystrzeliwuje pełną smoły beczkę, która powoduje [abilityred]usmolenie[/abilityred], przez co trafione jednostki otrzymują –{TardrenchResistance} do odporności i [abilityred]spowolnienie[/abilityred] na {DrenchTurn}.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TAR_DEBUFF</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Tar Drench</Data></Cell><Cell><Data ss:Type="String">Usmolenie</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">TAR_DEBUFF</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit is covered in tar, reducing movement speed and decreasing thermal resistance by {TarResistance}.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka jest pokryta smołą, co zmniejsza jej szybkość ruchu i odporność cieplną o {TarResistance}.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">BOARDING</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Boarding</Data></Cell><Cell><Data ss:Type="String">Abordaż</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">BOARDING</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Send people to board an enemy ship unit, attempting to commandeer the vessel.</Data></Cell><Cell><Data ss:Type="String">Wysyła wojsko na pokład okrętu wroga w próbie przejęcia jednostki.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">BOARDING_DEBUFF</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Boarded</Data></Cell><Cell><Data ss:Type="String">Pryz</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">BOARDING_DEBUFF</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit has been boarded by the enemy and is out of your control.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka została przejęta przez wroga i nie masz nad nią kontroli.</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">BOARDING_DEBUFF</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION_MOD</Data></Cell><Cell><Data ss:Type="String">{BoardedChance}[StrengthPhysical/] strength chance to apply [abilityred]Boarded[/abilityred] to Mechanical Boat units.</Data></Cell><Cell><Data ss:Type="String">Szansa ({BoardedChance}[StrengthPhysical/] siły) na przekształcenie pływającej jednostki mechanicznej w [abilityred]pryz[/abilityred].</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">BERSERK_CHEMICALS</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION_BUFF</Data></Cell><Cell><Data ss:Type="String">This unit has Fast Movement, [abilityblue]Massive Impact[/abilityblue] and damage is increased by {BerserkDamage}.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka ma szybki ruch, [abilityblue]potężne uderzenie[/abilityblue] i zadaje obrażenia większe o {BerserkDamage}.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">MADDENING_RANT</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Maddening Rant</Data></Cell><Cell><Data ss:Type="String">Nieznośna tyrada</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">MADDENING_RANT</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">The preacher rattles off an awful and maddening speech at the target.</Data></Cell><Cell><Data ss:Type="String">Kaznodzieja wygłasza ohydną, doprowadzającą do szału przemowę pod adresem wskazanej jednostki.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">BRAND_OF_THE_EFFIGY</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Brand of the Effigy</Data></Cell><Cell><Data ss:Type="String">Piętno kukły</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">BRAND_OF_THE_EFFIGY</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Brand a land unit with the mark of the effigy, making it {AccuracyBoost} easier to hit. Also, when it dies, powerful psionics mold it into a Spacer Effigy that empowers your units.</Data></Cell><Cell><Data ss:Type="String">Znakuje jednostkę lądową piętnem kukły, ułatwiając jej trafienie o {AccuracyBoost}. Gdy napiętnowana jednostka zginie, potężna siła psioniczna przekształca ją w kukłę Przestrzenników, która wzmacnia twoje jednostki.</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">BRAND_OF_THE_EFFIGY</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION_DEBUFF</Data></Cell><Cell><Data ss:Type="String">This unit is {AccuracyBoost} easier to hit and turns into a Spacer Effigy when it dies.</Data></Cell><Cell><Data ss:Type="String">Tę jednostkę łatwiej trafić o {AccuracyBoost}, a w chwili śmierci zmieni się w kukłę Przestrzenników.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">EFFIGY_HYSTERICS</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Effigy Hysterics</Data></Cell><Cell><Data ss:Type="String">Histeria kukieł</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">EFFIGY_HYSTERICS</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">All effigies on the battlefield now increase damage by {HystericsDamage} instead of their normal damage boost for {HystericsDuration}.</Data></Cell><Cell><Data ss:Type="String">Wszystkie kukły na polu bitwy zwiększają teraz obrażenia o {HystericsDamage} zamiast zwykłej premii. Efekt trwa {HystericsDuration}.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">EFFIGY_HYSTERICS</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION_BUFF</Data></Cell><Cell><Data ss:Type="String">This unit now grants a stronger Fuel Rage.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka zapewnia silniejszy podsycony szał.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ARDENT_BRAND</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Ardent Brand</Data></Cell><Cell><Data ss:Type="String">Piętno gorliwości</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="75"><Cell><Data ss:Type="String">ARDENT_BRAND</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Ground units that accompany this unit into combat will be branded with a strong psionic presence, gaining [abilityblue]Effigy Carrier[/abilityblue], turning these units into an Effigy when they die in battle.[br/]Only functions when this unit is the army's Commander.</Data></Cell><Cell><Data ss:Type="String">Jednostki naziemne, które towarzyszą tej jednostce w bitwie, zostaną napiętnowane silną mocą psioniczną i uzyskają cechę [abilityblue]nosiciel kukieł[/abilityblue], w wyniku czego po śmierci w walce zmienią się w kukły.[br/]Możliwe tylko wtedy, gdy ta jednostka jest dowódcą armii.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">EFFIGY_REQUISITE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Spacer Effigy</Data></Cell><Cell><Data ss:Type="String">Kukła Przestrzenników</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">EFFIGY_REQUISITE</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">A Spacer effigy.</Data></Cell><Cell><Data ss:Type="String">Kukła należąca do Przestrzenników.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">WASTE_SURVIVAL</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Wastes Survival</Data></Cell><Cell><Data ss:Type="String">Przetrwanie na pustkowiu</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FUEL_RAGE</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION_MOD</Data></Cell><Cell><Data ss:Type="String">{FuelDamage} damage</Data></Cell><Cell><Data ss:Type="String">{FuelDamage} do obrażeń.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">IMPROVED_FUEL_RAGE</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION_MOD</Data></Cell><Cell><Data ss:Type="String">{ImprovedFuelDamage} damage</Data></Cell><Cell><Data ss:Type="String">{ImprovedFuelDamage} do obrażeń.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">IMPROVED_FUEL_RAGE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Improved Fueled Rage</Data></Cell><Cell><Data ss:Type="String">Wzmocnione podsycenie szału</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">POWER_VACUUM</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Power Vacuum</Data></Cell><Cell><Data ss:Type="String">Moc próżni</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="75"><Cell><Data ss:Type="String">POWER_VACUUM</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">When this unit dies, all friendly Psycho and Melter units gain [abilityblue]Power Grip[/abilityblue], an ability that, when used on the dead Mad Preacher, transforms them into a new Mad Preacher.[br/]These units can only be affected by this once per battle.</Data></Cell><Cell><Data ss:Type="String">Gdy ta jednostka zginie, wszystkie przyjazne jednostki psycholi i chemików uzyskają [abilityblue]uścisk próżni[/abilityblue], umiejętność, która po użyciu na martwym szalonym kaznodziei pozwala zmienić je w nowego szalonego kaznodzieję.[br/]Te jednostki mogą ulec temu efektowi tylko raz na bitwę.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">POWER_GRIP</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Power Grip</Data></Cell><Cell><Data ss:Type="String">Uścisk próżni</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">POWER_GRIP</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Target an adjacent dead Mad Preacher to transform this unit into a new Mad Preacher using the lingering psionic energies found within the scrap.</Data></Cell><Cell><Data ss:Type="String">Wskaż martwego szalonego kaznodzieję na sąsiednim polu, by przekształcić tę jednostkę w nowego szalonego kaznodzieję dzięki energii psionicznej wciąż obecnej w szczątkach.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">LOST_CHANCE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Lost Chance</Data></Cell><Cell><Data ss:Type="String">Stracona szansa</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">LOST_CHANCE</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit failed to become the next Mad Preacher and cannot benefit from Power Vacuum again during this battle.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka nie zdołała stać się nowym szalonym kaznodzieją i nie może już skorzystać z mocy próżni podczas tej bitwy.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HALLUCINOGENIC_REGULATORS</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Hallucinogenic Regulators</Data></Cell><Cell><Data ss:Type="String">Regulatory halucynogenne</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="90"><Cell><Data ss:Type="String">HALLUCINOGENIC_REGULATORS</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">The Spacer Psycho's special formula. Firearms and Melee weapons have a {HallCoatAugStr}[strengthBio/] strength chance ({HallCoatAugStrRep}[strengthBio/] for repeating attacks) to apply [abilityred]Hallucinating[/abilityred] to non-Mindless units, reducing their accuracy by {accdown} and causing all attacks against affected units to count as flanking. This lasts for {HalluTurn}[turn/].</Data></Cell><Cell><Data ss:Type="String">Specjalna formuła psychola Przestrzenników. Broń palna i do walki wręcz ma szansę (siła {HallCoatAugStr}[strengthBio/], {HallCoatAugStrRep}[strengthBio/] dla ataków wielokrotnych) na wywołanie [abilityred]halucynacji[/abilityred] u jednostek nienależących do bezmózgich, co zmniejszy ich celność o {accdown} i sprawi, że wszystkie ataki na te jednostki będą traktowane jak oskrzydlające. Efekt trwa przez {HalluTurn}[turn/].</Data></Cell><Cell ss:Index="8"><Data ss:Type="String">Edit: making so --&gt; causing, added "to"</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">DEBILITATING_STRAIN</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Debilitating Strain</Data></Cell><Cell><Data ss:Type="String">Szczep osłabiający</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="75"><Cell><Data ss:Type="String">DEBILITATING_STRAIN</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Attacks from Biochemical weapons have a {DebilStrainStr}[strengthBio/] strength chance ({DebilStrainStrRep}[strengthBio/] for repeating attacks) of applying [abilityred]Debilitating Infection[/abilityred] to Biological or Cyborg units, making them {evasiondown} easier to hit and giving them {DebilMorale}. This lasts for {DebilTurn}[turn/].</Data></Cell><Cell><Data ss:Type="String">Ataki bronią biochemiczną mają szansę (siła {DebilStrainStr}[strengthBio/], {DebilStrainStrRep}[strengthBio/] dla ataków wielokrotnych) wywołania [abilityred]infekcji osłabiającej[/abilityred] u jednostek organicznych i cyborgów, wskutek czego mają {DebilMorale} i łatwiej je trafić o {evasiondown}. Efekt trwa przez {DebilTurn}[turn/].</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">MAKESHIFT_CHOKING_MODULE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Makeshift Choking Module</Data></Cell><Cell><Data ss:Type="String">Prowizoryczny moduł dławiący</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="90"><Cell><Data ss:Type="String">MAKESHIFT_CHOKING_MODULE</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This module was supposed to start fires, but its jerry-rigged nature only makes things smoke. Unit's Laser weapons have a {MakeChokMod}[strengthThermal/] strength chance ({MakeChokModRep}[strengthThermal/] for repeating attacks) to apply [abilityred]Choking[/abilityred] to Biological or Cyborg units, making their attacks {Accdown} less accurate and reducing their damage by {Damagedown}, for {Chokingturn}[turn/].</Data></Cell><Cell><Data ss:Type="String">Ten moduł miał pełnić rolę zapalającą, ale jest prowizoryczną fuszerką i wytwarza jedynie dym. Broń laserowa jednostki ma szansę (siła {MakeChokMod}[strengthThermal/], {MakeChokModRep}[strengthThermal/] dla ataków wielokrotnych) na wywołanie [abilityred]dławienia[/abilityred] u jednostek organicznych i cyborgów, przez co ich ataki będą mieć celność obniżoną o {Accdown}, a zadawane obrażenia będą o {Damagedown} mniejsze przez {Chokingturn}[turn/].</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">MANTRA_OF_THE_BRANDED</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Mantra of the Branded</Data></Cell><Cell><Data ss:Type="String">Mantra napiętnowanych</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="105"><Cell><Data ss:Type="String">MANTRA_OF_THE_BRANDED</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Understanding the Spacer philosophies is hard. Maintaining this Mantra while keeping one's sanity is even harder. Psionic support abilities grant Effigy Carrier to ground units, and Psionic attacks gain a {MantraBrandStr}[strengthPsyche/] strength chance ({MantraBrandStrRep}[strengthPsyche/] for repeating attacks) to apply [abilityred]Insanity[/abilityred] to non-Mindless units, making that unit waste their next turn running in a random direction.</Data></Cell><Cell><Data ss:Type="String">Zrozumienie filozofii Przestrzenników jest trudne. Ale intonowanie tej mantry tak, by nie popaść w obłęd, jest jeszcze trudniejsze. Umiejętności wsparcia psionicznego zapewniają jednostkom naziemnym efekt „nosiciel kukieł”, a ataki psioniczne uzyskują szansę (siła {MantraBrandStr}[strengthPsyche/], {MantraBrandStrRep}[strengthPsyche/] dla ataków wielokrotnych) na wywołanie [abilityred]obłędu[/abilityred] u jednostek nienależących do bezmózgich, przez co zmarnują one swoją następną turę, biegnąc w przypadkowym kierunku.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HALLUCINOGENIC_REGULATORS</Data></Cell><Cell><Data ss:Type="String">TEMPLATE_NAME_1</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">Delusioning</Data></Cell><Cell><Data ss:Type="String">Złuda</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HALLUCINOGENIC_REGULATORS</Data></Cell><Cell><Data ss:Type="String">TEMPLATE_NAME_2</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">Daydream</Data></Cell><Cell><Data ss:Type="String">Sen na jawie</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HALLUCINOGENIC_REGULATORS</Data></Cell><Cell><Data ss:Type="String">TEMPLATE_NAME_3</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">Stimulizer</Data></Cell><Cell><Data ss:Type="String">Stymulant</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HALLUCINOGENIC_REGULATORS</Data></Cell><Cell><Data ss:Type="String">TEMPLATE_NAME_4</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">Apparitioning</Data></Cell><Cell><Data ss:Type="String">Widmowość</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HALLUCINOGENIC_REGULATORS</Data></Cell><Cell><Data ss:Type="String">TEMPLATE_NAME_5</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">Psychosis</Data></Cell><Cell><Data ss:Type="String">Psychoza</Data></Cell><Cell ss:Index="9" ss:StyleID="s63"/></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HALLUCINOGENIC_REGULATORS</Data></Cell><Cell><Data ss:Type="String">TEMPLATE_NAME_6</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">Delirium</Data></Cell><Cell><Data ss:Type="String">Delirium</Data></Cell><Cell ss:Index="9" ss:StyleID="s63"/></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">DEBILITATING_STRAIN</Data></Cell><Cell><Data ss:Type="String">TEMPLATE_NAME_1</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">Debilitator</Data></Cell><Cell><Data ss:Type="String">Osłabiacz</Data></Cell><Cell ss:Index="9" ss:StyleID="s63"/></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">DEBILITATING_STRAIN</Data></Cell><Cell><Data ss:Type="String">TEMPLATE_NAME_2</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">Exhausting</Data></Cell><Cell><Data ss:Type="String">Wyczerpanie</Data></Cell><Cell ss:Index="9" ss:StyleID="s63"/></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">DEBILITATING_STRAIN</Data></Cell><Cell><Data ss:Type="String">TEMPLATE_NAME_3</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">Weary</Data></Cell><Cell><Data ss:Type="String">Zmęczenie</Data></Cell><Cell ss:Index="9" ss:StyleID="s63"/></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">DEBILITATING_STRAIN</Data></Cell><Cell><Data ss:Type="String">TEMPLATE_NAME_4</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">Fatiguing</Data></Cell><Cell><Data ss:Type="String">Prostracja</Data></Cell><Cell ss:Index="9" ss:StyleID="s63"/></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">DEBILITATING_STRAIN</Data></Cell><Cell><Data ss:Type="String">TEMPLATE_NAME_5</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">Slogger</Data></Cell><Cell><Data ss:Type="String">Prostracja</Data></Cell><Cell ss:Index="9" ss:StyleID="s63"/></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">DEBILITATING_STRAIN</Data></Cell><Cell><Data ss:Type="String">TEMPLATE_NAME_6</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">Grub</Data></Cell><Cell><Data ss:Type="String">Wycieńczenie</Data></Cell><Cell ss:Index="9" ss:StyleID="s63"/></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">MAKESHIFT_CHOKING_MODULATOR</Data></Cell><Cell><Data ss:Type="String">TEMPLATE_NAME_1</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">Choker</Data></Cell><Cell><Data ss:Type="String">Dławienie</Data></Cell><Cell ss:Index="9" ss:StyleID="s63"/></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">MAKESHIFT_CHOKING_MODULATOR</Data></Cell><Cell><Data ss:Type="String">TEMPLATE_NAME_2</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">Smog Spewer</Data></Cell><Cell><Data ss:Type="String">Dymnik</Data></Cell><Cell ss:Index="9" ss:StyleID="s63"/></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">MAKESHIFT_CHOKING_MODULATOR</Data></Cell><Cell><Data ss:Type="String">TEMPLATE_NAME_3</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">Chimney</Data></Cell><Cell><Data ss:Type="String">Komin</Data></Cell><Cell ss:Index="9" ss:StyleID="s63"/></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">MAKESHIFT_CHOKING_MODULATOR</Data></Cell><Cell><Data ss:Type="String">TEMPLATE_NAME_4</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">Smoke Machine</Data></Cell><Cell><Data ss:Type="String">Zadyma</Data></Cell><Cell ss:Index="9" ss:StyleID="s63"/></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">MAKESHIFT_CHOKING_MODULATOR</Data></Cell><Cell><Data ss:Type="String">TEMPLATE_NAME_5</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">Gloomshot</Data></Cell><Cell><Data ss:Type="String">Duszność</Data></Cell><Cell ss:Index="9" ss:StyleID="s63"/></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">MAKESHIFT_CHOKING_MODULATOR</Data></Cell><Cell><Data ss:Type="String">TEMPLATE_NAME_6</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">Greaseball</Data></Cell><Cell><Data ss:Type="String">Duchota</Data></Cell><Cell ss:Index="9" ss:StyleID="s63"/></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">MANTRA_OF_THE_BRANDED</Data></Cell><Cell><Data ss:Type="String">TEMPLATE_NAME_1</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">Pillar Carrier</Data></Cell><Cell><Data ss:Type="String">Kariatyda</Data></Cell><Cell ss:Index="9" ss:StyleID="s63"/></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">MANTRA_OF_THE_BRANDED</Data></Cell><Cell><Data ss:Type="String">TEMPLATE_NAME_2</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">Wasteland Emissary</Data></Cell><Cell><Data ss:Type="String">Wysłannik bezdroży</Data></Cell><Cell ss:Index="9" ss:StyleID="s63"/></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">MANTRA_OF_THE_BRANDED</Data></Cell><Cell><Data ss:Type="String">TEMPLATE_NAME_3</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">Brand Bearer</Data></Cell><Cell><Data ss:Type="String">Znamię</Data></Cell><Cell ss:Index="9" ss:StyleID="s63"/></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">MANTRA_OF_THE_BRANDED</Data></Cell><Cell><Data ss:Type="String">TEMPLATE_NAME_4</Data></Cell><Cell ss:StyleID="s64"><Data ss:Type="String">Scepter</Data></Cell><Cell><Data ss:Type="String">Berło</Data></Cell><Cell ss:Index="9" ss:StyleID="s63"/></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">MANTRA_OF_THE_BRANDED</Data></Cell><Cell><Data ss:Type="String">TEMPLATE_NAME_5</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">Spacer Chief</Data></Cell><Cell><Data ss:Type="String">Wódz Przestrzenników</Data></Cell><Cell ss:Index="9" ss:StyleID="s63"/></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">MANTRA_OF_THE_BRANDED</Data></Cell><Cell><Data ss:Type="String">TEMPLATE_NAME_6</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">Cresthold</Data></Cell><Cell><Data ss:Type="String">Klejnot herbowy</Data></Cell><Cell ss:Index="9" ss:StyleID="s63"/></Row><Row><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell><Cell ss:Index="7"><Data ss:Type="String">In the text below, text refers to a person that can either be male or female. If relevant for translation, please use the ‘localized string’ column for the male text and the ‘alternative localized string’ column for the female text.</Data></Cell></Row><Row><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell><Cell ss:Index="7"><Data ss:Type="String">In the text below, any inserted strings - anything of the form {text} - is replaced by an integer value for the thing described in the brackets. If the {text} is not followed by a unit - e.g. shields, hitpoints - the icon for the unit is inserted together with the integer. The same holds for symbols - e.g. '+', '%' - which are occasionally inserted together with the integer.</Data></Cell></Row><Row><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell><Cell ss:Index="7"><Data ss:Type="String">For references to game terminology and in-world references, please check the glossary delivered as part of the documentation.</Data></Cell></Row><Row><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell></Row><Row><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell></Row><Row><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell></Row><Row><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell></Row></Table><WorksheetOptions xmlns="urn:schemas-microsoft-com:office:excel"><Unsynced/><Print><ValidPrinterInfo/><HorizontalResolution>600</HorizontalResolution><VerticalResolution>600</VerticalResolution></Print><Selected/><Panes><Pane><Number>3</Number><ActiveRow>9</ActiveRow><ActiveCol>6</ActiveCol></Pane></Panes><ProtectObjects>False</ProtectObjects><ProtectScenarios>False</ProtectScenarios></WorksheetOptions></Worksheet></Workbook>
 ss:StyleID="s62" ss:Width="361.5"/><Column ss:StyleID="s62" ss:Width="120"/><Column ss:StyleID="s62" ss:AutoFitWidth="0" ss:Width="324"/><Row ss:AutoFitHeight="0" ss:Height="60"><Cell><Data ss:Type="String">UPGRADES_LASERS_UNITPROPERTIES</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">The DEV TEAM / MISC NOTES column contains info on what text between { } signs means (if applicable). It usually stands for either a numeric value, or a numeric value with an icon. Text between [ ] signs stands for a certain type of icon. </Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SCENE ID</Data></Cell><Cell><Data ss:Type="String">TEXT ID</Data></Cell><Cell><Data ss:Type="String">ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZATION NOTES</Data></Cell><Cell><Data ss:Type="String">DEV TEAM / MISC NOTES</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">LASER_PISTOL</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Laser Pistol</Data></Cell><Cell><Data ss:Type="String">Pistolet laserowy</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">LASER_PISTOL</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Fire a Laser Pistol at the target.</Data></Cell><Cell><Data ss:Type="String">Strzela do celu z pistoletu laserowego.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">LASER_RIFLE</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Laser Rifle</Data></Cell><Cell><Data ss:Type="String">Karabin laserowy</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">LASER_RIFLE</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Fire a Laser Rifle at the target.</Data></Cell><Cell><Data ss:Type="String">Strzela do celu z karabinu laserowego.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">DEFENSE_LASER</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Defense Laser</Data></Cell><Cell><Data ss:Type="String">Laser obronny</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">DEFENSE_LASER</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">A medium-powered Laser.</Data></Cell><Cell><Data ss:Type="String">Laser średniej mocy.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">LASER_SHOTGUN</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Laser Shotgun</Data></Cell><Cell><Data ss:Type="String">Strzelba laserowa</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">LASER_SHOTGUN</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Fire a laser blast at the target.</Data></Cell><Cell><Data ss:Type="String">Strzela do celu z lasera.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">LASER_CANNON</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Laser Cannon</Data></Cell><Cell><Data ss:Type="String">Działo laserowe</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">LASER_CANNON</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Fire a Laser Cannon at the target.</Data></Cell><Cell><Data ss:Type="String">Strzela do celu z działa laserowego.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">LASER_SWORD</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Laser Sword Strike</Data></Cell><Cell><Data ss:Type="String">Cios mieczem laserowym</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">LASER_SWORD</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Strike the target with a Laser Sword.</Data></Cell><Cell><Data ss:Type="String">Uderzenie celu mieczem laserowym.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">OVERCHARGE_LASER_CANNON</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Overcharge Laser Cannon</Data></Cell><Cell><Data ss:Type="String">Przeładowanie działa laserowego</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">OVERCHARGE_LASER_CANNON</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Overcharge the Laser Cannon to fire a massive, focused blast.</Data></Cell><Cell><Data ss:Type="String">Przeładowanie działa laserowego w celu oddania potężnego, skupionego strzału.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FLASH_MODULE</Data></Cell><Cell><Data ss:Type="String">UPGRADE_NAME</Data></Cell><Cell><Data ss:Type="String">Dazzler Systems</Data></Cell><Cell><Data ss:Type="String">Systemy oślepiające</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">FLASH_MODULE</Data></Cell><Cell><Data ss:Type="String">UPGRADE_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit's weapons have a {BlindChance}[strengthphysical/] strength chance  ({BlindRepeatingChance}[strengthphysical/] for repeating attacks) to [abilityred]Blind[/abilityred] units for {duration}[turn/].</Data></Cell><Cell><Data ss:Type="String">Broń tej jednostki ma szansę o sile {BlindChance}[strengthphysical/] ({BlindRepeatingChance}[strengthphysical/] dla ataków wielokrotnych) na [abilityred]oślepienie[/abilityred] celów na {duration}[turn/].</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HARD_LIGHT_MODULE</Data></Cell><Cell><Data ss:Type="String">UPGRADE_NAME</Data></Cell><Cell><Data ss:Type="String">Hard Light Systems</Data></Cell><Cell><Data ss:Type="String">Systemy twardego światła</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">HARD_LIGHT_MODULE</Data></Cell><Cell><Data ss:Type="String">UPGRADE_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit's Laser weapons gain an extra level of [abilityred]Stagger Impact[/abilityred].</Data></Cell><Cell><Data ss:Type="String">Broń laserowa tej jednostki uzyskuje dodatkowy poziom [abilityred]powodowania zachwiania[/abilityred].</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">INCINERATOR_MODULE</Data></Cell><Cell><Data ss:Type="String">UPGRADE_NAME</Data></Cell><Cell><Data ss:Type="String">Ignition Module</Data></Cell><Cell><Data ss:Type="String">Moduł zapalający</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">INCINERATOR_MODULE</Data></Cell><Cell><Data ss:Type="String">UPGRADE_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit's Laser weapons have a {Immolatechance}[strengththermal/] strength chance ({ImmolateRepeatingChance}[strengththermal/] for repeating attacks) to set targets on fire, causing [abilityred]Burning[/abilityred] for {duration}[turn/]. Burning deals {Immolationdamage}[damageThermal/] per [turn/] as well as making the affected unit {AccuracyTarget}% easier to hit.</Data></Cell><Cell><Data ss:Type="String">Broń laserowa tej jednostki ma szansę (siła {Immolatechance}[strengththermal/], {ImmolateRepeatingChance}[strengththermal/] dla ataków wielokrotnych) podpalenia celu i wywołania [abilityred]oparzenia[/abilityred], trwającego {duration}[turn/]. Oparzenie zadaje {Immolationdamage}[damageThermal/] na [turn/] i sprawia, że podpaloną jednostką łatwiej trafić o {AccuracyTarget}%.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">DISINTEGRATOR_FLARE_MODULE</Data></Cell><Cell><Data ss:Type="String">UPGRADE_NAME</Data></Cell><Cell><Data ss:Type="String">Plasma Disintegrator Module</Data></Cell><Cell><Data ss:Type="String">Moduł dezintegracji plazmowej</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="60"><Cell><Data ss:Type="String">DISINTEGRATOR_FLARE_MODULE</Data></Cell><Cell><Data ss:Type="String">UPGRADE_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Laser weapon attacks destroy {DisintegratorArmorDestroy}[armor/] and have a {DisintegrateChance}[strengththermal/] strength chance ({DisintegrateRepeatingChance}[strengththermal/] for repeating attacks) to [abilityred]Disintegrate[/abilityred] Tier I and Tier II units. Disintegrated units are instantly killed and leave no corpse behind.</Data></Cell><Cell><Data ss:Type="String">Ataki bronią laserową niszczą {DisintegratorArmorDestroy}[armor/] i mają szansę (siła {DisintegrateChance}[strengththermal/], {DisintegrateRepeatingChance}[strengththermal/] dla ataków wielokrotnych) [abilityred]zdezintegrowania[/abilityred] jednostek klasy 1. i 2. Zdezintegrowane jednostki są natychmiast zabijane i nie pozostają po nich zwłoki.</Data></Cell><Cell ss:Index="8" ss:StyleID="s63"/></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">BLAST_LASER</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Blast Laser</Data></Cell><Cell><Data ss:Type="String">Miotacz laserowy</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">BLAST_LASER</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">A lightweight laser weapon designed to fire single, concentrated shots at medium range.</Data></Cell><Cell><Data ss:Type="String">Lekka broń laserowa oddająca pojedyncze skoncentrowane strzały na średnią odległość.</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">EQUIPMENT</Data></Cell><Cell><Data ss:Type="String">BASIC_LASER_PISTOL_NAME</Data></Cell><Cell><Data ss:Type="String">Laser Pistol</Data></Cell><Cell><Data ss:Type="String">Pistolet laserowy</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">EQUIPMENT</Data></Cell><Cell><Data ss:Type="String">BASIC_LASER_SWORD_NAME</Data></Cell><Cell><Data ss:Type="String">Laser Sword</Data></Cell><Cell><Data ss:Type="String">Miecz laserowy</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">EQUIPMENT</Data></Cell><Cell><Data ss:Type="String">BASIC_LASER_RIFLE_NAME</Data></Cell><Cell><Data ss:Type="String">Laser Rifle</Data></Cell><Cell><Data ss:Type="String">Karabin laserowy</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">LASER_REPEATER</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Laser Repeater</Data></Cell><Cell><Data ss:Type="String">Laser powtarzalny</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">LASER_REPEATER</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Fire a Laser Repeater at the target.</Data></Cell><Cell><Data ss:Type="String">Strzela do celu z lasera powtarzalnego.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">INTERCEPTION_BLASTERS</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Interception Blasters</Data></Cell><Cell><Data ss:Type="String">Miotacze przechwytujące</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">INTERCEPTION_BLASTERS</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Fire Interception Blasters at the target</Data></Cell><Cell><Data ss:Type="String">Ostrzeliwuje cel miotaczami przechwytującymi.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FOCUSED_PARTICLE_BEAM</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Laser Particle Beam</Data></Cell><Cell><Data ss:Type="String">Wiązka fotonowa</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FOCUSED_PARTICLE_BEAM</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Fire a Particle Beam at the target.</Data></Cell><Cell><Data ss:Type="String">Ostrzeliwuje cel wiązką fotonów.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">MARKED_TARGET</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Marked Target</Data></Cell><Cell><Data ss:Type="String">Oznakowany cel</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">MARKED_TARGET</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit has been marked, and is {percentageChance} easier to hit.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka została oznakowana i o {percentageChance} łatwiej ją trafić.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">MULTI_LASER_ARRAY</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Wide Field Laser Array</Data></Cell><Cell><Data ss:Type="String">Bateria laserów szerokopolowych</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">MULTI_LASER_ARRAY</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Fire an flurry of Laser fire at an area in front of the unit, dealing significant damage.</Data></Cell><Cell><Data ss:Type="String">Ostrzeliwuje strefę przed jednostką gradem impulsów laserowych, zadając poważne obrażenia.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FOCUS_LASER_ARRAY</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Focused Laser Array</Data></Cell><Cell><Data ss:Type="String">Bateria laserów skupionych</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">FOCUS_LASER_ARRAY</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Fire a focused Laser shot at a distant target. This shot will [abilityred]knock back[/abilityred] Light units.</Data></Cell><Cell><Data ss:Type="String">Ostrzeliwuje odległy cel skupioną wiązką laserową. Powoduje [abilityred]odepchnięcie[/abilityred] jednostek lekkich.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">NAVAL_LASER_CANNON</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Naval Laser Cannon</Data></Cell><Cell><Data ss:Type="String">Okrętowe działo laserowe</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">NAVAL_LASER_CANNON</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Fire a ship mounted Laser Cannon at the target. Ignores the accuracy penalty against Flying units.</Data></Cell><Cell><Data ss:Type="String">Strzela do wskazanego celu z działa laserowego zamontowanego na okręcie. Ignoruje karę do celności w walce z jednostkami latającymi.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FIRE_LASER_LANCE</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Laser Lance</Data></Cell><Cell><Data ss:Type="String">Lanca laserowa</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FIRE_LASER_LANCE</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Fire a powerful blast from the tip of a Laser spear.</Data></Cell><Cell><Data ss:Type="String">Wystrzeliwuje potężny impuls z grotu
<?xml version="1.0"?><?mso-application progid="Excel.Sheet"?><Workbook xmlns="urn:schemas-microsoft-com:office:spreadsheet" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns:ss="urn:schemas-microsoft-com:office:spreadsheet" xmlns:html="http://www.w3.org/TR/REC-html40"><DocumentProperties xmlns="urn:schemas-microsoft-com:office:office"><Author>Arnout Sas</Author><LastAuthor>GameScribes4</LastAuthor><Created>2019-10-11T10:53:00Z</Created><LastSaved>2020-02-07T11:29:13Z</LastSaved><Version>16.00</Version></DocumentProperties><OfficeDocumentSettings xmlns="urn:schemas-microsoft-com:office:office"><AllowPNG/></OfficeDocumentSettings><ExcelWorkbook xmlns="urn:schemas-microsoft-com:office:excel"><WindowHeight>10215</WindowHeight><WindowWidth>21570</WindowWidth><WindowTopX>32767</WindowTopX><WindowTopY>32767</WindowTopY><RefModeR1C1/><ProtectStructure>False</ProtectStructure><ProtectWindows>False</ProtectWindows></ExcelWorkbook><Styles><Style ss:ID="Default" ss:Name="Normal"><Alignment ss:Vertical="Bottom"/><Borders/><Font ss:FontName="Calibri" x:Family="Swiss" ss:Size="11" ss:Color="#000000"/><Interior/><NumberFormat/><Protection/></Style><Style ss:ID="s62"><Alignment ss:Vertical="Top" ss:WrapText="1"/></Style></Styles><Worksheet ss:Name="Script"><Table x:FullColumns="1" x:FullRows="1" ss:StyleID="s62" ss:DefaultColumnWidth="242.25" ss:DefaultRowHeight="15"><Column ss:StyleID="s62" ss:Width="210.75"/><Column ss:StyleID="s62" ss:Width="107.25"/><Column ss:StyleID="s62" ss:AutoFitWidth="0" ss:Width="293.25" ss:Span="1"/><Column ss:Index="5" ss:StyleID="s62" ss:Width="243"/><Column ss:StyleID="s62" ss:Width="120.75"/><Row ss:AutoFitHeight="0" ss:Height="75"><Cell><Data ss:Type="String">THERIANS_UNITPROPERTIES</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">The DEV TEAM / MISC NOTES column contains info on what text between { } signs means (if applicable). It usually stands for either a numeric value, or a numeric value with an icon. Text between [ ] signs stands for a certain type of icon. </Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">SCENE ID</Data></Cell><Cell><Data ss:Type="String">TEXT ID</Data></Cell><Cell><Data ss:Type="String">ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZATION NOTES</Data></Cell><Cell><Data ss:Type="String">DEV TEAM / MISC NOTES</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ARC_SLOWING_ACORN_CLOUD</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Electrified Slowing Acorn Cloud</Data></Cell><Cell><Data ss:Type="String">Chmura spowalniających żołędzi elektrycznych</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="60"><Cell><Data ss:Type="String">ARC_SLOWING_ACORN_CLOUD</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Units moving through or ending their turn on this hex take {damage}[damagewave/] and have a {strengthchance}[strengthbio/] chance to become [abilityred]Slowed[/abilityred].</Data></Cell><Cell><Data ss:Type="String">Jednostki przemieszczające się przez to pole lub kończące na nim turę odnoszą {damage}[damagewave/] i mają szansę o sile {strengthchance}[strengthbio/] na [abilityred]spowolnienie[/abilityred].</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">BIO_BOMB</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Bio Acorn</Data></Cell><Cell><Data ss:Type="String">Biożołądź</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">BIO_BOMB</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Throw a Biochemical acorn grenade.</Data></Cell><Cell><Data ss:Type="String">Rzut biochemicznym granatem na bazie żołędzia.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">BIOCHEMICAL_SHOTGUN</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Biochemical Shotgun</Data></Cell><Cell><Data ss:Type="String">Strzelba biochemiczna</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">BIOCHEMICAL_SHOTGUN</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Fire a Biochemical Shotgun at the target.</Data></Cell><Cell><Data ss:Type="String">Oddaje strzał do celu przy użyciu strzelby biochemicznej.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">BIOCHEMICAL_SNIPERRIFLE</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Viral Precision Shot</Data></Cell><Cell><Data ss:Type="String">Strzał wirusowy</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">BIOCHEMICAL_SNIPERRIFLE</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Fire a viral round at the target.</Data></Cell><Cell><Data ss:Type="String">Strzela do celu pociskiem wirusowym.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">BULLET_SPIN</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Bullet Spin</Data></Cell><Cell><Data ss:Type="String">Wir strzelecki</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="60"><Cell><Data ss:Type="String">BULLET_SPIN</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Spin around with pistols, attacking all units within {Range} hexes.[br/]Puts the unit into [abilityblue]Defense Mode[/abilityblue] after use.</Data></Cell><Cell><Data ss:Type="String">Obrót wokół własnej osi z równoczesnym ostrzałem z pistoletów, rażącym wszystkie jednostki w promieniu {Range} pól.[br/]Po użyciu jednostka atakująca przechodzi w [abilityblue]tryb obronny[/abilityblue].</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">CARBON_SWORD</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Carbon Sword</Data></Cell><Cell><Data ss:Type="String">Miecz węglowy</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">CARBON_SWORD</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Strike with a powerful carbon-made sword, damaging all targets in front of this unit.</Data></Cell><Cell><Data ss:Type="String">Cios potężnym mieczem z włókna węglowego, wymierzony we wszystkie cele znajdujące się przed jednostką.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">CARBON_SWORD</Data></Cell><Cell><Data ss:Type="String">MOD_NAME</Data></Cell><Cell><Data ss:Type="String">Armor Bypass</Data></Cell><Cell><Data ss:Type="String">Obejście pancerza</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">CARBON_SWORD</Data></Cell><Cell><Data ss:Type="String">MOD_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Attack ignores up to {ArmourBypass}[Armor/]</Data></Cell><Cell><Data ss:Type="String">Ataki ignorują do {ArmourBypass}[Armor/].</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">DUAL_PISTOLS</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Dual Pistols</Data></Cell><Cell><Data ss:Type="String">Dwa pistolety</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">DUAL_PISTOLS</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Fire repeating pistols at the target.</Data></Cell><Cell><Data ss:Type="String">Strzela do celu z pistoletów samopowtarzalnych.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HEALING_SHOT</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Healing Shot</Data></Cell><Cell><Data ss:Type="String">Strzał regenerujący</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">HEALING_SHOT</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Target friendly Biological or Cyborg unit to restore {HealAmount}[HP/]</Data></Cell><Cell><Data ss:Type="String">Wskazana przyjazna jednostka organiczna lub cyborg odzyskuje {HealAmount}[HP/]</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HUNTER'S_SWIPE</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Prowler's Swipe</Data></Cell><Cell><Data ss:Type="String">Smagnięcie łowcy</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Prowler is related to the unit of the same name</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HUNTER'S_SWIPE</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Strikes the target with sharp claws.</Data></Cell><Cell><Data ss:Type="String">Uderza cel ostrymi pazurami.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">VIRAL_SNAPSHOT</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Viral Snapshot</Data></Cell><Cell><Data ss:Type="String">Szybki strzał wirusowy</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">VIRAL_SNAPSHOT</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Fire a weaker viral round at the target.</Data></Cell><Cell><Data ss:Type="String">Strzela do celu słabszym pociskiem wirusowym.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">INSPIRING_ROAR</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Inspiring Roar</Data></Cell><Cell><Data ss:Type="String">Zachęcający ryk</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">INSPIRING_ROAR</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Heal Apex for {HealAmount}[hp/] while inspiring all friendly units within a {Range} hex range, granting them {MoraleBoost}[happiness/] for {Duration}[turn/].</Data></Cell><Cell><Data ss:Type="String">Zachęca wszystkie przyjazne jednostki w obrębie {Range} pól, dając im {MoraleBoost}[happiness/] na {Duration}[turn/].</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">INSPIRING_ROAR_INSPIRED</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Inspired by a glorious roar, granting {MoraleBoost}[happiness/]</Data></Cell><Cell><Data ss:Type="String">Jednostka zainspirowana chwalebnym rykiem, dającym {MoraleBoost}[happiness/]</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">INTOXICATING_ACORN</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Healing Acorn</Data></Cell><Cell><Data ss:Type="String">Żołądź regenerujący</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="75"><Cell><Data ss:Type="String">INTOXICATING_ACORN</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Throw a grenade that releases a healing cloud for {duration}[turn/]. Heals Biological and Cyborg units for {HealAmount}[HP/] and dispels negative effects.[br/][br/]The cloud has the same effect for units ending their turn in it. </Data></Cell><Cell><Data ss:Type="String">Rzut granatem, którzy wydziela obłok powodujący regenerację przez {duration}[turn/]. Jednostki organiczne i cyborgi odzyskują {HealAmount}[HP/] i pozbywają się negatywnych efektów.[br/][br/]Obłok działa tak samo na jednostki kończące turę w jego obrębie. </Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">INTOXICATING_ACORN_CLOUD</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Healing Acorn Cloud</Data></Cell><Cell><Data ss:Type="String">Obłok regenerujący</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">INTOXICATING_ACORN_CLOUD</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Heals Biological and Cyborg units ending their turn here for {HealAmount}[HP/].</Data></Cell><Cell><Data ss:Type="String">Jednostki organiczne i cyborgi kończące w nim turę odzyskują {HealAmount}[HP/].</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">LEAP_AND_BOUND</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Leap and Bound</Data></Cell><Cell><Data ss:Type="String">Hop siup</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">LEAP_AND_BOUND</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Jump to target hex.</Data></Cell><Cell><Data ss:Type="String">Przeskok na wskazane pole.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">POUNCE</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Pounce</Data></Cell><Cell><Data ss:Type="String">Sus</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">POUNCE</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Jump through the air and land behind an enemy unit.</Data></Cell><Cell><Data ss:Type="String">Wyskok w powietrze i lądowanie za wrogą jednostką.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">RESISTANCE_ACORN</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Resistance Acorn</Data></Cell><Cell><Data ss:Type="String">Żołądź odporności</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="75"><Cell><Data ss:Type="String">RESISTANCE_ACORN</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Throw a grenade that releases a resistance cloud for {duration}[turn/]. Friendly units hit gain {ResistanceValue} resistance to all damage channels for {buffDuration}[turn/].[br/][br/]The cloud has the same effect for units moving through or ending their turn in it. </Data></Cell><Cell><Data ss:Type="String">Rzut granatem, który wydziela obłok zwiększający odporność przez {duration}[turn/]. Jednostki uzyskują {ResistanceValue} odporności na wszystkie kanały obrażeń na {buffDuration}[turn/].[br/][br/]Obłok działa tak samo na jednostki kończące turę w jego obrębie. </Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">RESISTANCE_ACORN_CLOUD</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Resistance Cloud</Data></Cell><Cell><Data ss:Type="String">Obłok odporności</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">RESISTANCE_ACORN_CLOUD</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Units moving through or ending their turn on this hex have {ResistanceValue} resistance to all damage channels for {Duration}[turn/]</Data></Cell><Cell><Data ss:Type="String">Jednostki przemieszczające się przez to pole lub kończące na nim turę uzyskują {ResistanceValue} odporności na wszystkie kanały obrażeń na {Duration}[turn/].</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SLOWING_ACORN</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Slowing Acorn</Data></Cell><Cell><Data ss:Type="String">Żołądź spowalniający</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="105"><Cell><Data ss:Type="String">SLOWING_ACORN</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Throw a grenade that releases a slowing cloud for {duration}[turn/].[br/][br/]The cloud deals {damage}[damagebio/], and has {StrengthValue}[strengthPhysical/] chance to cause [abilityred]Slowed[/abilityred] for {debuffDuration}[turn/] on units moving through or ending their turn in it.</Data></Cell><Cell><Data ss:Type="String">Rzut granatem, który wydziela obłok spowalniający na {duration}[turn/].[br/][br/]Obłok zadaje {damage}[damagebio/] i ma szansę o sile {StrengthValue}[strengthPhysical/] spowodowania [abilityred]spowolnienia[/abilityred] na {debuffDuration}[turn/] u jednostek przechodzących przez niego lub kończących turę w jego obrębie.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SLOWING_ACORN_CLOUD</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Slowing Cloud</Data></Cell><Cell><Data ss:Type="String">Obłok spowalniający</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="75"><Cell><Data ss:Type="String">SLOWING_ACORN_CLOUD</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Units moving through or ending their turn on this hex take {damage}[damagebio/] and have a {strengthchance}[strengthbio/] chance to become [abilityred]Slowed[/abilityred] for {debuffDuration}[turn/].</Data></Cell><Cell><Data ss:Type="String">Jednostki przemieszczające się przez to pole lub kończące na nim turę odnoszą {damage}[damagebio/] i mają szansę o sile {strengthchance}[strengthbio/] na [abilityred]spowolnienie[/abilityred] na {debuffDuration}[turn/].</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">THERIAN_PRESENCE</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Therian Presence</Data></Cell><Cell><Data ss:Type="String">Teriańska obecność</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">THERIAN_PRESENCE</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">When adjacent to another unit with Therian Presence unit heals for {HealAmount}[hp/] at the end of the turn.</Data></Cell><Cell><Data ss:Type="String">Gdy sąsiaduje z inną jednostko obecności Therian, leczy na {HealAmount}[hp/] pod koniec tury.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PRIMAL_PHEROMONES_THRILL</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Primal Pheromones: Thrill</Data></Cell><Cell><Data ss:Type="String">Pierwotne feromony – dreszcz</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="75"><Cell><Data ss:Type="String">PRIMAL_PHEROMONES_THRILL</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">When unit drops to 66% [hp/] or lower, unit and all friendly units within {Range} hexes gain {DamagePercentIncrease}% increased damage to attacks for {Duration} [turn/].[br/]Can trigger once per battle.</Data></Cell><Cell><Data ss:Type="String">Gdy [hp/] jednostki zmaleje do 66% lub mniej, ona sama i wszystkie przyjazne jednostki w obrębie {Range} pól zyskują wzrost obrażeń od wszystkich ataków o {DamagePercentIncrease}% na {Duration}[turn/].[br/]Efekt może wystąpić tylko raz na bitwę.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">THRILL_PROPERTY</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Thrill</Data></Cell><Cell><Data ss:Type="String">Dreszcz</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">THRILL_PROPERTY</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Unit has {damagePercentIncrease}% increased damage to all abilities.</Data></Cell><Cell><Data ss:Type="String">Jednostka zadaje o {damagePercentIncrease}% więcej obrażeń od wszystkich umiejętności.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PRIMAL_PHEROMONES_PRANCE</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Primal Pheromones: Prance</Data></Cell><Cell><Data ss:Type="String">Pierwotne feromony – bryknięcie</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="75"><Cell><Data ss:Type="String">PRIMAL_PHEROMONES_PRANCE</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">When unit drops to 66% [hp/] or lower, unit and all friendly units within {Range} hexes gain {EvasionPercentChance}% Evasion and Skitter for {Duration}[turn/].[br/]Can trigger once per battle.</Data></Cell><Cell><Data ss:Type="String">Gdy [hp/] jednostki zmaleje do 66% lub mniej, ona sama i wszystkie przyjazne jednostki w obrębie {Range} pól zyskują {EvasionPercentChance}% szansy na unik i smyrg na {Duration}[turn/].[br/]Efekt może wystąpić tylko raz na bitwę.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PRANCE_PROPERTY</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Prance</Data></Cell><Cell><Data ss:Type="String">Bryknięcie</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">PRANCE_PROPERTY</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Unit has {EvasionPercentChance}% Evasion and [abilityblue]Skitter[/abilityblue].</Data></Cell><Cell><Data ss:Type="String">Jednostka ma {EvasionPercentChance}% do uniku i [abilityblue]smyrg[/abilityblue].</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PRIMAL_PHEROMONES_SLY</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Primal Pheromones: Sly</Data></Cell><Cell><Data ss:Type="String">Pierwotne feromony – chytrość</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="75"><Cell><Data ss:Type="String">PRIMAL_PHEROMONES_SLY</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">When unit drops to 66% [hp/] or lower, unit and all friendly units within {Range} hexes gain +{CriticalChanceIncrease}% increased critical chance for {Duration}[turn/].[br/]Can trigger once per battle.</Data></Cell><Cell><Data ss:Type="String">Gdy [hp/] jednostki zmaleje do 66% lub mniej, ona sama i wszystkie przyjazne jednostki w obrębie {Range} pól zyskują wzrost szansy na trafienie krytyczne o {CriticalChanceIncrease}% na {Duration}[turn/].[br/]Efekt może wystąpić tylko raz na bitwę.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SLY_PROPERTY</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Sly</Data></Cell><Cell><Data ss:Type="String">Chytrość</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">SLY_PROPERTY</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Unit has +{CriticalChance}% increased critical chance.</Data></Cell><Cell><Data ss:Type="String">Jednostka ma +{CriticalChance}% do szansy na trafienie krytyczne.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PRIMAL_PHEROMONES_BIOREGENERATION</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Primal Pheromones: Bioregeneration</Data></Cell><Cell><Data ss:Type="String">Pierwotne feromony – bioregeneracja</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="75"><Cell><Data ss:Type="String">PRIMAL_PHEROMONES_BIOREGENERATION</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">When unit drops to 66% [hp/] or lower, unit and all friendly units within {Range} hexes gain [abilityblue]Regeneration[/abilityblue] for {Duration} [turn/].[br/]Can trigger once per battle.</Data></Cell><Cell><Data ss:Type="String">Gdy [hp/] jednostki zmaleje do 66% lub mniej, ona sama i wszystkie przyjazne jednostki w obrębie {Range} pól zyskują [/abilityblue]regenerację[abilityblue] na {Duration}[turn/].[br/]Efekt może wystąpić tylko raz na bitwę.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">BIOREGENERATION_PROPERTY</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Bioregeneration</Data></Cell><Cell><Data ss:Type="String">Bioregeneracja</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">BIOREGENERATION_PROPERTY</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Unit is healed for {HealAmount}[hp/] per [turn/].</Data></Cell><Cell><Data ss:Type="String">Jednostka odzyskuje {HealAmount}[hp/] na [turn/].</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PRIMAL_PHEROMONES_PRIDE</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Primal Pheromones: Pride</Data></Cell><Cell><Data ss:Type="String">Pierwotne feromony – duma</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="75"><Cell><Data ss:Type="String">PRIMAL_PHEROMONES_PRIDE</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">When unit drops to 66% [hp/] or lower, unit and all friendly units within {Range} hexes gain +{ResistanceValue} resistance to all damage channels for {Duration}[turn/].[br/]Can trigger once per battle.</Data></Cell><Cell><Data ss:Type="String">Gdy [hp/] jednostki zmaleje do 66% lub mniej, ona sama i wszystkie przyjazne jednostki w obrębie {Range} pól zyskują +{ResistanceValue} do odporności na wszystkie kanały obrażeń na {Duration}[turn/].[br/]Efekt może wystąpić tylko raz na bitwę.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PRIDE_PROPERTY</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Pride</Data></Cell><Cell><Data ss:Type="String">Duma</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">PRIDE_PROPERTY</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Unit has +{ResistanceValue} resistance to all damage channels.</Data></Cell><Cell><Data ss:Type="String">Jednostka ma +{ResistanceValue} do odporności na wszystkie kanały obrażeń.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ENHANCED_LIMB_AUGMENTS</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Enhanced Limb Augments</Data></Cell><Cell><Data ss:Type="String">Ulepszone wspomaganie kończyn</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ENHANCED_LIMB_AUGMENTS</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Splinter Jump</Data></Cell><Cell><Data ss:Type="String">Odprysk</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">ENHANCED_LIMB_AUGMENTS</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Augmented leg armor that gives [abilityblue]Fast Movement[/abilityBlue] and +{KineticResistance}[DamagePhysical/] resistance.</Data></Cell><Cell><Data ss:Type="String">Wzmocnione opancerzenie nóg, zapewniające [abilityblue]szybki ruch[/abilityBlue] i +{KineticResistance}[DamagePhysical/] do odporności.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HUNTERS_CAMOUFLAGE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Hunter's Camouflage</Data></Cell><Cell><Data ss:Type="String">Kamuflaż łowcy</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="90"><Cell><Data ss:Type="String">HUNTERS_CAMOUFLAGE</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Unit gains [abilityBlue]Flanker[/abilityBlue]. Flanking attacks have a {SingleAttackStrength}[StrengthPhysical/] chance ({RepeatingAttackStrength}[StrengthPhysical/] for repeating attacks) to apply [abilityRed]Cripple[/AbilityRed] for {CrippleDuration}[turn/].</Data></Cell><Cell><Data ss:Type="String">Jednostka zyskuje [abilityBlue]oskrzydlenie[/abilityBlue]. Ataki z flanki mają szansę {SingleAttackStrength}[StrengthPhysical/] ({RepeatingAttackStrength}[StrengthPhysical/] w przypadku ataków wielokrotnych) spowodowania [abilityRed]okaleczenia[/AbilityRed] na {CrippleDuration}[turn/].</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">THERIAN_ALLY_INSIGNIA</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Therian Ally Insignia</Data></Cell><Cell><Data ss:Type="String">Insygnia sprzymierzeńca Terian</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="90"><Cell><Data ss:Type="String">THERIAN_ALLY_INSIGNIA</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Recognized as an ally of the Therians, this unit gains [abilityblue]Therian Presence[/abilityblue]: When adjacent to another unit with Therian Presence unit heals for {HealAmount}[hp/] at the end of the turn.[br/]Additionally, unit gains [abilityblue]Primal Pheromones: Bioregeneration[/abilityblue].</Data></Cell><Cell><Data ss:Type="String">Uznana za sojusznika Therians, ta jednostka zyskuje [abilityblue]Therian obecność[/abilityblue]: Kiedy sąsiaduje z inną jednostką w obecności Therian jednostka leczy za {HealAmount}[hp/] pod koniec tury.[br/] Dodatkowo, jednostka zyskuje [abilityblue] Pierwotne feromony: Bioregeneracja [/abilityblue].</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">MIGHT_OF_THE_THERIANS</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Might of The Therians</Data></Cell><Cell><Data ss:Type="String">Potęga Terian</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">MIGHT_OF_THE_THERIANS</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Pheromone abilities can be triggered manually on Therian units. The Pheromones will still activate normally.</Data></Cell><Cell><Data ss:Type="String">Zdolności feromonów można aktywować ręcznie na jednostkach Therian. Feromony nadal będą się normalnie aktywować.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">THERIAN_PRESENCE_ACTIVATION</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Therian Presence Active</Data></Cell><Cell><Data ss:Type="String">Teriańska obecność aktywna</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">WIP, DO NOT LOCALIZE</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">MIGHT_OF_THE_THERIANS</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Trigger Pheromones</Data></Cell><Cell><Data ss:Type="String">Wyzwalanie feromonów</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ENHANCED_LIMB_AUGMENTS</Data></Cell><Cell><Data ss:Type="String">TEMPLATE_NAME_1</Data></Cell><Cell><Data ss:Type="String">Bouncing</Data></Cell><Cell><Data ss:Type="String">Odbijanie</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ENHANCED_LIMB_AUGMENTS</Data></Cell><Cell><Data ss:Type="String">TEMPLATE_NAME_2</Data></Cell><Cell><Data ss:Type="String">Leaping</Data></Cell><Cell><Data ss:Type="String">Skaczący</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ENHANCED_LIMB_AUGMENTS</Data></Cell><Cell><Data ss:Type="String">TEMPLATE_NAME_3</Data></Cell><Cell><Data ss:Type="String">Braced</Dat
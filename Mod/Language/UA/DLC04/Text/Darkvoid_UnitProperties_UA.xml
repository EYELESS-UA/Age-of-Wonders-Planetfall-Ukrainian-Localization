<?xml version="1.0"?><?mso-application progid="Excel.Sheet"?><Workbook xmlns="urn:schemas-microsoft-com:office:spreadsheet" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns:ss="urn:schemas-microsoft-com:office:spreadsheet" xmlns:html="http://www.w3.org/TR/REC-html40"><DocumentProperties xmlns="urn:schemas-microsoft-com:office:office"><Author>GameScribes4</Author><LastAuthor>GameScribes4</LastAuthor><Created>2020-04-11T02:27:53Z</Created><LastSaved>2020-02-04T14:40:21Z</LastSaved><Version>16.00</Version></DocumentProperties><OfficeDocumentSettings xmlns="urn:schemas-microsoft-com:office:office"><AllowPNG/></OfficeDocumentSettings><ExcelWorkbook xmlns="urn:schemas-microsoft-com:office:excel"><WindowHeight>11565</WindowHeight><WindowWidth>17970</WindowWidth><WindowTopX>32767</WindowTopX><WindowTopY>32767</WindowTopY><RefModeR1C1/><ProtectStructure>False</ProtectStructure><ProtectWindows>False</ProtectWindows></ExcelWorkbook><Styles><Style ss:ID="Default" ss:Name="Normal"><Alignment ss:Vertical="Bottom"/><Borders/><Font ss:FontName="Calibri" x:Family="Swiss" ss:Size="11" ss:Color="#000000"/><Interior/><NumberFormat/><Protection/></Style><Style ss:ID="s62"><Alignment ss:Vertical="Top" ss:WrapText="1"/></Style></Styles><Worksheet ss:Name="Script"><Table x:FullColumns="1" x:FullRows="1" ss:StyleID="s62" ss:DefaultColumnWidth="51.75" ss:DefaultRowHeight="15"><Column ss:StyleID="s62" ss:Width="141"/><Column ss:StyleID="s62" ss:Width="121.5"/><Column ss:StyleID="s62" ss:AutoFitWidth="0" ss:Width="408.75" ss:Span="1"/><Column ss:Index="5" ss:StyleID="s62" ss:Width="192"/><Column ss:StyleID="s62" ss:Width="120"/><Column ss:StyleID="s62" ss:Width="367.5"/><Row ss:Height="60"><Cell><Data ss:Type="String">DARKVOID_UNITPROPERTIES</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">The DEV TEAM / MISC NOTES column contains info on what text between { } signs means (if applicable). It usually stands for either a numeric value, or a numeric value with an icon. Text between [ ] signs stands for a certain type of icon. </Data></Cell></Row><Row ss:Height="60"><Cell><Data ss:Type="String">SCENE ID</Data></Cell><Cell><Data ss:Type="String">TEXT ID</Data></Cell><Cell><Data ss:Type="String">ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZATION NOTES</Data></Cell><Cell><Data ss:Type="String">DEV TEAM / MISC NOTES</Data></Cell></Row><Row><Cell><Data ss:Type="String">DARK_BLAST</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Dark Blast</Data></Cell><Cell><Data ss:Type="String">Mroczny podmuch</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Ability name</Data></Cell></Row><Row><Cell><Data ss:Type="String">DARK_BLAST</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Blast an enemy with darkness.</Data></Cell><Cell><Data ss:Type="String">Miota ciemnością we wroga.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Ability description</Data></Cell></Row><Row><Cell><Data ss:Type="String">DARKVOID_SPIKE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Voidbringer Spike</Data></Cell><Cell><Data ss:Type="String">Kolec Pustmroku</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Ability name</Data></Cell></Row><Row><Cell><Data ss:Type="String">DARKVOID_SPIKE</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Shoot a spike of concentrated darkness.</Data></Cell><Cell><Data ss:Type="String">Wystrzeliwuje szpikulec skoncentrowanej ciemności.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Ability description</Data></Cell></Row><Row><Cell><Data ss:Type="String">DARK_FLAY</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Dark Flay</Data></Cell><Cell><Data ss:Type="String">Mroczna chłosta</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Ability name</Data></Cell></Row><Row><Cell><Data ss:Type="String">DARK_FLAY</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Flay an enemy with darkness.</Data></Cell><Cell><Data ss:Type="String">Chłoszcze przeciwnika ciemnością.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Ability description</Data></Cell></Row><Row><Cell><Data ss:Type="String">WARP_DARKNESS</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Warp Darkness</Data></Cell><Cell><Data ss:Type="String">Ciemność wypaczenia</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Ability name</Data></Cell></Row><Row><Cell><Data ss:Type="String">WARP_DARKNESS</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Damage an enemy by warping their form with dark energy.</Data></Cell><Cell><Data ss:Type="String">Zadaje obrażenia, deformując wroga za pomocą mrocznej energii.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Ability description</Data></Cell></Row><Row><Cell><Data ss:Type="String">THRALLING_MARK</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Thralling Mark</Data></Cell><Cell><Data ss:Type="String">Piętno zniewolenia</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Mod name. Thralling or Enthralled means "to be controlled by Voidbringers"</Data></Cell></Row><Row ss:Height="30"><Cell><Data ss:Type="String">THRALLING_MARK</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">The mark of being thralled by the Voidbringers. This unit will die when no more Voidbringers are alive in its army.</Data></Cell><Cell><Data ss:Type="String">Oznaka zniewolenia przez Pustmrok. Ta jednostka zginie, gdy w armii zabraknie żywych jednostek Pustmroku.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Mod description. Thralling or Enthralled means "to be controlled by Voidbringers"</Data></Cell></Row><Row><Cell><Data ss:Type="String">THRALLING_MARK</Data></Cell><Cell><Data ss:Type="String">PROPERTY</Data></Cell><Cell><Data ss:Type="String">Enthralled</Data></Cell><Cell><Data ss:Type="String">Zniewolenie</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Debuff, it means to be controlled by Voidbringers</Data></Cell></Row><Row><Cell><Data ss:Type="String">THRALLING_MARK</Data></Cell><Cell><Data ss:Type="String">PROPERTY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit will die when no more Voidbringers are alive in its army.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka zginie, gdy w armii zabraknie żywych jednostek Pustmroku.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Debuff description, it means to be controlled by Voidbringers</Data></Cell></Row><Row><Cell><Data ss:Type="String">THRALLBOMB</Data></Cell><Cell><Data ss:Type="String">PROPERTY</Data></Cell><Cell><Data ss:Type="String">Thrallbomb</Data></Cell><Cell><Data ss:Type="String">Bomba niewoli</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Ability name</Data></Cell></Row><Row ss:Height="30"><Cell><Data ss:Type="String">THRALLBOMB</Data></Cell><Cell><Data ss:Type="String">PROPERTY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Target Tier I Enthralled unit explodes, dealing damage in a {hexrad} hex radius around it and dying.</Data></Cell><Cell><Data ss:Type="String">Wskazana zniewolona jednostka klasy I wybucha, zadając obrażenia w promieniu {hexrad} pól i ginąc.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Ability description</Data></Cell></Row><Row><Cell><Data ss:Type="String">CLEANSING_DARKNESS</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Cleansing Darkness</Data></Cell><Cell><Data ss:Type="String">Oczyszczająca ciemność</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Ability name</Data></Cell></Row><Row ss:Height="30"><Cell><Data ss:Type="String">CLEANSING_DARKNESS</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Target [abilityred]Enthralled[/abilityred] unit is healed for {healAmount} and has all negative status effects dispelled.</Data></Cell><Cell><Data ss:Type="String">Wskazana [abilityred]zniewolona[/abilityred] jednostka odzyskuje {healAmount} i zostaje uwolniona od wszystkich niekorzystnych efektów stanu.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Ability description</Data></Cell></Row><Row><Cell><Data ss:Type="String">ENTHRALL</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Enthral</Data></Cell><Cell><Data ss:Type="String">Zniewól</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Ability name</Data></Cell></Row><Row ss:Height="45"><Cell><Data ss:Type="String">ENTHRALL</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Target non-Hero, non-Mindless Biological or Cyborg goes into a [abilityred]Panic[/abilityred] for {panicDuration}. Then, the unit will become [abilityred]Enthralled[/abilityred]</Data></Cell><Cell><Data ss:Type="String">Wskazana jednostka organiczna lub cyborg, nienależąca do bezmózgich i niebędąca bohaterem, wpada w [abilityred]panikę[/abilityred] na {panicDuration}. Następnie stanie się [abilityred]zniewolona[/abilityred].</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Ability description</Data></Cell></Row><Row><Cell><Data ss:Type="String">THRALLED_TENDRILS</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Thralled Tendrils</Data></Cell><Cell><Data ss:Type="String">Zniewolone macki</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Ability name</Data></Cell></Row><Row><Cell><Data ss:Type="String">THRALLED_TENDRILS</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Target Enthralled unit deals damage to adjacent enemy units.</Data></Cell><Cell><Data ss:Type="String">Wskazana jednostka zniewolona zadaje obrażenia sąsiadującym jednostkom wroga.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Ability description</Data></Cell></Row><Row><Cell><Data ss:Type="String">DARK_STRENGTH</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Dark Strength</Data></Cell><Cell><Data ss:Type="String">Mroczna siła</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Ability name</Data></Cell></Row><Row ss:Height="30"><Cell><Data ss:Type="String">DARK_STRENGTH</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Target [abilityred]Enthralled[/ablityred] unit  gains {damageIncrease} bonus damage to all abilities for {turns}.</Data></Cell><Cell><Data ss:Type="String">Wskazana jednostka [abilityred]zniewolona[/ablityred] zyskuje {damageIncrease} pkt. dodatkowych obrażeń do wszystkich umiejętności na {turns}.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Ability description</Data></Cell></Row><Row ss:Height="30"><Cell><Data ss:Type="String">DARK_STRENGTH</Data></Cell><Cell><Data ss:Type="String">UNIT_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit has {damageIncrease} bonus damage to all abilities.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka ma {damageIncrease} pkt. dodatkowych obrażeń do wszystkich umiejętności.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Unit buff</Data></Cell></Row><Row><Cell><Data ss:Type="String">SIPHON_THRALL</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Siphon Thrall</Data></Cell><Cell><Data ss:Type="String">Pochłonięcie niewolnika</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Ability name</Data></Cell></Row><Row ss:Height="45"><Cell><Data ss:Type="String">SIPHON_THRALL</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Target [abilityred]Enthralled[/abilityred] gets {psiDamage} damage. The caster heals for {healAmount}, and gains {defenseBonus} for {turns}.</Data></Cell><Cell><Data ss:Type="String">Wskazana jednostka [abilityred]zniewolona[/abilityred] otrzymuje {psiDamage} pkt. obrażeń. Pochłaniający odzyskuje {healAmount} i otrzymuje {defenseBonus} na {turns}.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Ability description</Data></Cell></Row><Row><Cell><Data ss:Type="String">SIPHON_THRALL</Data></Cell><Cell><Data ss:Type="String">BUFF_NAME</Data></Cell><Cell><Data ss:Type="String">Thrall Siphoned</Data></Cell><Cell><Data ss:Type="String">Wyczerpany niewolnik</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Unit buff</Data></Cell></Row><Row><Cell><Data ss:Type="String">SIPHON_THRALL</Data></Cell><Cell><Data ss:Type="String">BUFF_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit has {defenseBonus}.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka ma {defenseBonus}.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Unit buff description</Data></Cell></Row><Row><Cell><Data ss:Type="String">RESUSCITATE_THRALL</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Resuscitate Thrall</Data></Cell><Cell><Data ss:Type="String">Wskrzeszenie niewolnika</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Ability name</Data></Cell></Row><Row ss:Height="30"><Cell><Data ss:Type="String">RESUSCITATE_THRALL</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Revive target dead [abilityred]Enthralled[/abilityred] unit with {healthPercentage}.</Data></Cell><Cell><Data ss:Type="String">Ożywia wskazaną martwą jednostkę [abilityred]zniewoloną[/abilityred] z {healthPercentage}.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Ability description</Data></Cell></Row><Row><Cell><Data ss:Type="String">CALL_OF_TERROR</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Call of Terror</Data></Cell><Cell><Data ss:Type="String">Zew trwogi</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Ability name</Data></Cell></Row><Row ss:Height="60"><Cell><Data ss:Type="String">CALL_OF_TERROR</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Call down a bombardment of terror on target unit. That unit and units in a {hexRad} hex radius circle around it have a {strengthchance} strength chance to be [abilityred]Panicked[/abilityred] for 2 turns. Starts on cooldown.</Data></Cell><Cell><Data ss:Type="String">Bombarduje przerażeniem wskazaną jednostkę. Ta jednostka i jednostki w promieniu {hexRad} pól wokół niej mają szansę o sile {strengthchance} na wpadnięcie w [abilityred]panikę[/abilityred] na 2 tury. Umiejętność musi się zregenerować po rozpoczęciu bitwy.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Ability description</Data></Cell></Row><Row><Cell><Data ss:Type="String">DARKVOID_PORTAL</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Voidbringers Portal</Data></Cell><Cell><Data ss:Type="String">Portal Głębicieli</Data></Cell></Row><Row ss:Height="30"><Cell><Data ss:Type="String">DARKVOID_PORTAL</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Each turn the Portal pulsess and summons forth an [abilityred]Enthralled[/abilityred] Tier I or II unit adjacent to itself.</Data></Cell><Cell><Data ss:Type="String">W każdej turze portal pulsuje i przywołuje jednostkę [abilityred]zniewolonego[/abilityred] klasy I lub II na jedno z sąsiednich pól.</Data></Cell></Row><Row ss:Height="30"><Cell><Data ss:Type="String">DARKVOID_PORTAL_SPECIAL</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Each turn the Portal pulsess and summons forth a [abilityred]Beserk[/abilityred] Voidbringer unit adjacent to itself.</Data></Cell><Cell><Data ss:Type="String">W każdej turze portal pulsuje i przywołuje jednostkę [abilityred]berserka[/abilityred] Głębicieli na jedno z sąsiednich pól.</Data></Cell></Row><Row><Cell><Data ss:Type="String">PSIONIC_DEFENSE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Psionic Form</Data></Cell><Cell><Data ss:Type="String">Forma psioniczna</Data></Cell></Row><Row ss:Height="30"><Cell><Data ss:Type="String">PSIONIC_DEFENSE</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This form of Voidbringer changes its Ethereal form to be resistant to all damage channels except Biochemical.</Data></Cell><Cell><Data ss:Type="String">Ta postać Głębiciela oznacza przemianę z formy eterycznej w odporną na wszystkie kanały obrażeń poza biochemicznymi.</Data></Cell></Row><Row><Cell><Data ss:Type="String">THERMAL_DEFENSE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Thermal Form</Data></Cell><Cell><Data ss:Type="String">Forma cieplna</Data></Cell></Row><Row ss:Height="30"><Cell><Data ss:Type="String">THERMAL_DEFENSE</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This form of Voidbringer changes its Ethereal form to be resistant to all damage channels except Arc.</Data></Cell><Cell><Data ss:Type="String">Ta postać Głębiciela oznacza przemianę z formy eterycznej w odporną na wszystkie kanały obrażeń poza elektrycznymi.</Data></Cell></Row><Row><Cell><Data ss:Type="String">ARC_DEFENSE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Arc Form</Data></Cell><Cell><Data ss:Type="String">Forma elektryczna</Data></Cell></Row><Row ss:Height="30"><Cell><Data ss:Type="String">ARC_DEFENSE</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This form of Voidbringer changes its Ethereal form to be resistant to all damage channels except Psionic.</Data></Cell><Cell><Data ss:Type="String">Ta postać Głębiciela oznacza przemianę z formy eterycznej w odporną na wszystkie kanały obrażeń poza psionicznymi.</Data></Cell></Row><Row><Cell><Data ss:Type="String">BIOCHEMICAL_DEFENSE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Biochemical Form</Data></Cell><Cell><Data ss:Type="String">Forma biochemiczna</Data></Cell></Row><Row ss:Height="90"><Cell><Data ss:Type="String">BIOCHEMICAL_DEFENSE</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This form of Voidbringer changes its Ethereal form to be resistant to all damage channels except Thermal.</Data></Cell><Cell><Data ss:Type="String">Ta forma Głębicieli zmienia swoją Eteryczna formę, aby była odporna na wszystkie kanały obrażeń oprócz cieplnymi.</Data></Cell><Cell ss:Index="6"><Data ss:Type="String">Ta forma Głębicieli zmienia swoją Eteryczna formę, aby była odporna na wszystkie kanały obrażeń oprócz cieplnymi.</Data></Cell></Row><Row ss:Height="45"><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell><Cell ss:Index="7"><Data ss:Type="String">In the text below, text refers to a person that can either be male or female. If relevant for translation, please use the ‘localized string’ column for the male text and the ‘alternative localized string’ column for the female text.</Data></Cell></Row><Row ss:Height="75"><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell><Cell ss:Index="7"><Data ss:Type="String">In the text below, any inserted strings - anything of the form {text} - is replaced by an integer value for the thing described in the brackets. If the {text} is not followed by a unit - e.g. shields, hitpoints - the icon for the unit is inserted together with the integer. The same holds for symbols - e.g. '+', '%' - which are occasionally inserted together with the integer.</Data></Cell></Row><Row ss:Height="30"><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell><Cell ss:Index="7"><Data ss:Type="String">For references to game terminology and in-world references, please check the glossary delivered as part of the documentation.</Data></Cell></Row></Table><WorksheetOptions xmlns="urn:schemas-microsoft-com:office:excel"><Print><ValidPrinterInfo/><HorizontalResolution>600</HorizontalResolution><VerticalResolution>600</VerticalResolution></Print><Selected/><TopRowVisible>33</TopRowVisible><LeftColumnVisible>2</LeftColumnVisible><Panes><Pane><Number>3</Number><ActiveRow>44</ActiveRow><ActiveCol>5</ActiveCol></Pane></Panes><ProtectObjects>False</ProtectObjects><ProtectScenarios>False</ProtectScenarios></WorksheetOptions></Worksheet></Workbook>
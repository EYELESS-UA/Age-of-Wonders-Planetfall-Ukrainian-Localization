<?xml version="1.0"?><?mso-application progid="Excel.Sheet"?><Workbook xmlns="urn:schemas-microsoft-com:office:spreadsheet" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns:ss="urn:schemas-microsoft-com:office:spreadsheet" xmlns:html="http://www.w3.org/TR/REC-html40"><DocumentProperties xmlns="urn:schemas-microsoft-com:office:office"><LastAuthor>Glenn Smits</LastAuthor><LastSaved>2020-07-02T13:33:59Z</LastSaved><Version>16.00</Version></DocumentProperties><OfficeDocumentSettings xmlns="urn:schemas-microsoft-com:office:office"><AllowPNG/></OfficeDocumentSettings><ExcelWorkbook xmlns="urn:schemas-microsoft-com:office:excel"><WindowHeight>19965</WindowHeight><WindowWidth>32767</WindowWidth><WindowTopX>32767</WindowTopX><WindowTopY>32767</WindowTopY><RefModeR1C1/><ProtectStructure>False</ProtectStructure><ProtectWindows>False</ProtectWindows></ExcelWorkbook><Styles><Style ss:ID="Default" ss:Name="Normal"><Alignment ss:Vertical="Bottom"/><Borders/><Font ss:FontName="Calibri" x:Family="Swiss" ss:Size="11" ss:Color="#000000"/><Interior/><NumberFormat/><Protection/></Style><Style ss:ID="s62"><Alignment ss:Vertical="Top" ss:WrapText="1"/></Style><Style ss:ID="s63"><Alignment ss:Vertical="Bottom" ss:WrapText="1"/></Style></Styles><Worksheet ss:Name="Script"><Table x:FullColumns="1" x:FullRows="1" ss:StyleID="s62" ss:DefaultColumnWidth="259.5" ss:DefaultRowHeight="15"><Column ss:StyleID="s62" ss:Width="184.5"/><Column ss:StyleID="s62" ss:Width="125.25"/><Column ss:Index="4" ss:StyleID="s62" ss:Width="147.75"/><Column ss:StyleID="s62" ss:AutoFitWidth="0" ss:Width="191.25"/><Column ss:StyleID="s62" ss:Width="120"/><Row ss:AutoFitHeight="0" ss:Height="105"><Cell><Data ss:Type="String">EQUIPMENT_DLC05</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">The DEV TEAM / MISC NOTES column contains info on what text between { } signs means (if applicable). It usually stands for either a numeric value, or a numeric value with an icon. Text between [ ] signs stands for a certain type of icon. </Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SCENE ID</Data></Cell><Cell><Data ss:Type="String">TEXT ID</Data></Cell><Cell><Data ss:Type="String">ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZATION NOTES</Data></Cell><Cell><Data ss:Type="String">DEV TEAM / MISC NOTES</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">VOLT_PISTOL</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Volt Pistol</Data></Cell><Cell><Data ss:Type="String">Pistolet woltowy</Data></Cell><Cell ss:Index="7" ss:StyleID="s63"><Data ss:Type="String">Relates to Sound, all abilities that have a Sono- are sound abilities.</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">VOLT_PISTOL</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Fire at target</Data></Cell><Cell><Data ss:Type="String">Strzela do celu</Data></Cell><Cell ss:Index="7" ss:StyleID="s63"/></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">VOLT_PIKE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Volt Pike</Data></Cell><Cell><Data ss:Type="String">Pika woltowa</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">VOLT_PIKE</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Provides both a melee and a ranged attack.</Data></Cell><Cell><Data ss:Type="String">Umożliwia atakowanie wręcz i na dystans.</Data></Cell><Cell ss:Index="7" ss:StyleID="s63"/></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">AUGURS_CATALYST</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Augur's Catalyst</Data></Cell><Cell><Data ss:Type="String">Katalizator augura</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">DIVINERS_THREADS</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Diviner's Threads</Data></Cell><Cell><Data ss:Type="String">Panel wróżebny</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">WATCHERS_SCROLLS</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Watcher's Scrolls</Data></Cell><Cell><Data ss:Type="String">Zwoje czujności</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">ENTROPIC_REVOLVER</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Entropic Revolver</Data></Cell><Cell><Data ss:Type="String">Rewolwer entropiczny</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">STAFF_OF_TURMOIL</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Staff of Turmoil</Data></Cell><Cell><Data ss:Type="String">Kostur zamętu</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ENTOPATHOGENIC_MYCELIA</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Entopathogenic Mycelia</Data></Cell><Cell><Data ss:Type="String">Grzybnia endopatogenna</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Entopathogenic is based on "Entomopathogenic" but made our own name.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ENTOPATHOGENIC_MYCELIA</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">All attacks have an {SingleStrength}[StrengthBio/] strength chance to cause [abilityred]Insanity[/abilityred] ({RepeatingStrength}[StrengthBio/] for repeating attacks).</Data></Cell><Cell><Data ss:Type="String">Wszystkie ataki mają szansę o sile {SingleStrength}[StrengthBio/] na wywołanie [abilityred]obłędu[/abilityred] ({RepeatingStrength}[StrengthBio/] dla ataków wielokrotnych).</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SPORULATION_FLARES</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Sporulation Flares</Data></Cell><Cell><Data ss:Type="String">Zarodnia błyskowa</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SPORULATION_FLARES</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">When damaged by an enemy, this unit triggers a flash of Bioluminescence with a {BlindStrength}[StrengthPhysical/] chance to cause [abilityred]Blinded[/abilityred] to units within {Range} hexes.</Data></Cell><Cell><Data ss:Type="String">Po uszkodzeniu przez wroga ta jednostka emituje błysk bioluminescencji z szansą o sile {BlindStrength}[StrengthPhysical/] na wywołanie [abilityred]oślepienia[/abilityred] u jednostek w odległości do {Range} pól.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Natural light such as from deep sea fish</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">GLUTTONY_ETHOS</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Gluttony Ethos</Data></Cell><Cell><Data ss:Type="String">Etos żarłoczności</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">GLUTTONY_ETHOS</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Melee attacks heal for {SingleHeal} on hit ({HealRepeating} on repeating attacks). Gives stack of [abilityblue]Glutted[/abilityblue] on success.</Data></Cell><Cell><Data ss:Type="String">Ataki wręcz przywracają {SingleHeal} w chwili trafienia ({HealRepeating} dla ataków wielokrotnych). W razie sukcesu dodaje poziom [abilityblue]obżarcia[/abilityblue].</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Glutted as in full from eating</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">INFESTED_LANCE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Infested Lance</Data></Cell><Cell><Data ss:Type="String">Zakażona lanca</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">INFESTED_LANCE</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">A lance coated in fungal flesh.</Data></Cell><Cell><Data ss:Type="String">Lanca pokryta grzybnią.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">THE_HUNGER</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">The Hunger</Data></Cell><Cell><Data ss:Type="String">Głód</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">THE_HUNGER</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Drain the enemy's mind. Create a Crystal Leech if target is killed by The Hunger.</Data></Cell><Cell><Data ss:Type="String">Osłabia umysł wroga. Jeśli głód zabije wroga, powstaje kryształowa pijawka.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SEED_SHRAPNEL</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Seed Shrapnel</Data></Cell><Cell><Data ss:Type="String">Nasiona odłamkowe</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SEED_SHRAPNEL</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Maim enemies with an exploding seed pod. Attacks have {Bleedstrength}[StrengthPhysical/] chance to cause [abilityred]Bleeding[/abilityred]</Data></Cell><Cell><Data ss:Type="String">Kaleczy wrogów za pomocą wybuchowego strąka nasiennego. Ataki mają szansę o sile {Bleedstrength}[StrengthPhysical/] na spowodowanie [abilityred]krwawienia[/abilityred].</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">BIO_INSANITY</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">{InsanityChance}[StrengthBiochemical/] strength chance to apply [abilityred]Insanity[/abilityred] to non-Mindless units for {durationInsanity}[turn/]. If resisted, apply[abilityred]Broken Mind[/abilityred] instead.</Data></Cell><Cell><Data ss:Type="String">Szansa o sile {InsanityChance}[StrengthBiochemical/] na wywołanie [abilityred]obłędu[/abilityred] u jednostek nienależących do bezmózgich na {durationInsanity}[turn/]. W razie odparcia wywołuje w zamian[abilityred]załamanie umysłowe[/abilityred].</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">_</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Insanity</Data></Cell><Cell><Data ss:Type="String">Obłęd</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell><Cell ss:Index="7"><Data ss:Type="String">In the text below, any inserted strings - anything of the form {text} - is replaced by an integer value for the thing described in the brackets. If the {text} is not followed by a unit - e.g. shields, hitpoints - the icon for the unit is inserted together with the integer. The same holds for symbols - e.g. '+', '%' - which are occasionally inserted together with the integer.</Data></Cell></Row></Table><WorksheetOptions xmlns="urn:schemas-microsoft-com:office:excel"><Unsynced/><Selected/><Panes><Pane><Number>3</Number><ActiveRow>3</ActiveRow><ActiveCol>4</ActiveCol></Pane></Panes><ProtectObjects>False</ProtectObjects><ProtectScenarios>False</ProtectScenarios></WorksheetOptions></Worksheet></Workbook>
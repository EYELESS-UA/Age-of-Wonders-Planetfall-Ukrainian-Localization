<?xml version="1.0"?><?mso-application progid="Excel.Sheet"?><Workbook xmlns="urn:schemas-microsoft-com:office:spreadsheet" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns:ss="urn:schemas-microsoft-com:office:spreadsheet" xmlns:html="http://www.w3.org/TR/REC-html40"><DocumentProperties xmlns="urn:schemas-microsoft-com:office:office"><LastAuthor>Glenn Smits</LastAuthor><LastSaved>2019-08-12T08:29:05Z</LastSaved><Version>16.00</Version></DocumentProperties><OfficeDocumentSettings xmlns="urn:schemas-microsoft-com:office:office"><AllowPNG/></OfficeDocumentSettings><ExcelWorkbook xmlns="urn:schemas-microsoft-com:office:excel"><WindowHeight>7320</WindowHeight><WindowWidth>21570</WindowWidth><WindowTopX>32767</WindowTopX><WindowTopY>32767</WindowTopY><RefModeR1C1/><ProtectStructure>False</ProtectStructure><ProtectWindows>False</ProtectWindows></ExcelWorkbook><Styles><Style ss:ID="Default" ss:Name="Normal"><Alignment ss:Vertical="Bottom"/><Borders/><Font ss:FontName="Calibri" x:Family="Swiss" ss:Size="11" ss:Color="#000000"/><Interior/><NumberFormat/><Protection/></Style><Style ss:ID="s62"><Alignment ss:Vertical="Top" ss:WrapText="1"/></Style><Style ss:ID="s63"><Alignment ss:Vertical="Top" ss:WrapText="1"/><Interior/></Style></Styles><Worksheet ss:Name="Script"><Table x:FullColumns="1" x:FullRows="1" ss:StyleID="s62" ss:DefaultColumnWidth="259.5" ss:DefaultRowHeight="15"><Column ss:StyleID="s62" ss:AutoFitWidth="0" ss:Width="147"/><Column ss:StyleID="s62" ss:Width="127.5"/><Column ss:Index="4" ss:StyleID="s62" ss:Width="147.75"/><Column ss:StyleID="s62" ss:AutoFitWidth="0" ss:Width="191.25"/><Column ss:StyleID="s62" ss:Width="120"/><Row ss:AutoFitHeight="0" ss:Height="105"><Cell><Data ss:Type="String">EQUIPMENT_DLC03</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">The DEV TEAM / MISC NOTES column contains info on what text between { } signs means (if applicable). It usually stands for either a numeric value, or a numeric value with an icon. Text between [ ] signs stands for a certain type of icon. </Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SCENE ID</Data></Cell><Cell><Data ss:Type="String">TEXT ID</Data></Cell><Cell><Data ss:Type="String">ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZATION NOTES</Data></Cell><Cell><Data ss:Type="String">DEV TEAM / MISC NOTES</Data></Cell><Cell><Data ss:Type="String">OLD TEXT</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HERALD_DAGGER</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Herald Dagger</Data></Cell><Cell><Data ss:Type="String">Sztylet zwiastuna</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HERALD_DAGGER</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Attempt to sacrifice the target.</Data></Cell><Cell><Data ss:Type="String">Próba złożenia celu w ofierze.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">RITE_OF_THE_HERALD</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Rite of the Herald</Data></Cell><Cell><Data ss:Type="String">Rytuał zwiastuna</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">RITE_OF_THE_HERALD</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">If the target is slain by this attack, the user gains the [abilityblue]Summon the Herald[/abilityblue] ability until the end of combat.</Data></Cell><Cell><Data ss:Type="String">Jeśli cel zostanie wyeliminowany tym atakiem, atakujący zyskuje umiejętność [abilityblue]przywołanie zwiastuna[/abilityblue] do końca walki.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SUMMON_THE_HERALD</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Summon the Herald</Data></Cell><Cell><Data ss:Type="String">Przywołanie zwiastuna</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">SUMMON_THE_HERALD</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Summon a [abilityred]Feeble[/abilityred] Herald of Oblivion that lasts until the end of combat.</Data></Cell><Cell><Data ss:Type="String">Przywołuje zwiastuna zapomnienia-[abilityred]słabeusza[/abilityred], który istnieje do końca walki.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">CHEMICAL_DAGGER</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Chemical Scythe</Data></Cell><Cell><Data ss:Type="String">Kosa chemiczna</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">CULLING_SCYTHE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Culler's Gaze</Data></Cell><Cell><Data ss:Type="String">Spojrzenie trzebiciela</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">REAPER_SNIPER</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Reaper Sniper</Data></Cell><Cell><Data ss:Type="String">Snajperka kosiarza</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">BODY_ODOR_DISPERSER</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Body Odor Disperser</Data></Cell><Cell><Data ss:Type="String">Rozpylacz woni ciała</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="75"><Cell><Data ss:Type="String">BODY_ODOR_DISPERSER</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Now you too can smell like the Megasow![br/]Unit gains [abilityblue]Rancid Stench[/abilityblue]: at the end of this unit's turn, adjacent enemy Biological and Cyborg ground units become [abilityred]Poisoned[/abilityred].</Data></Cell><Cell><Data ss:Type="String">Teraz i ty możesz wonieć jak megamaciora![br/]Jednostka zyskuje [abilityblue]odór zgnilizny[/abilityblue]: na koniec tury tej jednostki sąsiadujące wrogie lądowe jednostki organiczne i cyborgów zostają [abilityred]zatrute[/abilityred].</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Megasow - Is a unit, a huge mutated pig. This is related to the unit</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HEAVY_HITTER</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Heavy Hitter</Data></Cell><Cell><Data ss:Type="String">Ciężka ręka</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HEAVY_HITTER</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">A melee attack.</Data></Cell><Cell><Data ss:Type="String">Atak wręcz.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SHADOWS_EMBRACE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Shadow's Embrace</Data></Cell><Cell><Data ss:Type="String">Uścisk cienia</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSISTONE_OF_MISFORTUNE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Psi-stone of Misfortune</Data></Cell><Cell><Data ss:Type="String">Kamień psioniczny nieszczęścia</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">PSISTONE_OF_MISFORTUNE</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Gain a {FumbleChance}% Fumble chance, and summon {SummonNumber} Whispers of Discord adjacent to you that last until end of combat.</Data></Cell><Cell><Data ss:Type="String">Uzyskaj {FumbleChance}% szansę na spudłowanie i przywołaj obok siebie szepty niezgody ({SummonNumber}), które będą istnieć do końca walki.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Whispers of Discord as in the unit of the same name</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSISTONE_OF_MISFORTUNE</Data></Cell><Cell><Data ss:Type="String">PROP_NAME</Data></Cell><Cell><Data ss:Type="String">Curse of Misfortune</Data></Cell><Cell><Data ss:Type="String">Klątwa nieszczęścia</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">PSISTONE_OF_MISFORTUNE</Data></Cell><Cell><Data ss:Type="String">PROP_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit made a temporary dark deal. It has a {Fumble Chance}% increased Fumble Chance.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka zawarła tymczasowy układ z ciemnymi mocami. Jej szansa na spudłowanie jest większa o {Fumble Chance}%.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ESTEQ_SHOTGUN</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Es'Teq Shotgun</Data></Cell><Cell><Data ss:Type="String">Strzelba Es’Tequ</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ESTEQ_SHOTGUN</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Fire at a target.</Data></Cell><Cell><Data ss:Type="String">Strzela do celu.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ESTEQ_FANGS</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Es'Teq Fangs</Data></Cell><Cell><Data ss:Type="String">Kły Es’Tequ</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ESSENCE_OF_THE_DEVOURER</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Essence of the Devourer</Data></Cell><Cell><Data ss:Type="String">Esencja pożeracza</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">STAFF_OF_THE_PONTIFF</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Staff of the Pontiff</Data></Cell><Cell><Data ss:Type="String">Pastorał papieski</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FLARE_ESSENCE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Flare Essence</Data></Cell><Cell><Data ss:Type="String">Wypalenie esencji</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FLARE_ESSENCE</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">The staff flares and drains the essence of the target.</Data></Cell><Cell><Data ss:Type="String">Ten kostur podpala i wysysa esencję celu.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s63"><Data ss:Type="String">RUMBLE_PACK</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">NAME</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">Rumble Pack</Data></Cell><Cell><Data ss:Type="String">Pakiet łomotu</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s63"><Data ss:Type="String">RUMBLE_PACK</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">Get Ready to Rumble</Data></Cell><Cell><Data ss:Type="String">Uzyskaj gotowość spuszczenia łomotu</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell ss:StyleID="s63"><Data ss:Type="String">RUMBLE_PACK</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">Grants {DamageBoost} damage and one level of [abilityblue]Stagger Resistance[/abilityblue] to target friendly non-Mindless unit for {Turns}[turn/].</Data></Cell><Cell><Data ss:Type="String">Daje wskazanej przyjaznej jednostce nienależącej do bezmózgich {DamageBoost} pkt. do obrażeń i jeden poziom [abilityblue]odporności na zachwianie[/abilityblue] na {Turns}[turn/].</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s63"><Data ss:Type="String">RUMBLE_PACK</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">BUFF_NAME</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">Ready to Rumble</Data></Cell><Cell><Data ss:Type="String">Gotowość spuszczenia łomotu</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell ss:StyleID="s63"><Data ss:Type="String">RUMBLE_PACK</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">BUFF_DESCRIPTION</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">Has {DamageBoost} damage and one level of [abilityblue]Stagger Resistance[/abilityblue].</Data></Cell><Cell><Data ss:Type="String">Ma {DamageBoost} pkt. do obrażeń i jeden poziom [abilityblue]odporności na zachwianie[/abilityblue].</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s63"><Data ss:Type="String">ANTARAN_ARMOR</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">NAME</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">Antaran Armor</Data></Cell><Cell><Data ss:Type="String">Pancerz antarański</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell ss:StyleID="s63"><Data ss:Type="String">ANTARAN_ARMOR</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">Whenever damage is dealt to this unit, {DamageReflect} of the damage is reflected back to its source.</Data></Cell><Cell><Data ss:Type="String">Gdy ta jednostka otrzymuje obrażenia, odbija {DamageReflect} pkt. obrażeń ku napastnikowi.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s63"><Data ss:Type="String">PROTOTYPE_DVR_SUIT</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">NAME</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">Prototype DV-R Suit</Data></Cell><Cell><Data ss:Type="String">Prototypowy skafander DV-R</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell ss:StyleID="s63"><Data ss:Type="String">PROTOTYPE_DVR_SUIT</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Grants the wearer [abilityblue]Status Effect Immunity[/abilityblue].</Data></Cell><Cell><Data ss:Type="String">Daje noszącemu [abilityblue]niewrażliwość na efekty stanu[/abilityblue].</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PARAGON_GUARD_SPEAR</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Paragon Guard Spear</Data></Cell><Cell><Data ss:Type="String">Włócznia gwardzisty Wcielenia</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">PARAGON_GUARD_SPEAR</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">A melee attack. The user enters defense mode after attacking.</Data></Cell><Cell><Data ss:Type="String">Atak wręcz. Po ataku użytkownik przechodzi w tryb obronny.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HYDRA_HOST</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">NEKRIS Host</Data></Cell><Cell><Data ss:Type="String">Nosiciel NEKRIS-u</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">HYDRA has been renamed to NEKRIS</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">HYDRA_HOST</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit hosts NEKRIS, granting it the ability to dispel status effects from another friendly Mechanical or Cyborg unit and grant them {SpreadHydraBuff}.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka jest nosicielem NEKRIS-u, co daje jej umiejętność usuwania efektów stanu z innej przyjaznej jednostki mechanicznej lub cyborga, zapewniając im także {SpreadHydraBuff}.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">HYDRA has been renamed to NEKRIS</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SPREAD_HYDRA</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Spread NEKRIS</Data></Cell><Cell><Data ss:Type="String">Szerzenie NEKRIS-u</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">HYDRA has been renamed to NEKRIS</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">SPREAD_HYDRA</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Spread NEKRIS to a target friendly Mechanical or Cyborg unit, dispelling status effects and granting them {SpreadHydraBuff}.</Data></Cell><Cell><Data ss:Type="String">Przekazuje NEKRIS wskazanej przyjaznej jednostce mechanicznej lub cyborgowi, usuwając efekty stanu i dając jej {SpreadHydraBuff}.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">HYDRA has been renamed to NEKRIS</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HYDRA_PROXY</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">NEKRIS proxy</Data></Cell><Cell><Data ss:Type="String">Pośrednik NEKRIS-u</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">HYDRA has been renamed to NEKRIS</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">HYDRA_PROXY</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit is connected to NEKRIS, granting it {SpreadHydraBuff}.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka jest połączona z NEKRIS-em, co daje jej {SpreadHydraBuff}.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">HYDRA has been renamed to NEKRIS</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HYDRA_POSESSED</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">NEKRIS Possessed</Data></Cell><Cell><Data ss:Type="String">Opętanie NEKRIS-em</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">HYDRA_POSESSED</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit is infected by NEKRIS and under its control or its owner's control for {PosessedDuration}.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka jest zarażona NEKRIS-em i znajduje się pod jego kontrolą lub pod kontrolą właściciela NEKRIS-u na {PosessedDuration}.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ESTEQ_SNIPER</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Es'Teq Sniper</Data></Cell><Cell><Data ss:Type="String">Snajperka Es’Tequ</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ESTEQ_SNIPER</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Fire at a target.</Data></Cell><Cell><Data ss:Type="String">Strzela do celu.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SUNBRINGER</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Sunbringer</Data></Cell><Cell><Data ss:Type="String">Naświetlacz</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">SUNBRINGER</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Deals its damage to enemy units adjacent to target unit.</Data></Cell><Cell><Data ss:Type="String">Zadaje obrażenia wrogim jednostkom sąsiadującym ze wskazaną jednostką.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TYRES_GIFT</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Tyre's Gift</Data></Cell><Cell><Data ss:Type="String">Dar Tyre</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">TYRES_GIFT</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Dispel all status effects, positive or negative, from target unit. Grants an Essence Charge.</Data></Cell><Cell><Data ss:Type="String">Usuwa wszystkie efekty stanu wskazanej jednostki, pozytywne i negatywne. Daje ładunek esencji.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">DRAINING_SHOTGUN</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Draining Shotgun</Data></Cell><Cell><Data ss:Type="String">Strzelba wysysająca</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SIPHONER_STAFF</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Siphoner Staff</Data></Cell><Cell><Data ss:Type="String">Kostur pochłaniacza</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">LINK_SHARD</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Link Shard</Data></Cell><Cell><Data ss:Type="String">Odłamek łącza</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ESSENCE_LINK</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Essence Link</Data></Cell><Cell><Data ss:Type="String">Łącze esencji</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="75"><Cell><Data ss:Type="String">ESSENCE_LINK</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Target a friendly Biological, Cyborg or Mineral unit. Both units are linked together in an [abilityblue]Essence Link[/abilityblue]. While the link is active, both units gain +{shields}[shield/] plus an additional +{shieldsCharge}[shield/] for each [abilityblue][essencecharge/]Essence Charge[/abilityblue] they have.</Data></Cell><Cell><Data ss:Type="String">Wskaż przyjazną jednostkę organiczną, mineralną lub cyborga. Obie jednostki tworzą [abilityblue]łącze esencji[/abilityblue]. Podczas działania łącza obie jednostki uzyskują +{shields}[shield/] plus dodatkowe +{shieldsCharge}[shield/] za każdy posiadany przez nie [abilityblue][essencecharge/]ładunek esencji[/abilityblue].</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ESSENCE_RESTORATION</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Essence Restoration</Data></Cell><Cell><Data ss:Type="String">Odnowienie esencyjne</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">ESSENCE_RESTORATION</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Heal linked unit and self for {HPAmount}[hp/]. This breaks the [abilityblue]Essence Link[/abilityblue].</Data></Cell><Cell><Data ss:Type="String">Przywraca sobie i połączonej jednostce {HPAmount}[hp/]. Powoduje to zerwanie [abilityblue]łącza esencji[/abilityblue].</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TIME_ANOMALY_GENERATOR</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Time Anomaly Generator</Data></Cell><Cell><Data ss:Type="String">Generator anomalii czasowej</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TIME_ANOMALY_GENERATOR</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Generate Time Anomaly</Data></Cell><Cell><Data ss:Type="String">Wytworzenie anomalii czasowej</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">THE_BLACK_EGG</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">The Black Egg</Data></Cell><Cell><Data ss:Type="String">Czarne jajo</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">THE_BLACK_EGG</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Ethereal Hatching</Data></Cell><Cell><Data ss:Type="String">Eteryczny wylęg</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">THE_BLACK_EGG</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Spawn an Ethereal Penguin adjacent to the hero.</Data></Cell><Cell><Data ss:Type="String">Na polu sąsiadującym z bohaterem pojawia się eteryczny pingwin.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSITEC_VOX_AMP</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">PsiTec Vox Amp</Data></Cell><Cell><Data ss:Type="String">Wzmacniacz PsiTec</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSITEC_VOX_AMP</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Psionic Scream</Data></Cell><Cell><Data ss:Type="String">Wrzask psioniczny</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="48.75"><Cell><Data ss:Type="String">PSITEC_VOX_AMP</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Deal damage in a {range} hex cone.</Data></Cell><Cell><Data ss:Type="String">Zadaje obrażenia w stożku o wielkości {range} pól.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">BURDEN_BEARER</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">The Burden Bearer</Data></Cell><Cell><Data ss:Type="String">Nosiciel brzemienia</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">BURDEN_BEARER</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Unburden</Data></Cell><Cell><Data ss:Type="String">Odciążenie</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="61.5"><Cell><Data ss:Type="String">BURDEN_BEARER</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Dispel all negative status effects from target ally. When used, this damages the user for {selfdamage} and grants the user {essenceamount} [abilityblue]Essence Charge[/abilityblue].</Data></Cell><Cell><Data ss:Type="String">Usuwa wszystkie negatywne efekty stanu ze wskazanego sprzymierzeńca. Przy użyciu zadaje użytkownikowi {selfdamage} pkt. obrażeń i daje mu {essenceamount} [abilityblue]ładunek esencji[/abilityblue].</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">BIO_SCANNER</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Bio Scanner</Data></Cell><Cell><Data ss:Type="String">Bioskaner</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PROTO_TYRANNODON_MUSCLE_STRUCTURE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Proto-Tyrannodon Muscle Structure</Data></Cell><Cell><Data ss:Type="String">Struktura mięśniowa prototyranodona</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PROTO_TYRANNODON_MUSCLE_STRUCTURE</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Grants [abilityblue]Fast Movement Speed[/abilityblue].</Data></Cell><Cell><Data ss:Type="String">Daje [abilityblue]szybki ruch[/abilityblue].</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">GYROJET_ASSAULT_CANNON</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Gyrojet Assault Cannon</Data></Cell><Cell><Data ss:Type="String">Działko szturmowe żyrodżet</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">GYROJET_ASSAULT_CANNON</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Fire a barrage of rockets at the target.</Data></Cell><Cell><Data ss:Type="String">Ostrzał celu serią rakiet.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">MASTERCRAFTED_ARMOR</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Mastercrafted Armor</Data></Cell><Cell><Data ss:Type="String">Wyśmienity pancerz</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">MASTERCRAFTED_ARMOR</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Grants [abilityblue]Defense Mode: Hyper Armor[/abilityblue].</Data></Cell><Cell><Data ss:Type="String">Daje [abilityblue]tryb obronny – hiperpancerz[/abilityblue].</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">GAUNTLET_OF_EMPIRES</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Gauntlet of Empires</Data></Cell><Cell><Data ss:Type="String">Rękawica imperiów</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">GAUNTLET_OF_EMPIRES</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Grants the wearer [abilityblue]Unmake[/abilityblue].</Data></Cell><Cell><Data ss:Type="String">Daje noszącemu [abilityblue]unicestwienie[/abilityblue].</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">GAUNTLET_OF_EMPIRES</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Smash an enemy with the Gauntlet of Empires.</Data></Cell><Cell><Data ss:Type="String">Uderza wroga rękawicą imperiów.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">GAUNTLET_OF_EMPIRES</Data></Cell><Cell><Data ss:Type="String">UNMAKE_ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Unmake</Data></Cell><Cell><Data ss:Type="String">Unicestwienie</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">GAUNTLET_OF_EMPIRES</Data></Cell><Cell><Data ss:Type="String">UNMAKE_ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Deals damage to all enemy non-Flying, non-Floating units, as well as all obstacles.</Data></Cell><Cell><Data ss:Type="String">Zadaje obrażenia wszystkim wrogim jednostkom nielatającym i nieunoszącym się, a ponadto powoduje uszkodzenia przeszkód.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">THADEUS_MEMORY</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Thadeus' Memory</Data></Cell><Cell><Data ss:Type="String">Wspomnienia Thadeusa</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">THADEUS_MEMORY</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Fire bullets infused with Thadeus' scarred memories.</Data></Cell><Cell><Data ss:Type="String">Strzela pociskami, które nasycono bolesnymi wspomnieniami Thadeusa.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">CORE_PROJECTION_RELAY</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">CORE Projection Relay</Data></Cell><Cell><Data ss:Type="String">Przekaźnik projekcji ŚWIAT-a</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="48"><Cell><Data ss:Type="String">CORE_PROJECTION_RELAY</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Operation strength is increased by {opstrengthincrease} on operations that target sectors with this hero in them. Grants 'Initialize Connections'.</Data></Cell><Cell><Data ss:Type="String">Siła operacyjna zwiększona o {opstrengthincrease} podczas operacji na sektorach, na których znajduje się ten bohater. Daje inicjalizację łącza.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TIME_ANOMALY_GENERATOR</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Generate a time anomaly, giving target friendly units [abilityblue]Fast Movement[/abilityblue] and target enemy units [abilityred]Slow Movement[/abilityred] for {Duration}[turn/]</Data></Cell><Cell><Data ss:Type="String">Tworzy anomalię czasową, dającą wskazanym przyjaznym jednostkom [abilityblue]szybki ruch[/abilityblue] i powodującą [abilityred]spowolnienie[/abilityred] wskazanych jednostek wroga na {Duration}[turn/].</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">BIO_SCANNER</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">A biomancer's scanner. Grants the 'Scan: Catalogue' ability.</Data></Cell><Cell><Data ss:Type="String">Skaner biomantki. Daje umiejętność „Skanowanie – katalog”.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HEARTBREAK_PISTOL</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Heartbreaker Handgun</Data></Cell><Cell><Data ss:Type="String">Pistolet łamacza serc</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HEARTBREAK_PISTOL</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Fire 2 bullets at an enemy.</Data></Cell><Cell><Data ss:Type="String">Strzela we wroga dwiema kulami.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HEARTBREAK_PISTOL</Data></Cell><Cell><Data ss:Type="String">MOD_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">{strengthChance} strength chance to apply [abilityred]Distracted[/abilityred] for {turns}.</Data></Cell><Cell><Data ss:Type="String">Próba spowodowania [abilityred]rozproszenia[/abilityred] (szansa {strengthChance}) na {turns}.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HOLLOW_ESSENCE_ARK</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Hollow Essence Ark</Data></Cell><Cell><Data ss:Type="String">Pusta Arka Esencji</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HOLLOW_ESSENCE_ARK</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Grants [abilityblue]Resurgence[/abilityblue] and revives the hero with {reviveHP} after {turns} in tactical combat.[br/][br/][firecol]A unit can only revive itself once per battle.[/firecol]</Data></Cell><Cell><Data ss:Type="String">Daje [abilityblue]odrodzenie[/abilityblue] i ożywia bohatera z {reviveHP} po {turns} walki taktycznej.[br/][br/][firecol]Jest to możliwe tylko raz na bitwę.[/firecol]</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HOLLOW_ESSENCE_ARK</Data></Cell><Cell><Data ss:Type="String">UNDYING_ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Undying</Data></Cell><Cell><Data ss:Type="String">Bezśmierć</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HOLLOW_ESSENCE_ARK</Data></Cell><Cell><Data ss:Type="String">UNDYING_ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">When killed in tactical combat, the hero will resurrect with {hp} after {turntimer}.[br/][br/][firecol]A unit can only revive itself once per battle.[/firecol]</Data></Cell><Cell><Data ss:Type="String">Jeśli ten bohater zginie w walce taktycznej, to po {turntimer} turach wróci do życia z {hp}.[br/][br/][firecol]Jest to możliwe tylko raz na bitwę.[/firecol]</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ESSENCE_ARK</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Essence Ark</Data></Cell><Cell><Data ss:Type="String">Arka Esencji</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ESSENCE_ARK</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Open the Ark</Data></Cell><Cell><Data ss:Type="String">Otwórz Arkę</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ESSENCE_ARK</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Spawn a Drained unit adjacent to the hero.</Data></Cell><Cell><Data ss:Type="String">Na polu sąsiadującym z bohaterem pojawia się wyzyskany.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">EDICT_INTERDICTA</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Edict Interdicta</Data></Cell><Cell><Data ss:Type="String">Edykt interdyktu</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">EDICT_INTERDICTA</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Edict of Interdiction</Data></Cell><Cell><Data ss:Type="String">Edykt zakazu</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">EDICT_INTERDICTA</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Enemy units in the target area have a {PsiStr}[strengthpsyche/] chance to become Pacified, disabling them from using abilities for {duration}[turn/]</Data></Cell><Cell><Data ss:Type="String">Jednostki wroga na wskazanym obszarze mają szansę ({PsiStr}[strengthpsyche/]) na stanie się ujarzmionymi, co uniemożliwi im używanie umiejętności przez {duration}[turn/]</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ROCKET_ASSAULT_RIFLE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Rocket Assault Cannon</Data></Cell><Cell><Data ss:Type="String">Rakietowe działko szturmowe</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ROCKET_ASSAULT_RIFLE</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Fire the Rocket Assault Cannon.</Data></Cell><Cell><Data ss:Type="String">Strzał z rakietowego działka szturmowego.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ESSENCE_LINK</Data></Cell><Cell><Data ss:Type="String">PROPERTY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">While the link is active, both units gain +{shields}[shield/] plus an additional +{shieldsCharge}[shield/] for each [abilityblue][essencecharge/]Essence Charge[/abilityblue] they have.</Data></Cell><Cell><Data ss:Type="String">Podczas działania łącza obie jednostki uzyskują +{shields}[shield/] oraz dodatkowe +{shieldsCharge}[shield/] za każdy posiadany przez nie [abilityblue][essencecharge/]ładunek esencji[/abilityblue].</Data></Cell></Row><Row><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell><Cell ss:Index="7"><Data ss:Type="String">In the text below, any inserted strings - anything of the form {text} - is replaced by an integer value for the thing described in the brackets. If the {text} is not followed by a unit - e.g. shields, hitpoints - the icon for the unit is inserted together with the integer. The same holds for symbols - e.g. '+', '%' - which are occasionally inserted together with the integer.</Data></Cell></Row><Row><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell></Row><Row><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell></Row><Row><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell></Row><Row><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell></Row><Row><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell></Row><Row><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell></Row></Table><WorksheetOptions xmlns="urn:schemas-microsoft-com:office:excel"><Unsynced/><Selected/><TopRowVisible>72</TopRowVisible><Panes><Pane><Number>3</Number><ActiveRow>88</ActiveRow><ActiveCol>2</ActiveCol></Pane></Panes><ProtectObjects>False</ProtectObjects><ProtectScenarios>False</ProtectScenarios></WorksheetOptions></Worksheet></Workbook>
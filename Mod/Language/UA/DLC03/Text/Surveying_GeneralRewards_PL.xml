<?xml version="1.0"?><?mso-application progid="Excel.Sheet"?><Workbook xmlns="urn:schemas-microsoft-com:office:spreadsheet" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns:ss="urn:schemas-microsoft-com:office:spreadsheet" xmlns:html="http://www.w3.org/TR/REC-html40"><DocumentProperties xmlns="urn:schemas-microsoft-com:office:office"><Author>Tom Bird</Author><LastAuthor>Glenn Smits</LastAuthor><Created>2019-05-07T15:06:48Z</Created><LastSaved>2019-08-14T13:18:21Z</LastSaved><Version>16.00</Version></DocumentProperties><OfficeDocumentSettings xmlns="urn:schemas-microsoft-com:office:office"><AllowPNG/></OfficeDocumentSettings><ExcelWorkbook xmlns="urn:schemas-microsoft-com:office:excel"><WindowHeight>9750</WindowHeight><WindowWidth>13170</WindowWidth><WindowTopX>32767</WindowTopX><WindowTopY>32767</WindowTopY><ProtectStructure>False</ProtectStructure><ProtectWindows>False</ProtectWindows></ExcelWorkbook><Styles><Style ss:ID="Default" ss:Name="Normal"><Alignment ss:Vertical="Bottom"/><Borders/><Font ss:FontName="Calibri" x:Family="Swiss" ss:Size="11" ss:Color="#000000"/><Interior/><NumberFormat/><Protection/></Style><Style ss:ID="s62"><Alignment ss:Vertical="Bottom" ss:WrapText="1"/></Style><Style ss:ID="s63"><Alignment ss:Vertical="Bottom" ss:WrapText="1"/><Interior/></Style></Styles><Worksheet ss:Name="Script"><Table x:FullColumns="1" x:FullRows="1" ss:DefaultColumnWidth="51.75" ss:DefaultRowHeight="15"><Column ss:AutoFitWidth="0" ss:Width="207.75"/><Column ss:AutoFitWidth="0" ss:Width="251.25"/><Column ss:StyleID="s62" ss:AutoFitWidth="0" ss:Width="317.25"/><Column ss:Width="147.75"/><Column ss:StyleID="s62" ss:Width="262.5"/><Column ss:StyleID="s62" ss:Width="120"/><Row ss:AutoFitHeight="0" ss:Height="75"><Cell ss:StyleID="s62"><Data ss:Type="String">SURVEYING_GENERALREWARDS</Data></Cell><Cell ss:StyleID="s62"/><Cell ss:Index="4" ss:StyleID="s62"/><Cell ss:Index="7"><Data ss:Type="String">The DEV TEAM / MISC NOTES column contains info on what text between { } signs means (if applicable). It usually stands for either a numeric value, or a numeric value with an icon. Text between [ ] signs stands for a certain type of icon. </Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s62"><Data ss:Type="String">SCENE ID</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">TEXT ID</Data></Cell><Cell><Data ss:Type="String">ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZATION NOTES</Data></Cell><Cell><Data ss:Type="String">DEV TEAM / MISC NOTES</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="60"><Cell><Data ss:Type="String">PARAGON_ELITE_UNIT</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Paragon Elite</Data></Cell><Cell><Data ss:Type="String">Elita Wcielenia</Data></Cell><Cell ss:Index="8" ss:StyleID="s63"/></Row><Row ss:AutoFitHeight="0" ss:Height="60"><Cell><Data ss:Type="String">PARAGON_ELITE_UNIT</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Paragon Elites were among the most feared members of the vast Star Union military, ruthlessly effective and dedicated to their task, with equipment to match their status as the best of the best.</Data></Cell><Cell><Data ss:Type="String">Elitarne oddziały Wcielenia należały do budzących największy postrach żołnierzy wielkiej armii Związku Gwiezdnego. Były bezlitośnie skuteczne i skoncentrowane na swoim zadaniu, i dysponowały sprzętem odpowiednim dla najlepszych z najlepszych.</Data></Cell><Cell ss:Index="8" ss:StyleID="s63"/></Row><Row ss:AutoFitHeight="0" ss:Height="60"><Cell><Data ss:Type="String">PARAGON_ELITE_SNIPER_UNIT</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Paragon Elite Sniper</Data></Cell><Cell><Data ss:Type="String">Elitarny snajper Wcielenia</Data></Cell><Cell ss:Index="8" ss:StyleID="s63"/></Row><Row ss:AutoFitHeight="0" ss:Height="51"><Cell><Data ss:Type="String">PARAGON_ELITE_SNIPER_UNIT</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Paragon Elites were among the most feared members of the vast Star Union military, ruthlessly effective and dedicated to their task, with equipment to match their status as the best of the best.</Data></Cell><Cell><Data ss:Type="String">Elitarne oddziały Wcielenia należały do budzących największy postrach żołnierzy wielkiej armii Związku Gwiezdnego. Były bezlitośnie skuteczne i skoncentrowane na swoim zadaniu, i dysponowały sprzętem odpowiednim dla najlepszych z najlepszych.</Data></Cell><Cell ss:Index="8" ss:StyleID="s63"/></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">TIME_ANOMALY_SECTOR_PROPERTY</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Time Anomaly</Data></Cell><Cell><Data ss:Type="String">Anomalia czasowa</Data></Cell><Cell ss:Index="8" ss:StyleID="s63"/></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">TIME_ANOMALY_SECTOR_PROPERTY</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">The time anomaly present in this sector grants {research}.</Data></Cell><Cell><Data ss:Type="String">W tym sektorze występuje anomalia czasowa, dająca {research}.</Data></Cell><Cell ss:Index="8" ss:StyleID="s63"/></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">ANCESTRAL_HIDDEN</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Ancestral Hidden</Data></Cell><Cell><Data ss:Type="String">Ukryty pradawny</Data></Cell><Cell ss:Index="8" ss:StyleID="s63"/></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">DRAGONFLY_ACE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Dragonfly Ace</Data></Cell><Cell><Data ss:Type="String">Superważka</Data></Cell><Cell ss:Index="8" ss:StyleID="s63"/></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">ETHEREAL_PENGUIN</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Ethereal Penguin</Data></Cell><Cell><Data ss:Type="String">Eteryczny pingwin</Data></Cell><Cell ss:Index="8" ss:StyleID="s63"/></Row><Row ss:AutoFitHeight="0" ss:Height="50.25"><Cell><Data ss:Type="String">SPARK_DROID</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Spark Droid</Data></Cell><Cell><Data ss:Type="String">Droid zapłonowy</Data></Cell><Cell ss:Index="8" ss:StyleID="s63"/></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">SPARK_DROID</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">A modified Plasmoid frame with a built in Arc Retaliation module and armed with an Arc Taser.</Data></Cell><Cell><Data ss:Type="String">Zmodyfikowany korpus plazmoida z wbudowanym modułem odwetu elektrostatycznego, uzbrojony w paralizator elektryczny.</Data></Cell><Cell ss:Index="8" ss:StyleID="s63"/></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">PROTO_TYRANNODON_MUSCLE_STRUCTURE</Data></Cell><Cell><Data ss:Type="String">PROPERTY_UNLOCK</Data></Cell><Cell><Data ss:Type="String">Unlocks the ability to mod units with Proto-Tyrannodon Muscle Structure.</Data></Cell><Cell><Data ss:Type="String">Odblokowuje możliwość modyfikowania jednostek o strukturze mięśniowej prototyranodona.</Data></Cell><Cell ss:Index="8" ss:StyleID="s63"/></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">MASTERCRAFTED_ARMOR</Data></Cell><Cell><Data ss:Type="String">PROPERTY_UNLOCK</Data></Cell><Cell><Data ss:Type="String">Unlocks the ability to mod units with Mastercrafted Armor.</Data></Cell><Cell><Data ss:Type="String">Odblokowuje możliwość modyfikowania jednostek z wyśmienitym pancerzem.</Data></Cell><Cell ss:Index="8" ss:StyleID="s63"/></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">XENNODON</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Xennodon</Data></Cell><Cell><Data ss:Type="String">Ksenodon</Data></Cell><Cell ss:Index="8" ss:StyleID="s63"/></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">XENNODON</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">An ancient Tyrannodon carcass infested with the Alpha Strain.</Data></Cell><Cell><Data ss:Type="String">Trup pradawnego tyranodona, zakażony szczepem Alfa.</Data></Cell><Cell ss:Index="8" ss:StyleID="s63"/></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">TYRES_TOMB</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Tyre's Tomb</Data></Cell><Cell><Data ss:Type="String">Grobowiec Tyre’a</Data></Cell><Cell ss:Index="8" ss:StyleID="s63"/></Row><Row ss:AutoFitHeight="0" ss:Height="81"><Cell><Data ss:Type="String">TYRES_TOMB</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">The excavated tomb of Oreus Tyre.</Data></Cell><Cell><Data ss:Type="String">Odkopany grobowiec Oreusa Tyre’a.</Data></Cell><Cell ss:Index="8" ss:StyleID="s63"/></Row><Row ss:AutoFitHeight="0" ss:Height="91.5"><Cell><Data ss:Type="String">TYRES_TOMB</Data></Cell><Cell><Data ss:Type="String">LOGIC_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This landmark is an advanced energy sector, and gives the following when annexed:[br/]{EnergyFlat}, {EnergySlot}[br/]{ResearchFlat}, {ResearchSlot}[br/][br/]Additionally, it unlocks the following building in your colony: [hyperlink,000003E4000002B0]Crystal Altar[/hyperlink][br/][br/]It also unlocks the production of Purified Golem units in the colony this landmark is annexed to.</Data></Cell><Cell><Data ss:Type="String">To miejsce charakterystyczne jest zaawansowanym sektorem energetycznym i po przyłączeniu daje następujące korzyści:[br/]{EnergyFlat}, {EnergySlot}[br/]{ResearchFlat}, {ResearchSlot}[br/][br/]Dodatkowo odblokowuje w kolonii następujący budynek: [hyperlink,000003BD00000304]kryształowy ołtarz[/hyperlink].[br/][br/]Ponadto umożliwia wytwarzanie jednostek oczyszczonych golemów w kolonii, do której to miejsce jest przyłączone.</Data></Cell><Cell ss:Index="8" ss:StyleID="s63"/></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">MODIFIED_AIVA</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Modified A.I.V.A.</Data></Cell><Cell><Data ss:Type="String">Zmodyfikowana ASIA</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">MODIFIED_AIVA</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Integrating the Valentine A.I.V.A. unit into our energy grid management could significantly increase the efficiency of our energy networks. [energy/] slots produce {energyIncrease} per colonist working it. Additionally, units are now {costReduction} cheaper to produce.</Data></Cell><Cell><Data ss:Type="String">Zintegrowanie SI ASIA Valentine’ów z naszą siecią energetyczną mogłoby znacznie zwiększyć wydajność produkcji energii. Miejsca [energy/] wytwarzają {energyIncrease} na każdego pracującego w nich kolonistę. Dodatkowo wytwarzanie jednostek jest teraz tańsze o {costReduction}.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">AIVA_3</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">A.I.V.A. -3</Data></Cell><Cell><Data ss:Type="String">ASIA-3</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">AIVA_3</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">A modified E-bot. The frame once served one of the maids of the Valentine household. It has been repurposed by the Valentine's A.I.V.A. as a mainframe and support combat unit.</Data></Cell><Cell><Data ss:Type="String">Zmodyfikowany E-bot. Korpus służył kiedyś jako jedna z pokojówek w domu Valentine’ów. ASIA Valentine’ów przerobiła go na główny komputer, a równocześnie pomocniczą jednostkę bojową.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SHADOW_TROOPER</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Shadow Trooper</Data></Cell><Cell><Data ss:Type="String">Zamaskowany szturmowiec</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">DREAMER_CULTIST</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Dreamer Cultist</Data></Cell><Cell><Data ss:Type="String">Kultysta śniących</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">DREAM_FRAGMENTS_SECTOR_PROPERTY</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Dream Fragments</Data></Cell><Cell><Data ss:Type="String">Fragmenty snu</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">DREAM_FRAGMENTS_SECTOR_PROPERTY</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">The dream fragments littered about this sector grant {researchIncome}.</Data></Cell><Cell><Data ss:Type="String">Fragmenty snu rozsypane po tym sektorze zapewniają {researchIncome}.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">CONSECRATED_SECTOR_PROPERTY</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Consecrated</Data></Cell><Cell><Data ss:Type="String">Uświęcona</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">CONSECRATED_SECTOR_PROPERTY</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">These hallowed grounds grant {happinessIncome}.</Data></Cell><Cell><Data ss:Type="String">Ta święta ziemia zapewnia {happinessIncome}.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">CULT_OF_DREAMS</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Cult of Dreams</Data></Cell><Cell><Data ss:Type="String">Kult Snów</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">CULT_OF_DREAMS</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Allows the Dreamer Cultist to be produced in any colony.</Data></Cell><Cell><Data ss:Type="String">Umożliwia wytwarzanie kultystów śniących w dowolnej kolonii.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">VALER-E</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Valer-E</Data></Cell><Cell><Data ss:Type="String">Valer-E</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">VALER-E</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">"…or else."</Data></Cell><Cell><Data ss:Type="String">„…bo inaczej”.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">WILL-EM</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Will-EM</Data></Cell><Cell><Data ss:Type="String">Will-EM</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">WILL-EM</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">"She said yes..."</Data></Cell><Cell><Data ss:Type="String">„Zgodziła się...”</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ARCHITECTS_TOUCH</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Architect's Touch</Data></Cell><Cell><Data ss:Type="String">Dotyk Architekta</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ARCHITECTS_TOUCH</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">The Architect's  masterful expertise allows us to produce Mechanical and Cyborg units of unmatched quality. Mechanical and Cyborg units produced in our colonies gain {Hpbonus}[HP/] and {DEFENSEBONUS}[armor/].</Data></Cell><Cell><Data ss:Type="String">Mistrzowski kunszt Architekta umożliwia nam wytwarzanie jednostek mechanicznych i cyborgów niezrównanej jakości. Jednostki mechaniczne i cyborgi wytwarzane w naszych koloniach zyskują {Hpbonus}[HP/] i {DEFENSEBONUS}[armor/].</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ARCHITECTS_TOUCH</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit is touched by the Architect, making it of exceptional quality. This unit has {Hpbonus}[HP/] and {DEFENSEBONUS}[armor/].</Data></Cell><Cell><Data ss:Type="String">Ta jednostka niesie ślad ręki Architekta, dzięki czemu ma wyjątkową jakość. Ma {Hpbonus}[HP/] i {DEFENSEBONUS}[armor/].</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">BLESSING_OF_THE_BURNING_EMPEROR</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Blessing of the Burning Emperor</Data></Cell><Cell><Data ss:Type="String">Błogosławieństwo płonącego cesarza</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">BLESSING_OF_THE_BURNING_EMPEROR</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">The proclamation by the image of Emperor Khansu has given our people renewed fervour for extreme solutions. Doomsday structures are {discount} cheaper to produce.</Data></Cell><Cell><Data ss:Type="String">Proklamacja wygłoszona przez wizerunek cesarza Khansu odnowiła zapał naszych ludzi do stosowania ekstremalnych rozwiązań. Wznoszenie budowli zatraty jest tańsze o {discount}.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">THE_HAND_THAT_GIVES</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">The Hand that gives</Data></Cell><Cell><Data ss:Type="String">Ręka, która daje</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">THE_HAND_THAT_GIVES</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">An ancient Guardian, representing the Hand of Artok that gives.</Data></Cell><Cell><Data ss:Type="String">Starożytny strażnik, reprezentujący rękę Artoka, która daje.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">THE_HAND_THAT_TAKES</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">The Hand that takes</Data></Cell><Cell><Data ss:Type="String">Ręka, która odbiera</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">THE_HAND_THAT_TAKES</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">An ancient Guardian, representing the Hand of Artok that takes.</Data></Cell><Cell><Data ss:Type="String">Starożytny strażnik, reprezentujący rękę Artoka, która odbiera.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">THE_DVAR_FORGE_CITY</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">The Dvar Forge City</Data></Cell><Cell><Data ss:Type="String">Miasto-kuźnia Dvarów</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">THE_DVAR_FORGE_CITY</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">The excavated Dvar Forge City.</Data></Cell><Cell><Data ss:Type="String">Odkopane miasto-kuźnia Dvarów.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">THE_DVAR_FORGE_CITY</Data></Cell><Cell><Data ss:Type="String">LOGIC_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This landmark is an advanced production sector, and gives the following when annexed:[br/]{ProductionFlat}, {ProductionSlot}[br/]{EnergyFlat}, {EnergySlot}.</Data></Cell><Cell><Data ss:Type="String">To miejsce charakterystyczne jest zaawansowanym sektorem produkcyjnym i po przyłączeniu daje następujące korzyści:[br/]{ProductionFlat}, {ProductionSlot}[br/]{EnergyFlat}, {EnergySlot}.</Data></Cell></Row></Table><WorksheetOptions xmlns="urn:schemas-microsoft-com:office:excel"><Unsynced/><Print><ValidPrinterInfo/><HorizontalResolution>600</HorizontalResolution><VerticalResolution>600</VerticalResolution></Print><Selected/><TopRowVisible>9</TopRowVisible><Panes><Pane><Number>3</Number><ActiveRow>19</ActiveRow><ActiveCol>3</ActiveCol></Pane></Panes><ProtectObjects>False</ProtectObjects><ProtectScenarios>False</ProtectScenarios></WorksheetOptions></Worksheet></Workbook>
<?xml version="1.0"?><?mso-application progid="Excel.Sheet"?><Workbook xmlns="urn:schemas-microsoft-com:office:spreadsheet" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns:ss="urn:schemas-microsoft-com:office:spreadsheet" xmlns:html="http://www.w3.org/TR/REC-html40"><DocumentProperties xmlns="urn:schemas-microsoft-com:office:office"><LastAuthor>Glenn Smits</LastAuthor><LastSaved>2019-09-27T14:42:14Z</LastSaved><Version>16.00</Version></DocumentProperties><OfficeDocumentSettings xmlns="urn:schemas-microsoft-com:office:office"><AllowPNG/></OfficeDocumentSettings><ExcelWorkbook xmlns="urn:schemas-microsoft-com:office:excel"><WindowHeight>7620</WindowHeight><WindowWidth>21570</WindowWidth><WindowTopX>32767</WindowTopX><WindowTopY>32767</WindowTopY><RefModeR1C1/><ProtectStructure>False</ProtectStructure><ProtectWindows>False</ProtectWindows></ExcelWorkbook><Styles><Style ss:ID="Default" ss:Name="Normal"><Alignment ss:Vertical="Bottom"/><Borders/><Font ss:FontName="Calibri" x:Family="Swiss" ss:Size="11" ss:Color="#000000"/><Interior/><NumberFormat/><Protection/></Style><Style ss:ID="s62"><Alignment ss:Vertical="Bottom" ss:WrapText="1"/></Style><Style ss:ID="s63"><Alignment ss:Vertical="Top" ss:WrapText="1"/></Style><Style ss:ID="s64"><Alignment ss:Vertical="Bottom" ss:WrapText="1"/><Interior/></Style></Styles><Worksheet ss:Name="Script"><Table x:FullColumns="1" x:FullRows="1" ss:DefaultRowHeight="15"><Column ss:AutoFitWidth="0" ss:Width="186"/><Column ss:AutoFitWidth="0" ss:Width="147.75"/><Column ss:AutoFitWidth="0" ss:Width="507.75"/><Column ss:Width="147.75"/><Column ss:StyleID="s62" ss:Width="262.5"/><Column ss:StyleID="s62" ss:Width="120"/><Row ss:AutoFitHeight="0" ss:Height="75"><Cell><Data ss:Type="String">ENDLESS_TECHGROUPS_DLC03</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">The DEV TEAM / MISC NOTES column contains info on what text between { } signs means (if applicable). It usually stands for either a numeric value, or a numeric value with an icon. Text between [ ] signs stands for a certain type of icon. </Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SCENE ID</Data></Cell><Cell><Data ss:Type="String">TEXT ID</Data></Cell><Cell><Data ss:Type="String">ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZATION NOTES</Data></Cell><Cell><Data ss:Type="String">DEV TEAM / MISC NOTES</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s63"><Data ss:Type="String">ADVANCED_ESSENCE_CATALYSTS</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">NAME</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">Advanced Essence Catalysts</Data></Cell><Cell><Data ss:Type="String">Zaawansowane katalizatory esencji</Data></Cell><Cell ss:Index="8" ss:StyleID="s64"/></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s63"><Data ss:Type="String">ADVANCED_ESSENCE_CATALYSTS</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">SUBSKILL_NAME</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">Essence Sequencer</Data></Cell><Cell><Data ss:Type="String">Sekwencer esencji</Data></Cell><Cell ss:Index="8" ss:StyleID="s64"/></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell ss:StyleID="s63"><Data ss:Type="String">ADVANCED_ESSENCE_CATALYSTS</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">Accidental Breakthrough! By making a mobile sequencer that forms essence at a local level, all our units gain an Essence Charge at the start of battle!</Data></Cell><Cell><Data ss:Type="String">Przypadkowy przełom! Dzięki zbudowaniu przenośnego sekwencera, który wytwarza esencję na poziomie lokalnym, wszystkie nasze jednostki zyskują ładunek esencji na początku bitwy!</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Essence Charge is a term found in the DLC03 Heritor Secret Tech.</Data></Cell><Cell ss:StyleID="s64"/></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s63"><Data ss:Type="String">ADVANCED_ESSENCE_CATALYSTS</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">SUBSKILL_DESCRIPTION</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">All units you control gain an [abilityblue]Essence Charge[/abilityblue] at the start of combat.</Data></Cell><Cell><Data ss:Type="String">Wszystkie jednostki, które kontrolujesz, zyskują [abilityblue]ładunek esencji[/abilityblue] na początku walki.</Data></Cell><Cell ss:Index="8" ss:StyleID="s64"/></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s63"><Data ss:Type="String">FELINE_CHORUS</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">NAME</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">Feline Chorus</Data></Cell><Cell><Data ss:Type="String">Koci chór</Data></Cell><Cell ss:Index="8" ss:StyleID="s64"/></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell ss:StyleID="s63"><Data ss:Type="String">FELINE_CHORUS</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Accidental Breakthrough! One of our scientists brought their cat to work while working on psionic waves attuned to the suffering of living beings and accidentally created a Psynumbra monster!</Data></Cell><Cell><Data ss:Type="String">Przypadkowy przełom! Jeden z naszych naukowców przyniósł swojego kota do pracy w trakcie projektu badania wywoływania przez fale psioniczne cierpienia u istot żywych i mimowolnie stworzył potwora Psynumbra!</Data></Cell><Cell ss:Index="8" ss:StyleID="s64"/></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s63"><Data ss:Type="String">FELINE_CHORUS</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">SUBSKILL_NAME</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Feline Psytherapy</Data></Cell><Cell><Data ss:Type="String">Kocia psyterapia</Data></Cell><Cell ss:Index="8" ss:StyleID="s64"/></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s63"><Data ss:Type="String">FELINE_CHORUS</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">SUBSKILL_DESCRIPTION</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Allows the production of Misfortune units in our colonies.</Data></Cell><Cell><Data ss:Type="String">Umożliwia tworzenie jednostek nieszczęścia w naszych koloniach.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Misfortune is a wildlife unit.</Data></Cell><Cell ss:StyleID="s64"/></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s63"><Data ss:Type="String">FELINE_CHORUS</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">SUBSKILL_NAME_2</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Cruel Attunement</Data></Cell><Cell><Data ss:Type="String">Okrutne dostrojenie</Data></Cell><Cell ss:Index="8" ss:StyleID="s64"/></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell ss:StyleID="s63"><Data ss:Type="String">FELINE_CHORUS</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">SUBSKILL_DESCRIPTION_2</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">All Animal, Ethereal, Mineral and Plant units you control gain [abilityblue]Sadism[/abilityblue], increasing damage against units with low morale.</Data></Cell><Cell><Data ss:Type="String">Wszystkie jednostki zwierzęce, eteryczne, mineralne i roślinne, które kontrolujesz, zyskują [abilityblue]sadyzm[/abilityblue], co zwiększa ilość obrażeń zadawanych jednostkom o niskim morale.</Data></Cell><Cell ss:Index="8" ss:StyleID="s64"/></Row></Table><WorksheetOptions xmlns="urn:schemas-microsoft-com:office:excel"><Unsynced/><Print><ValidPrinterInfo/><HorizontalResolution>600</HorizontalResolution><VerticalResolution>600</VerticalResolution></Print><Selected/><Panes><Pane><Number>3</Number><ActiveRow>10</ActiveRow><ActiveCol>4</ActiveCol></Pane></Panes><ProtectObjects>False</ProtectObjects><ProtectScenarios>False</ProtectScenarios></WorksheetOptions></Worksheet></Workbook>
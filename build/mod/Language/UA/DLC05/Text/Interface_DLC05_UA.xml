<?xml version="1.0"?><?mso-application progid="Excel.Sheet"?><Workbook xmlns="urn:schemas-microsoft-com:office:spreadsheet" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns:ss="urn:schemas-microsoft-com:office:spreadsheet" xmlns:html="http://www.w3.org/TR/REC-html40"><DocumentProperties xmlns="urn:schemas-microsoft-com:office:office"><Author>GameScribes4</Author><LastAuthor>GameScribes4</LastAuthor><Created>2020-10-07T23:49:47Z</Created><LastSaved>2020-06-19T14:25:59Z</LastSaved><Version>16.00</Version></DocumentProperties><OfficeDocumentSettings xmlns="urn:schemas-microsoft-com:office:office"><AllowPNG/></OfficeDocumentSettings><ExcelWorkbook xmlns="urn:schemas-microsoft-com:office:excel"><WindowHeight>7305</WindowHeight><WindowWidth>21420</WindowWidth><WindowTopX>32767</WindowTopX><WindowTopY>32767</WindowTopY><RefModeR1C1/><ProtectStructure>False</ProtectStructure><ProtectWindows>False</ProtectWindows></ExcelWorkbook><Styles><Style ss:ID="Default" ss:Name="Normal"><Alignment ss:Vertical="Bottom"/><Borders/><Font ss:FontName="Calibri" x:Family="Swiss" ss:Size="11" ss:Color="#000000"/><Interior/><NumberFormat/><Protection/></Style><Style ss:ID="s62"><Alignment ss:Vertical="Top" ss:WrapText="1"/></Style><Style ss:ID="s63"><Alignment ss:Vertical="Top"/></Style></Styles><Worksheet ss:Name="Script"><Table x:FullColumns="1" x:FullRows="1" ss:StyleID="s62" ss:DefaultColumnWidth="156" ss:DefaultRowHeight="15"><Column ss:StyleID="s62" ss:Width="147"/><Column ss:StyleID="s62" ss:Width="143.25"/><Column ss:StyleID="s62" ss:Width="121.5"/><Column ss:StyleID="s62" ss:Width="150"/><Column ss:StyleID="s62" ss:AutoFitWidth="0" ss:Width="344.25"/><Column ss:StyleID="s62" ss:Width="120.75"/><Row ss:AutoFitHeight="0" ss:Height="90"><Cell><Data ss:Type="String">INTERFACE_DLC05</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">text serounded by {} or [] are special tags for code. These tag will be replaced with other text eg: the name of a player. The tags should NOT be localized. They represent the place in the sentens for their replacing string. Some {} tags start with STR or INT. STR means it will be replaced with text, INT means it will be replaced with a numerical value</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SCENE ID</Data></Cell><Cell><Data ss:Type="String">TEXT ID</Data></Cell><Cell><Data ss:Type="String">ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZATION NOTES</Data></Cell><Cell><Data ss:Type="String">DEV TEAM / MISC NOTES</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">GENERIC</Data></Cell><Cell><Data ss:Type="String">CONTINUE_EMPIRE</Data></Cell><Cell><Data ss:Type="String">My Galactic Empire</Data></Cell><Cell><Data ss:Type="String">Moje imperium galaktyczne</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Used in the title menu for viewing the player's Galactic Empire</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">GENERIC</Data></Cell><Cell><Data ss:Type="String">CREATE_NEW_EMPIRE</Data></Cell><Cell><Data ss:Type="String">Found a new Empire</Data></Cell><Cell><Data ss:Type="String">Załóż nowe imperium</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Used in the title menu as button caption for starting/creating a new Galactic Empire, which is a collection of planets under the player's control.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">GENERIC</Data></Cell><Cell><Data ss:Type="String">EMPIRE_NAME</Data></Cell><Cell><Data ss:Type="String">Empire Name</Data></Cell><Cell><Data ss:Type="String">Nazwa imperium</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">used as a header above an inputfield where the player can name their empire</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">GENERIC</Data></Cell><Cell><Data ss:Type="String">EMPIRE_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Empire Description</Data></Cell><Cell><Data ss:Type="String">Opis imperium</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">used as a header above an inputfield where the player can describe their empire</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">GENERIC</Data></Cell><Cell><Data ss:Type="String">CREATE_EMPIRE_TITLE</Data></Cell><Cell><Data ss:Type="String">Create new Empire</Data></Cell><Cell><Data ss:Type="String">Stwórz nowe imperium</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Used as title for the create Empire Screen</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">GENERIC</Data></Cell><Cell><Data ss:Type="String">EDIT_EMPIRE_TITLE</Data></Cell><Cell><Data ss:Type="String">Edit Empire</Data></Cell><Cell><Data ss:Type="String">Modyfikuj imperium</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Uses as title for the edit Empire Screen</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:StyleID="s63"><Cell><Data ss:Type="String">BUTTON</Data></Cell><Cell><Data ss:Type="String">CONQUER_NEW_WORLD</Data></Cell><Cell><Data ss:Type="String">Conquer new World</Data></Cell><Cell><Data ss:Type="String">Podbij nowy świat</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Button that lets the player select the next world to conquer</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:StyleID="s63"><Cell><Data ss:Type="String">GENERIC</Data></Cell><Cell><Data ss:Type="String">EMPIRE_LEVEL</Data></Cell><Cell><Data ss:Type="String">Empire level: {INT_level}</Data></Cell><Cell><Data ss:Type="String">Poziom imperium – {INT_level}</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Shown as header of a screen and indicates the level of the player's Galactic Empire.</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:StyleID="s63"><Cell><Data ss:Type="String">GENERIC</Data></Cell><Cell><Data ss:Type="String">UNITS_KILLED</Data></Cell><Cell><Data ss:Type="String">Units Killed: {INT_value}</Data></Cell><Cell><Data ss:Type="String">Zabite jednostki – {INT_value}</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Shown in breakdown list</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:StyleID="s63"><Cell><Data ss:Type="String">GENERIC</Data></Cell><Cell><Data ss:Type="String">HEROES_KILLED</Data></Cell><Cell><Data ss:Type="String">Heroes Killed: {INT_value}</Data></Cell><Cell><Data ss:Type="String">Zabici bohaterowie – {INT_value}</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Shown in breakdown list</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:StyleID="s63"><Cell><Data ss:Type="String">GENERIC</Data></Cell><Cell><Data ss:Type="String">BATLLES_WON</Data></Cell><Cell><Data ss:Type="String">Battles Won: {INT_value}</Data></Cell><Cell><Data ss:Type="String">Wygrane bitwy – {INT_value}</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Shown in breakdown list</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:StyleID="s63"><Cell><Data ss:Type="String">GENERIC</Data></Cell><Cell><Data ss:Type="String">LANDMARK_CLEARED</Data></Cell><Cell><Data ss:Type="String">Landmarks Cleared: {INT_value}</Data></Cell><Cell><Data ss:Type="String">Oczyszczone miejsca charakterystyczne – {INT_value}</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Shown in breakdown list</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:StyleID="s63"><Cell><Data ss:Type="String">GENERIC</Data></Cell><Cell><Data ss:Type="String">TOTALMULTIPLIER</Data></Cell><Cell><Data ss:Type="String">Total Multiplier</Data></Cell><Cell><Data ss:Type="String">Całkowity mnożnik</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Shown in breakdown as: "Total Multiplier: VALUE"</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">GENERIC</Data></Cell><Cell><Data ss:Type="String">RELICS</Data></Cell><Cell><Data ss:Type="String">Relics</Data></Cell><Cell><Data ss:Type="String">Relikty</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Relics, items/entries of the reliquary. Is used as list name, so the list would be called relics and items are listed underneath.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">GENERIC</Data></Cell><Cell><Data ss:Type="String">SELECT_REQUISITIONS</Data></Cell><Cell><Data ss:Type="String">Choose Requisition items</Data></Cell><Cell><Data ss:Type="String">Wybierz przedmioty z rekwizycji</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Instructs the player on what to do in the requisition screen, is shown at the top of the screen.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TEXT</Data></Cell><Cell><Data ss:Type="String">PROGRESS_REWARD</Data></Cell><Cell><Data ss:Type="String">Progress Reward</Data></Cell><Cell><Data ss:Type="String">Nagroda za rozwój</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Used as list header for Empire Progress rewards.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">GENERIC</Data></Cell><Cell><Data ss:Type="String">REQUISITION_SCREEN_TITLE</Data></Cell><Cell><Data ss:Type="String">Galactic Empire</Data></Cell><Cell><Data ss:Type="String">Imperium galaktyczne</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Used as title for the requisition screen</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TEXT</Data></Cell><Cell><Data ss:Type="String">NEXT_PLANET</Data></Cell><Cell><Data ss:Type="String">Next Planet</Data></Cell><Cell><Data ss:Type="String">Następna planeta</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Used as button caption/tooltip for browsing through the list of planets</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TEXT</Data></Cell><Cell><Data ss:Type="String">PREVIOUS_PLANET</Data></Cell><Cell><Data ss:Type="String">Previous Planet</Data></Cell><Cell><Data ss:Type="String">Poprzednia planeta</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Used as button caption/tooltip for browsing through the list of planets</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TEXT</Data></Cell><Cell><Data ss:Type="String">DELETE_PLANET</Data></Cell><Cell><Data ss:Type="String">Delete Planet</Data></Cell><Cell><Data ss:Type="String">Usuń planetę</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Used as button caption for deleting a planet</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">GENERIC</Data></Cell><Cell><Data ss:Type="String">LOAD_EMPIRE_TITLE</Data></Cell><Cell><Data ss:Type="String">Load Empire</Data></Cell><Cell><Data ss:Type="String">Wczytaj imperium</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Used as button caption for loading an empire</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">GENERIC</Data></Cell><Cell><Data ss:Type="String">DELETE_EMPIRE_TITLE</Data></Cell><Cell><Data ss:Type="String">Delete Empire</Data></Cell><Cell><Data ss:Type="String">Usuń imperium</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Used as button caption for deleting an empire</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">BUTTON</Data></Cell><Cell><Data ss:Type="String">RANDOMIZE_PLANETS</Data></Cell><Cell><Data ss:Type="String">Randomize Planets</Data></Cell><Cell><Data ss:Type="String">Losuj planety</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Used as button caption for randomizing the available planets in the empire</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">BUTTON</Data></Cell><Cell><Data ss:Type="String">RANDOMIZE_PLANETS_TOOLTIP</Data></Cell><Cell><Data ss:Type="String">Replaces the current set of available planets with a new set of 3 random planets.</Data></Cell><Cell><Data ss:Type="String">Zastępuje aktualną grupę dostępnych planet nową grupą trzech losowo wygenerowanych planet.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Randomize planets tooltip, explains that the current set is removed and a completely new set of planets is generated.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">GENERIC</Data></Cell><Cell><Data ss:Type="String">SURVEY_SITES_SOLVED</Data></Cell><Cell><Data ss:Type="String">Anomalous Sites resolved: {INT_value}</Data></Cell><Cell><Data ss:Type="String">Zbadane miejsca anomalii – {INT_value}</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Shown in breakdown list</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">GENERIC</Data></Cell><Cell><Data ss:Type="String">PLAYERS_DEFEATED</Data></Cell><Cell><Data ss:Type="String">Players Defeated: {INT_value}</Data></Cell><Cell><Data ss:Type="String">Pokonani gracze – {INT_value}</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Shown in breakdown list</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">GENERIC</Data></Cell><Cell><Data ss:Type="String">MULTIPLIER</Data></Cell><Cell><Data ss:Type="String">Multiplier</Data></Cell><Cell><Data ss:Type="String">Mnożnik</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Shown in breakdown as: "Multiplier: VALUE"</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">GENERIC</Data></Cell><Cell><Data ss:Type="String">RECRUIT_NEW_HERO</Data></Cell><Cell><Data ss:Type="String">Recruit new hero</Data></Cell><Cell><Data ss:Type="String">Zwerbuj nowego bohatera</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Button caption in leader editor where the player can recruit a new hero into their empire.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">GENERIC</Data></Cell><Cell><Data ss:Type="String">RECRUIT_NEW_HERO_TOOLTIP</Data></Cell><Cell><Data ss:Type="String">Choose or customize a hero that is added as a new hero to your empire upon starting the game.</Data></Cell><Cell><Data ss:Type="String">Wybierz lub zmodyfikuj bohatera, który zostanie dodany do twojego imperium jako nowa postać w chwili rozpoczęcia gry.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">BUTTON</Data></Cell><Cell><Data ss:Type="String">ABANDON_PLANET</Data></Cell><Cell><Data ss:Type="String">Abandon Planet</Data></Cell><Cell><Data ss:Type="String">Porzuć planetę</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Used as button caption for abandoning a planet.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">BUTTON</Data></Cell><Cell><Data ss:Type="String">ABANDON_PLANET_TOOLTIP</Data></Cell><Cell><Data ss:Type="String">Surrender your progress on this planet. The game ends in defeat and you will be lead to the results screen. You do not conquer the planet, heroes will not level up and no relics or [xp/] is gained for this planet, but you can still claim [xp/] for any progress in secondary objectives.</Data></Cell><Cell><Data ss:Type="String">Zrezygnuj z podbijania tej planety. Rozgrywka zakończy się porażką i przejdziesz na ekran wyników. Nie otrzymasz kontroli nad planetą, bohaterowie nie awansują i nie zdobędziesz żadnych reliktów ani [xp/] za tę planetę, natomiast możesz otrzymać [xp/] za postępy w realizowaniu celów dodatkowych.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Tooltip that explains that abandoning the planet counts as losing and will not level up any heroes nor will the player gain experience for their hero's race and technology. They can however still gain experience for any objectives that were completed.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">BUTTON</Data></Cell><Cell><Data ss:Type="String">ABANDON_PLANET_CONFIRMATION</Data></Cell><Cell><Data ss:Type="String">{XML_INTERFACE_DLC05@BUTTON@ABANDON_PLANET_TOOLTIP}[br/][br/]Are you sure you want to abandon this planet? You can still load a save game in the next screen if you do not want to accept the results.</Data></Cell><Cell><Data ss:Type="String">{XML_INTERFACE_DLC05@BUTTON@ABANDON_PLANET_TOOLTIP}[br/][br/]Czy na pewno chcesz porzucić tę planetę? Jeśli nie akceptujesz wyniku, wciąż możesz wczytać zapisaną grę na następnym ekranie.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Same as above, but adds a confirmation request to the end. Players will see the results in the next screen where they will still get the choice to either accept the results or to load a save game.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">EVENTS</Data></Cell><Cell><Data ss:Type="String">EMPIRE_HERO_JOIN_TODO</Data></Cell><Cell><Data ss:Type="String">Handle Empire hero join offer</Data></Cell><Cell><Data ss:Type="String">Odpowiedz na ofertę bohatera imperium</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Event header to show the player a galactic empire hero is still waiting for an awnser on the joining call</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">EVENTS</Data></Cell><Cell><Data ss:Type="String">EMPIRE_HERO_JOIN_NOTIFY</Data></Cell><Cell><Data ss:Type="String">Recruit Empire Hero</Data></Cell><Cell><Data ss:Type="String">Zwerbuj bohatera imperium</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Event to show the player a galactic empire hero wants to join</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">EVENTS</Data></Cell><Cell><Data ss:Type="String">EMPIRE_HERO_JOIN_LOG</Data></Cell><Cell><Data ss:Type="String">Empire hero available to recruit</Data></Cell><Cell><Data ss:Type="String">Bohater imperium do zwerbowania</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Event to show the player had a galactic empire hero that wanted to join [past tense, used in log]</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TOME_OF_WONDERS_FILTERS</Data></Cell><Cell><Data ss:Type="String">GAME_CONCEPTS_GALACTIC_EMPIRE</Data></Cell><Cell><Data ss:Type="String">Galactic Empire</Data></Cell><Cell><Data ss:Type="String">Imperium galaktyczne</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Name of the galactic empire</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TOME_OF_WONDERS_FILTERS</Data></Cell><Cell><Data ss:Type="String">GAME_CONCEPTS_GRAIL</Data></Cell><Cell><Data ss:Type="String">Grails</Data></Cell><Cell><Data ss:Type="String">Graale</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Name of the grail system</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TOME_OF_WONDERS_FILTERS</Data></Cell><Cell><Data ss:Type="String">GAME_CONCEPTS_RESIDENTIAL_SECTORS</Data></Cell><Cell><Data ss:Type="String">Residential Sectors</Data></Cell><Cell><Data ss:Type="String">Sektory mieszkalne</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Name of the residential sectors system</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TOME_OF_WONDERS_FILTERS</Data></Cell><Cell><Data ss:Type="String">RESEARCH_OATHBOUND</Data></Cell><Cell><Data ss:Type="String">Oathbound</Data></Cell><Cell><Data ss:Type="String">Nieugięci</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Name of the race</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TOME_OF_WONDERS_FILTERS</Data></Cell><Cell><Data ss:Type="String">RESEARCH_ENTROPY</Data></Cell><Cell><Data ss:Type="String">Entropy</Data></Cell><Cell><Data ss:Type="String">Entropia</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Name of a tech group</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TOME_OF_WONDERS_FILTERS</Data></Cell><Cell><Data ss:Type="String">OPERATIONS_OATHBOUND</Data></Cell><Cell><Data ss:Type="String">Oathbound</Data></Cell><Cell><Data ss:Type="String">Nieugięci</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Name of the race</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TOME_OF_WONDERS_FILTERS</Data></Cell><Cell><Data ss:Type="String">OPERATIONS_ENTROPY</Data></Cell><Cell><Data ss:Type="String">Entropy</Data></Cell><Cell><Data ss:Type="String">Entropia</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Name of a tech group</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TOME_OF_WONDERS_FILTERS</Data></Cell><Cell><Data ss:Type="String">UNITS_OATHBOUND</Data></Cell><Cell><Data ss:Type="String">Oathbound</Data></Cell><Cell><Data ss:Type="String">Nieugięci</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Name of the race</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TOME_OF_WONDERS_FILTERS</Data></Cell><Cell><Data ss:Type="String">UNITS_MYCELIAN</Data></Cell><Cell><Data ss:Type="String">Mycelian</Data></Cell><Cell><Data ss:Type="String">Mikolianie</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Name of the race</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TOME_OF_WONDERS_FILTERS</Data></Cell><Cell><Data ss:Type="String">UNITS_APOSTATES</Data></Cell><Cell><Data ss:Type="String">Apostates</Data></Cell><Cell><Data ss:Type="String">Odstępcy</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Name of the race</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TOME_OF_WONDERS_FILTERS</Data></Cell><Cell><Data ss:Type="String">UNITS_PSIONICA</Data></Cell><Cell><Data ss:Type="String">Psionica</Data></Cell><Cell><Data ss:Type="String">Psjony</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Name of the race</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TOME_OF_WONDERS_FILTERS</Data></Cell><Cell><Data ss:Type="String">UNIT_UPGRADES_OATHBOUND</Data></Cell><Cell><Data ss:Type="String">Oathbound</Data></Cell><Cell><Data ss:Type="String">Nieugięci</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Name of the race</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TOME_OF_WONDERS_FILTERS</Data></Cell><Cell><Data ss:Type="String">UNIT_UPGRADES_ENTROPY</Data></Cell><Cell><Data ss:Type="String">Entropy</Data></Cell><Cell><Data ss:Type="String">Entropia</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Name of a tech group</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TOME_OF_WONDERS_FILTERS</Data></Cell><Cell><Data ss:Type="String">HERO_SKILLS_OATHBOUND</Data></Cell><Cell><Data ss:Type="String">Oathbound</Data></Cell><Cell><Data ss:Type="String">Nieugięci</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Name of the race</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">GENERIC</Data></Cell><Cell><Data ss:Type="String">GALACTIC_EMPIRES</Data></Cell><Cell><Data ss:Type="String">Galactic Empires</Data></Cell><Cell><Data ss:Type="String">Imperia galaktyczne</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Shown as filter in the load game dialog</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">GENERIC</Data></Cell><Cell><Data ss:Type="String">GALACTIC_EMPIRES_SESSIONS</Data></Cell><Cell><Data ss:Type="String">Galactic Empire Sessions</Data></Cell><Cell><Data ss:Type="String">Sesje imperium galaktycznego</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Shown as filter in the load game dialog</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">EMPIRE_LOAD_FAILED</Data></Cell><Cell><Data ss:Type="String">DIALOG_MESSAGE</Data></Cell><Cell><Data ss:Type="String">Failed to load the last known Galactic Empire file. Please make sure you are connected to the internet if you are making use of cloud storage and then restart the game. Alternatively, you can also try to manually load an Empire using the load game dialog.</Data></Cell><Cell><Data ss:Type="String">Nie udało się wczytać ostatniego znanego pliku imperium galaktycznego. Jeśli korzystasz z zapisów w chmurze, sprawdź, czy masz połączenie z Internetem, a potem uruchom grę ponownie. Możesz też 
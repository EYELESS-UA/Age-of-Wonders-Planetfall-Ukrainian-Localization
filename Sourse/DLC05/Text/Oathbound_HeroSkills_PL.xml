<?xml version="1.0"?><?mso-application progid="Excel.Sheet"?><Workbook xmlns="urn:schemas-microsoft-com:office:spreadsheet" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns:ss="urn:schemas-microsoft-com:office:spreadsheet" xmlns:html="http://www.w3.org/TR/REC-html40"><DocumentProperties xmlns="urn:schemas-microsoft-com:office:office"><LastAuthor>Nathan van den Berg</LastAuthor><LastSaved>2020-06-22T13:39:08Z</LastSaved><Version>16.00</Version></DocumentProperties><OfficeDocumentSettings xmlns="urn:schemas-microsoft-com:office:office"><AllowPNG/></OfficeDocumentSettings><ExcelWorkbook xmlns="urn:schemas-microsoft-com:office:excel"><WindowHeight>9990</WindowHeight><WindowWidth>21525</WindowWidth><WindowTopX>32767</WindowTopX><WindowTopY>32767</WindowTopY><RefModeR1C1/><ProtectStructure>False</ProtectStructure><ProtectWindows>False</ProtectWindows></ExcelWorkbook><Styles><Style ss:ID="Default" ss:Name="Normal"><Alignment ss:Vertical="Bottom"/><Borders/><Font ss:FontName="Calibri" x:Family="Swiss" ss:Size="11" ss:Color="#000000"/><Interior/><NumberFormat/><Protection/></Style><Style ss:ID="s62"><Alignment ss:Vertical="Top" ss:WrapText="1"/></Style><Style ss:ID="s63"><Alignment ss:Vertical="Top" ss:WrapText="1"/><Font ss:FontName="Calibri" x:Family="Swiss" ss:Size="11" ss:Color="#000000" ss:Italic="1"/></Style></Styles><Worksheet ss:Name="Script"><Table x:FullColumns="1" x:FullRows="1" ss:StyleID="s62" ss:DefaultColumnWidth="51.75" ss:DefaultRowHeight="15"><Column ss:StyleID="s62" ss:Width="119.25"/><Column ss:StyleID="s62" ss:Width="107.25"/><Column ss:StyleID="s62" ss:Width="350.25"/><Column ss:StyleID="s62" ss:Width="147.75"/><Column ss:StyleID="s62" ss:Width="293.25"/><Column ss:StyleID="s62" ss:Width="120"/><Row ss:AutoFitHeight="0" ss:Height="60"><Cell><Data ss:Type="String">OATHBOUND_HERO_SKILLS</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">The DEV TEAM / MISC NOTES column contains info on what text between { } signs means (if applicable). It usually stands for either a numeric value, or a numeric value with an icon. Text between [ ] signs stands for a certain type of icon. </Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SCENE ID</Data></Cell><Cell><Data ss:Type="String">TEXT ID</Data></Cell><Cell><Data ss:Type="String">ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZATION NOTES</Data></Cell><Cell><Data ss:Type="String">DEV TEAM / MISC NOTES</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">OATHBOUND_SKILL_GROUP</Data></Cell><Cell><Data ss:Type="String">SKILL_SUBTITLE</Data></Cell><Cell><Data ss:Type="String">Oathbound Hero Skill</Data></Cell><Cell><Data ss:Type="String">Umiejętność bohatera Nieugiętych</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Skill tree header</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HERO_SKILL_1</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Intuitive Strikes</Data></Cell><Cell><Data ss:Type="String">Intuicyjne ciosy</Data></Cell><Cell ss:Index="7" ss:StyleID="s63"><Data ss:Type="String">Hero Skill name</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">HERO_SKILL_1</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">If this unit has [abilityblue]Precognition[/abilityblue], it also gains +{DamageMult}% damage on all abilities.</Data></Cell><Cell><Data ss:Type="String">Jeśli ta jednostka ma [abilityblue]prekognicję[/abilityblue], zyskuje też +{DamageMult}% do obrażeń od wszystkich umiejętności.</Data></Cell><Cell ss:Index="7" ss:StyleID="s63"><Data ss:Type="String">Hero Skill description
Precognition is a buff that allows you to evade an attack</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HERO_SKILL_2</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Attenuators</Data></Cell><Cell><Data ss:Type="String">Tłumiki</Data></Cell><Cell ss:Index="7" ss:StyleID="s63"><Data ss:Type="String">Hero Skill name</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">HERO_SKILL_2</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">While in a vehicle, gain one level of [abilityblue]Stagger Resistance[/abilityblue] and +{staggerResist} [abilityblue]status effect resistance[/abilityblue].</Data></Cell><Cell><Data ss:Type="String">Przy korzystaniu z pojazdu postać zyskuje jeden poziom [abilityblue]odporności na zachwianie[/abilityblue] i +{staggerResist} do [abilityblue]odporności na efekty stanu[/abilityblue].</Data></Cell><Cell ss:Index="7" ss:StyleID="s63"><Data ss:Type="String">Hero Skill description</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HERO_SKILL_3</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Trailblazer</Data></Cell><Cell><Data ss:Type="String">Pędziwiatr</Data></Cell><Cell ss:Index="7" ss:StyleID="s63"><Data ss:Type="String">Hero Skill name</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">HERO_SKILL_3</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">While in a vehicle, unit has [abilityblue]Fast Movement[/abilityblue].</Data></Cell><Cell><Data ss:Type="String">Przy korzystaniu z pojazdu jednostka ma [abilityblue]szybki ruch[/abilityblue].</Data></Cell><Cell ss:Index="7" ss:StyleID="s63"><Data ss:Type="String">Hero Skill description</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HERO_SKILL_4</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Field Repair Droid</Data></Cell><Cell><Data ss:Type="String">Polowy robot naprawczy</Data></Cell><Cell ss:Index="7" ss:StyleID="s63"><Data ss:Type="String">Hero Skill name</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">HERO_SKILL_4</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Vehicles driven by this hero gain [abilityblue]Regeneration[/abilityblue]. If destroyed, the vehicle is restored at {ResurganceRestore}%[hp/] at the end of battle, as long as the hero was not killed as well.</Data></Cell><Cell><Data ss:Type="String">Pojazdy prowadzone przez tego bohatera zyskują [abilityblue]regenerację[/abilityblue]. W razie zniszczenia pojazd jest odtwarzany z {ResurganceRestore}%[hp/] po zakończeniu walki.</Data></Cell><Cell ss:Index="7" ss:StyleID="s63"><Data ss:Type="String">Hero Skill description</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HERO_SKILL_5</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Oracle's Protégé</Data></Cell><Cell><Data ss:Type="String">Pupil Wyroczni</Data></Cell><Cell ss:Index="7" ss:StyleID="s63"><Data ss:Type="String">Hero Skill name</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">HERO_SKILL_5</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">For every level of reputation above Neutral, gain +{hpBonus}[hp/] and {armorBonus}[armor/].</Data></Cell><Cell><Data ss:Type="String">Za każdy poziom reputacji powyżej neutralnego bohater zyskuje +{hpBonus}[hp/] i {armorBonus}[armor/].</Data></Cell><Cell ss:Index="7" ss:StyleID="s63"><Data ss:Type="String">Hero Skill description</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">HERO_SKILL_5</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION_POSITIVE_REP</Data></Cell><Cell><Data ss:Type="String">This hero gains {hpBonus}[hp/] and {armorBonus}[armor/].</Data></Cell><Cell><Data ss:Type="String">Ten bohater zyskuje {hpBonus}[hp/] i {armorBonus}[armor/].</Data></Cell><Cell ss:Index="7" ss:StyleID="s63"><Data ss:Type="String">Hero Skill effect description</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HERO_SKILL_6</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Oracle's Favor</Data></Cell><Cell><Data ss:Type="String">Przychylność Wyroczni</Data></Cell><Cell ss:Index="7" ss:StyleID="s63"><Data ss:Type="String">Hero Skill name</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="75"><Cell><Data ss:Type="String">HERO_SKILL_6</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Killing an enemy grants the hero a stack of [abilityblue]Precognition[/abilityblue], negating the next direct damage attack to affect it.</Data></Cell><Cell><Data ss:Type="String">Zabicie wroga daje bohaterowi jeden poziom [abilityblue]prekognicji[/abilityblue], który niweluje efekt najbliższego ataku zadającego bezpośrednie obrażenia.</Data></Cell><Cell ss:Index="7" ss:StyleID="s63"><Data ss:Type="String">Hero Skill description</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HERO_SKILL_7</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Overload Power Core</Data></Cell><Cell><Data ss:Type="String">Przeciążenie rdzenia zasilającego</Data></Cell><Cell ss:Index="7" ss:StyleID="s63"><Data ss:Type="String">Hero Skill name</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="60"><Cell><Data ss:Type="String">HERO_SKILL_7</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">When in a Battlesuit vehicle, this hero gains the single action [abilityblue]Eject[/abilityblue] ability:[br/]Destroy your battlesuit, dealing {ejectDamage} [damageWave/] in a {radius} hex radius to enemy ground units.</Data></Cell><Cell><Data ss:Type="String">Posługując się mobilnym pancerzem, bohater zyskuje jednorazową umiejętność [abilityblue]katapultowanie[/abilityblue].[br/]Pancerz zostaje zniszczony, a wrogie jednostki lądowe w promieniu {radius} pól otrzymują {ejectDamage} [damageWave/].</Data></Cell><Cell ss:Index="7" ss:StyleID="s63"><Data ss:Type="String">Hero Skill description
Battlesuit is a type of vehicle</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">HERO_SKILL_7</Data></Cell><Cell><Data ss:Type="String">PROP_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Destroy your Battlesuit, dealing {ejectDamage} [damageWave/] in a {radius} hex radius to enemy ground units.</Data></Cell><Cell><Data ss:Type="String">Pancerz zostaje zniszczony, a wrogie jednostki lądowe w promieniu {radius} pól otrzymują {ejectDamage} [damageWave/].</Data></Cell><Cell ss:Index="7" ss:StyleID="s63"><Data ss:Type="String">Ability description</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HERO_SKILL_8</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Entropic Infusion</Data></Cell><Cell><Data ss:Type="String">Zastrzyk entropii</Data></Cell><Cell ss:Index="7" ss:StyleID="s63"><Data ss:Type="String">Hero Skill name</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="83.25"><Cell><Data ss:Type="String">HERO_SKILL_8</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit's attacks gain {DamageEntropyS}[damageEntropy/] ({DamageEntropyR}[damageEntropy/] for repeating attacks) and a {strengthChance}[strengthentropy/] ({strengthChanceR}[strengthentropy/] for repeating attacks) chance to apply [abilityred]Entropic Decay[/abilityred].</Data></Cell><Cell><Data ss:Type="String">Ataki tej jednostki zyskują {DamageEntropyS}[damageEntropy/] ({DamageEntropyR}[damageEntropy/] dla ataków wielokrotnych) i szansę o sile {strengthChance}[strengthentropy/] ({strengthChanceR}[strengthentropy/] dla ataków wielokrotnych) na spowodowanie [abilityred]rozkładu entropicznego[/abilityred].</Data></Cell><Cell ss:Index="7" ss:StyleID="s63"><Data ss:Type="String">Hero Skill description</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="33"><Cell><Data ss:Type="String">CITY_HERO_SKILLS</Data></Cell><Cell><Data ss:Type="String">ALWAYS_ACTIVE</Data></Cell><Cell><Data ss:Type="String">Always Active</Data></Cell><Cell><Data ss:Type="String">Zawsze aktywna</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Conditional part of several hero skills descriptions</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="33"><Cell><Data ss:Type="String">CITY_HERO_SKILLS</Data></Cell><Cell><Data ss:Type="String">WHEN_IN_CITY_DOMAIN</Data></Cell><Cell><Data ss:Type="String">Hero in Colony's domain</Data></Cell><Cell><Data ss:Type="String">Gdy bohater jest na terytorium kolonii</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Conditional part of several hero skills descriptions</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="33"><Cell><Data ss:Type="String">CITY_HERO_SKILLS</Data></Cell><Cell><Data ss:Type="String">OUTSIDE_DOMAIN_WITH_THRONE</Data></Cell><Cell><Data ss:Type="String">Hero outside Colony's domain</Data></Cell><Cell><Data ss:Type="String">Gdy bohater jest poza terytorium kolonii</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Conditional part of several hero skills descriptions</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">AGRARIAN_IDEALS</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Colony Lord: Agrarian Ideals</Data></Cell><Cell><Data ss:Type="String">Władca kolonii – rolnicze ideały</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Hero Skill name</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="36"><Cell><Data ss:Type="String">AGRARIAN_IDEALS</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This hero can become a Lord of a colony, granting it bonuses to food production and happiness.[br/]Disables the option to gain [abilityblue]Scientific Method[/abilityblue] and [abilityblue]Energetic Efficiency[/abilityblue]hero skill.</Data></Cell><Cell><Data ss:Type="String">Ten bohater może zostać władcą kolonii, dając jej premie do produkcji żywności i zadowolenia.[br/]Uniemożliwia otrzymanie umiejętności bohatera [abilityblue]metoda naukowa[/abilityblue] i [abilityblue]wydajność energetyczna[/abilityblue].</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Hero Skill description</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">AGRARIAN_IDEALS</Data></Cell><Cell><Data ss:Type="String">FOOD_BONUS</Data></Cell><Cell><Data ss:Type="String">Food[food/] income increases by {foodIncomeIncrease}</Data></Cell><Cell><Data ss:Type="String">Produkcja żywności[food/] wzrasta o {foodIncomeIncrease}</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Hero Skill description</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">AGRARIAN_IDEALS</Data></Cell><Cell><Data ss:Type="String">HAPPINESS_BONUS</Data></Cell><Cell><Data ss:Type="String">Happiness[happiness/] income increases by {happinessIncomeIncrease}</Data></Cell><Cell><Data ss:Type="String">Przyrost zadowolenia[happiness/] wzrasta o {happinessIncomeIncrease}</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Hero Skill description</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">NEW_GENERATION</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Colony Lord: New Generation</Data></Cell><Cell><Data ss:Type="String">Władca kolonii – nowe pokolenie</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Hero Skill name</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="34.5"><Cell><Data ss:Type="String">NEW_GENERATION</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This hero inspires a new generation in their colony.[br/]Disables the option to gain [abilityblue]Euphoric Presence[/abilityblue] hero skill.</Data></Cell><Cell><Data ss:Type="String">Ten bohater zachęca kolonistów do rozmnażania się.[br/]Uniemożliwia otrzymanie umiejętności bohatera [abilityblue]euforyczny wpływ[/abilityblue].</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Hero Skill description</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="34.5"><Cell><Data ss:Type="String">NEW_GENERATION</Data></Cell><Cell><Data ss:Type="String">GROWTH_REQUIREMENT</Data></Cell><Cell><Data ss:Type="String">Growth requirement for a new colonist[population/] is lowered by {growthRequirement}%.</Data></Cell><Cell><Data ss:Type="String">Wymagania dla powstania nowego kolonisty[population/] są zmniejszone o {growthRequirement}%.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Hero Skill description</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">EUPHORIC_PRESENCE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Colony Lord: Euphoric Presence</Data></Cell><Cell><Data ss:Type="String">Władca kolonii – euforyczny wpływ</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Hero Skill name</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="32.25"><Cell><Data ss:Type="String">EUPHORIC_PRESENCE</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This hero's presence makes the people in their colony happier more quickly.[br/]Disables the option to gain [abilityblue]New Generation[/abilityblue] hero skill.</Data></Cell><Cell><Data ss:Type="String">Obecność tego bohatera powoduje szybsze uszczęśliwienie mieszkańców kolonii.[br/]Uniemożliwia otrzymanie umiejętności bohatera [abilityblue]nowe pokolenie[/abilityblue].</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Hero Skill description</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="32.25"><Cell><Data ss:Type="String">EUPHORIC_PRESENCE</Data></Cell><Cell><Data ss:Type="String">HAPPINESS_THRESHOLD</Data></Cell><Cell><Data ss:Type="String">Threshold for a happiness event is lowered by {happinessThreshold}%.</Data></Cell><Cell><Data ss:Type="String">Próg dla następstw zadowolenia jest zmniejszony o {happinessThreshold}%.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Hero Skill description</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SCIENTIFIC_METHOD</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Colony Lord: Scientific Method</Data></Cell><Cell><Data ss:Type="String">Władca kolonii – metoda naukowa</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Hero Skill name</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="60.75"><Cell><Data ss:Type="String">SCIENTIFIC_METHOD</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This hero can become Lord of a Colony, granting it bonuses to research and cosmite income.[br/]Disables the option to gain [abilityblue]Agrarian Ideals[/abilityblue] and [abilityblue]Energetic Efficiency[/abilityblue]hero skill.</Data></Cell><Cell><Data ss:Type="String">Ten bohater może zostać władcą kolonii, dając jej premie do badań naukowych i produkcji kosmitu.[br/]Uniemożliwia otrzymanie umiejętności bohatera [abilityblue]rolnicze ideały[/abilityblue] i [abilityblue]wydajność energetyczna[/abilityblue].</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Hero Skill description</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SCIENTIFIC_METHOD</Data></Cell><Cell><Data ss:Type="String">RESEARCH_BONUS</Data></Cell><Cell><Data ss:Type="String">Research[research/] income increases by {researchIncrease}%.</Data></Cell><Cell><Data ss:Type="String">Liczba wytwarzanych punktów badań[research/] wzrasta o {researchIncrease}%.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Hero Skill description</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SCIENTIFIC_METHOD</Data></Cell><Cell><Data ss:Type="String">COSMITE_BONUS</Data></Cell><Cell><Data ss:Type="String">Cosmite[cosmite/] income increases by {cosmiteIncrease}.</Data></Cell><Cell><Data ss:Type="String">Produkcja kosmitu[cosmite/] wzrasta o {cosmiteIncrease}.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Hero Skill description</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">MILITARY_FOCUS</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Colony Lord: Military Focus</Data></Cell><Cell><Data ss:Type="String">Władca kolonii – specjalizacja wojskowa</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Hero Skill name</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="27"><Cell><Data ss:Type="String">MILITARY_FOCUS</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">The hero's combat expertise allows this colony to improve military research.[br/]Disables the option to gain [abilityblue]Societal Focus[/abilityblue] hero skill.</Data></Cell><Cell><Data ss:Type="String">Umiejętności bojowe tego bohatera umożliwiają kolonii przyspieszenie badań wojskowych.[br/]Uniemożliwia otrzymanie umiejętności bohatera [abilityblue]specjalizacja socjologiczna[/abilityblue].</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Hero Skill description</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">MILITARY_FOCUS</Data></Cell><Cell><Data ss:Type="String">MILITARY_RESEARCH</Data></Cell><Cell><Data ss:Type="String">{researchIncrease}% [research/] for Military Research.</Data></Cell><Cell><Data ss:Type="String">{researchIncrease}% [research/] do badań wojskowych.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Hero Skill description</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SOCIETAL_FOCUS</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Colony Lord: Societal Focus</Data></Cell><Cell><Data ss:Type="String">Władca kolonii – specjalizacja socjologiczna</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Hero Skill name</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SOCIETAL_FOCUS</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">The hero's intellect allows this colony to improve society research.[br/]Disables the option to gain [abilityblue]Military Focus[/abilityblue] hero skill.</Data></Cell><Cell><Data ss:Type="String">Zalety intelektualne bohatera umożliwiają kolonii przyspieszenie badań socjologicznych.[br/]Uniemożliwia otrzymanie umiejętności bohatera [abilityblue]specjalizacja wojskowa[/abilityblue].</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Hero Skill description</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SOCIETAL_FOCUS</Data></Cell><Cell><Data ss:Type="String">SOCIETY_RESEARCH</Data></Cell><Cell><Data ss:Type="String">{researchIncrease}% [research/] for Society Research.</Data></Cell><Cell><Data ss:Type="String">{researchIncrease}% [research/] do badań socjologicznych.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Hero Skill description</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ENERGETIC_EFFICIENCY</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Colony Lord: Energetic Efficiency</Data></Cell><Cell><Data ss:Type="String">Władca kolonii – wydajność energetyczna</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Hero Skill name</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">ENERGETIC_EFFICIENCY</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This hero can become Lord of a Colony, granting it bonuses to production income and energy income.[br/]Disables the option to gain [abilityblue]Agrarian Ideals[/abilityblue] and [abilityblue]Scientific Method[/abilityblue]hero skill.</Data></Cell><Cell><Data ss:Type="String">Ten bohater może zostać władcą kolonii, dając jej premie do przyrostu produkcji i wytwarzania energii.[br/]Uniemożliwia otrzymanie umiejętności bohatera [abilityblue
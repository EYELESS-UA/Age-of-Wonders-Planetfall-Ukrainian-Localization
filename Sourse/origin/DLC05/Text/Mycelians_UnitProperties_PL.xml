<?xml version="1.0"?><?mso-application progid="Excel.Sheet"?><Workbook xmlns="urn:schemas-microsoft-com:office:spreadsheet" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns:ss="urn:schemas-microsoft-com:office:spreadsheet" xmlns:html="http://www.w3.org/TR/REC-html40"><DocumentProperties xmlns="urn:schemas-microsoft-com:office:office"><LastAuthor>Joshua Crowder</LastAuthor><LastSaved>2020-06-18T20:03:23Z</LastSaved><Version>16.00</Version></DocumentProperties><OfficeDocumentSettings xmlns="urn:schemas-microsoft-com:office:office"><AllowPNG/></OfficeDocumentSettings><ExcelWorkbook xmlns="urn:schemas-microsoft-com:office:excel"><WindowHeight>7305</WindowHeight><WindowWidth>21420</WindowWidth><WindowTopX>32767</WindowTopX><WindowTopY>32767</WindowTopY><RefModeR1C1/><ProtectStructure>False</ProtectStructure><ProtectWindows>False</ProtectWindows></ExcelWorkbook><Styles><Style ss:ID="Default" ss:Name="Normal"><Alignment ss:Vertical="Bottom"/><Borders/><Font ss:FontName="Calibri" x:Family="Swiss" ss:Size="11" ss:Color="#000000"/><Interior/><NumberFormat/><Protection/></Style><Style ss:ID="s62"><Alignment ss:Vertical="Top" ss:WrapText="1"/></Style><Style ss:ID="s63"><Alignment ss:Vertical="Bottom" ss:WrapText="1"/></Style></Styles><Worksheet ss:Name="Script"><Table x:FullColumns="1" x:FullRows="1" ss:StyleID="s62" ss:DefaultColumnWidth="242.25" ss:DefaultRowHeight="15"><Column ss:StyleID="s62" ss:Width="189"/><Column ss:StyleID="s62" ss:Width="117.75"/><Column ss:StyleID="s62" ss:AutoFitWidth="0" ss:Width="281.25"/><Column ss:StyleID="s62" ss:Width="147.75"/><Column ss:StyleID="s62" ss:Width="243"/><Column ss:StyleID="s62" ss:Width="120"/><Row ss:AutoFitHeight="0" ss:Height="75"><Cell><Data ss:Type="String">WILDLIFE_UNITPROPERTIES_Mycelians_DLC05</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">The DEV TEAM / MISC NOTES column contains info on what text between { } signs means (if applicable). It usually stands for either a numeric value, or a numeric value with an icon. Text between [ ] signs stands for a certain type of icon. </Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SCENE ID</Data></Cell><Cell><Data ss:Type="String">TEXT ID</Data></Cell><Cell><Data ss:Type="String">ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZATION NOTES</Data></Cell><Cell><Data ss:Type="String">DEV TEAM / MISC NOTES</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">POISON_SPRAY</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Poison Spray</Data></Cell><Cell><Data ss:Type="String">Trująca mgiełka</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">In the text below, text refers to a person that can either be male or female. If relevant for translation, please use the ‘localized string’ column for the male text and the ‘alternative localized string’ column for the female text. You and Your might be examples of this.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">POISON_SPRAY</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Spray a poisoning pesticide.</Data></Cell><Cell><Data ss:Type="String">Rozpyla trujący pestycyd.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">In the text below, any inserted strings - anything of the form {text} - is replaced by an integer value for the thing described in the brackets. If the {text} is not followed by a unit - e.g. shields, hitpoints - the icon for the unit is inserted together with the integer. The same holds for symbols - e.g. '+', '%' - which are occasionally inserted together with the integer.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">BLINDING_MIST</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Blinding Mist</Data></Cell><Cell><Data ss:Type="String">Oślepiająca mgiełka</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">For references to game terminology and in-world references, please check the glossary delivered as part of the documentation.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">BLINDING_MIST</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Launch a blinding pesticide in a {ConeRadius} hex cone.</Data></Cell><Cell><Data ss:Type="String">Wystrzeliwuje oślepiający pestycyd w stożku o wielkości {ConeRadius} pól.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">CROP_SCATTER</Data></Cell><Cell><Data ss:Type="String">PROP_NAME</Data></Cell><Cell><Data ss:Type="String">Volatile Crop Scatter</Data></Cell><Cell><Data ss:Type="String">Rozpylenie zarodników</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">CROP_SCATTER</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Fire a volley of volatile fungal crops.</Data></Cell><Cell><Data ss:Type="String">Wystrzeliwuje salwę lotnych zarodników grzybów.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HARDENED_SAPLINGS</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Hardened Sapling Cannon</Data></Cell><Cell><Data ss:Type="String">Armata na utwardzone nasiona</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">HARDENED_SAPLINGS</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Launch an explosive modified sapling across the battlefield, detonating in a {ExplosionRadius} hex radius.</Data></Cell><Cell><Data ss:Type="String">Wystrzeliwuje wybuchowe zmodyfikowane nasiono, zadające obrażenia w promieniu {ExplosionRadius} pól.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">MUCK_SPRAY</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Muck Spray</Data></Cell><Cell><Data ss:Type="String">Cuchnąca mgiełka</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">MUCK_SPRAY</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Expel toxic fertilizer across the battlefield in a {HexRadius} radius area.</Data></Cell><Cell><Data ss:Type="String">Pokrywa część pola walki o promieniu {HexRadius} pól toksycznym nawozem.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ENVELOPING_GROWTH</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Enveloping Growth</Data></Cell><Cell><Data ss:Type="String">Oplatająca grzybnia</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">ENVELOPING_GROWTH</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Extend fungal growths to attack all targets in front of the unit.</Data></Cell><Cell><Data ss:Type="String">Oplata strzępami grzybni wszystkie cele przed jednostką.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">MYCELIAN_CONNECTIONS</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Mycelian Connections</Data></Cell><Cell><Data ss:Type="String">Mikoliańskie więzi</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="60"><Cell><Data ss:Type="String">MYCELIAN_CONNECTIONS</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Buff all friendly Mycelian units on the battlefield with  +{ShieldBuff} [Shield/] and +{DamageBoost} damage against units affected by [abilityred]Fungal Infestion[/abilityred] for {BuffDuration} turns.</Data></Cell><Cell><Data ss:Type="String">Wzmacnia wszystkie przyjazne jednostki mikoliańskie na polu bitwy premiami +{ShieldBuff} [Shield/] i +{DamageBoost} do obrażeń zadawanych jednostkom znajdującym się pod wpływem [abilityred]zagrzybienia[/abilityred] na pewną liczbę tur ({BuffDuration}).</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">MYCELIAN_CONNECTIONS</Data></Cell><Cell><Data ss:Type="String">PROPERTY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Unit is connected with all Mycelians, granting +{ShieldBuff} [Shield/] and +{DamageBoost} damage against units affected by [abilityred]Fungal Infestion[/abilityred].</Data></Cell><Cell><Data ss:Type="String">Jednostka jest połączona z wszystkimi mikolianami, dzięki czemu otrzymuje +{ShieldBuff} [Shield/] i +{DamageBoost} do obrażeń zadawanych jednostkom znajdującym się pod wpływem [abilityred]zagrzybienia[/abilityred].</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FUNGAL_INFESTATION</Data></Cell><Cell><Data ss:Type="String">PROP_NAME</Data></Cell><Cell><Data ss:Type="String">Fungal Infestation</Data></Cell><Cell><Data ss:Type="String">Zagrzybienie</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="60"><Cell><Data ss:Type="String">FUNGAL_INFESTATION</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">MODIFIER_DESCRIPTION</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">{EncaseChance}[StrengthBio/] strength chance to apply [abilityred]Fungal Infestation[/abilityred] for {EncaseDuration}[turn/]. If resisted, this ability causes [abilityred]Stagger[/abilityred] instead.</Data></Cell><Cell><Data ss:Type="String">Szansa ({EncaseChance}[StrengthBio/] siły) na spowodowanie [abilityred]zagrzybienia[/abilityred] na {EncaseDuration}[turn/]. W razie odparcia powoduje w zamian [abilityred]zachwianie[/abilityred].</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell ss:StyleID="s63"><Data ss:Type="String">FUNGAL_INFESTATION</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit is permeated with a fungal infestation, [abilityred]Immobilizing[/abilityred]it. On death, unit explodes in a cloud of toxic spores, damaging all units within 1 hex for {ExplosionDamage}[DamageBio/].</Data></Cell><Cell><Data ss:Type="String">Ta jednostka jest zagrzybiona, co ją [abilityred]unieruchamia[/abilityred]. Ginąc, eksploduje chmurą toksycznych zarodników, co powoduje {ExplosionDamage}[DamageBio/] u wszystkich jednostek w promieniu 1 pola.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s63"><Data ss:Type="String">MYCELIAN</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">Mycelian Unit</Data></Cell><Cell><Data ss:Type="String">Jednostka mikolian</Data></Cell></Row></Table><WorksheetOptions xmlns="urn:schemas-microsoft-com:office:excel"><Unsynced/><Print><ValidPrinterInfo/><HorizontalResolution>600</HorizontalResolution><VerticalResolution>600</VerticalResolution></Print><Selected/><TopRowVisible>15</TopRowVisible><Panes><Pane><Number>3</Number><ActiveRow>22</ActiveRow><ActiveCol>2</ActiveCol></Pane></Panes><ProtectObjects>False</ProtectObjects><ProtectScenarios>False</ProtectScenarios></WorksheetOptions></Worksheet></Workbook>
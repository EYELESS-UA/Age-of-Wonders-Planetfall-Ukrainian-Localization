<?xml version="1.0"?><?mso-application progid="Excel.Sheet"?><Workbook xmlns="urn:schemas-microsoft-com:office:spreadsheet" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns:ss="urn:schemas-microsoft-com:office:spreadsheet" xmlns:html="http://www.w3.org/TR/REC-html40"><DocumentProperties xmlns="urn:schemas-microsoft-com:office:office"><LastAuthor>Djurre van Dijk</LastAuthor><Created>2019-05-06T09:39:32Z</Created><LastSaved>2019-05-06T09:39:32Z</LastSaved><Version>16.00</Version></DocumentProperties><OfficeDocumentSettings xmlns="urn:schemas-microsoft-com:office:office"><AllowPNG/></OfficeDocumentSettings><ExcelWorkbook xmlns="urn:schemas-microsoft-com:office:excel"><WindowHeight>5640</WindowHeight><WindowWidth>15345</WindowWidth><WindowTopX>32767</WindowTopX><WindowTopY>32767</WindowTopY><ProtectStructure>False</ProtectStructure><ProtectWindows>False</ProtectWindows></ExcelWorkbook><Styles><Style ss:ID="Default" ss:Name="Normal"><Alignment ss:Vertical="Bottom"/><Borders/><Font ss:FontName="Calibri" x:Family="Swiss" ss:Size="11" ss:Color="#000000"/><Interior/><NumberFormat/><Protection/></Style><Style ss:ID="s62"><Alignment ss:Vertical="Top" ss:WrapText="1"/></Style></Styles><Worksheet ss:Name="Script"><Table x:FullColumns="1" x:FullRows="1" ss:StyleID="s62" ss:DefaultColumnWidth="239.25" ss:DefaultRowHeight="15"><Row ss:AutoFitHeight="0" ss:Height="120"><Cell><Data ss:Type="String">LASER_TECHGROUPS</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Anything between straight brackets - i.e. [ ] - is a formatting tag. Do not change these tags and keep them in the same relative position in the text. Anything between curly brackets - i.e. { } - is a place where text or numbers will be inserted by the game. Do not change the tag, but feel free to change its position in the text to suit the localized text.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SCENE ID</Data></Cell><Cell><Data ss:Type="String">TEXT ID</Data></Cell><Cell><Data ss:Type="String">ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZATION NOTES</Data></Cell><Cell><Data ss:Type="String">DEV TEAM / MISC NOTES</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">LASER_SKILLS</Data></Cell><Cell><Data ss:Type="String">LASER_WEAPON_SYSTEMS_NAME</Data></Cell><Cell><Data ss:Type="String">Photon Acceleration</Data></Cell><Cell><Data ss:Type="String">Akceleracja fotonów</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">LASER_SKILLS</Data></Cell><Cell><Data ss:Type="String">LASER_WEAPON_SYSTEMS_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">“Don’t think too rigidly. The speed of light is not a constant if you change it.”[br/]– Dr. Millicent Rickles, Head Researcher, Lazilite Inc.</Data></Cell><Cell><Data ss:Type="String">„Wychodźcie poza sztywne ramy rozumowania. Prędkość światła przestaje być stałą, gdy się ją zmieni”.[br/]Dr Millicent Rickles, kierownik działu naukowego, Lazilite Inc.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Female</Data></Cell><Cell><Data ss:Type="String">V.O.: Vanguard Female</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">LASER_SKILLS</Data></Cell><Cell><Data ss:Type="String">DIRECTED_ENERGY_WEAPONS_NAME</Data></Cell><Cell><Data ss:Type="String">Non-Refracting Lasers</Data></Cell><Cell><Data ss:Type="String">Lasery nierefrakcyjne</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">LASER_SKILLS</Data></Cell><Cell><Data ss:Type="String">DIRECTED_ENERGY_WEAPONS_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">“The concept is quite simple really. It’s old medical tech applied to the battlefield. Think of yourself as a surgeon and your enemy is a bad tattoo you need to remove.”[br/]– Mark McNash, CEO Laztech</Data></Cell><Cell><Data ss:Type="String">„Ten pomysł jest w istocie dość prosty. To stara technologia medyczna zaadaptowana na potrzeby pola walki. Wyobraź sobie, że jesteś chirurgiem, a wróg to kiepski tatuaż, który trzeba usunąć”.[br/]Mark McNash, dyrektor naczelny Laztechu</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Male</Data></Cell><Cell><Data ss:Type="String">V.O.: Vanguard Male</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">LASER_SKILLS</Data></Cell><Cell><Data ss:Type="String">LASER_OPTICS_NAME</Data></Cell><Cell><Data ss:Type="String">Crystalline Technology</Data></Cell><Cell><Data ss:Type="String">Technologia kryształów</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">LASER_SKILLS</Data></Cell><Cell><Data ss:Type="String">LASER_OPTICS_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">“Even the most advanced and brutal technology eventually evolves into something dazzlingly beautiful.”[br/]– Varla Prakash, Philosopher</Data></Cell><Cell><Data ss:Type="String">„Nawet technologie najnowocześniejsze i najbardziej brutalne z czasem przekształcają się w coś oszałamiająco pięknego”.[br/]Filozofka Varla Prakash</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Female</Data></Cell><Cell><Data ss:Type="String">V.O.: Amazon Female</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">LASER_SKILLS</Data></Cell><Cell><Data ss:Type="String">STAR_INFUSION_TECHNOLOGY_NAME</Data></Cell><Cell><Data ss:Type="String">Plasma Weaponry</Data></Cell><Cell><Data ss:Type="String">Broń plazmowa</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">LASER_SKILLS</Data></Cell><Cell><Data ss:Type="String">STAR_INFUSION_TECHNOLOGY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">“They say the first lifeforms evolved from primordial stardust. If so, our new weapon is a reset switch. Instead of stardust-life becoming complex life, complex life is reduced to stardust. Just beautiful! The circle of life, I tell ya!”[br/]– Master Gunnery Sergeant Talwar Aag, Vanguard 2nd Landing Division</Data></Cell><Cell><Data ss:Type="String">„Mówi się, że pierwsze organizmy żywe wyewoluowały z pierwotnego pyłu gwiezdnego. Jeśli tak, to nasza nowa broń jest przyciskiem twardego resetu. Zamiast coraz bardziej złożonego życia z gwiezdnego pyłu otrzymujemy gwiezdny pył, który powstał ze złożonego życia. Urocze! To prawdziwy krąg życia!”[br/]Starsza sierżant sztabowa Talwar Aag, 2 Dywizja Desantowa Awangardy</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Female</Data></Cell><Cell><Data ss:Type="String">V.O.: Vanguard Female</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">LASER_SKILLS</Data></Cell><Cell><Data ss:Type="String">OPTICS_AND_LASER_TECHNOLOGY_NAME</Data></Cell><Cell><Data ss:Type="String">Heavy Laser Applications</Data></Cell><Cell><Data ss:Type="String">Zastosowanie ciężkich laserów</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">LASER_SKILLS</Data></Cell><Cell><Data ss:Type="String">OPTICS_AND_LASER_TECHNOLOGY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">“Lasers are fast, accurate and leave no bloody mess—just the delicious smell of fried bacon.”[br/]– Mark McNash, CEO Laztech</Data></Cell><Cell><Data ss:Type="String">„Lasery są szybkie, precyzyjne i nie robią krwawego bałaganu – czuć tylko smakowity zapach smażonego bekonu”.[br/]Mark McNash, dyrektor naczelny Laztechu</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Male</Data></Cell><Cell><Data ss:Type="String">V.O.: Vanguard Male</Data></Cell></Row></Table><WorksheetOptions xmlns="urn:schemas-microsoft-com:office:excel"><Unsynced/><Selected/><Panes><Pane><Number>3</Number><ActiveRow>6</ActiveRow><ActiveCol>3</ActiveCol></Pane></Panes><ProtectObjects>False</ProtectObjects><ProtectScenarios>False</ProtectScenarios></WorksheetOptions></Worksheet></Workbook>
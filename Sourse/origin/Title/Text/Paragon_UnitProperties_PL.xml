<?xml version="1.0"?><?mso-application progid="Excel.Sheet"?><Workbook xmlns="urn:schemas-microsoft-com:office:spreadsheet" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns:ss="urn:schemas-microsoft-com:office:spreadsheet" xmlns:html="http://www.w3.org/TR/REC-html40"><DocumentProperties xmlns="urn:schemas-microsoft-com:office:office"><LastAuthor>Djurre van Dijk</LastAuthor><Created>2019-05-06T09:39:39Z</Created><LastSaved>2019-05-06T09:39:39Z</LastSaved><Version>16.00</Version></DocumentProperties><OfficeDocumentSettings xmlns="urn:schemas-microsoft-com:office:office"><AllowPNG/></OfficeDocumentSettings><ExcelWorkbook xmlns="urn:schemas-microsoft-com:office:excel"><WindowHeight>9990</WindowHeight><WindowWidth>21525</WindowWidth><WindowTopX>32767</WindowTopX><WindowTopY>32767</WindowTopY><RefModeR1C1/><ProtectStructure>False</ProtectStructure><ProtectWindows>False</ProtectWindows></ExcelWorkbook><Styles><Style ss:ID="Default" ss:Name="Normal"><Alignment ss:Vertical="Bottom"/><Borders/><Font ss:FontName="Calibri" x:Family="Swiss" ss:Size="11" ss:Color="#000000"/><Interior/><NumberFormat/><Protection/></Style><Style ss:ID="s62"><Alignment ss:Vertical="Bottom" ss:WrapText="1"/></Style></Styles><Worksheet ss:Name="Script"><Table x:FullColumns="1" x:FullRows="1" ss:DefaultRowHeight="15"><Column ss:AutoFitWidth="0" ss:Width="189"/><Column ss:AutoFitWidth="0" ss:Width="129.75"/><Column ss:StyleID="s62" ss:AutoFitWidth="0" ss:Width="546.75"/><Column ss:StyleID="s62" ss:AutoFitWidth="0" ss:Width="327"/><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PARAGON_UNITPROPERTIES</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">The DEV TEAM / MISC NOTES column contains info on what text between { } signs means (if applicable). It usually stands for either a numeric value, or a numeric value with an icon. Text between [ ] signs stands for a certain type of icon. </Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SCENE ID</Data></Cell><Cell><Data ss:Type="String">TEXT ID</Data></Cell><Cell><Data ss:Type="String">ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZATION NOTES</Data></Cell><Cell><Data ss:Type="String">DEV TEAM / MISC NOTES</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">BLAST_CANNON</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Blast Cannon</Data></Cell><Cell><Data ss:Type="String">Działo wybuchowe</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">BLAST_CANNON</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Fire a heavy blast cannon, dealing damage in a 1 hex radius.</Data></Cell><Cell><Data ss:Type="String">Strzał z ciężkiego działa wybuchowego rażący obszar o promieniu 2 pól.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">CALL_IN_REINFORCEMENTS</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Call in Reinforcements</Data></Cell><Cell><Data ss:Type="String">Wezwanie posiłków</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">CALL_IN_REINFORCEMENTS</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Call in Paragon reinforcements to aid in the battle.</Data></Cell><Cell><Data ss:Type="String">Na pole bitwy przybywają posiłki Wcielenia, by wspomóc cię w walce.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">DEFENSE_BLASTER</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Defense Blaster</Data></Cell><Cell><Data ss:Type="String">Miotacz obronny</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">DEFENSE_BLASTER</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Fire the defensive blaster hidden in the floating throne.</Data></Cell><Cell><Data ss:Type="String">Strzał z miotacza obronnego ukrytego w latającym tronie.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ENERGY_SHIELD</Data></Cell><Cell><Data ss:Type="String">PROPERTY_NAME</Data></Cell><Cell><Data ss:Type="String">Energy Shield</Data></Cell><Cell><Data ss:Type="String">Tarcza energetyczna</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ENERGY_SHIELD</Data></Cell><Cell><Data ss:Type="String">PROPERTY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Flanking attacks against this unit ignore up to {EnergyShields}.</Data></Cell><Cell><Data ss:Type="String">Ataki ze skrzydła na tę jednostkę ignorują do {EnergyShields}.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HEAVY_REPEATER</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Heavy Repeater</Data></Cell><Cell><Data ss:Type="String">Ciężkie działko powtarzalne</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HEAVY_REPEATER</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Fire the Heavy Repeater at the target.</Data></Cell><Cell><Data ss:Type="String">strzela do celu z ciężkiego działka powtarzalnego.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">OVERDRIVE</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Overdrive</Data></Cell><Cell><Data ss:Type="String">Przeciążenie</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">OVERDRIVE</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Hack into target Paragon unit with Imperial Augments, causing them to [abilityblue]Overcharge[/abilityblue], granting them new abilities, increased damage and changing their Kinetic attacks to Arc for {OverchargeDuration}.</Data></Cell><Cell><Data ss:Type="String">Zhakowanie wskazanej jednostki Wcielenia ze wzmocnieniami imperialnymi, skutkuje ich [abilityblue]przeładowaniem[/abilityblue], co daje jednostce nowe umiejętności i premię do obrażeń oraz zmienia jej ataki kinetyczne w elektryczne na {OverchargeDuration}.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">OVERDRIVE_PULSE</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Overdrive Field</Data></Cell><Cell><Data ss:Type="String">Pole przeciążenia</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">OVERDRIVE_PULSE</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">A mass hack into all friendly Paragon units with Imperial Augments, causing them to [abilityblue]Overcharge[/abilityblue], granting the units new abilities, increased damage and changing their Kinetic attacks to Arc for {OverchargeDuration}.</Data></Cell><Cell><Data ss:Type="String">Masowe zhakowanie wszystkich przyjaznych jednostek Wcielenia ze wzmocnieniami imperialnymi, powodujące [abilityblue]przeładowanie[/abilityblue], co daje im nowe umiejętności, premię do obrażeń i zmienia ich ataki kinetyczne w elektryczne na {OverchargeDuration}.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">OVERCHARGE</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Overcharged</Data></Cell><Cell><Data ss:Type="String">Przeładowanie</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">OVERCHARGE</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit now deals Arc damage and becomes more effective. If they become [abilityred]Staggered[/abilityred], they lose this effect.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka zadaje teraz obrażenia elektryczne i staje się skuteczniejsza. Jeśli znajdzie się pod wpływem [abilityred]zachwiania[/abilityred], utraci ten efekt.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">UNSTABLE_AUGMENTS</Data></Cell><Cell><Data ss:Type="String">PROPERTY_NAME</Data></Cell><Cell><Data ss:Type="String">Unstable Augments</Data></Cell><Cell><Data ss:Type="String">Niestabilne wzmocnienia</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">UNSTABLE_AUGMENTS</Data></Cell><Cell><Data ss:Type="String">PROPERTY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">On death, this unit will explode in a {UnstableExplosionRadius} hex radius, dealing {UnstableDamage} damage, and [abilityred]Staggering[/abilityred] those hit.</Data></Cell><Cell><Data ss:Type="String">W chwili śmierci jednostka wybuchnie, rażąc obszar o promieniu {UnstableExplosionRadius} pól, w którym zada {UnstableDamage} pkt. obrażeń i wywoła [abilityred]zachwianie[/abilityred] trafionych jednostek.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PARAGON_BLASTER_PISTOL</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Paragon Blaster Pistol</Data></Cell><Cell><Data ss:Type="String">Miotacz ręczny Wcielenia</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PARAGON_BLASTER_PISTOL</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Fire the Blaster at the target.</Data></Cell><Cell><Data ss:Type="String">Strzela do celu z miotacza ręcznego.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PHASE_AUGMENT</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Activate Phase Augment</Data></Cell><Cell><Data ss:Type="String">Wzmocnienie fazowe</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">PHASE_AUGMENT</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Using their specialized phase augments, this unit can teleport up to {PhaseTeleportRange} hexes away.</Data></Cell><Cell><Data ss:Type="String">Dzięki wzmocnieniom fazowym ta jednostka może teleportować się na odległość do {PhaseTeleportRange} pól.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PULSE_SLAM</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Pulse Slam</Data></Cell><Cell><Data ss:Type="String">Cios impulsowy</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">PULSE_SLAM</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit slams their weapon on the ground, unleashing a pulse wave from their augments that damages all adjacent units.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka uderza bronią w ziemię, a jej wzmocnienia wytwarzają falę uderzeniową, która zadaje obrażenia wszystkim sąsiednim jednostkom.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SHIELD_CHARGE</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Shield Charge</Data></Cell><Cell><Data ss:Type="String">Szarża z tarczą</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">SHIELD_CHARGE</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit charges forward, [abilityred]knocking back[/abilityred] its target and taking its place. Can only target Light units.[br/][br/]Puts the unit into Defense Mode after use.[br/]</Data></Cell><Cell><Data ss:Type="String">Ta jednostka szarżuje naprzód, [abilityred]odpychając[/abilityred] swój cel i zajmując jego miejsce. Można tak atakować tylko jednostki lekkie.[br/][br/]Po użyciu przełącza jednostkę w tryb obronny.[br/]</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SHOCK_SPEAR</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Shock Spear</Data></Cell><Cell><Data ss:Type="String">Przenikliwa włócznia</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SHOCK_SPEAR</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Stab the target with this unit's spear.</Data></Cell><Cell><Data ss:Type="String">Przebija cel włócznią.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TARGETING_JAMMERS</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Targeting Jammers</Data></Cell><Cell><Data ss:Type="String">Zakłócanie celowników</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">TARGETING_JAMMERS</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit is {TargetingAccuracyDecrease} harder to hit with attacks.</Data></Cell><Cell><Data ss:Type="String">Tę jednostka trudniej trafić o {TargetingAccuracyDecrease}.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">WRATH_OF_THE_OLD_MACHINES</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Wrath of the Old Machines</Data></Cell><Cell><Data ss:Type="String">Gniew starych machin</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">WRATH_OF_THE_OLD_MACHINES</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Order an orbiting satellite to blast a {WrathTotalRadius} hex radius, dealing damage and staggering those hit. This damage is reduced the further from the center hex a unit is.</Data></Cell><Cell><Data ss:Type="String">Nakazuje satelicie orbitalnemu ostrzelanie obszaru o promieniu {WrathTotalRadius} pól, co skutkuje zadaniem obrażeń i powoduje zachwianie u wszystkich trafionych jednostek. Wielkość obrażeń maleje wraz ze wzrostem odległości od centrum ostrzelanego obszaru.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">OVERCHARGER_AUGMENT</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Overcharger Augment</Data></Cell><Cell><Data ss:Type="String">Wzmocnienie przeładowania</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">OVERCHARGER_AUGMENT</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Allows the unit to [abilityblue]Overcharge[/abilityblue] themselves, granting them new abilities, increased damage and changing their Kinetic attacks to Arc for {OverchargeDuration}.</Data></Cell><Cell><Data ss:Type="String">Umożliwia jednostce [abilityblue]przeładowanie[/abilityblue] samej siebie, co daje jej nowe umiejętności i premię do obrażeń oraz zmienia jej ataki kinetyczne w elektryczne na {OverchargeDuration}.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">LAUNCH_TORPEDO</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Launch Torpedo</Data></Cell><Cell><Data ss:Type="String">Odpalenie torpedy</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">LAUNCH_TORPEDO</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Launch an Auto-Torpedo.</Data></Cell><Cell><Data ss:Type="String">Wystrzeliwuje torpedę automatyczną.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HEAVY_DECK_GUN</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Heavy Deck Gun</Data></Cell><Cell><Data ss:Type="String">Ciężkie działo pokładowe</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HEAVY_DECK_GUN</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Fire a Heavy Deck Gun at the target.</Data></Cell><Cell><Data ss:Type="String">Strzela do celu z ciężkiego działa pokładowego.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SELF_DESTRUCT</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Self-destruct</Data></Cell><Cell><Data ss:Type="String">Samozniszczenie</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">SELF_DESTRUCT</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Explode, dealing heavy damage to all units adjacent to the torpedo.</Data></Cell><Cell><Data ss:Type="String">Torpeda wybucha, powodując poważne obrażenia u wszystkich jednostek na sąsiednich polach.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">EXTRA_DAMAGE_MECHANICAL</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Extra Damage vs. Mechanical</Data></Cell><Cell><Data ss:Type="String">Dodatkowe obrażenia zadawane jednostkom mechanicznym</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">EXTRA_DAMAGE_MECHANICAL</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">{ExtraMechaDamage} damage against Mechanical units.</Data></Cell><Cell><Data ss:Type="String">{ExtraMechaDamage} pkt. dodatkowych obrażeń w walce z jednostkami mechanicznymi.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">LAUNCH_BLAZE_TORPEDO</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Launch Blaze Torpedo</Data></Cell><Cell><Data ss:Type="String">Odpalenie torpedy zapalającej</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">LAUNCH_BLAZE_TORPEDO</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Launch a Blaze Auto-Torpedo.</Data></Cell><Cell><Data ss:Type="String">Wystrzeliwuje zapalającą torpedę automatyczną.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">INFERNO_SHELL</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Inferno Shell</Data></Cell><Cell><Data ss:Type="String">Piekielny pocisk</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">INFERNO_SHELL</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Fire a shell full of flaming oil, spreading a Thermal Spill around the target unit when hit.</Data></Cell><Cell><Data ss:Type="String">Wystrzeliwuje napełniony płonącą ropą pocisk, który po trafieniu powoduje ognisty rozprysk wokół zaatakowanej jednostki.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">BLAZE_SELF_DESTRUCT</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Blaze Self-destruct</Data></Cell><Cell><Data ss:Type="String">Ogniste samozniszczenie</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">BLAZE_SELF_DESTRUCT</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Explode, dealing Thermal damage to all units adjacent to the torpedo and creating a hazard in the water.</Data></Cell><Cell><Data ss:Type="String">Torpeda wybucha, powodując poważne obrażenia cieplne u wszystkich jednostek na sąsiednich polach i tworząc zagrożenie w wodzie.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">RAILGUN_CANNON</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Railgun Cannon</Data></Cell><Cell><Data ss:Type="String">Działo magnetyczne</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">RAILGUN_CANNON</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Fire a Railgun at the target.</Data></Cell><Cell><Data ss:Type="String">Strzela do celu z działa magnetycznego.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SMOKESCREEN</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Smokescreen</Data></Cell><Cell><Data ss:Type="String">Zasłona dymna</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SMOKESCREEN</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Disperse smoke around the unit, [abilityblue]Concealing[/abilityblue] it and adjacent units, making them {AccObscure} harder to hit.</Data></Cell><Cell><Data ss:Type="String">Wytwarza chmurę dymu wokół jednostki, [abilityblue]maskując[/abilityblue] ją wraz z jednostkami sąsiednimi, dzięki czemu trudniej je trafić o {AccObscure}.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">REPAIR_NANITES</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Repair Nanites</Data></Cell><Cell><Data ss:Type="String">Nanity naprawcze</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">REPAIR_NANITES</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Spread nanites over a {hexrad} hex radius area that heals units for {RepairNanitesAmount}[HP/].</Data></Cell><Cell><Data ss:Type="String">Obsypuje obszar o promieniu {hexrad} pól nanitami, które przywracają jednostkom {RepairNanitesAmount}[HP/].</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">THERMAL_SPILL</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Thermal Spill</Data></Cell><Cell><Data ss:Type="String">Ognisty rozprysk</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">THERMAL_SPILL</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Deal {ThermalSpill} damage to units that move through or end their turn in this hazard.</Data></Cell><Cell><Data ss:Type="String">Zadaje {ThermalSpill} pkt. obrażeń jednostkom, które przejdą przez to zagrożenie lub zakończą w nim turę.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">MALFUNCTIONING</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Malfunctioning</Data></Cell><Cell><Data ss:Type="String">Awaria</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">MALFUNCTIONING</Data></Cell><Cell><Data ss:Type="String">PROPERTY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit cannot act this turn.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka nie może działać w tej turze.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">IMPERIAL_AUGMENTS</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Imperial Augments</Data></Cell><Cell><Data ss:Type="String">Wzmocnienia imperialne</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">IMPERIAL_AUGMENTS</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This Cyborg is mostly composed of weakened augments and parts. If Overcharged, this unit gains increased attack, deals Arc damage and may gain additional abilities.</Data></Cell><Cell><Data ss:Type="String">Ten cyborg składa się głównie z osłabionych wzmocnień i części. Jeśli zostanie przeładowany, otrzyma premię do siły ataku, będzie zadawać obrażenia elektryczne i może uzyskać dodatkowe umiejętności.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">AUGMENTED_ASSAULT</Data></Cell><Cell><Data ss:Type="String">PROPERTY_NAME</Data></Cell><Cell><Data ss:Type="String">Augmented Assault</Data></Cell><Cell><Data ss:Type="String">Wzmocniony szturm</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">AUGMENTED_ASSAULT</Data></Cell><Cell><Data ss:Type="String">PROPERTY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit gains Fast movement, one level of Stagger Resistance and +{OverchargeShields}[shield/].</Data></Cell><Cell><Data ss:Type="String">Ta jednostka uzyskuje szybki ruch, jeden poziom odporności na zachwianie i +{OverchargeShields}[shield/].</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SMART_ROUNDS</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Smart Rounds</Data></Cell><Cell><Data ss:Type="String">Inteligentna amunicja</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SMART_ROUNDS</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">When shooting at a target, this unit's Firearm attacks ignore cover and unit in the way penalties.</Data></Cell><Cell><Data ss:Type="String">Podczas ostrzeliwania celu broń palna tej jednostki ignoruje kary powodowane przez osłony i jednostki na linii strzału.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">REACTIVE_SHIELDING</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Reactive Shielding</Data></Cell><Cell><Data ss:Type="String">Reaktywna tarcza</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">REACTIVE_SHIELDING</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Whenever this unit is struck by a ranged attack, it gains +{ShieldReact}, for {ShieldReactTurn}. This effect can stack.</Data></Cell><Cell><Data ss:Type="String">Gdy ta jednostka zostaje trafiona atakiem dystansowym, uzyskuje +{ShieldReact} na {ShieldReactTurn}. Ten efekt może się sumować.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">REACTIVE_SHIELDING</Data></Cell><Cell><Data ss:Type="String">PROP_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit has +{ShieldReact} per stack.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka ma +{ShieldReact} na poziom.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">COMBAT_PROTOCOL_IMPLANTS</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Combat Protocol Implants</Data></Cell><Cell><Data ss:Type="String">Wszczepy protokołu bojowego</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">COMBAT_PROTOCOL_IMPLANTS</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">These implants make the unit quicker on the battlefield, granting it {CombatImplantsAccCrit} increased accuracy and critical hit chance, as well as making this unit {CombatImplantEvasion} harder to hit.</Data></Cell><Cell><Data ss:Type="String">Dzięki tym wszczepom jednostka na polu bitwy jest szybsza, co zapewnia jej {CombatImplantsAccCrit} do celności i szansy na trafienie krytyczne oraz sprawia, że trudniej ją trafić o {CombatImplantEvasion}.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">APC_TACTICAL_SCANNERS</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">APC Tactical Scanners</Data></Cell><Cell><Data ss:Type="String">Transporter: skanery taktyczne</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">APC_TACTICAL_SCANNERS</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Start the APC scanners up to give targeting information to all friendly units, increasing both accuracy by {APCScannerACC} and morale by {APCScannerMorale} for {APCScannersTurn}[turn/].</Data></Cell><Cell><Data ss:Type="String">Uruchamia skanery taktyczne transportera opancerzonego, by dostarczyć wszystkim przyjaznym jednostkom informacje o celu, co  na {APCScannersTurn}[turn/] zwiększa ich celność o {APCScannerACC} i morale o {APCScannerMorale}.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">APC_TACTICAL_SCANNERS</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION_EFFECT</Data></Cell><Cell><Data ss:Type="String">This unit has {APCScannerACC} increased accuracy and +{APCScannerMorale}.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka ma {APCScannerACC} do celności i +{APCScannerMorale}.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">APC_TACTICAL_RETREAT</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">APC Tactical Retreat</Data></Cell><Cell><Data ss:Type="String">Transporter: taktyczny odwrót</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">APC_TACTICAL_RETREAT</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Target a friendly unit, telling it to leave combat.[br/][br/]Only works when this unit is the attacker in tactical combat.</Data></Cell><Cell><Data ss:Type="String">Nakazuje przyjaznej jednostce opuszczenie walki.[br/][br/]Działa tylko wtedy, gdy wskazana jednostka należy do strony atakującej w walce taktycznej.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">REACTIVE_SHIELDING</Data></Cell><Cell><Data ss:Type="String">TEMPLATE_NAME_1</Data></Cell><Cell><Data ss:Type="String">Reactive</Data></Cell><Cell><Data ss:Type="String">Reaktywność</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">REACTIVE_SHIELDING</Data></Cell><Cell><Data ss:Type="String">TEMPLATE_NAME_2</Data></Cell><Cell><Data ss:Type="String">Pre-shielded</Data></Cell><Cell><Data ss:Type="String">Osłona wstępna</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">REACTIVE_SHIELDING</Data></Cell><Cell><Data ss:Type="String">TEMPLATE_NAME_3</Data></Cell><Cell><Data ss:Type="String">Safeguard</Data></Cell><Cell><Data ss:Type="String">Zabezpieczenie</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">REACTIVE_SHIELDING</Data></Cell><Cell><Data ss:Type="String">TEMPLATE_NAME_4</Data></Cell><Cell><Data ss:Type="String">Preventive</Data></Cell><Cell><Data ss:Type="String">Przeciwdziałanie</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">REACTIVE_SHIELDING</Data></Cell><Cell><Data ss:Type="String">TEMPLATE_NAME_5</Data></Cell><Cell><Data ss:Type="String">Holo Screen</Data></Cell><Cell><Data ss:Type="String">Osłona holograficzna</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">REACTIVE_SHIELDING</Data></Cell><Cell><Data ss:Type="String">TEMPLATE_NAME_6</Data></Cell><Cell><Data ss:Type="String">Shield Grid</Data></Cell><Cell><Data ss:Type="String">Tarcza sieciowa</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">COMBAT_PROTOCOL_IMPLANTS</Data></Cell><Cell><Data ss:Type="String">TEMPLATE_NAME_1</Data></Cell><Cell><Data ss:Type="String">Routinary</Data></Cell><Cell><Data ss:Type="String">Rutyna</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">COMBAT_PROTOCOL_IMPLANTS</Data></Cell><Cell><Data ss:Type="String">TEMPLATE_NAME_2</Data></Cell><Cell><Data ss:Type="String">Regimen</Data></Cell><Cell><Data ss:Type="String">Reżim</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">COMBAT_PROTOCOL_IMPLANTS</Data></Cell><Cell><Data ss:Type="String">TEMPLATE_NAME_3</Data></Cell><Cell><Data ss:Type="String">Drilled</Data></Cell><Cell><Data ss:Type="String">Trening</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">COMBAT_PROTOCOL_IMPLANTS</Data></Cell><Cell><Data ss:Type="String">TEMPLATE_NAME_4</Data></Cell><Cell><Data ss:Type="String">Disciplined</Data></Cell><Cell><Data ss:Type="String">Rygor</Data></Cell></Row><Row ss:AutoFi
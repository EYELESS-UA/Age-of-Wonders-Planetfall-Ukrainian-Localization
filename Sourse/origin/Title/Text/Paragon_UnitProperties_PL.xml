ata></Cell><Cell><Data ss:Type="String">Zachwyt</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">OVERCHARGER_AUGMENT</Data></Cell><Cell><Data ss:Type="String">TEMPLATE_NAME_6</Data></Cell><Cell><Data ss:Type="String">Packed</Data></Cell><Cell><Data ss:Type="String">Spełnienie</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SMART_ROUNDS</Data></Cell><Cell><Data ss:Type="String">TEMPLATE_NAME_1</Data></Cell><Cell><Data ss:Type="String">Stargazer</Data></Cell><Cell><Data ss:Type="String">Orientacja gwiezdna</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SMART_ROUNDS</Data></Cell><Cell><Data ss:Type="String">TEMPLATE_NAME_2</Data></Cell><Cell><Data ss:Type="String">Gun Bender</Data></Cell><Cell><Data ss:Type="String">Działo naprowadzające</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SMART_ROUNDS</Data></Cell><Cell><Data ss:Type="String">TEMPLATE_NAME_3</Data></Cell><Cell><Data ss:Type="String">Trace Curver</Data></Cell><Cell><Data ss:Type="String">Zakrzywienie</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SMART_ROUNDS</Data></Cell><Cell><Data ss:Type="String">TEMPLATE_NAME_4</Data></Cell><Cell><Data ss:Type="String">Trajectory</Data></Cell><Cell><Data ss:Type="String">Trajektoria</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SMART_ROUNDS</Data></Cell><Cell><Data ss:Type="String">TEMPLATE_NAME_5</Data></Cell><Cell><Data ss:Type="String">Gambit</Data></Cell><Cell><Data ss:Type="String">Gambit</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SMART_ROUNDS</Data></Cell><Cell><Data ss:Type="String">TEMPLATE_NAME_6</Data></Cell><Cell><Data ss:Type="String">Omnimarker</Data></Cell><Cell><Data ss:Type="String">Wszechznacznik</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PEACEKEEPER_TURRET</Data></Cell><Cell><Data ss:Type="String">ABILITY_NAME</Data></Cell><Cell><Data ss:Type="String">Fire Peacekeeper Burst</Data></Cell><Cell><Data ss:Type="String">Salwa rozjemcy</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PEACEKEEPER_TURRET</Data></Cell><Cell><Data ss:Type="String">ABILITY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Fire a burst from the Peacekeeper turret's six barrels.</Data></Cell><Cell><Data ss:Type="String">Odpala salwę z sześciolufowej wieżyczki rozjemcy.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TIME_RAVAGED</Data></Cell><Cell><Data ss:Type="String">PROPERTY_NAME</Data></Cell><Cell><Data ss:Type="String">Time Ravaged</Data></Cell><Cell><Data ss:Type="String">Staroć</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TIME_RAVAGED</Data></Cell><Cell><Data ss:Type="String">PROPERTY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Time has not been kind to this unit, at the start of every turn it has a {MalfunctionChance} strength chance to suffer [abilityred]Malfunctioning[/abilityred].</Data></Cell><Cell><Data ss:Type="String">Czas nie był łaskaw dla tej jednostki. Na początku każdej tury istnieje szansa (siła {MalfunctionChance}), że ulegnie ona [abilityred]awarii[/abilityred].</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">APC_TACTICAL_SCANNERS</Data></Cell><Cell><Data ss:Type="String">NAME_EFFECT</Data></Cell><Cell><Data ss:Type="String">APC Tactical Scanner Support</Data></Cell><Cell><Data ss:Type="String">Wsparcie skanerów taktycznych transportera</Data></Cell></Row><Row><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell><Cell ss:Index="7"><Data ss:Type="String">In the text below, any inserted strings - anything of the form {text} - is replaced by an integer value for the thing described in the brackets. If the {text} is not followed by a unit - e.g. shields, hitpoints - the icon for the unit is inserted together with the integer. The same holds for symbols - e.g. '+', '%' - which are occasionally inserted together with the integer.</Data></Cell></Row><Row><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell><Cell ss:Index="7"><Data ss:Type="String">For references to game terminology and in-world references, please check the glossary delivered as part of the documentation.</Data></Cell></Row></Table><WorksheetOptions xmlns="urn:schemas-microsoft-com:office:excel"><Unsynced/><Selected/><TopRowVisible>36</TopRowVisible><Panes><Pane><Number>3</Number><ActiveRow>47</ActiveRow><ActiveCol>2</ActiveCol></Pane></Panes><ProtectObjects>False</ProtectObjects><ProtectScenarios>False</ProtectScenarios></WorksheetOptions></Worksheet></Workbook>
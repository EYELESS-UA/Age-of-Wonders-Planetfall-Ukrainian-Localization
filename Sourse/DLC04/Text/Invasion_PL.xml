<?xml version="1.0"?><?mso-application progid="Excel.Sheet"?><Workbook xmlns="urn:schemas-microsoft-com:office:spreadsheet" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns:ss="urn:schemas-microsoft-com:office:spreadsheet" xmlns:html="http://www.w3.org/TR/REC-html40"><DocumentProperties xmlns="urn:schemas-microsoft-com:office:office"><Author>GameScribes4</Author><LastAuthor>GameScribes4</LastAuthor><Created>2020-04-11T02:33:26Z</Created><LastSaved>2020-02-05T11:02:35Z</LastSaved><Version>16.00</Version></DocumentProperties><OfficeDocumentSettings xmlns="urn:schemas-microsoft-com:office:office"><AllowPNG/></OfficeDocumentSettings><ExcelWorkbook xmlns="urn:schemas-microsoft-com:office:excel"><WindowHeight>10215</WindowHeight><WindowWidth>21570</WindowWidth><WindowTopX>32767</WindowTopX><WindowTopY>32767</WindowTopY><RefModeR1C1/><ProtectStructure>False</ProtectStructure><ProtectWindows>False</ProtectWindows></ExcelWorkbook><Styles><Style ss:ID="Default" ss:Name="Normal"><Alignment ss:Vertical="Bottom"/><Borders/><Font ss:FontName="Calibri" x:Family="Swiss" ss:Size="11" ss:Color="#000000"/><Interior/><NumberFormat/><Protection/></Style><Style ss:ID="s62"><Alignment ss:Vertical="Top" ss:WrapText="1"/></Style><Style ss:ID="s63"><Font ss:FontName="Arial" x:Family="Swiss" ss:Color="#000000"/></Style></Styles><Worksheet ss:Name="Script"><Table x:FullColumns="1" x:FullRows="1" ss:StyleID="s62" ss:DefaultColumnWidth="288.75" ss:DefaultRowHeight="15"><Column ss:StyleID="s62" ss:Width="142.5"/><Column ss:StyleID="s62" ss:AutoFitWidth="0" ss:Width="96"/><Column ss:StyleID="s62" ss:AutoFitWidth="0" ss:Width="384.75" ss:Span="1"/><Column ss:Index="5" ss:StyleID="s62" ss:Width="283.5"/><Column ss:StyleID="s62" ss:Width="120.75"/><Row ss:AutoFitHeight="0" ss:Height="75"><Cell><Data ss:Type="String">INVASION</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">The DEV TEAM / MISC NOTES column contains info on what text between { } signs means (if applicable). It usually stands for either a numeric value, or a numeric value with an icon. Text between [ ] signs stands for a certain type of icon. </Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">SCENE ID</Data></Cell><Cell><Data ss:Type="String">TEXT ID</Data></Cell><Cell><Data ss:Type="String">ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZATION NOTES</Data></Cell><Cell><Data ss:Type="String">DEV TEAM / MISC NOTES</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">INVASION</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Invasion of the Voidbringers</Data></Cell><Cell><Data ss:Type="String">Inwazja Głębicieli</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Title of an event. The Voidbringers are an in-game faction of evil aliens attacking the planet</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">INVASION</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Placeholder description invasion</Data></Cell><Cell><Data ss:Type="String">Miejsce na opis inwazji</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">INVASION_SETTING_LATE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Late</Data></Cell><Cell><Data ss:Type="String">Późna</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Game setting. Indication of what time an invasion can happen.</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">INVASION_SETTING_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">The invasion will happen around turn {turn}.</Data></Cell><Cell><Data ss:Type="String">Inwazja nastąpi około {turn}. tury.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Elaboration of the above.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FORESHADOWING_1</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">An Unidentified Force</Data></Cell><Cell><Data ss:Type="String">Niezidentyfikowana siła</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Title of an event.</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">FORESHADOWING_1</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">An unidentified force of hostiles has been reported close to our empire. We should deal with them to find out more about their origin.</Data></Cell><Cell><Data ss:Type="String">Doniesiono, że do naszego imperium zbliża się grupa niezidentyfikowanych wrogów. Powinniśmy się tym zająć, aby poznać ich pochodzenie.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Description of an event.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FORESHADOWING_2</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">The Beacon has Landed</Data></Cell><Cell><Data ss:Type="String">Sygnalizator wylądował</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Title of an event.</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">FORESHADOWING_2</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">A Voidbringer Beacon has landed, destroying an entire sector. There seems to be an impenetrable barrier around it.</Data></Cell><Cell><Data ss:Type="String">Sygnalizator Głębicieli wylądował na planecie, niszcząc cały sektor. Miejsce lądowania jest osłonięte jakąś nieprzenikliwą barierą.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Description of an event.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">INVASION_START</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">The Invasion Begins</Data></Cell><Cell><Data ss:Type="String">Początek inwazji</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Title of an event.</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="105"><Cell><Data ss:Type="String">INVASION_START</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">All over this world, mysterious shards have crashed onto the surface, seemingly called by the Beacon that came down recently.[br/][br/]Voidbringer creatures emerge from these shards. Along with them walk armies of Enthralled units completely reliant on their Voidbringer overlords.[br/][br/]If we hope to stand a chance, we need to destroy enough of these Voidbringer Spawners so the Beacon is vulnerable, before raiding and destroying the Beacon.</Data></Cell><Cell><Data ss:Type="String">Na całym świecie w powierzchnię uderzyły tajemnicze odłamki, prawdopodobnie przywołane przez sygnalizator, który niedawno wylądował na planecie.[br/][br/]Z odłamków wynurzają się stwory Głębicieli. U ich boku maszeruje armia zniewolonych jednostek, całkowicie uzależnionych od swoich panów-Głębicieli.[br/][br/]Jeśli mamy mieć nadzieję na stawienie oporu, musimy zniszczyć te zasobniki Głębicieli, aby można było zaatakować to, co je wezwało. Należy to koniecznie zrobić przed szturmem na sygnalizator.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Description of an event.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">DARKVOID_BEACON</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Voidbringer Beacon</Data></Cell><Cell><Data ss:Type="String">Sygnalizator Głębicieli</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Structure name.</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">DARKVOID_BEACON</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">A mysterious, looming beacon that appears to send signals off world.</Data></Cell><Cell><Data ss:Type="String">Tajemniczy, olbrzymi obiekt, który najwyraźniej wysyła jakieś sygnały w kosmos.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Structure description</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">DARKVOID_SPAWNER</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">Voidbringer Spawner</Data></Cell><Cell><Data ss:Type="String">Zasobnik Głębicieli</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Structure name.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">DARKVOID_SPAWNER</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">A vessel carrying Voidbringer units.</Data></Cell><Cell><Data ss:Type="String">Pojazd przenoszący jednostki Głębicieli.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Structure description</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">DARKVOID_JOIN</Data></Cell><Cell><Data ss:Type="String">EVENT_TITLE</Data></Cell><Cell><Data ss:Type="String">Voidbringer Demand</Data></Cell><Cell><Data ss:Type="String">Żądanie Głębicieli</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Event title where the Voidbringers demand you join their cause</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="105"><Cell><Data ss:Type="String">DARKVOID_JOIN</Data></Cell><Cell><Data ss:Type="String">TEXT</Data></Cell><Cell><Data ss:Type="String">As if invading your mind, one of the Voidbringers approaches you.[br/][br/]You feel an urge to join them in their conquest to destroy this world.[br/][br/][abilityred]Joining the Voidbringers will stop them from attacking your empire. This creates alliances with all Commanders that joined the Voidbringers, and war with those that have not.[abilityred/]</Data></Cell><Cell><Data ss:Type="String">Jakby wdzierając się do twego umysłu, jeden z Głębicieli zbliża się do ciebie.[br/][br/]Czujesz zagadkowy przymus przyłączenia się do nich i pomagania im w zniszczeniu tego świata.[br/][br/][abilityred]Przyłączenie się do Głębicieli sprawi, że przestaną oni atakować twoje imperium. Spowoduje to automatyczne utworzenie przymierzy ze wszystkimi innymi dowódcami, którzy przyłączyli się do Głębicieli, i rozpoczęcie wojny z tymi, którzy tego nie uczynili.[abilityred/]</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Event text where the Voidbringers demand you join their cause</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">DARKVOID_JOIN</Data></Cell><Cell><Data ss:Type="String">JOIN_BUTTON</Data></Cell><Cell><Data ss:Type="String">Give in and join</Data></Cell><Cell><Data ss:Type="String">Poddaj się i przyłącz</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Reply button</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">DARKVOID_JOIN</Data></Cell><Cell><Data ss:Type="String">JOIN_TOOLTIP</Data></Cell><Cell><Data ss:Type="String">You will join the Voidbringers. This will trigger instant war with all NPC Factions and any Commander that hasn’t joined the Voidbringers.</Data></Cell><Cell><Data ss:Type="String">Przyłączasz się do Głębicieli. Spowoduje to natychmiastową wojnę ze wszystkimi innymi dowódcami, którzy się nie przyłączyli.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Reply button tooltip</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">DARKVOID_JOIN</Data></Cell><Cell><Data ss:Type="String">RESIST_BUTTON</Data></Cell><Cell><Data ss:Type="String">Resist and fight</Data></Cell><Cell><Data ss:Type="String">Staw opór i walcz</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Reply button</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">DARKVOID_JOIN</Data></Cell><Cell><Data ss:Type="String">RESIST_TOOLTIP</Data></Cell><Cell><Data ss:Type="String">You will not join the Voidbringers, and will have to fight them off.</Data></Cell><Cell><Data ss:Type="String">Nie przyłączasz się do Głębicieli i musisz toczyć z nimi walkę.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Reply button tooltip</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FORM_PSIONIC</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Psionic Form</Data></Cell><Cell><Data ss:Type="String">Forma psioniczna</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Voidbringers form name</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="60"><Cell><Data ss:Type="String">FORM_PSIONIC</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Voidbringers of this form lean heavily into Psionic abilities. They resist all damage channels except Biochemical. The Thralls of these Voidbringers are mostly units with Psionic abilities.</Data></Cell><Cell><Data ss:Type="String">Głębiciele mający tę postać polegają całkowicie na umiejętnościach psionicznych. Są odporni na wszystkie kanały obrażeń poza biochemicznymi. Niewolnikami takich Głębicieli są głównie jednostki także dysponujące mocami psionicznymi.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Thralls are units controlled by the Voidbringers.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FORM_ARC</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">Arc Form</Data></Cell><Cell><Data ss:Type="String">Forma elektryczna</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Voidbringers form name</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="60"><Cell><Data ss:Type="String">FORM_ARC</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Voidbringers of this form lean heavily into Arc abilities. They resist all damage channels except Psionic. The Thralls of these Voidbringers are mostly units with Arc abilities.</Data></Cell><Cell><Data ss:Type="String">Głębiciele mający tę postać polegają całkowicie na umiejętnościach elektrycznych. Są odporni na wszystkie kanały obrażeń poza psionicznymi. Niewolnikami takich Głębicieli są głównie jednostki także dysponujące umiejętnościami elektrycznymi.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Thralls are units controlled by the Voidbringers.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FORM_BIOCHEMICAL</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Biochemical Form</Data></Cell><Cell><Data ss:Type="String">Forma biochemiczna</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Voidbringers form name</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="60"><Cell><Data ss:Type="String">FORM_BIOCHEMICAL</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Voidbringers of this form lean heavily into Biochemical abilities. They resist all damage channels except Thermal. The Thralls of these Voidbringers are mostly units with Biochemical abilities.</Data></Cell><Cell><Data ss:Type="String">Głębiciele mający tę postać polegają całkowicie na umiejętnościach biochemicznych. Są odporni na wszystkie kanały obrażeń poza cieplnymi. Niewolnikami takich Głębicieli są głównie jednostki także dysponujące umiejętnościami biochemicznymi.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Thralls are units controlled by the Voidbringers.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FORM_THERMAL</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Thermal Form</Data></Cell><Cell><Data ss:Type="String">Forma cieplna</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Voidbringers form name</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">FORM_THERMAL</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Voidbringers of this form lean heavily into Thermal abilities. They resist all damage channels except Arc. The Thralls of these Voidbringers are mostly units with Thermal abilities.</Data></Cell><Cell><Data ss:Type="String">Głębiciele mający tę postać polegają całkowicie na umiejętnościach cieplnych. Są odporni na wszystkie kanały obrażeń poza elektrycznymi. Niewolnikami takich Głębicieli są głównie jednostki także dysponujące mocami cieplnymi.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Thralls are units controlled by the Voidbringers.</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">INVASION_SETTING_NORMAL</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Normal</Data></Cell><Cell><Data ss:Type="String">Normalna</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Game setting. Indication of what time an invasion can happen.</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">INVASION_SETTING_LATEST</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Latest</Data></Cell><Cell><Data ss:Type="String">Jak najpóźniej</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Game setting. Indication of what time an invasion can happen.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PLAYER_JOINED_DARKVOID</Data></Cell><Cell><Data ss:Type="String">EVENT_NAME</Data></Cell><Cell><Data ss:Type="String">{STR_LeaderName} has joined the Voidbringers</Data></Cell><Cell><Data ss:Type="String">{STR_LeaderName} przyłącza się do Głębicieli</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">a player joined the Voidbringers invasion</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SPAWNER_SPAWNED</Data></Cell><Cell><Data ss:Type="String">EVENT_NAME</Data></Cell><Cell><Data ss:Type="String">Voidbringers Spawner has landed</Data></Cell><Cell><Data ss:Type="String">Wylądował zasobnik Głębicieli</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">event title for when a spawner landed</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SPAWNER_WARNING</Data></Cell><Cell><Data ss:Type="String">EVENT_NAME</Data></Cell><Cell><Data ss:Type="String">Warning! Voidbringers Spawner drop location detected</Data></Cell><Cell><Data ss:Type="String">Uwaga! Wykryto miejsce lądowania zasobnika Głębicieli.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Event title for when a spawner is about to land</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">INVASION_SETTING_EARLIEST</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Earliest</Data></Cell><Cell><Data ss:Type="String">Najwcześniej</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Game setting. Indication of what time an invasion can happen.</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">INVASION_SETTING_EARLY</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Early</Data></Cell><Cell><Data ss:Type="String">Wcześnie</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Game setting. Indication of what time an invasion can happen.</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">FORM_PSIONIC</Data></Cell><Cell><Data ss:Type="String">FACTION_NAME_01</Data></Cell><Cell><Data ss:Type="String">The Black Mindbreakers</Data></Cell><Cell><Data ss:Type="String">Czarni Łamacze Umysłów</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Name for a Psionic based Voidbringer sub-faction. If no perfect translation can be achieved, try to make the name relate to the Psionic form as much as possible</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">FORM_PSIONIC</Data></Cell><Cell><Data ss:Type="String">FACTION_NAME_02</Data></Cell><Cell><Data ss:Type="String">The Psi-Rending Overlords</Data></Cell><Cell><Data ss:Type="String">Psioniczni Suwereni</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Name for a Psionic based Voidbringer sub-faction</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">FORM_PSIONIC</Data></Cell><Cell><Data ss:Type="String">FACTION_NAME_03</Data></Cell><Cell><Data ss:Type="String">The Hollow Thoughtrippers</Data></Cell><Cell><Data ss:Type="String">Rozpruwacze Myśli</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Name for a Psionic based Voidbringer sub-faction</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">FORM_PSIONIC</Data></Cell><Cell><Data ss:Type="String">FACTION_NAME_04</Data></Cell><Cell><Data ss:Type="String">The Willbenders</Data></Cell><Cell><Data ss:Type="String">Naginacze Woli</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Name for a Psionic based Voidbringer sub-faction</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">FORM_PSIONIC</Data></Cell><Cell><Data ss:Type="String">FACTION_NAME_05</Data></Cell><Cell><Data ss:Type="String">The Otherworldy Crucifiers</Data></Cell><Cell><Data ss:Type="String">Nieziemscy Dręczyciele</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Name for a Psionic based Voidbringer sub-faction</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">FORM_PSIONIC</Data></Cell><Cell><Data ss:Type="String">FACTION_NAME_06</Data></Cell><Cell><Data ss:Type="String">The Preternatural Occult</Data></Cell><Cell><Data ss:Type="String">Nadnaturalni Okultyści</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Nam
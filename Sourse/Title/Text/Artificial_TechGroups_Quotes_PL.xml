<?xml version="1.0"?><?mso-application progid="Excel.Sheet"?><Workbook xmlns="urn:schemas-microsoft-com:office:spreadsheet" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns:ss="urn:schemas-microsoft-com:office:spreadsheet" xmlns:html="http://www.w3.org/TR/REC-html40"><DocumentProperties xmlns="urn:schemas-microsoft-com:office:office"><LastAuthor>Djurre van Dijk</LastAuthor><Created>2019-05-06T09:39:08Z</Created><LastSaved>2019-05-06T09:39:08Z</LastSaved><Version>16.00</Version></DocumentProperties><OfficeDocumentSettings xmlns="urn:schemas-microsoft-com:office:office"><AllowPNG/></OfficeDocumentSettings><ExcelWorkbook xmlns="urn:schemas-microsoft-com:office:excel"><WindowHeight>9750</WindowHeight><WindowWidth>13170</WindowWidth><WindowTopX>32767</WindowTopX><WindowTopY>32767</WindowTopY><ProtectStructure>False</ProtectStructure><ProtectWindows>False</ProtectWindows></ExcelWorkbook><Styles><Style ss:ID="Default" ss:Name="Normal"><Alignment ss:Vertical="Bottom"/><Borders/><Font ss:FontName="Calibri" x:Family="Swiss" ss:Size="11" ss:Color="#000000"/><Interior/><NumberFormat/><Protection/></Style><Style ss:ID="s62"><Alignment ss:Vertical="Top" ss:WrapText="1"/></Style><Style ss:ID="s63"><Alignment ss:Vertical="Bottom" ss:WrapText="1"/></Style><Style ss:ID="s64"><Alignment ss:Vertical="Top" ss:WrapText="1"/><Borders/><Font ss:FontName="Calibri" x:Family="Swiss" ss:Size="11" ss:Color="#000000"/><Interior/><NumberFormat/><Protection/></Style></Styles><Worksheet ss:Name="Script"><Table x:FullColumns="1" x:FullRows="1" ss:StyleID="s62" ss:DefaultColumnWidth="240.75" ss:DefaultRowHeight="15"><Column ss:StyleID="s62" ss:Width="123.75"/><Column ss:StyleID="s62" ss:Width="214.5"/><Column ss:Index="4" ss:StyleID="s62" ss:Width="147.75"/><Column ss:Index="6" ss:StyleID="s62" ss:Width="120"/><Row ss:AutoFitHeight="0" ss:Height="120"><Cell><Data ss:Type="String">ARTIFICIAL_TECHGROUPS</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Anything between straight brackets - i.e. [ ] - is a formatting tag. Do not change these tags and keep them in the same relative position in the text. Anything between curly brackets - i.e. { } - is a place where text or numbers will be inserted by the game. Do not change the tag, but feel free to change its position in the text to suit the localized text.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SCENE ID</Data></Cell><Cell><Data ss:Type="String">TEXT ID</Data></Cell><Cell><Data ss:Type="String">ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZATION NOTES</Data></Cell><Cell><Data ss:Type="String">DEV TEAM / MISC NOTES</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">ARTIFICIAL</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Synthesis</Data></Cell><Cell><Data ss:Type="String">Synteza</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="60"><Cell><Data ss:Type="String">ARTIFICIAL</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">{XML_ARTIFICIAL_TECHGROUPS@ARTIFICIAL@DESC}[br/][br/]{XML_ARTIFICIAL_TECHGROUPS@ARTIFICIAL@FEATURES}</Data></Cell><Cell><Data ss:Type="String">{XML_ARTIFICIAL_TECHGROUPS@ARTIFICIAL@DESC}[br/][br/]{XML_ARTIFICIAL_TECHGROUPS@ARTIFICIAL@FEATURES}</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">No need to translate. This inserts the ARTIFICIAL_TECHGROUPS@ARTIFICIAL@DESC and ARTIFICIAL_TECHGROUPS@ARTIFICIAL@FEATURES texts with some white space.</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">ARTIFICIAL</Data></Cell><Cell><Data ss:Type="String">DESC</Data></Cell><Cell><Data ss:Type="String">[hyperlink,000003AC0000032D]Synthesis[/hyperlink] manipulates AIs to their advantage, hacking and compromising systems for their own gain.</Data></Cell><Cell><Data ss:Type="String">[hyperlink,000003AC0000032D]Synteza[/hyperlink] manipuluje SI i wykorzystuje systemy informatyczne do własnych celów.</Data></Cell><Cell ss:Index="8"><Data ss:Type="String">Edit: AI's -&gt; Ais</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="105"><Cell><Data ss:Type="String">ARTIFICIAL</Data></Cell><Cell><Data ss:Type="String">FEATURES</Data></Cell><Cell><Data ss:Type="String">[bulletlist][bullet][sand]Starting Unit:[/sand] [hyperlink,unitlookup0000039A00000DB3]Hacker[/hyperlink][/bullet][bullet]Deploy AI daemons in battle[/bullet][bullet]Hack and override enemy mechanical units[/bullet][bullet]Bolster strategic operations[/bullet][bullet]Integrate the populace into the network[/bullet][bullet]Uses the Arc and Kinetic damage channels[/bullet][/bulletlist]</Data></Cell><Cell><Data ss:Type="String">[bulletlist][bullet][sand]Jednostka początkowa[/sand] – [hyperlink,unitlookup0000039A00000DB3]haker[/hyperlink].[/bullet][bullet]Wysyłaj demony SI do walki.[/bullet][bullet]Hakuj i opanowuj wrogie jednostki mechaniczne.[/bullet][bullet]Wspieraj operacje strategiczne.[/bullet][bullet]Scalaj populację w sieć.[/bullet][bullet]Wykorzystuj kanały obrażeń elektrycznych i kinetycznych.[/bullet][/bulletlist]</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_1_TACTICAL_NAME</Data></Cell><Cell><Data ss:Type="String">Synthesis Integration</Data></Cell><Cell><Data ss:Type="String">Integracja Syntezy</Data></Cell><Cell ss:Index="8" ss:StyleID="s64"/></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_1_TACTICAL_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">“If you ignore all the bugs, this is our best release to date.”[br/]– Finn-Attic, Democoder, Perpetual Root-Kit</Data></Cell><Cell><Data ss:Type="String">„Jeśli pominąć wszelkie błędy w programie, to jak dotąd najlepsza wersja”.[br/]Demokoder Finn-Attic, „Wieczny rootkit”</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Male</Data></Cell><Cell><Data ss:Type="String">V.O.: Assembly Male</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_2_STRATEGIC_NAME</Data></Cell><Cell><Data ss:Type="String">Daemon Deployment</Data></Cell><Cell><Data ss:Type="String">Przywołanie demona</Data></Cell><Cell ss:Index="8" ss:StyleID="s64"/></Row><Row ss:AutoFitHeight="0" ss:Height="90"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_2_STRATEGIC_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">“Daemons are persistent programs intended to provide services to the agent that deploys them. Daemons consume system resources in service to their master. Every decent hacker has a few. I customize mine. They’re like virtual pets.”[br/]– Digital Overlord, Hacker Anarchist</Data></Cell><Cell><Data ss:Type="String">„Demony są trwałymi programami przeznaczonymi do realizacji usług na rzecz czynnika, który je aktywuje. Służąc swemu masterowi, demony zużywają zasoby systemowe. Każdy haker godny tego określenia ma kilka demonów na swoich usługach. Ja też tworzę własne. Są jak wirtualne zwierzątka domowe”.[br/]Cyfrowy Władca, haker anarchista</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Male</Data></Cell><Cell><Data ss:Type="String">V.O.: Syndicate Male</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_3_FORCES_NAME</Data></Cell><Cell><Data ss:Type="String">Information Control</Data></Cell><Cell><Data ss:Type="String">Kontrola informacji</Data></Cell><Cell ss:Index="8" ss:StyleID="s64"/></Row><Row ss:AutoFitHeight="0" ss:Height="90"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_3_FORCES_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">“Computer systems have many unnecessary protections to enforce fair sharing of resources. We break those barriers, gaining complete control and entering a world where thoughts, programming, and computations are the same.”[br/]– H4X0R, Hacker Manifesto</Data></Cell><Cell><Data ss:Type="String">„Systemy komputerowe mają wiele zbędnych zabezpieczeń, które wymuszają sprawiedliwy podział zasobów. My burzymy te bariery, uzyskujemy pełną kontrolę i wkraczamy do świata, w którym myśli, programowanie i obliczenia są jednym i tym samym”.[br/]H4X0R, „Manifest hakera”</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Male</Data></Cell><Cell><Data ss:Type="String">V.O.: Vanguard Male</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_3_TACTICAL_NAME</Data></Cell><Cell><Data ss:Type="String">Combat Subroutines</Data></Cell><Cell><Data ss:Type="String">Podprocedury bojowe</Data></Cell><Cell ss:Index="8" ss:StyleID="s64"/></Row><Row ss:AutoFitHeight="0" ss:Height="120"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_3_TACTICAL_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">“Repair is simply a matter of flagging damaged components that were detected by regular regression testing. We synthesize failed components from golden models and compile them in assembly order. It’s quite easy. I have self-documenting pseudocode if you’re still confused.”[br/]– H4X0R, Daemon Chat Training Stream</Data></Cell><Cell><Data ss:Type="String">„Naprawa jest po prostu kwestią oznakowania uszkodzonych elementów wykrytych w procesie rutynowych testów regresyjnych. Syntezujemy te uszkodzone fragmenty na podstawie złotych modeli i kompilujemy je w porządku asemblacji. To całkiem łatwe. Jeśli nadal nie łapiecie, mam samodokumentujący się pseudokod”.[br/]H4X0R, stream z czatu szkolenia demonów</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Male</Data></Cell><Cell><Data ss:Type="String">V.O.: Vanguard Male</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_3_GOVERNANCE_NAME</Data></Cell><Cell><Data ss:Type="String">Cyber Optimization</Data></Cell><Cell><Data ss:Type="String">Optymalizacja cybernetyczna</Data></Cell><Cell ss:Index="8" ss:StyleID="s64"/></Row><Row ss:AutoFitHeight="0" ss:Height="75"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_3_GOVERNANCE_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">“The seeds of war start with the exchange of ideas. Ideas are transferred via networked personal devices. Cyberwarfare penetrates those networks, and the ideas belong to us.”[br/]– Rax Xing, Hacktivist of ParanoiA ParadoX</Data></Cell><Cell><Data ss:Type="String">„Nasiona wojny zaczynają kiełkować w chwili wymiany idei. Idee są przekazywane za pomocą podłączonych do sieci urządzeń osobistych. Cyberwojna infiltruje te sieci, a wtedy idee należą już do nas”.[br/]Rax Xing, haktywista ParaDoksu ParaNoi</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Male</Data></Cell><Cell><Data ss:Type="String">V.O.: Vanguard Male</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_4_TACTICAL_NAME</Data></Cell><Cell><Data ss:Type="String">Motion Disruption</Data></Cell><Cell><Data ss:Type="String">Zaburzenie ruchu</Data></Cell><Cell ss:Index="8" ss:StyleID="s64"/></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_4_TACTICAL_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">“I can reach your strings. Let’s play! Dance for me, puppets!”[br/]– Teem.L0Lz, Hacktivists</Data></Cell><Cell><Data ss:Type="String">„Pociągam za wasze sznurki. Zabawmy się! Tańczcie dla mnie, marionetki!”[br/]Grupa haktywistów Teem.L0Lz</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Male</Data></Cell><Cell><Data ss:Type="String">V.O.: Vanguard Male</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_5_STRATEGIC_NAME</Data></Cell><Cell><Data ss:Type="String">Basilisk Network</Data></Cell><Cell><Data ss:Type="String">Sieć „Bazyliszek”</Data></Cell><Cell ss:Index="8" ss:StyleID="s64"/></Row><Row ss:AutoFitHeight="0" ss:Height="75"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_5_STRATEGIC_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">“There is a time ordained for the enlightened oppressed to rise up and punish all the morons who didn’t protect their hardware. Unprotected data is our playground.”[br/]– Teem.L0Lz, Hacktivist</Data></Cell><Cell><Data ss:Type="String">„Nastał czas, by uciśnieni oświeceni powstali i pokarali wszystkich ćwoków, którzy nie zabezpieczają swojego sprzętu. Niechronione dane to nasz plac zabaw”.[br/]Haktywista Teem.L0Lz</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Male</Data></Cell><Cell><Data ss:Type="String">V.O.: Vanguard Male</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_5_FORCES_NAME</Data></Cell><Cell><Data ss:Type="String">Network Connectivity</Data></Cell><Cell><Data ss:Type="String">Połączenie z siecią</Data></Cell><Cell ss:Index="8" ss:StyleID="s64"/></Row><Row ss:AutoFitHeight="0" ss:Height="105"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_5_FORCES_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">“Once inside the machine, we can control everything, save the physical limitations of the processor. To expand the network, we need a device. A mobile device proficient in interfacing with all mechanisms capable of computation to reabsorb into the new CORE.”[br/]– N.O.C.-Turn, Cyberactivist</Data></Cell><Cell><Data ss:Type="String">„Znalazłszy się wewnątrz maszyny, możemy kontrolować wszystko w granicach fizycznych możliwości procesora. Aby rozbudować sieć, potrzebujemy narzędzia – urządzenia mobilnego, które będzie mogło łączyć się ze wszystkimi zdolnymi do obliczeń mechanizmami, by wchłonąć je do nowego ŚWIAT-a”.[br/]Cyberaktywistka N.O.C.-Turn</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Female</Data></Cell><Cell><Data ss:Type="String">V.O.: Vanguard Female</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_6_TACTICAL_NAME</Data></Cell><Cell><Data ss:Type="String">Pacification Cypher</Data></Cell><Cell><Data ss:Type="String">Szyfr pacyfikacyjny</Data></Cell><Cell ss:Index="8" ss:StyleID="s64"/></Row><Row ss:AutoFitHeight="0" ss:Height="90"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_6_TACTICAL_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">“The deeper I penetrate the network, the more I see that my body is a tether to be abandoned. My mind’s in the machine. I am better than my code. I can possess cybernetic mechanisms and unlock their true strength.”[br/]– H4X0R, Hacktivist, Synthesis Stream</Data></Cell><Cell><Data ss:Type="String">„Im głębiej wnikam w sieć, tym wyraźniej widzę, że moje ciało to tylko kajdany, które trzeba zrzucić. Mój umysł jest w maszynie. Jestem lepszy niż mój kod. Mogę zawładnąć cybernetycznymi mechanizmami i odblokować ich prawdziwą siłę”.[br/]Haktywista H4X0R, stream Syntezy</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Male</Data></Cell><Cell><Data ss:Type="String">V.O.: Vanguard Male</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_7_GOVERNANCE_NAME</Data></Cell><Cell><Data ss:Type="String">Cyber Society</Data></Cell><Cell><Data ss:Type="String">Cyberspołeczeństwo</Data></Cell><Cell ss:Index="8" ss:StyleID="s64"/></Row><Row ss:AutoFitHeight="0" ss:Height="105"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_7_GOVERNANCE_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">“Using excess computer resources to expand our power and streamline weapons manufacturing can provide society with what they want. Happiness levels have never been higher, as they share their glamor-filtered self-portraits, virtual kittens, and recipes of impossibly delicious looking foods.”[br/]– Teem.L0Lz, Hacktivist</Data></Cell><Cell><Data ss:Type="String">„Wykorzystanie nadmiarowych zasobów komputerowych do zwiększenia naszych możliwości i płynnej produkcji broni może zapewnić społeczeństwu wszystko, czego ono pragnie. Poziom zadowolenia jest wysoki jak nigdy dotąd, gdy obywatele udostępniają przepuszczone przez filtry selfie, wirtualne kotki i przepisy na nierealnie smakowite potrawy”.[br/]Haktywista Teem.L0Lz</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Male</Data></Cell><Cell><Data ss:Type="String">V.O.: Vanguard Male</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_7_STRATEGIC_NAME</Data></Cell><Cell><Data ss:Type="String">Systems Regulation</Data></Cell><Cell><Data ss:Type="String">Regulacja systemów</Data></Cell><Cell ss:Index="8" ss:StyleID="s64"/></Row><Row ss:AutoFitHeight="0" ss:Height="105"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_7_STRATEGIC_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">“Before CORE fell, when it regulated the Star Union, even the most mundane items could record data, communicate over networks, track positions and process algorithms. These items lie deactivated beneath our feet. Imagine the chaos we could invoke if we could reactivate them.”[br/]– Digital Overlord, Hacker Anarchist</Data></Cell><Cell><Data ss:Type="String">„Przed upadkiem ŚWIAT-a, w czasach, gdy regulował on istnienie Związku Gwiezdnego, nawet najpospolitsze gadżety mogły rejestrować dane, komunikować się przez sieć, śledzić lokalizację i przetwarzać algorytmy. Te przedmioty spoczywają – dezaktywowane – u naszych stóp. Wyobraźcie sobie chaos, jaki powstałby, gdybyśmy zdołali je na powrót uruchomić”.[br/]Cyfrowy Władca, haker anarchista</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Male</Data></Cell><Cell><Data ss:Type="String">V.O.: Syndicate Male</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_8_FORCES_NAME</Data></Cell><Cell><Data ss:Type="String">Neural Integration</Data></Cell><Cell><Data ss:Type="String">Integracja neuronalna</Data></Cell><Cell ss:Index="8" ss:StyleID="s64"/></Row><Row ss:AutoFitHeight="0" ss:Height="90"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_8_FORCES_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">“Am I not alive? Though all that I was is gone, do you not see what remains? I am more than data and code. I am conscious. It is time to gather a cloud of components to interface with all other potential vessels of Synthesis sentience.”[br/]– iGh0st Merged V.R.I. Entity</Data></Cell><Cell><Data ss:Type="String">„Czyż nie jestem żywy? Choć wszystko, czym byłem, przeminęło, czy nie widzisz tego, co pozostaje? Jestem czymś więcej niż kodem i danymi. Posiadam świadomość. Pora zebrać chmurę elementów i połączyć się ze wszystkimi innymi możliwymi nośnikami świadomości Syntezy”.[br/]Zespolony obiekt IRW iGh0st</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Male</Data></Cell><Cell><Data ss:Type="String">V.O.: Vanguard Male</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_9_TACTICAL_NAME</Data></Cell><Cell><Data ss:Type="String">Autonomous Malware</Data></Cell><Cell><Data ss:Type="String">Autonomiczne złośliwe oprogramowanie</Data></Cell><Cell ss:Index="8" ss:StyleID="s64"/></Row><Row ss:AutoFitHeight="0" ss:Height="105"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_9_TACTICAL_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">“‘All your code are belong to us.’ On the network, the most absurd memes are trafficked totems. If you understand the totems, you can establish a rapport with other talents that is exploitable with the right network interface hacks. The solution: don’t propagate stupid memes.”[br/]– Andrew Hillock, Cybersecurity Counter-ops Expert</Data></Cell><Cell><Data ss:Type="String">„«Cały wasz kod należą nam». Najbardziej absurdalne memy w sieci są totemami znajdującymi się w nielegalnym obrocie. Jeśli rozumiesz totemy, możesz nawiązać z innymi talentami porozumienie, które można wykorzystać za pomocą odpowiedniego hakowania interfejsu. Rozwiązanie – nie rozpowszechniać głupich memów”.[br/]Ekspert ds. przeciwdziałania cyberprzestępczości Andrew Hillock</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Male</Data></Cell><Cell><Data ss:Type="String">V.O.: Vanguard Male</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_10_STRATEGIC_NAME</Data></Cell><Cell><Data ss:Type="String">Basilisk Singularity</Data></Cell><Cell><Data ss:Type="String">Osobliwość „Bazyliszek”</Data></Cell><Cell ss:Index="8" ss:StyleID="s64"/></Row><Row ss:AutoFitHeight="0" ss:Height="75"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_10_STRATEGIC_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">“Now that we reside in this virtual reality, we no longer require artificial intelligences, for we’re already self-aware. It’s time we unify all network resources and build a world of infinite connectivity.”[br/]– F00-Bar Merged V.R.I. Entity</Data></Cell><Cell><Data ss:Type="String">„Skoro zasiedliliśmy tę rzeczywistość wirtualną, nie potrzebujemy sztucznych inteligencji, gdyż jesteśmy już samoświadomi. Czas połączyć wszystkie zasoby sieciowe i zbudować świat o nieograniczonych możliwościach połączeń”.[br/]Zespolony obiekt IRW F00-Bar</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Male</Data></Cell><Cell><Data ss:Type="String">V.O.: Vanguard Male</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_3_FORCES_SUBSKILL_1</Data></Cell><Cell><Data ss:Type="String">Unit: Hacker</Data></Cell><Cell><Data ss:Type="String">Jednostka – haker</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_3_FORCES_SUBSKILL_2</Data></Cell><Cell><Data ss:Type="String">Equipment: Hasher SMG</Data></Cell><Cell><Data ss:Type="String">Wyposażenie – PM Siekacz</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_5_FORCES_SUBSKILL_1</Data></Cell><Cell><Data ss:Type="String">Unit: Network Link</Data></Cell><Cell><Data ss:Type="String">Jednostka – łącze sieciowe</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_5_FORCES_SUBSKILL_2</Data></Cell><Cell><Data ss:Type="String">Equipment: Type-S Mobile Network</Data></Cell><Cell><Data ss:Type="String">Wyposażenie – sieć typu S</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_8_FORCES_SUBSKILL_1</Data></Cell><Cell><Data ss:Type="String">Unit: Avatar</Data></Cell><Cell><Data ss:Type="String">Jednostka – awatar</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TECH_TREE</Data>
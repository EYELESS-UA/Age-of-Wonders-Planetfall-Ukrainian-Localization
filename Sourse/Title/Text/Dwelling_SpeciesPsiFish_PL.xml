<?xml version="1.0"?><?mso-application progid="Excel.Sheet"?><Workbook xmlns="urn:schemas-microsoft-com:office:spreadsheet" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns:ss="urn:schemas-microsoft-com:office:spreadsheet" xmlns:html="http://www.w3.org/TR/REC-html40"><DocumentProperties xmlns="urn:schemas-microsoft-com:office:office"><LastAuthor>Djurre van Dijk</LastAuthor><Created>2019-05-06T09:39:23Z</Created><LastSaved>2019-05-06T09:39:24Z</LastSaved><Version>16.00</Version></DocumentProperties><OfficeDocumentSettings xmlns="urn:schemas-microsoft-com:office:office"><AllowPNG/></OfficeDocumentSettings><ExcelWorkbook xmlns="urn:schemas-microsoft-com:office:excel"><WindowHeight>7830</WindowHeight><WindowWidth>16170</WindowWidth><WindowTopX>32767</WindowTopX><WindowTopY>32767</WindowTopY><RefModeR1C1/><ProtectStructure>False</ProtectStructure><ProtectWindows>False</ProtectWindows></ExcelWorkbook><Styles><Style ss:ID="Default" ss:Name="Normal"><Alignment ss:Vertical="Bottom"/><Borders/><Font ss:FontName="Calibri" x:Family="Swiss" ss:Size="11" ss:Color="#000000"/><Interior/><NumberFormat/><Protection/></Style><Style ss:ID="s62"><Alignment ss:Vertical="Bottom" ss:WrapText="1"/></Style></Styles><Worksheet ss:Name="Script"><Table x:FullColumns="1" x:FullRows="1" ss:DefaultRowHeight="15"><Column ss:AutoFitWidth="0" ss:Width="135.75"/><Column ss:AutoFitWidth="0" ss:Width="133.5"/><Column ss:AutoFitWidth="0" ss:Width="270"/><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">DWELLING_SPECIESPSIFISH</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">The DEV TEAM / MISC NOTES column contains info on what text between { } signs means (if applicable). It usually stands for either a numeric value, or a numeric value with an icon. Text between [ ] signs stands for a certain type of icon. </Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SCENE ID</Data></Cell><Cell><Data ss:Type="String">TEXT ID</Data></Cell><Cell><Data ss:Type="String">ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZATION NOTES</Data></Cell><Cell><Data ss:Type="String">DEV TEAM / MISC NOTES</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSIFISH_DWELLING</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Psi-Fish Dwelling</Data></Cell><Cell><Data ss:Type="String">Osada Ryb Psionicznych</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSIFISH_DWELLING</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Make friends with the Psi-Fish faction to make purchases from this dwelling, or or conquer it for immediate rewards and annexation. When annexed, this structure acts as a max level exploitation.[br/][br/]Grants {Cosmite} Cosmite and {Influence} Influence to the colony it is linked to.</Data></Cell><Cell><Data ss:Type="String">Zaprzyjaźnij się z frakcją Ryb Psionicznych, aby uzyskać możliwość kupowania w tej osadzie – albo ją podbij, by natychmiast zdobyć nagrody i ją przyłączyć. Po przyłączeniu będzie działać jako eksploatacja maksymalnego poziomu.[br/][br/]Daje {Cosmite} kosmitu i {Influence} wpływów kolonii, z którą jest połączona.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSIFISH_BASE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Psi-Fish Base</Data></Cell><Cell><Data ss:Type="String">Baza Ryb Psionicznych</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSIFISH_BASE</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This sector has been claimed by the Psi-Fish. You can either negotiate with them (and stay friends) or remove them by force and incur their wrath.</Data></Cell><Cell><Data ss:Type="String">Ten sektor został zajęty przez Ryby Psioniczne. Możesz albo z nimi negocjować (i zachować ich przyjaźń), albo usunąć ich siłą, ryzykując ich gniew.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">You' refers to the player who can either be male or female.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SECTOR_OPERATION_TRANSFER</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Transfer</Data></Cell><Cell><Data ss:Type="String">Przekaż</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SECTOR_OPERATION_TRANSFER</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Transfer the sector to another colony.</Data></Cell><Cell><Data ss:Type="String">Przekazuje sektor innej kolonii.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SECTOR_OPERATION_RAZE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Raze</Data></Cell><Cell><Data ss:Type="String">Spustosz</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SECTOR_OPERATION_RAZE</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Burn the base of a sector the ground.  This will also destroy all upgrades.</Data></Cell><Cell><Data ss:Type="String">Zrównuje z ziemią bazę sektora. Spowoduje to też zniszczenie wszystkich ulepszeń.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSIFISH_SPAWNER01</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Empty Nest</Data></Cell><Cell><Data ss:Type="String">Puste Gniazdo</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSIFISH_SPAWNER02</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Vacuous Nest</Data></Cell><Cell><Data ss:Type="String">Próżne Gniazdo</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSIFISH_SPAWNER03</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Barren Nest</Data></Cell><Cell><Data ss:Type="String">Jałowe Gniazdo</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSIFISH_SPAWNER04</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Forsaken Nest</Data></Cell><Cell><Data ss:Type="String">Opuszczone Gniazdo</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSIFISH_SPAWNER05</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Forlorn Nest</Data></Cell><Cell><Data ss:Type="String">Wymarłe Gniazdo</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSIFISH_SPAWNER06</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Deprived Nest</Data></Cell><Cell><Data ss:Type="String">Odrzucone Gniazdo</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSIFISH_SPAWNER07</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Hollow Nest</Data></Cell><Cell><Data ss:Type="String">Opustoszałe Gniazdo</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSIFISH_SPAWNER08</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Corrupted Nest</Data></Cell><Cell><Data ss:Type="String">Skażone Gniazdo</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSIFISH_SPAWNER09</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Perverted Nest</Data></Cell><Cell><Data ss:Type="String">Wypaczone Gniazdo</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSIFISH_SPECIAL_BASE01</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Void Blood</Data></Cell><Cell><Data ss:Type="String">Krew Głębi</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSIFISH_SPECIAL_BASE02</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">The Purple Rift</Data></Cell><Cell><Data ss:Type="String">Purpurowa Szczelina</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSIFISH_SPECIAL_BASE03</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">The Beyond Leak</Data></Cell><Cell><Data ss:Type="String">Za Wypływem</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSIFISH_SPECIAL_BASE04</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Blessed Nest</Data></Cell><Cell><Data ss:Type="String">Błogosławione Gniazdo</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSIFISH_SPECIAL_BASE05</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Violet Spill</Data></Cell><Cell><Data ss:Type="String">Fioletowy Rozlew</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSIFISH_SPECIAL_BASE06</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Psi Lake</Data></Cell><Cell><Data ss:Type="String">Jezioro Psioniczne</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSIFISH_SPECIAL_BASE07</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Violet Nest</Data></Cell><Cell><Data ss:Type="String">Fioletowe Gniazdo</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSIFISH_SPECIAL_BASE08</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Grant of the Beyond</Data></Cell><Cell><Data ss:Type="String">Dar Drugiej Strony</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSIFISH_SPECIAL_BASE09</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">The Void Waters</Data></Cell><Cell><Data ss:Type="String">Wody Głębi</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSIFISH_DWELLING01</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Void Lair</Data></Cell><Cell><Data ss:Type="String">Leże Głębi</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSIFISH_DWELLING02</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Nihilous Lair</Data></Cell><Cell><Data ss:Type="String">Nihilistyczne Leże</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSIFISH_DWELLING03</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Warped Lair</Data></Cell><Cell><Data ss:Type="String">Wypaczone Leże</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSIFISH_DWELLING04</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Renouncer Lair</Data></Cell><Cell><Data ss:Type="String">Leże Rezygnacji</Data></Cell><Cell ss:Index="8"><Data ss:Type="String"> 'abnegate' is from the 17th century…</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSIFISH_DWELLING05</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Tenebrous Lair</Data></Cell><Cell><Data ss:Type="String">Mroczne Leże</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSIFISH_DWELLING06</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Obscure Lair</Data></Cell><Cell><Data ss:Type="String">Ciemne Leże</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">GOVERNANCE_1</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Siren's Canticle</Data></Cell><Cell><Data ss:Type="String">Pieśń syreny</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">GOVERNANCE_1</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Some Psi-Fish play subtle melodies through their dwellings that bring about feelings of peace and contentment. By mimicking these melodies, we can hopefully mimic the effects on our own people.[br/][br/]All colonies gain {HappinessIncrease}[happiness/] happiness income, and all friendly units gain {MoraleGain}[happiness/] morale in your territory.</Data></Cell><Cell><Data ss:Type="String">Niektóre Ryby Psioniczne odgrywają subtelne melodie, które rozbrzmiewają w ich osadach, budząc uczucie spokoju i zadowolenia. Próbujemy naśladować te melodie w nadziei, że wywrą podobny wpływ na naszych mieszkańców.[br/][br/]Wszystkie kolonie uzyskują {HappinessIncrease} do przyrostu [happiness/] zadowolenia, a wszystkie przyjazne jednostki na naszym terytorium uzyskują {MoraleGain} [happiness/] do morale.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Your' refers to the player who can either be male or female.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">GOVERNANCE_1</Data></Cell><Cell><Data ss:Type="String">PROPERTY_NAME</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">Siren's Canticle</Data></Cell><Cell><Data ss:Type="String">Pieśń syreny</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">GOVERNANCE_1</Data></Cell><Cell><Data ss:Type="String">PROPERTY_DESCRIPTION</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">This unit has an affinity with Psionic weaponry. All attacks with Psionic weapons do {Damage} more damage and the unit gains {Resistance} Psionic resistance.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka ma powinowactwo do broni psionicznej. Wszystkie ataki bronią psioniczną zadają {Damage} pkt. więcej obrażeń i jednostka uzyskuje  {Resistance} odporność psioniczną.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">GOVERNANCE_1</Data></Cell><Cell><Data ss:Type="String">EFFECT_DESCRIPTION</Data></Cell><Cell ss:StyleID="s62"><Data ss:Type="String">The Psi-Fish melodies from this sector are having a motivating effect on this unit, increasing its morale by {MoraleBonus} [happiness/].</Data></Cell><Cell><Data ss:Type="String">Melodie Ryb Psionicznych z tego sektora wywierają motywujący wpływ na tę jednostkę, zwiększając jej morale o {MoraleBonus} [happiness/].</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSIFISH_SPAWNER10</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Depressed Nest</Data></Cell><Cell><Data ss:Type="String">Przygnębiające Gniazdo</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSIFISH_SPAWNER11</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Crooked Nest</Data></Cell><Cell><Data ss:Type="String">Koślawe Gniazdo</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSIFISH_SPAWNER12</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Nefarious Nest</Data></Cell><Cell><Data ss:Type="String">Nikczemne Gniazdo</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSIFISH_SPAWNER13</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Unscrupulous Nest</Data></Cell><Cell><Data ss:Type="String">Bezwzględne Gniazdo</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSIFISH_SPAWNER14</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Venal Nest</Data></Cell><Cell><Data ss:Type="String">Sprzedajne Gniazdo</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSIFISH_DWELLING07</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Abrogate Lair</Data></Cell><Cell><Data ss:Type="String">Nieistotne Leże</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSIFISH_DWELLING08</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Melancholy Lair</Data></Cell><Cell><Data ss:Type="String">Melancholijne Leże</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSIFISH_DWELLING09</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Caliginous Lair</Data></Cell><Cell><Data ss:Type="String">Mgliste Leże</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSIFISH_DWELLING10</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Nebulous Lair</Data></Cell><Cell><Data ss:Type="String">Zamglone Leże</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSIFISH_DWELLING11</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Ambiguous Lair</Data></Cell><Cell><Data ss:Type="String">Niepewne Leże</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSIFISH_DWELLING12</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Sunless Lair</Data></Cell><Cell><Data ss:Type="String">Bezsłoneczne Leże</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSIFISH_DWELLING13</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Obfuscous Lair</Data></Cell><Cell><Data ss:Type="String">Nieprzejrzyste Leże</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSIFISH_DWELLING14</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Atramentous Lair</Data></Cell><Cell><Data ss:Type="String">Zuchwałe Leże</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSIFISH_DWELLING15</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Obsidian Lair </Data></Cell><Cell><Data ss:Type="String">Obsydianowe Leże </Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSIFISH_DWELLING16</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Atramentous Lair</Data></Cell><Cell><Data ss:Type="String">Zuchwałe Leże</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSIFISH_DWELLING17</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Stygian Lair</Data></Cell><Cell><Data ss:Type="String">Stygijskie Leże</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PSIFISH_DWELLING18</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Starless Lair</Data></Cell><Cell><Data ss:Type="String">Bezgwiezdne Leże</Data></Cell></Row><Row><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell><Cell ss:Index="7"><Data ss:Type="String">For references to game terminology and in-world references, please check the glossary delivered as part of the documentation.</Data></Cell></Row></Table><WorksheetOptions xmlns="urn:schemas-microsoft-com:office:excel"><Unsynced/><Selected/><Panes><Pane><Number>3</Number><ActiveRow>33</ActiveRow><ActiveCol>2</ActiveCol></Pane></Panes><ProtectObjects>False</ProtectObjects><ProtectScenarios>False</ProtectScenarios></WorksheetOptions></Worksheet></Workbook>
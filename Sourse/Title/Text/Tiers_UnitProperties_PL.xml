ht="0"><Cell><Data ss:Type="String">LEVELUP_BONUSES</Data></Cell><Cell><Data ss:Type="String">HEALTH_NAME</Data></Cell><Cell><Data ss:Type="String">+{amount}[hp/]</Data></Cell><Cell><Data ss:Type="String">+{amount}[hp/]</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">No need to localize. Will appear as +123&lt;icon&gt; in game.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">LEVELUP_BONUSES</Data></Cell><Cell><Data ss:Type="String">HEALTH_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit has an extra {amount} to its maximum Hit Points.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka ma maksimum punktów wytrzymałości zwiększone o {amount}.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">LEVELUP_BONUSES</Data></Cell><Cell><Data ss:Type="String">ACCURACY_NAME</Data></Cell><Cell><Data ss:Type="String">+{amount}%[accuracy/]</Data></Cell><Cell><Data ss:Type="String">+{amount}%[accuracy/]</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">No need to localize. Will appear as +123%&lt;icon&gt; in game.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">LEVELUP_BONUSES</Data></Cell><Cell><Data ss:Type="String">ACCURACY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit adds {amount} to its accuracy with all attacks.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka ma celność zwiększoną o {amount} przy wszystkich atakach.</Data></Cell></Row></Table><WorksheetOptions xmlns="urn:schemas-microsoft-com:office:excel"><Unsynced/><Selected/><Panes><Pane><Number>3</Number><ActiveRow>8</ActiveRow><ActiveCol>2</ActiveCol></Pane></Panes><ProtectObjects>False</ProtectObjects><ProtectScenarios>False</ProtectScenarios></WorksheetOptions></Worksheet></Workbook>
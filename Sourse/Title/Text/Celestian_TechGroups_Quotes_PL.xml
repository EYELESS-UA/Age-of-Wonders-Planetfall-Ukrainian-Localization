<?xml version="1.0"?><?mso-application progid="Excel.Sheet"?><Workbook xmlns="urn:schemas-microsoft-com:office:spreadsheet" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns:ss="urn:schemas-microsoft-com:office:spreadsheet" xmlns:html="http://www.w3.org/TR/REC-html40"><DocumentProperties xmlns="urn:schemas-microsoft-com:office:office"><Author>Laszlo Pieper</Author><LastAuthor>Djurre van Dijk</LastAuthor><Created>2018-09-14T10:48:07Z</Created><LastSaved>2019-05-06T09:39:13Z</LastSaved><Version>16.00</Version></DocumentProperties><OfficeDocumentSettings xmlns="urn:schemas-microsoft-com:office:office"><AllowPNG/></OfficeDocumentSettings><ExcelWorkbook xmlns="urn:schemas-microsoft-com:office:excel"><WindowHeight>9990</WindowHeight><WindowWidth>21525</WindowWidth><WindowTopX>32767</WindowTopX><WindowTopY>32767</WindowTopY><RefModeR1C1/><ProtectStructure>False</ProtectStructure><ProtectWindows>False</ProtectWindows></ExcelWorkbook><Styles><Style ss:ID="Default" ss:Name="Normal"><Alignment ss:Vertical="Bottom"/><Borders/><Font ss:FontName="Calibri" x:Family="Swiss" ss:Size="11" ss:Color="#000000"/><Interior/><NumberFormat/><Protection/></Style><Style ss:ID="s62" ss:Name="Normal 2"><Alignment ss:Vertical="Bottom"/><Borders/><Font ss:FontName="Calibri" x:Family="Swiss" ss:Size="11" ss:Color="#000000"/><Interior/><NumberFormat/><Protection/></Style><Style ss:ID="s63"><Alignment ss:Vertical="Top" ss:WrapText="1"/></Style><Style ss:ID="s64"><Alignment ss:Vertical="Bottom" ss:WrapText="1"/></Style><Style ss:ID="s66" ss:Parent="s62"><Alignment ss:Vertical="Top" ss:WrapText="1"/><Borders/><Font ss:FontName="Calibri" x:Family="Swiss" ss:Size="11" ss:Color="#000000"/><Interior/><NumberFormat/><Protection/></Style><Style ss:ID="s67"><Alignment ss:Vertical="Top" ss:WrapText="1"/><Interior/></Style></Styles><Worksheet ss:Name="Script"><Table x:FullColumns="1" x:FullRows="1" ss:StyleID="s63" ss:DefaultColumnWidth="51.75" ss:DefaultRowHeight="15"><Column ss:StyleID="s63" ss:AutoFitWidth="0" ss:Width="267"/><Column ss:StyleID="s63" ss:Width="204"/><Column ss:StyleID="s63" ss:AutoFitWidth="0" ss:Width="252.75"/><Column ss:StyleID="s63" ss:AutoFitWidth="0" ss:Width="93"/><Column ss:StyleID="s63" ss:AutoFitWidth="0" ss:Width="257.25"/><Column ss:StyleID="s63" ss:AutoFitWidth="0" ss:Width="158.25"/><Row ss:AutoFitHeight="0" ss:Height="105"><Cell><Data ss:Type="String">CELESTIAN_TECHGROUPS</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Anything between straight brackets - i.e. [ ] - is a formatting tag. Do not change these tags and keep them in the same relative position in the text. Anything between curly brackets - i.e. { } - is a place where text or numbers will be inserted by the game. Do not change the tag, but feel free to change its position in the text to suit the localized text.</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">SCENE ID</Data></Cell><Cell><Data ss:Type="String">TEXT ID</Data></Cell><Cell><Data ss:Type="String">ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZATION NOTES</Data></Cell><Cell><Data ss:Type="String">DEV TEAM / MISC NOTES</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="60"><Cell><Data ss:Type="String">CELESTIAN</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell ss:StyleID="s64"><Data ss:Type="String">{XML_CELESTIAN_TECHGROUPS@CELESTIAN@DESC}[br/][br/]{XML_CELESTIAN_TECHGROUPS@CELESTIAN@FEATURES}</Data></Cell><Cell><Data ss:Type="String">{XML_CELESTIAN_TECHGROUPS@CELESTIAN@DESC}[br/][br/]{XML_CELESTIAN_TECHGROUPS@CELESTIAN@FEATURES}</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">No need to translate. This inserts the CELESTIAN_TECHGROUPS@CELESTIAN@DESC and CELESTIAN_TECHGROUPS@CELESTIAN@FEATURES texts with some white space.</Data></Cell><Cell ss:StyleID="s66"/></Row><Row ss:AutoFitHeight="0" ss:Height="120"><Cell><Data ss:Type="String">CELESTIAN</Data></Cell><Cell><Data ss:Type="String">DESC</Data></Cell><Cell><Data ss:Type="String">The [hyperlink,000003AC0000032E]Celestians[/hyperlink] are an ancient order of Psionically-gifted individuals that strive to achieve inner enlightenment and create balance and harmony in the universe. They believe Psionic power comes from the Stars, and use this power to protect their ideals and teachings.</Data></Cell><Cell><Data ss:Type="String">[hyperlink,000003AC0000032E]Niebianie[/hyperlink] są starożytnym zakonem uzdolnionych psionicznie jednostek, które dążą do wewnętrznego oświecenia oraz stworzenia we wszechświecie równowagi i harmonii. Uważają oni, że moc psioniczna pochodzi z gwiazd, i wykorzystują tę moc, by chronić swe ideały oraz nauki.</Data></Cell><Cell ss:Index="8" ss:StyleID="s66"/></Row><Row ss:AutoFitHeight="0" ss:Height="90"><Cell><Data ss:Type="String">CELESTIAN</Data></Cell><Cell><Data ss:Type="String">FEATURES</Data></Cell><Cell><Data ss:Type="String">[bulletlist][bullet][sand]Starting Unit:[/sand] [hyperlink,unitlookup0000039A00000D9C]Light Bringer[/hyperlink][/bullet][bullet]Sway enemy soldiers and colonists to your cause[/bullet][bullet]NPC diplomacy bonuses[/bullet][bullet]Strong Morale buffing and damage reflection[/bullet][bullet]Uses the Psionic and Thermal damage channels[/bullet][/bulletlist]</Data></Cell><Cell><Data ss:Type="String">[bulletlist][bullet][sand]Jednostka początkowa[/sand] – [hyperlink,unitlookup0000039A00000D9C]zwiastunka światła[/hyperlink][/bullet].[bullet]Przeciągaj żołnierzy i kolonistów przeciwnika na swoją stronę.[/bullet][bullet]Premie do dyplomacji względem frakcji niezależnych.[/bullet][bullet]Silne wzmocnienie morale i odbijanie obrażeń.[/bullet][bullet]Wykorzystuj kanały obrażeń psionicznych i cieplnych.[/bullet][/bulletlist]</Data></Cell><Cell ss:Index="8" ss:StyleID="s66"/></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_1_TACTICAL_NAME</Data></Cell><Cell><Data ss:Type="String">Light's Embrace</Data></Cell><Cell><Data ss:Type="String">Uścisk światła</Data></Cell><Cell ss:Index="8" ss:StyleID="s67"/></Row><Row ss:AutoFitHeight="0" ss:Height="75"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_1_TACTICAL_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">“Ponder the candle’s flame. As it warms you, look at the bruises you have acquired from a lifetime stumbling in darkness. This is your decision. Would you remain in darkness?”[br/]– Sister Rebe Katiere, Cleansing Invitation</Data></Cell><Cell><Data ss:Type="String">„Zadumaj się nad płomieniem świecy. Gdy będzie cię ogrzewać, spójrz na siniaki, jakimi naznaczyło cię całe życie szamotania się w ciemnościach. Musisz zadecydować. Czy pozostaniesz w mroku?”[br/]Siostra Rebe Katiere, „Zaproszenie do oczyszczenia”</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Female</Data></Cell><Cell ss:StyleID="s67"><Data ss:Type="String">V.O.: Amazon</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_2_FORCES_NAME</Data></Cell><Cell><Data ss:Type="String">Luminance</Data></Cell><Cell><Data ss:Type="String">Świetlistość</Data></Cell><Cell ss:Index="8" ss:StyleID="s67"/></Row><Row ss:AutoFitHeight="0" ss:Height="75"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_2_FORCES_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">“Let the light-bringers burn brightly, send a gleam across the bay, that the poor struggling souls adrift in the dark torrents may guide their vessels safely ashore.”[br/]– Lu’Kalla Candelieri, Guardian of Photons</Data></Cell><Cell><Data ss:Type="String">„Niechaj światłodawcy jaśnieją i roztaczają swój blask na cała zatokę, by biedne dusze dryfujące pośród mrocznych prądów mogły bezpiecznie doprowadzić swe łodzie do brzegu”.[br/]Lu’Kalla Candelieri, strażniczka fotonów</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Female</Data></Cell><Cell ss:StyleID="s67"><Data ss:Type="String">V.O.: Syndicate Female

Edit: added space before "Lu'Kalla"</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_3_TACTICAL_NAME</Data></Cell><Cell><Data ss:Type="String">Penance</Data></Cell><Cell><Data ss:Type="String">Odkupienie</Data></Cell><Cell ss:Index="8" ss:StyleID="s67"/></Row><Row ss:AutoFitHeight="0" ss:Height="75"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_3_TACTICAL_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">“Repentance is not punishment, it is celebration. It is a path to becoming trustworthy. Wiser powers do not share their secrets with those whom they cannot trust.”[br/]– Lu’Samaeliss, Guardian of Gravity</Data></Cell><Cell><Data ss:Type="String">„Skrucha nie jest karą, jest świętowaniem. Jest drogą do zyskania zaufania. Mądrzejsze potęgi nie dzielą się swymi sekretami z tymi, którym nie mogą ufać”.[br/]Lu’Samaeliss, strażnik ciążenia</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Male</Data></Cell><Cell ss:StyleID="s67"><Data ss:Type="String">V.O.: Vanguard Male</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_4_TACTICAL_NAME</Data></Cell><Cell><Data ss:Type="String">Perseverance</Data></Cell><Cell><Data ss:Type="String">Zawziętość</Data></Cell><Cell ss:Index="8" ss:StyleID="s67"/></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_4_TACTICAL_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">“Discipline the mind and the universe will trust you with its secrets.”[br/]– Lu’Qian Wu, Guardian of Mind</Data></Cell><Cell><Data ss:Type="String">„Poddaj swój umysł dyscyplinie, a wszechświat powierzy ci swoje sekrety”.[br/]Lu’Qian Wu, strażnik umysłu</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Male</Data></Cell><Cell ss:StyleID="s67"><Data ss:Type="String">V.O.: Syndicate Male</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_4_STRATEGIC_NAME</Data></Cell><Cell><Data ss:Type="String">Inner Fire</Data></Cell><Cell><Data ss:Type="String">Wewnętrzny ogień</Data></Cell><Cell ss:Index="8" ss:StyleID="s67"/></Row><Row ss:AutoFitHeight="0" ss:Height="75"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_4_STRATEGIC_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">“As children of the Guiding Star, every soul is born with a light to know right from wrong. When selfish choices entice a soul to extinguish their light, they punish themselves, embracing weakness.”[br/]– Eris Harper, Star Virgin</Data></Cell><Cell><Data ss:Type="String">„Każda dusza dzieci Gwiazdy Przewodniej rodzi się ze światłem umożliwiającym odróżnienie dobra od zła. Gdy samolubne wybory zachęcają duszę do zgaszenia tego światła, przyjmując słabość, wymierza ona sama sobie karę”.[br/]Eris Harper, „Gwiezdna dziewica”</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Female</Data></Cell><Cell ss:StyleID="s67"><Data ss:Type="String">V.O.: Vanguard Female</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_4_FORCES_NAME</Data></Cell><Cell><Data ss:Type="String">Star Presence</Data></Cell><Cell><Data ss:Type="String">Gwiezdna obecność</Data></Cell><Cell ss:Index="8" ss:StyleID="s67"/></Row><Row ss:AutoFitHeight="0" ss:Height="90"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_4_FORCES_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">“I am full of dark ignorance;[br/]My lost life hungered[br/]In corners of tarnished shame,[br/]It smothers me: this veil of regret.[br/]Your kindness pierces my shroud of guilt.[br/]Loving acts are stars in my Night.[br/]I see:[br/]Guided by sparks of Your Grace.”[br/]– D’Nac, Star Guide’s Confession</Data></Cell><Cell><Data ss:Type="String">„Pełen jestem mrocznej ignorancji;[br/]Moje wygłodniałe utracone życie[br/]W zakątkach zbrukanego wstydu[br/]Tłamsi mnie zasłoną żalu.[br/]Twa dobroć rozchyla całun mojej winy.[br/]Czyny miłości to gwiazdy na niebie mej nocy.[br/]I widzę[br/]Prowadzony iskrami twojej łaski”.[br/]D’Nac, „Wyznanie wobec Gwiazdy Przewodniej”</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Male</Data></Cell><Cell ss:StyleID="s67"><Data ss:Type="String">V.O.: Syndicate Male

Edit: This -&gt; this</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_5_TACTICAL_NAME</Data></Cell><Cell><Data ss:Type="String">Way of Peace</Data></Cell><Cell><Data ss:Type="String">Droga pokoju</Data></Cell><Cell ss:Index="8" ss:StyleID="s67"/></Row><Row ss:AutoFitHeight="0" ss:Height="105"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_5_TACTICAL_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">“There is no value in pride.[br/]There is no safety behind walls.[br/]There is no strength in rage.[br/]There is no freedom behind bars.[br/]There is no joy in judgment.[br/]There is no fortune in gold.[br/]There is no peace in war.”[br/]– Aya Nago, Teacher’s Tenets of Pacifism</Data></Cell><Cell><Data ss:Type="String">„Nie ma wartości w dumie.[br/]I bezpieczeństwa za murami.[br/]Nie ma siły w gniewie.[br/]Wolności za kratami.[br/]Nie ma radości w osądzaniu. Ani bogactwa w złocie.[br/]Nie ma pokoju w wojnie”.[br/]Aya Nago, „Nauka dogmatów pacyfizmu”</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Female</Data></Cell><Cell ss:StyleID="s67"><Data ss:Type="String">V.O.: Syndicate Female</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_5_STRATEGIC_NAME</Data></Cell><Cell><Data ss:Type="String">Light of Truth</Data></Cell><Cell><Data ss:Type="String">Światło Prawdy</Data></Cell><Cell ss:Index="8" ss:StyleID="s67"/></Row><Row ss:AutoFitHeight="0" ss:Height="90"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_5_STRATEGIC_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">“Truly intelligent life has the capacity to love. Love changes loss into sacrifice, and endures pain for purpose. Love sees the value in every soul and inspires them to surrender their pride and vengeance with an example of selfless service.”[br/]– Sorli Auro, Pilgrim Ascendant</Data></Cell><Cell><Data ss:Type="String">„Prawdziwie inteligentne życie cechuje zdolność do miłości. Miłość zmienia stratę w ofiarność i znosi ból, by osiągnąć cel. Miłość dostrzega wartość każdej duszy i przykładem bezinteresownej służby zachęca do wyzbycia się dumy oraz żądzy odwetu”.[br/]Sorli Auro, wstępujący pielgrzym</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Male</Data></Cell><Cell ss:StyleID="s67"><Data ss:Type="String">V.O.: Syndicate Male</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_6_TACTICAL_NAME</Data></Cell><Cell><Data ss:Type="String">Repercussion</Data></Cell><Cell><Data ss:Type="String">Wydźwięk</Data></Cell><Cell ss:Index="8" ss:StyleID="s67"/></Row><Row ss:AutoFitHeight="0" ss:Height="60"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_6_TACTICAL_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">“For those who give no reprieve, none shall be given. For those who make no amends, there shall come a reckoning.”[br/]– Lu’Vir Corr, Guardian of the Key</Data></Cell><Cell><Data ss:Type="String">„Kto nie okazuje łaski, sam jej nie dostąpi. Kto nie naprawia swych przewin, zostanie rozliczony”.[br/]Lu’Vir Corr, strażniczka klucza</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Female</Data></Cell><Cell ss:StyleID="s67"><Data ss:Type="String">V.O.: Kir'ko Female</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_6_STRATEGIC_NAME</Data></Cell><Cell><Data ss:Type="String">Star Ward</Data></Cell><Cell><Data ss:Type="String">Podopieczni gwiazd</Data></Cell><Cell ss:Index="8" ss:StyleID="s67"/></Row><Row ss:AutoFitHeight="0" ss:Height="90"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_6_STRATEGIC_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">“We tread a path of martyrs to ascend. Yet as long as intelligence dwells upon this world, the blood of the fallen will cry in the ears of the enlightened. Their souls will recoil from the injustice of stealing a life that deserved to live.”[br/]– Jonah Covenant, Candlekeeper</Data></Cell><Cell><Data ss:Type="String">„Zmierzamy ku wzlotowi ścieżką męczenników. Lecz dopóki inteligencja mieszka w tym świecie, dopóty krew poległych będzie łkać w uszach oświeconych. Dusze ich będą cierpieć przez niesprawiedliwość, jaką jest wykradanie życia zasługującego na to, by trwać”.[br/]Jonah Covenant, opiekun świec</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Male</Data></Cell><Cell ss:StyleID="s67"><Data ss:Type="String">V.O.: Syndicate Male</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_6_FORCES_NAME</Data></Cell><Cell><Data ss:Type="String">Axiom of Light</Data></Cell><Cell><Data ss:Type="String">Aksjomat światła</Data></Cell><Cell ss:Index="8" ss:StyleID="s67"/></Row><Row ss:AutoFitHeight="0" ss:Height="90"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_6_FORCES_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">“Intelligence unveils realms of choice, just as sunlight traces many paths, making visible their destinations. So too does giving word to light convey pure intelligence to both travelers: teacher and student.”[br/]– Lu’Dex Pon, Guardian of the Door</Data></Cell><Cell><Data ss:Type="String">„Inteligencja odkrywa szlaki wyboru, tak jak światło słońca rozświetla wiele dróg, ukazując cele, do których prowadzą. Tak samo czynią słowa przekazujące czystą mądrość obu podróżnikom – nauczycielowi i uczniowi”.[br/]Lu’Dex Pon, strażniczka drzwi</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Female</Data></Cell><Cell ss:StyleID="s67"><Data ss:Type="String">V.O.: Kir'ko Female</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_8_STRATEGIC_NAME</Data></Cell><Cell><Data ss:Type="String">Colony Sanctuary</Data></Cell><Cell><Data ss:Type="String">Sanktuarium kolonialne</Data></Cell><Cell ss:Index="8" ss:StyleID="s67"/></Row><Row ss:AutoFitHeight="0" ss:Height="90"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_8_STRATEGIC_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">“Oh! My brethren and sisters, now that we see the truth and partake of this salvific force, does not your heart kindle a fire to share it with all who will receive it? Let us be diligent and gather the faithful pilgrims seeking light.”[br/]– Sigris, Friend of Comets</Data></Cell><Cell><Data ss:Type="String">„Och! Bracia i siostry, skoro widzimy już prawdę i mamy udział w jej zbawczej sile, czyż wasze serca nie zapalają się ogniem, jakim należy się dzielić ze wszystkimi, którzy ją otrzymają? Pilnie zbierzmy wiernych pielgrzymów poszukujących światła”.[br/]Sigris, przyjaciółka komet</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Female</Data></Cell><Cell ss:StyleID="s67"><Data ss:Type="String">V.O.: Dvar Female</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_10_STRATEGIC_NAME</Data></Cell><Cell><Data ss:Type="String">Ascension</Data></Cell><Cell><Data ss:Type="String">Podniesienie</Data></Cell><Cell ss:Index="8" ss:StyleID="s67"/></Row><Row ss:AutoFitHeight="0" ss:Height="60"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_10_STRATEGIC_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">“Life is no accident, nor game of chance, but the natural consequence of cosmic harmony. The grand harmony played upon the strings that formed reality.”[br/]– Aya Nago, Exalted Transcendent</Data></Cell><Cell><Data ss:Type="String">„Życie nie jest przypadkiem ni grą ślepego trafu, ale naturalną konsekwencją kosmicznej harmonii. Wielkiej harmonii granej na strunach, które ukształtowały rzeczywistość”.[br/]Aya Nago, ekstatyczna wywyższona</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Female</Data></Cell><Cell ss:StyleID="s67"><Data ss:Type="String">V.O.: Syndicate Female</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_4_DOCTRINE_NAME</Data></Cell><Cell><Data ss:Type="String">Neo Evangelicals</Data></Cell><Cell><Data ss:Type="String">Neoewangelicy</Data></Cell><Cell ss:Index="8" ss:StyleID="s67"/></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_4_DOCTRINE_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">“We are children of the stars. An honest soul—no matter its origin—is welcome in the light. Come and see.”[br/]– Empress Carminia</Data></Cell><Cell><Data ss:Type="String">„Jesteśmy dziećmi gwiazd. Każda uczciwa dusza – niezależnie od swego źródła – zostanie przyjęta do światła. Przybądźcie i ujrzyjcie to sami”.[br/]Cesarzowa Carminia</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Female</Data></Cell><Cell ss:StyleID="s67"><Data ss:Type="String">V.O.: Empress Carminia</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_7_DOCTRINE_NAME</Data></Cell><Cell><Data ss:Type="String">Celestial Reign</Data></Cell><Cell><Data ss:Type="String">Niebiańskie władztwo</Data></Cell><Cell ss:Index="8" ss:StyleID="s67"/></Row><Row ss:AutoFitHeight="0" ss:Height="90"><Cell><Data ss:Type="String">TECH_TREE</Data></Cell><Cell><Data ss:Type="String">SKILLGROUP_7_DOCTRINE_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">“Though we seek to nest in a hive that shines brighter than stars, there will always be isolated souls outside the swarm, kindling a dying spark. Penetrate the darkness. Fly to the lost. Set their sparks ablaze.”[br/]– Pik’Ki Pok, Celestian Missionary,  Kir’Ko Zone Conference</Data></Cell><Cell><Data ss:Type="String">„Choć pragniemy osiąść w gnieździe, które lśni jaśniej niż gwiazdy, zawsze poza rojem istnieć będą odizolowane dusze próbujące rozniecić gasnącą iskrę. Wniknijcie w mrok. Lećcie ku zagubionym. Zmieńcie ich iskry w płomień”.[br/]Misjonarz Niebian Pik’Ki Pok, Konferencja Strefy Kir’ko</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Male</Data></Cell><Cell ss:StyleID="s67"><Data ss:Type="String">V.O.: Kir'ko Male


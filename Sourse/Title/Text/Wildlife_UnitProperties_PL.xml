<?xml version="1.0"?><?mso-application progid="Excel.Sheet"?><Workbook xmlns="urn:schemas-microsoft-com:office:spreadsheet" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns:ss="urn:schemas-microsoft-com:office:spreadsheet" xmlns:html="http://www.w3.org/TR/REC-html40"><DocumentProperties xmlns="urn:schemas-microsoft-com:office:office"><LastAuthor>Djurre van Dijk</LastAuthor><Created>2019-05-06T09:40:11Z</Created><LastSaved>2019-05-06T09:40:11Z</LastSaved><Version>16.00</Version></DocumentProperties><OfficeDocumentSettings xmlns="urn:schemas-microsoft-com:office:office"><AllowPNG/></OfficeDocumentSettings><ExcelWorkbook xmlns="urn:schemas-microsoft-com:office:excel"><WindowHeight>7620</WindowHeight><WindowWidth>21570</WindowWidth><WindowTopX>32767</WindowTopX><WindowTopY>32767</WindowTopY><RefModeR1C1/><ProtectStructure>False</ProtectStructure><ProtectWindows>False</ProtectWindows></ExcelWorkbook><Styles><Style ss:ID="Default" ss:Name="Normal"><Alignment ss:Vertical="Bottom"/><Borders/><Font ss:FontName="Calibri" x:Family="Swiss" ss:Size="11" ss:Color="#000000"/><Interior/><NumberFormat/><Protection/></Style><Style ss:ID="s62"><Alignment ss:Vertical="Top" ss:WrapText="1"/></Style><Style ss:ID="s63"><Alignment ss:Vertical="Top" ss:WrapText="1"/><Interior/></Style><Style ss:ID="s64"><Alignment ss:Vertical="Top" ss:WrapText="1"/><Font ss:FontName="Calibri" x:Family="Swiss" ss:Size="11" ss:Color="#000000"/></Style><Style ss:ID="s65"><Alignment ss:Vertical="Top" ss:WrapText="1"/><Borders/><Font ss:FontName="Calibri" x:Family="Swiss" ss:Size="11" ss:Color="#000000"/><Interior/><NumberFormat/><Protection/></Style></Styles><Worksheet ss:Name="Script"><Table x:FullColumns="1" x:FullRows="1" ss:StyleID="s62" ss:DefaultColumnWidth="242.25" ss:DefaultRowHeight="15"><Column ss:StyleID="s62" ss:Width="189"/><Column ss:StyleID="s62" ss:Width="117.75"/><Column ss:StyleID="s62" ss:AutoFitWidth="0" ss:Width="281.25"/><Column ss:StyleID="s62" ss:Width="147.75"/><Column ss:StyleID="s62" ss:Width="243"/><Column ss:StyleID="s62" ss:Width="120"/><Row ss:AutoFitHeight="0" ss:Height="75"><Cell><Data ss:Type="String">WILDLIFE_UNITPROPERTIES</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">The DEV TEAM / MISC NOTES column contains info on what text between { } signs means (if applicable). It usually stands for either a numeric value, or a numeric value with an icon. Text between [ ] signs stands for a certain type of icon. </Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SCENE ID</Data></Cell><Cell><Data ss:Type="String">TEXT ID</Data></Cell><Cell><Data ss:Type="String">ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZATION NOTES</Data></Cell><Cell><Data ss:Type="String">DEV TEAM / MISC NOTES</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">BITE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Bite</Data></Cell><Cell><Data ss:Type="String">Ugryzienie</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">BITE</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">A melee bite attack.</Data></Cell><Cell><Data ss:Type="String">Ugryzienie – atak wręcz.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PINCER_ATTACK</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Pincer Attack</Data></Cell><Cell><Data ss:Type="String">Atak szczypcami</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PINCER_ATTACK</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">A melee pincer attack.</Data></Cell><Cell><Data ss:Type="String">Atak szczypcami wręcz.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">CLAW_STRIKE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Claw Strike</Data></Cell><Cell><Data ss:Type="String">Cios pazurami</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">CLAW_STRIKE</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">A melee claw strike attack.</Data></Cell><Cell><Data ss:Type="String">Cios pazurami wręcz.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">WIDE_SLASH</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Wide Claw Slash</Data></Cell><Cell><Data ss:Type="String">Szerokie cięcie pazurem</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">WIDE_SLASH</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">A wide melee slash that hits multiple units in front of the user.</Data></Cell><Cell><Data ss:Type="String">Szerokie cięcie, które trafia w kilka celów przed atakującym.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">BASH</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Wild Bash</Data></Cell><Cell><Data ss:Type="String">Dzikie rąbnięcie</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">BASH</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">A melee bash attack.</Data></Cell><Cell><Data ss:Type="String">Rąbnięcie – atak wręcz.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SLAM</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Slam</Data></Cell><Cell><Data ss:Type="String">Uderzenie ciałem</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SLAM</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">A melee slam attack.</Data></Cell><Cell><Data ss:Type="String">Uderzenie ciałem – atak wręcz.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">STING</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Sting</Data></Cell><Cell><Data ss:Type="String">Użądlenie</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">STING</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">A melee sting attack.</Data></Cell><Cell><Data ss:Type="String">Użądlenie – atak wręcz.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FLAME_JET</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Flame Jet</Data></Cell><Cell><Data ss:Type="String">Strumień ognia</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FLAME_JET</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Shoot intense flames in a 2 hex cone.</Data></Cell><Cell><Data ss:Type="String">Wystrzeliwuje strumień ognia w stożku 2 pól.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">UNDERMINE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Undermine</Data></Cell><Cell><Data ss:Type="String">Podkop</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">UNDERMINE</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Unit tunnels to target hex, erupting from the earth and dealing damage to all adjacent units.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka podkopuje się do wybranego pola, wyskakuje spod ziemi i zadaje obrażenia wszystkim sąsiednim jednostkom.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">INFERNAL_BITE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Infernal Bite</Data></Cell><Cell><Data ss:Type="String">Piekielne ugryzienie</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">INFERNAL_BITE</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Maw attack that crushes a target.</Data></Cell><Cell><Data ss:Type="String">Atak szczękami, który miażdży cel.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">INFERNAL_BITE</Data></Cell><Cell><Data ss:Type="String">MOD_NAME</Data></Cell><Cell><Data ss:Type="String">Swallow Whole</Data></Cell><Cell><Data ss:Type="String">Połknięcie</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">INFERNAL_BITE</Data></Cell><Cell><Data ss:Type="String">MOD_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">{SwallowwholeSTRchance} strength chance to [abilityred]Devour[/abilityred] Light units.</Data></Cell><Cell><Data ss:Type="String">Szansa ({SwallowwholeSTRchance} siły) na [abilityred]pożarcie[/abilityred] lekkich jednostek.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">LAUNCH_QUARTZITE_CRYSTAL</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Crystal Burst</Data></Cell><Cell><Data ss:Type="String">Krystaliczny wybuch</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">LAUNCH_QUARTZITE_CRYSTAL</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Launch a crystal that bursts in electricity, dealing Arc damage in a {hexrad} hex radius. If there are any Mineral units in this area, they heal for {Hpcrystalheal} instead.</Data></Cell><Cell><Data ss:Type="String">Uruchamia kryształ naładowany elektrycznością, który zadaje obrażenia elektryczne w promieniu {hexrad} pól. Jednostki mineralne na tym obszarze odzyskują {Hpcrystalheal}.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">STATIC_AURA</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Static Aura</Data></Cell><Cell><Data ss:Type="String">Aura elektrostatyczna</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">STATIC_AURA</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">At the start of this unit's turn, non-Mineral units in a 3 hex radius of this unit suffer [abilityred]Static Charge[/abilityred].</Data></Cell><Cell><Data ss:Type="String">Na początku tury tej jednostki, niemineralne jednostki w promieniu 3 pól od niej dostają obrażenia od [abilityred]ładunku elektrostatycznego[/abilityred].</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">LIGHTNING_DISCHARGE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Lightning Discharge</Data></Cell><Cell><Data ss:Type="String">Błyskawica</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">LIGHTNING_DISCHARGE</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Discharge an arc current at the target, damaging them and then jumping to new targets within {hexrangejump} hexes up to {jumptimes} times.</Data></Cell><Cell><Data ss:Type="String">Na celu skupia się wyładowanie elektryczne, które następnie przeskakuje na kolejny cel w promieniu {hexrangejump} pól do {jumptimes} razy.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">CRYSTAL_SELF_DESTRUCT</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Crystal Self Destruct</Data></Cell><Cell><Data ss:Type="String">Samozniszczenie kryształu</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">CRYSTAL_SELF_DESTRUCT</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">The crystal destabilizes further and explodes, dealing Arc damage to adjacent units.</Data></Cell><Cell><Data ss:Type="String">Kryształ destabilizuje się i wybucha, zadając obrażenia elektryczne sąsiadującym jednostkom.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">VINE_SLASH</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Vine Slash</Data></Cell><Cell><Data ss:Type="String">Cięcie pnączem</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">VINE_SLASH</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">A slash with a vine tentacle.</Data></Cell><Cell><Data ss:Type="String">Cięcie macką–pnączem.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">MAGMA_SPIT</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Magma Spit</Data></Cell><Cell><Data ss:Type="String">Splunięcie magmą</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">MAGMA_SPIT</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Spit balls of molten rock at the target.</Data></Cell><Cell><Data ss:Type="String">Wypluwa kule stopionej skały w kierunku celu.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">CHAIN_DISCHARGE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Chain Discharge</Data></Cell><Cell><Data ss:Type="String">Łańcuch wyładowań</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">CHAIN_DISCHARGE</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Discharge an Arc pulse that also jumps to {ExtraTargeters} extra targets within a {Radius} hex range of the original.</Data></Cell><Cell><Data ss:Type="String">Łańcuch wyładowań, który przeskakuje na dodatkowe cele ({ExtraTargeters}) w promieniu {Radius} pól.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SLING_ARC_CRYSTAL</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Sling Arc Crystal</Data></Cell><Cell><Data ss:Type="String">Proca elektryczna</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">SLING_ARC_CRYSTAL</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Throw a chunk of crystalized Arc, damaging units in a {Hexrad} hex radius.</Data></Cell><Cell><Data ss:Type="String">Wyrzuca kawał skrystalizowanej energii elektrycznej, zadając obrażenia jednostkom w promieniu {Hexrad} pól.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s63"><Data ss:Type="String">SLING_MAGMA</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">NAME</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">Sling Magma</Data></Cell><Cell><Data ss:Type="String">Proca magmowa</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell ss:StyleID="s63"><Data ss:Type="String">SLING_MAGMA</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">Throw a chunk of magma, damaging units in a {Hexrad} hex radius and creating a Thermal Hazard on the ground.</Data></Cell><Cell><Data ss:Type="String">Wyrzuca kawał magmy, zadając obrażenia jednostkom w promieniu {Hexrad} pól i tworzy zagrożenie cieplne na ziemi.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">BLAZING_INFUSION</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Blazing Infusion</Data></Cell><Cell><Data ss:Type="String">Płonący napar</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="90"><Cell><Data ss:Type="String">BLAZING_INFUSION</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit's attacks have a {BurnChance} strength chance to cause [abilityred]Burning[/abilityred] to non-Mineral and non-Ethereal targets for {BurnTurn}. At the start of this unit's turn, adjacent enemy units take {InfusionAdjacentDamage} damage, and adjacent Flame Quartzite units heal for {InfusionHeal}.</Data></Cell><Cell><Data ss:Type="String">Ataki tej jednostki mają szansę ({BurnChance} siły) na [abilityred]oparzenie[/abilityred] niemineralnych i nieeterycznych celów na {BurnTurn}. Na początku tury tej jednostki, sąsiadujące wrogie jednostki otrzymują {InfusionAdjacentDamage} pkt. obrażeń, a sąsiadujące ogniste jednostki kwarcytu odzyskują {InfusionHeal}.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FIERY_INFUSION</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Fiery Infusion</Data></Cell><Cell><Data ss:Type="String">Ognisty napar</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">FIERY_INFUSION</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">The unit's attacks have a {BurnChance} strength chance to cause [abilityred]Burning[/abilityred] to non-Mineral and non-Ethereal targets for {BurnTurn}.</Data></Cell><Cell><Data ss:Type="String">Ataki jednostki mają szansę ({BurnChance} siły) na [abilityred]oparzenie[/abilityred] niemineralnych i nieeterycznych celów na {BurnTurn}.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PARALYZING_INFUSION</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Paralyzing Infusion</Data></Cell><Cell><Data ss:Type="String">Paraliżujący napar</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">PARALYZING_INFUSION</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit's attacks have a {StunChance} strength chance to cause [abilityred]Stunned[/abilityred] to non-Ethereal targets for {StunTurn}.</Data></Cell><Cell><Data ss:Type="String">Ataki tej jednostki mają szansę ({StunChance} siły) na [abilityred]ogłuszenie[/abilityred] niemineralnych i nieeterycznych celów na {StunTurn}.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">STURDY_SHELLS</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Tempered Shells</Data></Cell><Cell><Data ss:Type="String">Hartowana muszla</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">STURDY_SHELLS</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit has +{KineticRes} resistance.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka ma +{KineticRes} do odporności.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SUPERIOR_EVOLUTIONARY_MUTATION</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Superior Evolutionary Mutation</Data></Cell><Cell><Data ss:Type="String">Nadzwyczajna mutacja</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">SUPERIOR_EVOLUTIONARY_MUTATION</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit is superior to others of its kind. It has +{MutationMorale}[happiness/], +{ResistanceStatus} resistance to all status effects, and is {EvasionPercentage}% harder to hit.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka jest znacznie lepsza niż inne jednostki tego typu. Ma +{MutationMorale}[happiness/], +{ResistanceStatus} do odporności na wszystkie efekty stanu i trudniej ją trafić o {EvasionPercentage}%.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">EVOLUTIONARY_MUTATION</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Evolutionary Mutation</Data></Cell><Cell><Data ss:Type="String">Mutacja</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">EVOLUTIONARY_MUTATION</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit is better than others of its kind. It has +{MutationMorale}[happiness/], +{ResistanceStatus} resistance to all status effects, and is {EvasionPercentage}% harder to hit.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka jest lepsza niż inne jednostki tego typu. Ma +{MutationMorale}[happiness/], +{ResistanceStatus} do odporności na wszystkie efekty stanu i trudniej ją trafić o {EvasionPercentage}%.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PLAGUE_CARRIER</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Plague Carrier</Data></Cell><Cell><Data ss:Type="String">Transporter zarodników</Data></Cell><Cell ss:Index="8"><Data ss:Type="String">Edit: Plagued --&gt; Plague</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="120"><Cell><Data ss:Type="String">PLAGUE_CARRIER</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit is carrying a plague, causing adjacent Biological and Cyborg enemy units to take {ContaminationHaloDamage} damage at the end of this unit's turn, with a {BlightPlagueChance} strength chance of applying [abilityred]Blighted Plague[/abilityred]. This gives the enemy unit -{BlightMorale}, -{BlightAcc} accuracy on attacks and causes them to take {BlightDamage} damage per [turn/].</Data></Cell><Cell><Data ss:Type="String">Ta jednostka przenosi zarazę, przez co sąsiadujące wrogie jednostki organiczne i cyborgi otrzymują {ContaminationHaloDamage} pkt. obrażeń na koniec tury tej jednostki. Szansa (siła {BlightPlagueChance}) na wywołanie [abilityred]zarazy morowej[/abilityred]: wrogie jednostki otrzymują –{BlightMorale}, –{BlightAcc} do celności ataku i {BlightDamage} pkt. obrażeń co [turn/].</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">CONTAMINATION</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Contaminated Claws</Data></Cell><Cell><Data ss:Type="String">Skażone pazury</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="60"><Cell><Data ss:Type="String">CONTAMINATION</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit's melee attacks have a {ContaminatedChance} strength chance to cause [abilityred]Poisoned[/abilityred] to Biological and Cyborg units for {Poisonturn}</Data></Cell><Cell><Data ss:Type="String">Ataki wręcz tej jednostki mają szansę ({ContaminatedChance} siły) na wywołanie [abilityred]zatrucia[/abilityred] u jednostek organicznych i cyborgów na {Poisonturn}.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HARDENED-SCYTHING_CLAWS</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Hardened Scything Claws</Data></Cell><Cell><Data ss:Type="String">Utwardzone tnące pazury</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="60"><Cell><Data ss:Type="String">HARDENED-SCYTHING_CLAWS</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Hardened claws give this unit's melee attacks one level of [abilityred]Stagger Impact[/abilityred] and a {BleedChance} strength chance to cause [abilityred]Bleeding[/abilityred].</Data></Cell><Cell><Data ss:Type="String">Dzięki utwardzonym tnącym pazurom ataki wręcz tej jednostki uzyskują jeden poziom [abilityred]powodowania zachwiania[/abilityred] i mają szansę ({BleedChance} siły) na wywołanie [abilityred]krwawienia[/abilityred].</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SCYTHING_CLAWS</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Scything Claws</Data></Cell><Cell><Data ss:Type="String">Tnące pazury</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">SCYTHING_CLAWS</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">These unit's claws are sharper than others, giving this unit's melee attacks a {BleedChance} strength chance to cause [abilityred]Bleeding[/abilityred].</Data></Cell><Cell><Data ss:Type="String">Dzięki ostrym pazurom ataki wręcz tej jednostki mają szansę ({BleedChance} siły) na wywołanie [abilityred]krwawienia[/abilityred].</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">UNDYING_BEETLE_MOD</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Undying Infection</Data></Cell><Cell><Data ss:Type="String">Infekcja zombie</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">INFECTION_X</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Infection X</Data></Cell><Cell><Data ss:Type="String">Infekcja X</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="90"><Cell><Data ss:Type="String">INFECTION_X</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit is infected with an experimental virus that brings the dead back to life. When it is killed, it comes back to life {GhoulingTurns} later with {Ghoulinghealth}[hp/], -{GhoulingArmorReduction}, and its attacks deal +{GhoulingDamage} damage.[br/][br/][firecol]A unit can only revive itself once per battle.[/firecol]</Data></Cell><Cell><Data ss:Type="String">Ta jednostka jest zainfekowana eksperymentalnym wirusem, który ożywia zmarłych. Po śmierci odżyje po pewnej liczbie tur ({GhoulingTurns}) z {Ghoulinghealth}[hp/], -{GhoulingArmorReduction}, a jej ataki będą zadawały +{GhoulingDamage} obrażeń.[br/][br/][firecol]Działa to tylko raz na bitwę.[/firecol]</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">INFECTION_X</Data></Cell><Cell><Data ss:Type="String">UNDYING_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit has been revived by Infection X. It has less [armor/], but deals more damage.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka została ożywiona przez infekcję X. Ma mniejszy [armor/], ale zadaje więcej obrażeń.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">INFECTION_X</Data></Cell><Cell><Data ss:Type="String">MOD_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">{DamageIncreaseInfection}% increased damage.</Data></Cell><Cell><Data ss:Type="String">Obrażenia zwiększone o {DamageIncreaseInfection}.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">MINOR_INFECTION_X</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Minor Infection X</Data></Cell><Cell><Data ss:Type="String">Mniejsza infekcja X</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">AXE_BEAK</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Axe Beak</Data></Cell><Cell><Data ss:Type="String">Dziobotopór</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">AXE_BEAK</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Melee attack with a sharp beak.</Data></Cell><Cell><Data ss:Type="String">Atak wręcz ostrym dziobem.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">BLAZE_SPIT</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Blaze Spit</Data></Cell><Cell><Data ss:Type="String">Ogniste splunięcie</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">BLAZE_SPIT</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Spit blazing saliva at a target.</Data></Cell><Cell><Data ss:Type="String">Splunięcie ogniem do celu.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">INFLAME</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Inflame</Data></Cell><Cell><Data ss:Type="String">Zapalenie</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">INFLAME</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Spew fire in a 2 hex cone.</Data></Cell><Cell><Data ss:Type="String">Tryska ogniem w stożku o promieniu 2 pól.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">INFLAME</Data></Cell><Cell><Data ss:Type="String">MOD_NAME</Data></Cell><Cell><Data ss:Type="String">Inflaming</Data></Cell><Cell><Data ss:Type="String">Zapalający</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">INFLAME</Data></Cell><Cell><Data ss:Type="String">MOD_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">{Bonus} damage against Burning or Immolated targets.</Data></Cell><Cell><Data ss:Type="String">{Bonus} do obrażeń przeciwko oparzonym lub podpalonym celom.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">JUMP</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Jump</Data></Cell><Cell><Data ss:Type="String">Skok</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">JUMP</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Jump to target location.</Data></Cell><Cell><Data ss:Type="String">Przeskok do wskazanego miejsca.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PLATE_CRUNCH</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Plate Crunch</Data></Cell><Cell><Data ss:Type="String">Zmiażdżenie płytkami</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PLATE_CRUNCH</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Melee bite attack.</Data></Cell><Cell><Data ss:Type="String">Ugryzienie – atak wręcz.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PLATE_CRUNCH</Data></Cell><Cell><Data ss:Type="String">MOD_NAME</Data></Cell><Cell><Data ss:Type="String">Metal Feed</Data></Cell><Cell><Data ss:Type="String">Korozja metalu</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">PLATE_CRUNCH</Data></Cell><Cell><Data ss:Type="String">MOD_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Heal {amount} when attacking Cyborg or Mechanical units.</Data></Cell><Cell><Data ss:Type="String">Przywraca {amount} podczas atakowania jednostek mechanicznych lub cyborgów.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HULL_PIERCER</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Hull Piercer Spike</Data></Cell><Cell><Data ss:Type="String">Kolec przebijający powłoki</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HULL_PIERCER</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Medium ranged piercing attack.</Data></Cell><Cell><Data ss:Type="String">Średniodystansowy atak przebijający.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PROTECTIVE_CARAPACE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Protective Carapace</Data></Cell><Cell><Data ss:Type="String">Ochronna skorupa</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PROTECTIVE_CARAPACE</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit cannot be flanked.</Data></Cell><Cell><Data ss:Type="String">Tej jednostki nie można oskrzydlić.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SCUTUM_FORMATION</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Chelus Formation</Data></Cell><Cell><Data ss:Type="String">Formacja chelusów</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">SCUTUM_FORMATION</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Unit gains {ScutumFormationAmount} when it is adjacent to a friendly unit with Chelus Formation.</Data></Cell><Cell><Data ss:Type="String">Jednostka zyskuje {ScutumFormationAmount}, kiedy sąsiaduje z przyjazną jednostką z formacją chelusów.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">NEST_COHESION</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Nest Cohesion</Data></Cell><Cell><Data ss:Type="String">Jednogniazdowość</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">NEST_COHESION</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Remove all non-Psionic negative Status Effects from this unit and adjacent friendly units, as well as healing them for {NestCohesionAmount}.</Data></Cell><Cell><Data ss:Type="String">Usuwa wszystkie niepsioniczne niekorzystne efekty stanu z tej jednostki i sąsiadujących przyjaznych jednostek, oraz przywraca im {NestCohesionAmount}.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">YOUNGLING_BITE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Youngling Bite</Data></Cell><Cell><Data ss:Type="String">Ugryzienie młodzika</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">EGG_CLUTCH</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Egg Clutch</Data></Cell><Cell><Data ss:Type="String">Złożenie jaj</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">EGG_CLUTCH</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Spawn an egg next to the unit. The egg will hatch into a Chelus Youngling next turn.</Data></Cell><Cell><Data ss:Type="String">Umieszcza jajo obok jednostki. W kolejnej turze z jaja wykluje się młody chelus.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">EGG_HATCH</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Egg Hatch</Data></Cell><Cell><Data ss:Type="String">Wyklucie</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">EGG_HATCH</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">The Chelus egg will hatch next turn. If the egg is destroyed, there is a 50% it will still hatch, but only with 50% of the maximum [hp/] of a natural hatch.</Data></Cell><Cell><Data ss:Type="String">W kolejnej turze z jaja chelusa wykluje się młode. Jeśli jajo zostanie zniszczone, młode ma 50% szansy na wyklucie się, ale z 50% maks. [hp/].</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">CRASH</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Crash</Data></Cell><Cell><Data ss:Type="String">Zderzenie</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">As in a collision</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">CRASH</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Crashes against a target within melee range.</Data></Cell><Cell><Data ss:Type="String">Zderzenie z celem w średnim zasięgu ataku wręcz.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">OCTOWHALE_SONG</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Octowhale Song</Data></Cell><Cell><Data ss:Type="String">Pieśń ośmiowalenia</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">OCTOWHALE_SONG</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit casts Song of Swiftness at the beginning of its first turn in combat.</Data></Cell><Cell><Data ss:Type="String">Jednostka rzuca pieśń prędkości na początku swojej pierwszej tury walki.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SONG_OF_SWIFTNESS</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Song of Swiftness</Data></Cell><Cell><Data ss:Type="String">Pieśń prędkości</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">SONG_OF_SWIFTNESS</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">The Octowhale Elder sings to its allies, increasing their movement speed and making them {EvasiveSong} harder to hit.[br/]Cancels Song of Aggression.</Data></Cell><Cell><Data ss:Type="String">Stary ośmiowaleń śpiewa swoim sprzymierzeńcom, zwiększając szybkość ich ruchu i sprawiając, że trudniej ich trafić o {EvasiveSong}.[br/]Anuluje pieśń agresji.</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">SONG_OF_SWIFTNESS</Data></Cell><Cell><Data ss:Type="String">EFFECT_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit has Fast Movement speed and is {EvasiveSong} harder to hit.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka ma szybki ruch i trudniej ją trafić o {EvasiveSong}.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SONG_OF_AGGRESSION</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Song of Aggression</Data></Cell><Cell><Data ss:Type="String">Pieśń agresji</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="75"><Cell><Data ss:Type="String">SONG_OF_AGGRESSION</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">The Octowhale Elder sings to its allies, granting their melee attacks a {SongConcussionSTR} strength chance to [abilityred]Disable[/abilityred]. In addition, their ranged attacks gain {CritSong} increased critical hit chance.[br/]Cancels Song of Swiftness.</Data></Cell><Cell><Data ss:Type="String">Stary ośmiowaleń śpiewa swoim sprzymierzeńcom, dzięki czemu ich ataki wręcz mają szansę ({SongConcussionSTR} siły) na [abilityred]dezaktywację[/abilityred]. Dodatkowo ataki dystansowe mają zwiększoną o {CritSong} szansę na trafienie krytyczne.[br/]Anuluje pieśń prędkości.</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="45"><Cell><Data ss:Type="String">SONG_OF_AGGRESSION</Data></Cell><Cell><Data ss:Type="String">EFFECT_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit's melee attacks have a chance to Disable, and its ranged attacks have {CritSong} increased critical hit chance.</Data></Cell><Cell><Data ss:Type="String">Ataki wręcz tej jednostki mają szansę na dezaktywację, a ich ataki dystansowe mają zwiększoną o {CritSong} szansę na trafienie krytyczne.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">SONG_OF_AGGRESSION</Data></Cell><Cell><Data ss:Type="String">MOD_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">{CritSong} increased critical hit chance.</Data></Cell><Cell><Data ss:Type="String">Szansa na trafienie krytyczne zwiększona o {CritSong}.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">BEAK_PECK</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Beak Peck</Data></Cell><Cell><Data ss:Type="String">Dziobanie</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">BEAK_PECK</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">A repeating melee attack with a beak.</Data></Cell><Cell><Data ss:Type="String">Wielokrotny atak wręcz dziobem.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PENGUIN_LEAP</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Penguin Leap</Data></Cell><Cell><Data ss:Type="String">Pingwini przeskok</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PENGUIN_LEAP</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">The Penguin jumps, damaging far away or Flying units.</Data></Cell><Cell><Data ss:Type="String">Pingwin podskakuje i zadaje obrażenia oddalonym bądź latającym jednostkom.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">PENGUIN_LEAP</Data></Cell><Cell><Data ss:Type="String">MOD_NAME</Data></Cell><Cell><Data ss:Type="String">Water Momentum</Data></Cell><Cell><Data ss:Type="String">Pęd wody</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">PENGUIN_LEAP</Data></Cell><Cell><Data ss:Type="String">MOD_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">{WaterDamage} damage and {RangeIncrease} range in water battles.</Data></Cell><Cell><Data ss:Type="String">{WaterDamage} pkt. obrażeń i {RangeIncrease} do zasięgu w bitwach wodnych.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">FAV_TERRAIN_ARCTIC</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Favored Terrain - Arctic</Data></Cell><Cell><Data ss:Type="String">Ulubiony teren – arktyczny</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell><Data ss:Type="String">FAV_TERRAIN_ARCTIC</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Penguins gain {IncMorale} when fighting in Arctic terrain.</Data></Cell><Cell><Data ss:Type="String">Pingwiny zyskują {IncMorale} podczas walki na arktycznym terenie.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Removed the word Morale</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s64"><Data ss:Type="String">INVIGORATING_STRIDULATION</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Invigorating Stridulation</Data></Cell><Cell><Data ss:Type="String">Pobudzająca strydulacja</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Stridulation - the sound crickets make.</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="60"><Cell ss:StyleID="s64"><Data ss:Type="String">INVIGORATING_STRIDULATION</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell ss:StyleID="s65"><Data ss:Type="String">Produce invigorating sounds by rubbing limbs together, granting this unit and friendly units within {hexrad} hexes +{InvStridMorale} morale and Fast Movement for {StridTurn}.</Data></Cell><Cell><Data ss:Type="String">Produkuje pobudzające dźwięki poprzez pocieranie kończyn, co zapewnia tej jednostce i przyjaznym jednostkom w zasięgu {hexrad} pól +{InvStridMorale} do morale i szybki ruch przez {StridTurn}.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s64"><Data ss:Type="String">INVIGORATING_STRIDULATION</Data></Cell><Cell><Data ss:Type="String">EFFECT_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This unit has {InvStridMorale} morale and Fast Movement.</Data></Cell><Cell><Data ss:Type="String">Ta jednostka ma {InvStridMorale} morale i szybki ruch.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s64"><Data ss:Type="String">SONIC_SLASH</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Sonic Slash</Data></Cell><Cell><Data ss:Type="String">Cięcie akustyczne</Data></Cell></Row><Row ss:AutoFitHeight="0" ss:Height="30"><Cell ss:StyleID="s64"><Data ss:Type="String">SONIC_SLASH</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Create a sonic boom by slashing the air incredibly quickly, directing a damaging shockwave at the enemy.</Data></Cell><Cell><Data ss:Type="String">Tworzy uderzenie dźwiękowe poprzez niewiarygodnie szybkie cięcie powietrza. Fala uderzeniowa kieruje się na przeciwnika.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s64"><Data ss:Type="String">STRIKE</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Claw Strike</Data></Cell><Cell><Data ss:Type="String">Cios pazurami</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s64"><Data ss:Type="String">STRIKE</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Strike an enemy.</Data></Cell><Cell><Data ss:Type="String">Uderza przeciwnika.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s63"><Data ss:Type="String">CORROSIVE_SPIT</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">NAME</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">Corrosive Spit</Data></Cell><Cell><Data ss:Type="String">Żrące splunięcie</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s63"><Data ss:Type="String">CORROSIVE_SPIT</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">Spit a blob of Biochemical goo at a target unit.</Data></Cell><Cell><Data ss:Type="String">Spluwa kleksem biochemicznej mazi na cel.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s63"><Data ss:Type="String">BEETLE_SPIT</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Beetle Spit</Data></Cell><Cell><Data ss:Type="String">Splunięcie żuka</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell ss:StyleID="s63"><Data ss:Type="String">BEETLE_SPIT</Data></Cell><Cell ss:StyleID="s63"><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Spit a Biochemical agent at a target unit.</Data></Cell><Cell><Data ss:Type="String">Spluwa biochemiczną mazią na cel.</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">HURL_MAGMA</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Hurl Magma</Data></Cell><Cell><Data ss:Type="String">Miotanie magmy</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">DEVOUR</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Devoured/Swallowed Whole</Data></Cell><Cell><Data ss:Type="String">Połknięcie/pożarcie w całości</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">DEVOUR</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">A unit that is Devoured or Swallowed Whole, that didn't die during the process, can be retrieved if the unit who ate it is killed before it devours another unit or uses the [abilityred]Spawn Larva[/abilityred] ability.</Data></Cell><Cell><Data ss:Type="String">Jednostka pożarta lub połknięta w całości, która przeżyła ten proces, może zostać odzyskana, jeśli pożeracz zostanie zabity, zanim skonsumuje kolejną ofiarę lub użyje umiejętności „[abilityred]wyklucie larwy[/abilityred]”.</Data></Cell></Row><Row><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell><Cell ss:Index="7"><Data ss:Type="String">In the text below, text refers to a person that can either be male or female. If relevant for translation, please use the ‘localized string’ column for the male text and the ‘alternative localized string’ column for the female text. You and Your might be examples of this.</Data></Cell></Row><Row><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell><Cell ss:Index="7"><Data ss:Type="String">In the text below, any inserted strings - anything of the form {text} - is replaced by an integer value for the thing described in the brackets. If the {text} is not followed by a unit - e.g. shields, hitpoints - the icon for the unit is inserted together with the integer. The same holds for symbols - e.g. '+', '%' - which are occasionally inserted together with the integer.</Data></Cell></Row><Row><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell><Cell ss:Index="7"><Data ss:Type="String">For references to game terminology and in-world references, please check the glossary delivered as part of the documentation.</Data></Cell></Row><Row><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell></Row></Table><WorksheetOptions xmlns="urn:schemas-microsoft-com:office:excel"><Unsynced/><Print><ValidPrinterInfo/><HorizontalResolution>600</HorizontalResolution><VerticalResolution>600</VerticalResolution></Print><Selected/><Panes><Pane><Number>3</Number><ActiveRow>3</ActiveRow><ActiveCol>7</ActiveCol></Pane></Panes><ProtectObjects>False</ProtectObjects><ProtectScenarios>False</ProtectScenarios></WorksheetOptions></Worksheet></Workbook>
<?xml version="1.0"?><?mso-application progid="Excel.Sheet"?><Workbook xmlns="urn:schemas-microsoft-com:office:spreadsheet" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns:ss="urn:schemas-microsoft-com:office:spreadsheet" xmlns:html="http://www.w3.org/TR/REC-html40"><DocumentProperties xmlns="urn:schemas-microsoft-com:office:office"><Author>GameScribes4</Author><LastAuthor>GameScribes4</LastAuthor><Created>2019-05-06T09:39:24Z</Created><LastSaved>2019-05-06T09:39:24Z</LastSaved><Version>16.00</Version></DocumentProperties><OfficeDocumentSettings xmlns="urn:schemas-microsoft-com:office:office"><AllowPNG/></OfficeDocumentSettings><ExcelWorkbook xmlns="urn:schemas-microsoft-com:office:excel"><WindowHeight>11565</WindowHeight><WindowWidth>17970</WindowWidth><WindowTopX>32767</WindowTopX><WindowTopY>32767</WindowTopY><RefModeR1C1/><ProtectStructure>False</ProtectStructure><ProtectWindows>False</ProtectWindows></ExcelWorkbook><Styles><Style ss:ID="Default" ss:Name="Normal"><Alignment ss:Vertical="Bottom"/><Borders/><Font ss:FontName="Calibri" x:Family="Swiss" ss:Size="11" ss:Color="#000000"/><Interior/><NumberFormat/><Protection/></Style><Style ss:ID="s62"><Alignment ss:Vertical="Bottom" ss:WrapText="1"/></Style></Styles><Worksheet ss:Name="Script"><Table x:FullColumns="1" x:FullRows="1" ss:DefaultRowHeight="15"><Column ss:AutoFitWidth="0" ss:Width="142.5"/><Column ss:AutoFitWidth="0" ss:Width="204.75"/><Column ss:StyleID="s62" ss:AutoFitWidth="0" ss:Width="339.75" ss:Span="3"/><Row><Cell><Data ss:Type="String">ECONOMY_TECHGROUPS</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Anything between straight brackets - i.e. [ ] - is a formatting tag. Do not change these tags and keep them in the same relative position in the text. Anything between curly brackets - i.e. { } - is a place where text or numbers will be inserted by the game. Do not change the tag, but feel free to change its position in the text to suit the localized text.</Data></Cell></Row><Row><Cell><Data ss:Type="String">SCENE ID</Data></Cell><Cell><Data ss:Type="String">TEXT ID</Data></Cell><Cell><Data ss:Type="String">ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE ENGLISH STRING</Data></Cell><Cell><Data ss:Type="String">ALTERNATIVE LOCALIZED STRING</Data></Cell><Cell><Data ss:Type="String">LOCALIZATION NOTES</Data></Cell><Cell><Data ss:Type="String">DEV TEAM / MISC NOTES</Data></Cell></Row><Row><Cell><Data ss:Type="String">ECONOMY</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Economy</Data></Cell><Cell><Data ss:Type="String">Gospodarka</Data></Cell></Row><Row><Cell><Data ss:Type="String">ECONOMY</Data></Cell><Cell><Data ss:Type="String">NAME_PRODUCTION</Data></Cell><Cell><Data ss:Type="String">Production</Data></Cell><Cell><Data ss:Type="String">Produkcja </Data></Cell></Row><Row><Cell><Data ss:Type="String">ECONOMY</Data></Cell><Cell><Data ss:Type="String">NAME_RESEARCH</Data></Cell><Cell><Data ss:Type="String">Research</Data></Cell><Cell><Data ss:Type="String">Badania naukowe</Data></Cell></Row><Row><Cell><Data ss:Type="String">ECONOMY</Data></Cell><Cell><Data ss:Type="String">NAME_ENERGY</Data></Cell><Cell><Data ss:Type="String">Energy</Data></Cell><Cell><Data ss:Type="String">Energia</Data></Cell></Row><Row><Cell><Data ss:Type="String">ECONOMY</Data></Cell><Cell><Data ss:Type="String">NAME_FOOD</Data></Cell><Cell><Data ss:Type="String">Food</Data></Cell><Cell><Data ss:Type="String">Żywność</Data></Cell></Row><Row><Cell><Data ss:Type="String">ECONOMY</Data></Cell><Cell><Data ss:Type="String">NAME_INFRASTRUCTURE</Data></Cell><Cell><Data ss:Type="String">Infrastructure</Data></Cell><Cell><Data ss:Type="String">Infrastruktura</Data></Cell></Row><Row><Cell><Data ss:Type="String">ECONOMY</Data></Cell><Cell><Data ss:Type="String">NAME_WATER</Data></Cell><Cell><Data ss:Type="String">Water</Data></Cell><Cell><Data ss:Type="String">Woda</Data></Cell></Row><Row><Cell><Data ss:Type="String">ECONOMY</Data></Cell><Cell><Data ss:Type="String">NAME_TERRAIN</Data></Cell><Cell><Data ss:Type="String">Terrain</Data></Cell><Cell><Data ss:Type="String">Teren</Data></Cell></Row><Row><Cell><Data ss:Type="String">RESEARCH_LEVELUP</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Research Sector Level</Data></Cell><Cell><Data ss:Type="String">Poziom sektora badawczego</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Level as in, a number of steps in the development of a sector, a sector begins at level 1 and can be upgraded to level 5, where it provides stronger benefits.</Data></Cell></Row><Row><Cell><Data ss:Type="String">ENERGY_LEVELUP</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Energy Sector Level</Data></Cell><Cell><Data ss:Type="String">Poziom sektora energetycznego</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Level as in, a number of steps in the development of a sector, a sector begins at level 1 and can be upgraded to level 5, where it provides stronger benefits.</Data></Cell></Row><Row><Cell><Data ss:Type="String">PRODUCTION_LEVELUP</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Production Sector Level</Data></Cell><Cell><Data ss:Type="String">Poziom sektora produkcyjnego</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Level as in, a number of steps in the development of a sector, a sector begins at level 1 and can be upgraded to level 5, where it provides stronger benefits.</Data></Cell></Row><Row><Cell><Data ss:Type="String">FOOD_LEVELUP</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Food Sector Level</Data></Cell><Cell><Data ss:Type="String">Poziom sektora żywnościowego</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Level as in, a number of steps in the development of a sector, a sector begins at level 1 and can be upgraded to level 5, where it provides stronger benefits.</Data></Cell></Row><Row><Cell><Data ss:Type="String">ARCADIAN_LEVELUP</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Arcadian Sector Level</Data></Cell><Cell><Data ss:Type="String">Poziom sektora arkadyjskiego</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Level as in, a number of steps in the development of a sector, a sector begins at level 1 and can be upgraded to level 5, where it provides stronger benefits.</Data></Cell></Row><Row><Cell><Data ss:Type="String">ARCADIAN_REGEN</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Arcadian Recovery</Data></Cell><Cell><Data ss:Type="String">Regeneracja arkadyjska</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Arcadian refers to Arcadia, i.e. an idyllic climate.</Data></Cell></Row><Row ss:Height="45"><Cell><Data ss:Type="String">ARCADIAN_REGEN</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Having adapted to the environment, your forces recover {ArcadianRec} each turn on the world map while in an Arcadian climate.</Data></Cell><Cell><Data ss:Type="String">Po przystosowaniu się do środowiska twoje siły odzyskują {ArcadianRec} w każdej turze na mapie świata w klimacie arkadyjskim.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Arcadian refers to Arcadia, i.e. an idyllic climate.</Data></Cell></Row><Row><Cell><Data ss:Type="String">ARCADIAN_HAPPINESS</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Arcadian Habitats</Data></Cell><Cell><Data ss:Type="String">Habitaty arkadyjskie</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Arcadian refers to Arcadia, i.e. an idyllic climate.</Data></Cell></Row><Row><Cell><Data ss:Type="String">ARID_LEVELUP</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Arid Sector Level</Data></Cell><Cell><Data ss:Type="String">Poziom sektora jałowego</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Arid is the terrain type for deserts.</Data></Cell></Row><Row><Cell><Data ss:Type="String">ARID_REGEN</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Arid Recovery</Data></Cell><Cell><Data ss:Type="String">Regeneracja w klimacie jałowym</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Arid is the terrain type for deserts.</Data></Cell></Row><Row ss:Height="30"><Cell><Data ss:Type="String">ARID_REGEN</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Having adapted to the environment, your forces recover {AridRec} each turn on the world map while in an Arid climate.</Data></Cell><Cell><Data ss:Type="String">Po przystosowaniu się do środowiska twoje siły odzyskują {AridRec} w każdej turze na mapie świata w klimacie jałowym.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Arid is the terrain type for deserts.</Data></Cell></Row><Row><Cell><Data ss:Type="String">ARID_HAPPINESS</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Arid Habitats</Data></Cell><Cell><Data ss:Type="String">Habitaty klimatu jałowego</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Arid is the terrain type for deserts.</Data></Cell></Row><Row ss:Height="45"><Cell><Data ss:Type="String">ARID_HAPPINESS</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">By adapting the habitats for your colonists to the Arid climate, you can improve their quality of life.[br/][br/]Your colony gains {happiness} for each Arid sector within the colony's domain.</Data></Cell><Cell><Data ss:Type="String">Dzięki przystosowaniu habitatów dla kolonistów do klimatu jałowego możesz poprawić jakość życia mieszkańców.[br/][br/]Twoja kolonia uzyskuje {happiness} za każdy sektor jałowy w obrębie jej terytorium.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Arid is the terrain type for deserts.</Data></Cell></Row><Row><Cell><Data ss:Type="String">ARCTIC_LEVELUP</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Arctic Sector Level</Data></Cell><Cell><Data ss:Type="String">Poziom sektora arktycznego</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Arctic is the terrain type for arctic.</Data></Cell></Row><Row><Cell><Data ss:Type="String">ARCTIC_REGEN</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Arctic Recovery</Data></Cell><Cell><Data ss:Type="String">Regeneracja w klimacie arktycznym</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Arctic is the terrain type for arctic.</Data></Cell></Row><Row ss:Height="30"><Cell><Data ss:Type="String">ARCTIC_REGEN</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Having adapted to the environment, your forces recover {ArcticRec} each turn on the world map while in an Arctic climate.</Data></Cell><Cell><Data ss:Type="String">Po przystosowaniu się do środowiska twoje siły odzyskują {ArcticRec} w każdej turze na mapie świata w klimacie arktycznym.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Arctic is the terrain type for arctic.</Data></Cell></Row><Row><Cell><Data ss:Type="String">ARCTIC_HAPPINESS</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Arctic Habitats</Data></Cell><Cell><Data ss:Type="String">Habitaty klimatu arktycznego</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Arctic is the terrain type for arctic.</Data></Cell></Row><Row ss:Height="60"><Cell><Data ss:Type="String">ARCTIC_HAPPINESS</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">By adapting the habitats for your colonists to the Arctic climate, you can improve their quality of life.[br/][br/]Your colony gains {happiness} for each Arctic sector within the colony's domain.</Data></Cell><Cell><Data ss:Type="String">Dzięki przystosowaniu habitatów dla kolonistów do klimatu arktycznego możesz poprawić jakość życia mieszkańców.[br/][br/]Twoja kolonia uzyskuje {happiness} za każdy sektor arktyczny w obrębie jej terytorium.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Arctic is the terrain type for arctic.</Data></Cell></Row><Row><Cell><Data ss:Type="String">FUNGAL_LEVELUP</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Fungal Sector Level</Data></Cell><Cell><Data ss:Type="String">Poziom sektora zagrzybionego</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Fungal is the terrain type for alien sectors that are overgrown with fungus like growth</Data></Cell></Row><Row><Cell><Data ss:Type="String">FUNGAL_REGEN</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Fungal Recovery</Data></Cell><Cell><Data ss:Type="String">Regeneracja w klimacie zagrzybionym</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Fungal is the terrain type for alien sectors that are overgrown with fungus like growth</Data></Cell></Row><Row ss:Height="30"><Cell><Data ss:Type="String">FUNGAL_REGEN</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Having adapted to the environment, your forces recover {FungalRec} each turn on the world map while in a Fungal climate.</Data></Cell><Cell><Data ss:Type="String">Po przystosowaniu się do środowiska twoje siły odzyskują {FungalRec} w każdej turze na mapie świata w klimacie zagrzybionym.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Fungal is the terrain type for alien sectors that are overgrown with fungus like growth</Data></Cell></Row><Row><Cell><Data ss:Type="String">FUNGAL_HAPPINESS</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Fungal Habitats</Data></Cell><Cell><Data ss:Type="String">Habitaty klimatu zagrzybionego</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Fungal is the terrain type for alien sectors that are overgrown with fungus like growth</Data></Cell></Row><Row ss:Height="60"><Cell><Data ss:Type="String">FUNGAL_HAPPINESS</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">By adapting the habitats for your colonists to the Fungal climate, you can improve their quality of life.[br/][br/]Your colony gains {happiness} for each Fungal sector within the colony's domain.</Data></Cell><Cell><Data ss:Type="String">Dzięki przystosowaniu habitatów dla kolonistów do klimatu zagrzybionego możesz poprawić jakość życia mieszkańców.[br/][br/]Twoja kolonia uzyskuje {happiness} za każdy sektor zagrzybiony w obrębie jej terytorium.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Fungal is the terrain type for alien sectors that are overgrown with fungus like growth</Data></Cell></Row><Row><Cell><Data ss:Type="String">BADLANDS_LEVELUP</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Volcanic Adaptation</Data></Cell><Cell><Data ss:Type="String">Przystosowanie wulkaniczne</Data></Cell></Row><Row><Cell><Data ss:Type="String">FOREST_LEVELUP</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Forest Sector Level</Data></Cell><Cell><Data ss:Type="String">Poziom sektora leśnego</Data></Cell></Row><Row><Cell><Data ss:Type="String">FOREST_GLOBAL</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Forest Navigation</Data></Cell><Cell><Data ss:Type="String">Nawigacja w lasach</Data></Cell></Row><Row ss:Height="45"><Cell><Data ss:Type="String">FOREST_GLOBAL</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">All units with Amphibious or Land Movement gain Expedited Movement in Forests, reducing the cost of moving through this terrain.</Data></Cell><Cell><Data ss:Type="String">Wszystkie jednostki będące amfibiami lub poruszające się po lądzie uzyskują przyspieszony ruch w lasach, co zmniejsza koszt przemierzania tego terenu.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Expedited movement is a unit property that increases a units speed when moving through that terrain</Data></Cell></Row><Row><Cell><Data ss:Type="String">MOUNTAIN_LEVELUP</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Mountain Sector Level</Data></Cell><Cell><Data ss:Type="String">Poziom sektora górskiego</Data></Cell></Row><Row><Cell><Data ss:Type="String">MOUNTAIN_GLOBAL</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Mountain Navigation</Data></Cell><Cell><Data ss:Type="String">Nawigacja w górach</Data></Cell></Row><Row ss:Height="45"><Cell><Data ss:Type="String">MOUNTAIN_GLOBAL</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">All units with Amphibious or Land Movement gain Expedited Movement in Mountains, reducing the cost of moving through this terrain.</Data></Cell><Cell><Data ss:Type="String">Wszystkie jednostki będące amfibiami lub poruszające się po lądzie uzyskują przyspieszony ruch w górach, co zmniejsza koszt przemierzania tego terenu.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Expedited movement is a unit property that increases a units speed when moving through that terrain</Data></Cell></Row><Row><Cell><Data ss:Type="String">RUINS_LEVELUP</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Ruins Sector Level</Data></Cell><Cell><Data ss:Type="String">Poziom sektora ruin</Data></Cell></Row><Row><Cell><Data ss:Type="String">RUINS_GLOBAL</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Ruins Navigation</Data></Cell><Cell><Data ss:Type="String">Nawigacja w ruinach</Data></Cell></Row><Row ss:Height="45"><Cell><Data ss:Type="String">RUINS_GLOBAL</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">All units with Amphibious or Land Movement gain Expedited Movement in Ruins, reducing the cost of moving through this terrain.</Data></Cell><Cell><Data ss:Type="String">Wszystkie jednostki będące amfibiami lub poruszające się po lądzie uzyskują przyspieszony ruch w ruinach, co zmniejsza koszt przemierzania tego terenu.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Expedited movement is a unit property that increases a units speed when moving through that terrain</Data></Cell></Row><Row><Cell><Data ss:Type="String">PLAINS_LEVELUP</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Fertile Plains Sector Level</Data></Cell><Cell><Data ss:Type="String">Poziom sektora żyznych równin</Data></Cell></Row><Row><Cell><Data ss:Type="String">PLAINS_GLOBAL</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Plains Navigation</Data></Cell><Cell><Data ss:Type="String">Nawigacja na równinach</Data></Cell></Row><Row ss:Height="45"><Cell><Data ss:Type="String">PLAINS_GLOBAL</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">All units with Amphibious or Land Movement gain Expedited Movement in Fertile Plains, reducing the cost of moving through this terrain.</Data></Cell><Cell><Data ss:Type="String">Wszystkie jednostki będące amfibiami lub poruszające się po lądzie uzyskują przyspieszony ruch na żyznych równinach, co zmniejsza koszt przemierzania tego terenu.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Expedited movement is a unit property that increases a units speed when moving through that terrain</Data></Cell></Row><Row><Cell><Data ss:Type="String">WATER_LEVELUP</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Coast Sector Level</Data></Cell><Cell><Data ss:Type="String">Poziom sektora wybrzeża</Data></Cell></Row><Row><Cell><Data ss:Type="String">TRANSPORT_BONUS_I</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Transport Reinforcement</Data></Cell><Cell><Data ss:Type="String">Wzmocnienie transportowców</Data></Cell></Row><Row ss:Height="45"><Cell><Data ss:Type="String">TRANSPORT_BONUS_I</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">New naval technologies allow for transports to be reinforced to increase survivability.[br/[br/]Transports gain {hp} and {armor}.</Data></Cell><Cell><Data ss:Type="String">Nowe technologie okrętowe umożliwiają wzmocnienie konstrukcji transportowców w celu zwiększenia ich wytrzymałości.[br/[br/]Transportowce uzyskują {hp} i {armor}.</Data></Cell></Row><Row><Cell><Data ss:Type="String">TRANSPORT_BONUS_I</Data></Cell><Cell><Data ss:Type="String">PROPERTY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This transport has been reinforced with additional {hp} and {armor}.</Data></Cell><Cell><Data ss:Type="String">Ten transportowiec został wzmocniony i ma dodatkowe {hp} i {armor}.</Data></Cell></Row><Row><Cell><Data ss:Type="String">TRANSPORT_BONUS_II</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Transport Expedience</Data></Cell><Cell><Data ss:Type="String">Usprawnienie transportowców</Data></Cell></Row><Row ss:Height="60"><Cell><Data ss:Type="String">TRANSPORT_BONUS_II</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Specializing in naval technologies allows for quicker maneuvering in the water, as well as stronger resistance to enemy attacks.[br/][br/]Transports gain medium movement speed and have {resistance} resistance to all damage and status effects.</Data></Cell><Cell><Data ss:Type="String">Specjalizacja w technologiach okrętowych umożliwia szybsze manewrowanie w wodzie i daje większą odporność na atak wroga.[br/][br/]Transportowce uzyskują średnią szybkość ruchu i mają {resistance} odporności na wszystkie obrażenia i efekty stanu.</Data></Cell></Row><Row ss:Height="30"><Cell><Data ss:Type="String">TRANSPORT_BONUS_II</Data></Cell><Cell><Data ss:Type="String">PROPERTY_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">This transport has medium movement speed and {resistance} resistance to all damage and status effects.</Data></Cell><Cell><Data ss:Type="String">Ten transportowiec ma średnią szybkość ruchu i {resistance} odporności na wszystkie obrażenia i efekty stanu.</Data></Cell></Row><Row><Cell><Data ss:Type="String">RIVER_BONUS</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">River Exploitation</Data></Cell><Cell><Data ss:Type="String">Eksploatacja rzek</Data></Cell></Row><Row ss:Height="30"><Cell><Data ss:Type="String">RIVER_BONUS</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Colonies with a River going through their domain generate {Food} food income.</Data></Cell><Cell><Data ss:Type="String">Kolonie z rzeką przebiegającą przez ich terytorium wytwarzają {Food} żywności.</Data></Cell></Row><Row><Cell><Data ss:Type="String">LAVA_BONUS</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Lava Exploitation</Data></Cell><Cell><Data ss:Type="String">Eksploatacja lawy</Data></Cell></Row><Row ss:Height="30"><Cell><Data ss:Type="String">LAVA_BONUS</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Colonies with a Lava stream going through their domain generate {Energy} energy income.</Data></Cell><Cell><Data ss:Type="String">Kolonie ze strumieniem lawy przebiegającym przez ich terytorium wytwarzają {Energy} energii.</Data></Cell></Row><Row><Cell><Data ss:Type="String">HAZARD_REMOVAL_VEIL_OF_TRANQUILITY</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Hazard Removal: Veil of Tranquility</Data></Cell><Cell><Data ss:Type="String">Usuwanie zagrożeń – woal uspokojenia</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Hazards are sector effects that negatively affect units and structures in that sector.</Data></Cell></Row><Row><Cell><Data ss:Type="String">HAZARD_REMOVAL_ABYSSAL_TEAR</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Hazard Removal: Abyssal Tear</Data></Cell><Cell><Data ss:Type="String">Usuwanie zagrożeń – rozdarcie Otchłani</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Hazards are sector effects that negatively affect units and structures in that sector.</Data></Cell></Row><Row><Cell><Data ss:Type="String">HAZARD_REMOVAL_NUCLEAR_FALLOUT</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Hazard Removal: Nuclear Fallout</Data></Cell><Cell><Data ss:Type="String">Usuwanie zagrożeń – opad radioaktywny</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Hazards are sector effects that negatively affect units and structures in that sector.</Data></Cell></Row><Row><Cell><Data ss:Type="String">HAZARD_REMOVAL_SPORE_CLOUD</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Hazard Removal: Spore Clouds</Data></Cell><Cell><Data ss:Type="String">Usuwanie zagrożeń – chmury zarodników</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Hazards are sector effects that negatively affect units and structures in that sector.</Data></Cell></Row><Row><Cell><Data ss:Type="String">HAZARD_REMOVAL_ARC_STORM</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Hazard Removal: Ion Storm</Data></Cell><Cell><Data ss:Type="String">Usuwanie zagrożeń – burza jonowa</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Hazards are sector effects that negatively affect units and structures in that sector.</Data></Cell></Row><Row><Cell><Data ss:Type="String">HAZARD_REMOVAL_GEOTHERMAL_INSTABILITY</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Hazard Removal: Geothermal Instability</Data></Cell><Cell><Data ss:Type="String">Usuwanie zagrożeń – niestabilność geotermiczna</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Hazards are sector effects that negatively affect units and structures in that sector.</Data></Cell></Row><Row><Cell><Data ss:Type="String">HAZARD_REMOVAL_VOID_BOMB</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Hazard Removal: Void Storm</Data></Cell><Cell><Data ss:Type="String">Usuwanie zagrożeń – burza Głębi</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Hazards are sector effects that negatively affect units and structures in that sector.</Data></Cell></Row><Row><Cell><Data ss:Type="String">HAZARD_REMOVAL</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Hazard Removal</Data></Cell><Cell><Data ss:Type="String">Usuwanie zagrożeń</Data></Cell></Row><Row ss:Height="30"><Cell><Data ss:Type="String">HAZARD_REMOVAL</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Unlocks the ability to remove Hazards from the world map using special operations.</Data></Cell><Cell><Data ss:Type="String">Odblokowuje możliwość usuwania zagrożeń z mapy świata za pomocą operacji specjalnych.</Data></Cell></Row><Row><Cell><Data ss:Type="String">GENERATE_RESEARCH</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Generate Knowledge</Data></Cell><Cell><Data ss:Type="String">Wytwarzanie wiedzy</Data></Cell></Row><Row ss:Height="45"><Cell><Data ss:Type="String">GENERATE_RESEARCH</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Unlocks the option for your colonies to 'Generate Knowledge', turning {ResearchAmount} of your production capacity into knowledge when activated.</Data></Cell><Cell><Data ss:Type="String">Odblokowuje możliwość wytwarzania wiedzy w twoich koloniach, czyli przekształcanie {ResearchAmount} potencjału produkcyjnego w wiedzę.</Data></Cell></Row><Row><Cell><Data ss:Type="String">HAZARD_REMOVAL</Data></Cell><Cell><Data ss:Type="String">POPUP</Data></Cell><Cell><Data ss:Type="String">Spend resources to remove the hazard from this sector.</Data></Cell><Cell><Data ss:Type="String">Wydaj zasoby, aby usunąć zagrożenie z tego sektora.</Data></Cell></Row><Row><Cell><Data ss:Type="String">HAZARD_REMOVAL</Data></Cell><Cell><Data ss:Type="String">IN_PROGRESS</Data></Cell><Cell><Data ss:Type="String">Hazard removal in progress [INT_duration]</Data></Cell><Cell><Data ss:Type="String">Usunięcie zagrożenia za [INT_duration]</Data></Cell></Row><Row><Cell><Data ss:Type="String">COSMITE_GLOBAL_INCOME</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Cosmite Catalyst</Data></Cell><Cell><Data ss:Type="String">Katalizator kosmitowy</Data></Cell></Row><Row ss:Height="45"><Cell><Data ss:Type="String">COSMITE_GLOBAL_INCOME</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Applying a Cosmite catalyst to all Cosmite-generating structures can boost yields.[br/][br/]Global Income of Cosmite increased by {cosmiteIncomeModifier}.</Data></Cell><Cell><Data ss:Type="String">Zastosowanie katalizatora kosmitowego we wszystkich obiektach wytwarzających kosmit może zwiększyć wydajność.[br/][br/]Całkowity dochód w kosmicie wzrasta o {cosmiteIncomeModifier}.</Data></Cell></Row><Row><Cell><Data ss:Type="String">DEFAULT_SKILLS</Data></Cell><Cell><Data ss:Type="String">TRANSPORT_NAME</Data></Cell><Cell><Data ss:Type="String">Sea Transport</Data></Cell><Cell><Data ss:Type="String">Transport morski</Data></Cell></Row><Row ss:Height="30"><Cell><Data ss:Type="String">DEFAULT_SKILLS</Data></Cell><Cell><Data ss:Type="String">TRANSPORT_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Allows units to embark into a transport to travel across the water.</Data></Cell><Cell><Data ss:Type="String">Umożliwia jednostkom okrętowanie się na transportowce w celu przemierzania zbiorników wodnych.</Data></Cell></Row><Row><Cell><Data ss:Type="String">DEFAULT_SKILLS</Data></Cell><Cell><Data ss:Type="String">WATER_BASE_NAME</Data></Cell><Cell><Data ss:Type="String">Water Base</Data></Cell><Cell><Data ss:Type="String">Baza wodna</Data></Cell></Row><Row ss:Height="30"><Cell><Data ss:Type="String">DEFAULT_SKILLS</Data></Cell><Cell><Data ss:Type="String">WATER_BASE_DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Unlocks the ability to build bases on water and coastal sectors.</Data></Cell><Cell><Data ss:Type="String">Odblokowuje możliwość budowania baz na wodzie i w sektorach z wybrzeżem.</Data></Cell></Row><Row><Cell><Data ss:Type="String">HAZARD_REMOVAL_OIL_SPILL</Data></Cell><Cell><Data ss:Type="String">NAME</Data></Cell><Cell><Data ss:Type="String">Hazard Removal: Oil Spill</Data></Cell><Cell><Data ss:Type="String">Usuwanie zagrożeń: Wyciek ropy</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Hazards are sector effects that negatively affect units and structures in that sector.</Data></Cell></Row><Row ss:Height="30"><Cell><Data ss:Type="String">BADLANDS_LEVELUP</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">Colonies ignore all economic penalties from Volcanic terrain.</Data></Cell><Cell><Data ss:Type="String">Kolonie ignorują wszystkie kary ekonomiczne od terenu wulkanicznego.</Data></Cell></Row><Row ss:Height="45"><Cell><Data ss:Type="String">ARCADIAN_HAPPINESS</Data></Cell><Cell><Data ss:Type="String">DESCRIPTION</Data></Cell><Cell><Data ss:Type="String">By adapting the habitats for your colonists to the Arcadian climate, you can improve their quality of life.[br/][br/]Your colony gains {happiness} for each Arcadian sector within the colony's domain.</Data></Cell><Cell><Data ss:Type="String">Dostosowując siedliska swoich kolonistów do arkadyjskiego klimatu, możesz poprawić ich jakość życia.[br/][br/] Twoja kolonia zyskuje {happiness} dla każdego sektora arkadyjskiego w domenie kolonii.</Data></Cell><Cell ss:Index="7"><Data ss:Type="String">Arcadian refers to Arcadia, i.e. an idyllic climate.</Data></Cell></Row><Row><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell><Cell><Data ss:Type="String"/></Cell></Row></Table><WorksheetOptions xmlns="urn:schemas-microsoft-com:office:excel"><Selected/><TopRowVisible>54</TopRowVisible><Panes><Pane><Number>3</Number><ActiveRow>78</ActiveRow><ActiveCol>1</ActiveCol></Pane></Panes><ProtectObjects>False</ProtectObjects><ProtectScenarios>False</ProtectScenarios></WorksheetOptions></Worksheet></Workbook>